  abstract={As the prevalence of depression in women continues to increase, there is a need to improve early diagnosis and intervention methods. Using a novel multimodal deep learning architecture and combining multiple data sources, this study seeks to develop a better artificial intelligence (AI)-based model for predicting depression in women. Using dedicated deep learning encoders and attention-based synthesis methods, we believe that combining self-report questionnaires, physiological data, social media activity, and environmental factors will create a simpler and simpler, as well as more intuitive, predictive model. This study describes a hybrid deep learning architecture, data collection methods, appropriate behavior engineering procedures, and a robust assessment framework. The potential for this advanced AI model to help provide early diagnosis and tailored treatment and improve mental health outcomes for women is being seriously investigated.},
  keywords={Deep learning;Social networking (online);Computational modeling;Soft sensors;Mental health;Predictive models;Depression;Data models;Physiology;Artificial intelligence;Depression Prediction;Women's Mental Health;Artificial Intelligence;Deep Learning;Multimodal Data Fusion;Attention Mechanisms;Early Detection;Personalized Healthcare},
  doi={10.1109/ICCCA66364.2025.11411698},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{10612304,
  author={Singh, Manish Kumar and Kumar, Sunil},
  booktitle={2024 International Conference on Expert Clouds and Applications (ICOECA)}, 
  title={Stress Detection During Social Interactions with Natural Language Processing and Machine Learning}, 
  year={2024},
  volume={},
  number={},
  pages={297-301},
  abstract={The field of Natural Language Processing (NLP) is witnessing a growing recognition of the significance of investigating stress-related phenomena. This research study proposes a new framework to address the diagnostic challenges associated with mental health conditions such as anxiety, depression, and stress, which can worsen if left unaddressed. Within this research study, social media postings and comments are used to enhance sentiment and emotion analysis for assessing individuals' stress levels. Specifically, text analysis of social media data, including Twitter tweets, serves as a pivotal application. The proposed system is implemented by employing a combination of Machine Learning (ML), Natural Language Processing (NLP), and Deep Learning (DL) methodologies. The proposed system utilizes Convolutional Neural Network (CNN), BERT transfer learning techniques, as well as Machine Learning (ML) algorithms such as Naive Bayes, Support Vector Machine (SVM), and K-Nearest Neighbors (KNN). This study aims to predict five distinct emotional categories: “Happy, ” “Angry, ” “Depression, ” “Sad, ” and “Fear.” Remarkably, the proposed system has achieved an accuracy and F1 score exceeding 93%, outperforming the performance of other existing human emotion recognition systems.},
  keywords={Support vector machines;Emotion recognition;Accuracy;Social networking (online);Transfer learning;Mental health;Nearest neighbor methods;Machine learning;deep learning;BERT;CNN;stress;NLP;social media},
  doi={10.1109/ICOECA62351.2024.00060},
  ISSN={},
