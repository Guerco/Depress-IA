  month={},}@INPROCEEDINGS{10426143,
  author={Mundra, Aryan and Rothe, Mrudula and Bagad, Priyank and Shinde, Anoushka and Lath, Ritika and Aylani, Amit},
  booktitle={2023 Global Conference on Information Technologies and Communications (GCITC)}, 
  title={Enhancing Mental Health Care: A Proposed Approach for Depression Detection using CNN and LSTM Model}, 
  year={2023},
  volume={},
  number={},
  pages={1-6},
  abstract={In the landscape of mental health research, the detection of depression from textual content has gained paramount importance, promising crucial early intervention for those struggling with their mental health. This paper introduces an innovative LSTM-CNN model, meticulously crafted to analyze social media posts, online discussions, and blogs, showcasing a remarkable 93.41% accuracy in depression detection. This model, proficient in capturing both sequential intricacies and localized patterns, surpasses existing classifiers, firmly establishing its efficacy. This research marks a significant advancement in mental health technology, illuminating the potential of sophisticated machine learning architectures in revolutionizing precise and dependable depression detection. In an era where mental health support is paramount, this study heralds a promising future where cutting-edge technologies redefine our approach, ensuring timely help for individuals battling depression.},
  keywords={Analytical models;Social networking (online);Mental health;Machine learning;Depression;Data models;Testing;Depression;Artificial Intelligence;LSTM;CNN;Mental Health;social media},
  doi={10.1109/GCITC60406.2023.10426143},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{10673965,
  author={Wei, Jiaying and Zhou, Jing},
  booktitle={2024 IEEE/ACIS 27th International Conference on Software Engineering, Artificial Intelligence, Networking and Parallel/Distributed Computing (SNPD)}, 
  title={Exploring Personality and Emotion in Risk Prediction of Depression}, 
  year={2024},
  volume={},
  number={},
  pages={228-233},
  abstract={During the pandemic, there has been a significant increase in the number of depression diagnoses. Meanwhile, the popularity of social media and the Myers-Briggs Type Indicator (MBTI) has provided new perspectives for designing lightweight and effective early warning methods for depression. These methods utilize personality traits and emotional characteristics obtained from social media posts to analyze users’ mental states and come to relevant conclusions. We therefore designed the PEER-MIND model, which classifies users’ depression status using MBTI labels obtained from their social media posts and emotion features determined by text and images from the posts as well. This model achieves a 3.58% higher prediction accuracy compared to baseline models when using fine-grained emotion detection. Also, we developed the TimeSlider-HMM model, an interpretable tool for assessing depression risk. This model evaluates changes in depression probability across different MBTI dimensions before and after significant depressive trends appear, providing us with insights into the interaction between personality and emotional factors in depression detection.},
  keywords={Training;Accuracy;Social networking (online);Pandemics;Computational modeling;Pathogenesis;Predictive models;MBTI;emotion;depression detection;Hidden Markov Model},
  doi={10.1109/SNPD61259.2024.10673965},
  ISSN={2693-8421},
  month={July},}@INPROCEEDINGS{11254198,
  author={J, Sheril AngeL and Andrushia, Diana and Neebha, Mary and S, Thajna and A, Sharon Rose and Deogharia, Shreya},
  booktitle={2025 3rd International Conference on Intelligent Cyber Physical Systems and Internet of Things (ICoICI)}, 
  title={AI-Powered Mental Health Screening: Comparing Boosting Algorithms on PHQ-9}, 
  year={2025},
  volume={},
  number={},
  pages={364-369},
  abstract={Depression is one of the leading mental health disorders worldwide, particularly affecting young adults. Early identification is essential for timely intervention, yet detecting depressive symptoms from unstructured text remains a significant challenge. This study evaluates the performance of four boosting algorithms—Gradient Boosting, XGBoost, LightGBM, and CatBoost—for classifying depression severity levels based on real-time textual responses to the PHQ-9 questionnaire. A dataset comprising 109 responses was collected and processed using TF-IDF-based feature extraction. All models were trained under identical conditions and evaluated using accuracy scores, F1-scores, and confusion matrices. The results indicate that while Gradient Boosting and XGBoost achieved moderate performance, LightGBM and CatBoost outperformed them, each achieving approximately 97% accuracy and demonstrating better class-wise separation. These findings highlight the potential of LightGBM and CatBoost for developing scalable and reliable AI-driven mental health screening tools that can support early detection of depression through automated text analysis.},
  keywords={Accuracy;Text categorization;Mental health;Boosting;Depression;Feature extraction;Real-time systems;Classification algorithms;Reliability;Internet of Things;Depression Detection;PHQ-9;Text Classification;Gradient Boosting;XG Boosting;Light-GBM;Cat-Boost;Mental Health Screening;Boosting Algorithms;Early Detection;Emotion Analysis},
  doi={10.1109/ICoICI65217.2025.11254198},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10963171,
  author={Alizada, Adil and Thomas, Johan John and Ali, Mir Imaad and Karim, Kayvan},
  booktitle={2024 5th International Conference on Computers and Artificial Intelligence Technology (CAIT)}, 
  title={To BI or not to BI?}, 
  year={2024},
  volume={},
  number={},
  pages={586-590},
  abstract={Suicide continues to be an issue in our society. Studies agree that it is best to deal with suicidal ideation in its early stages, and for this reason, researchers have been conducting experiments training different Neural Networks (NN) to detect it. Transformers are the dominant Neural Network architecture in the domain of Suicidal Ideation detection, being a robust solution for not only the proposed problem but for a wide variety of NLP problems. LSTM-CNN, one of the prominent architectures in the field is also proposed as a great solution. This study aims to evaluate the performance of BERT, RoBERTa, LSTM-CNN, and Bi-LSTM-CNN models for suicidal ideation detection. Our experiments indicated that BERT models have an edge over both LSTM-CNN and BI-LSTM-CNN models, scoring up to 0.986 accuracy on our test set. Furthermore, while directly comparing LSTM-CNN with Bi-LSTM-CNN, it was observed that the difference between the models isn’t significant. Our paper contributes to the domain by proving no advantage of using LSTM-CNN models over the Transformers.},
  keywords={Training;Deep learning;Filtering;Image edge detection;Computer architecture;Bidirectional control;Transformers;Depression;Natural language processing;Encoding;suicide;depression;machine learning;NLP;natural language processing;deep learning},
  doi={10.1109/CAIT64506.2024.10963171},
  ISSN={},
