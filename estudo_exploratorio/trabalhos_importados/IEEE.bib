  doi={10.1109/ICMLA58977.2023.00316},
  ISSN={1946-0759},
  month={Dec},}@ARTICLE{10409495,
  author={Maruf, Abdullah Al and Khanam, Fahima and Haque, Md. Mahmudul and Jiyad, Zakaria Masud and Mridha, M. F. and Aung, Zeyar},
  journal={IEEE Access}, 
  title={Challenges and Opportunities of Text-Based Emotion Detection: A Survey}, 
  year={2024},
  volume={12},
  number={},
  pages={18416-18450},
  abstract={Emotion detection has become an intriguing issue for researchers owing to its psychological, social, and commercial significance. People express their feelings directly or indirectly through facial expressions, language, writing, or behavior. An emotion detection tool is a critical and practical way to recognize and categorize moods in various applications. Artificial intelligence (AI) is often used to identify emotions. Machine learning and deep learning algorithms produce high-quality solutions for diagnosing emotional diseases among social media users. Numerous studies and survey articles have been published on emotion detection using textual data. However, most of these studies did not comprehensively address the emerging architectures and performance analyses in emotion detection. This study provides an extensive survey of state-of-the-art systems, techniques, and datasets for textual emotion recognition. Another goal of this study is to emphasize the limitations and provide up-and-coming research directions to fill these gaps in this rapidly evolving field. This survey paper investigated the concepts and performance of different categories of textual emotion detection models, approaches, and methodologies.},
  keywords={Emotion recognition;Surveys;Social networking (online);Machine learning;Depression;Feature extraction;Business;Text analysis;Data models;Performance evaluation;Psychology;Text-based emotion detection;datasets;machine learning models;performance metrics;challenges and emerging trends},
  doi={10.1109/ACCESS.2024.3356357},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{10441452,
  author={Islam, Md. Shamimul and Saha, Subrata and Alam, Md. Mahbub and Kumar Datta, Nayan and Ali, Md. Haidar and Mahbub Alam, Md. and Hossain, Md. Dulal and Golam Moazzam, Md.},
  booktitle={2023 26th International Conference on Computer and Information Technology (ICCIT)}, 
  title={Natural Language Processing and Machine Learning Approaches to Detect Bangla Hate Speech on Social Media}, 
  year={2023},
  volume={},
  number={},
  pages={1-6},
  abstract={In this modern era, with the popularity of the Unicode system, many people use Bangla text to express their opinions, comments, emotions on Facebook, Twitter, and YouTube, etc. However, this social connectivity always does not create positive impacts. Trolling, cyberbullying, online harassment, sexual and political abuse, and cybercrime often create a huge negative physiological effect on victims. In most cases, women, children, and celebrities are the victims which may often lead them to depression and suicidal activity. Therefore, at the early stage, cyberbullying and hate speech detection can reduce these cyber crimes.A few researches have been carried out in the Bangla language to detect cyberbullying and hate speech due to annotated corpora, lexical and morphological analyzers. This research aims to design and develop an effective model to detect Bangla cyberbullying and hate speech text with the combination of Natural Language Processing (NLP) and Machine Learning Classifier algorithms. In this study, we have collected 6244 Bangla text data from various online social platforms consisting of 6 categories of hate speeches. Then, we labeled the data into two main classes-bullied and neutral that were used to train our classifiers after preprocessing and features extracted by the Bangla NLP tool and TF-IDF(Term Frequency –Inverse Document Frequency). Our comparative study outlines that, with an accuracy rate of 89% and considering parameters Recall, Precision, Specificity, F-Score, and ROC, the Random Forest Classifier achieves the best results compared to others.},
  keywords={Video on demand;Hate speech;Cyberbullying;Feature extraction;Natural language processing;Web sites;Random forests;Hate Speech;Bangla text;machine learning;NLP;classification;Detection},
  doi={10.1109/ICCIT60459.2023.10441452},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{11307987,
  author={P J, Alphonsa Sini and K K, Sherky},
  booktitle={2025 Innovations in Power and Advanced Computing Technologies (i-PACT)}, 
  title={MindSync:An Enhanced Depression Detection Deep Learning Using Multimodal Data Fusion}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={This study proposes MindSync, a novel multimodal deep learning framework for enhanced depression detection that integrates audio, video, and EEG data. In the preprocessing stage, modalityspecific techniques are applied: Mel-Frequency Cepstral Coefficients (MFCCs) are used for noise reduction and feature extraction from audio signals; MobileNet V2, MobileViT, and OpenFace are employed for facial feature extraction from video data; and ShallowConvNet, Power Spectral Density (PSD), and Fractal Dimensions are utilized to extract neurological features from EEG signals. A Light-Weight Self-Refinement Attention (LSRA) mechanism is introduced to refine and fuse the extracted features, selecting the most relevant indicators for depression classification. Experimental results demonstrate that the proposed model achieves superior performance, with an accuracy of 99.11 %, a balanced F1score of 98.49 %, precision of 97.89 %, and sensitivity of 98.20 %. Furthermore, the model demonstrates rapid training efficiency, completing training within 10.28 seconds, and maintains low false positive (1.00 %) and false negative (0.92 %) rates. Extensive validation confirms the robustness and effectiveness of MindSync, highlighting its potential as a reliable tool for objective mental health evaluation.},
  keywords={Training;Deep learning;Accuracy;Mental health;Feature extraction;Brain modeling;Depression;Electroencephalography;Data models;Data mining;Deep Learning;Depression Detection;Multimodal Analysis;Feature Fusion;and Mental Health;Emotion Recognition;Neural Networks;Feature Extraction},
  doi={10.1109/i-PACT65952.2025.11307987},
