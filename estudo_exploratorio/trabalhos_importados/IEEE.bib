  year={2022},
  volume={2022},
  number={},
  pages={163-167},
  abstract={Natural language processing (NLP) is a technique that can be used to identify whether a machine perceives social media data as positive, negative, or neutral. If left untreated, these feelings can lead to depression, suicide, or making dangerous decisions. For NLP and text analytics, machine learning entails a set of statistical approaches for detecting bits of speech, entities, sentiment, and other properties of text. The strategies can be expressed as a model that is then applied to other texts, referred to as supervised machine learning. Unsupervised machine learning is a set of algorithms that work across enormous sets of data to extract meaning.},
  keywords={},
  doi={10.1049/icp.2023.0390},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{10083724,
  author={Sailesh, Lakkimsetti Jayanth and Kumar, Vutukuri Kishore and Nimala, K. and Nareshkumar, R.},
  booktitle={2023 International Conference on Artificial Intelligence and Knowledge Discovery in Concurrent Engineering (ICECONF)}, 
  title={Emotion Detection in Instagram Social Media Platform}, 
  year={2023},
  volume={},
  number={},
  pages={1-6},
  abstract={Depression is regarded as an important issue because it is the largest cause of disability around the world and a major factor in the formation of serious medical conditions, which can even lead to suicidal thoughts and behaviors. Sad feelings and a loss of interest in activities that were once pleasurable both are signs of depression. This existence medical condition has a significant impact on how you think, how you feel, and how you behave. There are millions of people who are struggling with depression, yet only a small proportion of them are receiving treatment that really is appropriate and sufficient. Because the majority of us are now very connected to social media, we came to the conclusion that it would be helpful to examine any depression-related behaviors that people show in their posts on social media. In most cases, this is the result of the activities that a person engages in on a daily basis, such as working, pondering, relationship problems, learning, and so on. It is recognized as the serious challenge that we face in our day-to-day lives. Forums on social media are where a lot of people spend their time these days. It is critical to be able to identify posts that are related to depression in order to avoid people in the community from spreading negativity.},
