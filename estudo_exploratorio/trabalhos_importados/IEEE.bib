  number={6},
  pages={4439-4451},
  abstract={Computational approaches to predicting mental health conditions in social media have been substantially explored in the past years. Multiple reviews have been published on this topic, providing the community with comprehensive accounts of the research in this area. Among all mental health conditions, depression is the most widely studied due to its worldwide prevalence. The COVID-19 global pandemic, starting in early 2020, has had a great impact on mental health worldwide. Harsh measures employed by governments to slow the spread of the virus (e.g., lockdowns) and the subsequent economic downturn experienced in many countries have significantly impacted people's lives and mental health. Studies have shown a substantial increase of above 50% in the rate of depression in the population. In this context, we present a review on natural language processing (NLP) approaches to modeling depression in social media, providing the reader with a post-COVID-19 outlook. This review contributes to the understanding of the impacts of the pandemic on modeling depression in social media. We outline how state-of-the-art approaches and new datasets have been used in the context of the COVID-19 pandemic. Finally, we also discuss ethical issues in collecting and processing mental health data, considering fairness, accountability, and ethics.},
  keywords={Depression;Social networking (online);Mental health;Pandemics;COVID-19;Data models;Natural language processing;COVID-19;Depression;NLP;Mental health;Social media},
  doi={10.1109/JBHI.2025.3540507},
  ISSN={2168-2208},
  month={June},}@INPROCEEDINGS{10687916,
  author={Nema, Neetesh Kumar and Shukla, Vivek and Pimpalkar, Amit and Tandan, S. R.},
  booktitle={2024 OPJU International Technology Conference (OTCON) on Smart Computing for Innovation and Advancement in Industry 4.0}, 
  title={Sentiment Analysis of Depression and Anxiety Social Media Tweets Using TF-IDF Weighting and Supervised Learning Algorithm}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={One of the most prevalent mental illnesses and a significant contributing factor to suicides is depression. The increased usage of social media platforms has made it possible to diagnose depression early on by speaking to individuals in their native tongue. This research explores sentiment analysis on a Twitter dataset by categorizing tweets into ‘positive’ and ‘negative’ sentiments. The proposed model exhibits exceptional performance in the context of depression and anxiety sentiment classification. Employing pre-processing techniques enhanced dataset quality, including tokenization, lemmatization, and stop word removal. The entire process, including the analysis and sorting steps, would use social media data, including text data and emoticons, emojis, and other graphics. Incorporating the TF-IDF weighting scheme further refined sentiment conveyance by emphasizing specific terms. A supervised machine-learning algorithm was applied, and the proposed model demonstrated superior performance, achieving precision, recall, F1-Score, and accuracy at 98.27%, 98.07%, 98.00%, and 98.01%, respectively. These remarkable metrics underscore the proposed model’s exceptional ability to classify tweets accurately, highlighting its robustness in handling X (formally Twitter) data distinctions for advanced social media analytics.},
  keywords={Sentiment analysis;Analytical models;Accuracy;Social networking (online);Blogs;Anxiety disorders;Depression;Depression;Machine Learning;Mental Health;Sentiment Analysis;Social Media;Emotion},
  doi={10.1109/OTCON60325.2024.10687916},
  ISSN={},
  month={June},}@INPROCEEDINGS{10947911,
  author={Chauhan, Shanvi},
  booktitle={2024 International Conference on Artificial Intelligence and Emerging Technology (Global AI Summit)}, 
  title={Exploring LSTM RNNs for Depression Detection: A Deep Learning Perspective}, 
  year={2024},
  volume={},
  number={},
  pages={536-540},
  abstract={One common mental illness that affects individuals's daily life and general state of affairs is depression. Early diagnosis of depression is important since it can lead to timely intervention, better treatment outcomes, and less long-term psychological and physical health impacts, therefore improving good health and well-being. This work attempts to classify sadness using a dataset including 7,732 entries collected from web scraping SubReddit and cleaned using many NLP techniques. With ‘1’ denoting a depressed person and ‘0’ denoting a non-depressed individual, the data—exclusively in English—is separated into two categories: ‘clean_text’ and ‘is_depression’. Long short-term memory (LSTM) and recurrent neural network (RNN) deep learning approaches were used to group the data. The method called for 80% of the data for training and 20% for validation. The algorithm underscored its probable contribution in early depression detection and showed outstanding 96% accuracy in recognizing depressive symptoms from text data. This study increases quality education and helps to reduce inequality by way of its innovative approach, utilization of industry, innovation, and infrastructure in its technology implementation, and expansion of mental health support accessibility.},
  keywords={Deep learning;Training;Technological innovation;Recurrent neural networks;Accuracy;Text recognition;Training data;Mental health;Depression;Long short term memory;Artificial Intelligence;Deep Learning;Long Short-Term Memory (LSTM);Recurrent neural Networks (RNN);Depression Detection Model},
  doi={10.1109/GlobalAISummit62156.2024.10947911},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10859632,
  author={Gori, Fiza and Harshita and Singh, Samrat and Quraishi, Suhail Javed},
  booktitle={2024 9th International Conference on Communication and Electronics Systems (ICCES)}, 
  title={The Role of AI in Identifying Depression: A Review of Techniques and Approaches}, 
  year={2024},
  volume={},
  number={},
  pages={1830-1834},
  abstract={Depression affects over 280 million people globally, posing challenges to traditional diagnostic methods due to their subjectivity and time inefficiency. This review examines the role of Artificial Intelligence (AI) in detecting depression, emphasizing Natural Language Processing (NLP), deep learning, and multimodal techniques. Social media analytics and sentiment analysis are pivotal in early detection, addressing patterns in user behavior and interactions. While AI shows potential, challenges such as privacy concerns, data diversity, and ethical considerations persist. This paper emphasizes the need for robust model validation, improved interpretability, and collaborative frameworks for deploying AI in mental health care.},
  keywords={Deep learning;Ethics;Data privacy;Social networking (online);Reviews;Explainable AI;Soft sensors;Mental health;Depression;Standards;Depression;Natural language processing;Chatbot;Text processing;Image processing},
  doi={10.1109/ICCES63552.2024.10859632},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{11081381,
  author={Deepthi, K. Jaya and Sravanthi, G. and Suvarna, M. and Reddy, K. Srinivasa and Yamini, L.},
  booktitle={2025 International Conference on Advances in Modern Age Technologies for Health and Engineering Science (AMATHE)}, 
  title={Advanced Text-Based Depression Detection Using Machine Learning Techniques}, 
  year={2025},
  volume={},
  number={},
  pages={1-7},
  abstract={Early and correct diagnose of depression are critical when planning for mental health intervention. In this work, we propose a new method for studying depression via text analysis through state-of-the-art machine learning and deep learning techniques. In particular, we examine the performance of Classical CNN and LGBM algorithms for depression predictors using text data. CNNs are good at capturing intricate features in unstructured text and on the other hand, LGBM is one of the best performing models trained on structured data. Presentation methods effectiveness in depression detection is assessed by conducting a comparative analysis of two dissimilar approaches, which are examined in this research. Two models are trained on training data, and hyperparameter tuning is done to improve the predictiveness of each. The models will be evaluated with performance metrics; for example: accuracy, precision recall, F1-score and others in order to understand how well the different models could deal with text. This study attempts to find the most proficient technique in text-based depression detection, specifically using CNN and LGBM for comparison, a study that provides potential scalable solutions for health monitoring. These findings support the development of early intervention strategies, and may be used by mental health professionals to identify cases through automated and personalized text messages.},
  keywords={Deep learning;Analytical models;Accuracy;Text analysis;Mental health;Depression;Data models;Convolutional neural networks;Monitoring;Tuning;depression;mental health;text analysis;machine learning and deep learning techniques;Convolutional Neural Networks (CNN);Light Gradient Boosting Machine (LGBM);linguistic patterns in textual data;accuracy;precision;recall;F1-score},
  doi={10.1109/AMATHE65477.2025.11081381},
  ISSN={},
  month={April},}@INPROCEEDINGS{11100499,
  author={Kokila, S and Yashaswini, K A and Manasa, C M and Preethi and Sangani, Sangeetha Parameshwar and Sapna, R},
  booktitle={2025 IEEE International Conference on Automatic Control and Intelligent Systems (I2CACIS)}, 
  title={Hybrid Machine Learning Model for Detecting Depression on its Early Stage}, 
  year={2025},
  volume={1},
  number={},
  pages={232-237},
  abstract={The proposed study presents a simplified and yet innovative idea of addressing the early detection problem for depression from social media post. Review of literature suggest different variants of machine learning model towards detection of depression; however, there are open-end issues. Hence, the current work introduced a hybridized machine learning model using Gradient Boosting, Random Forest, and Support Vector Machine. The model also contributes to a novel manifold feature extraction approach to enrich the final feature vector quality. The prime contribution of this study is its improved generalization, adaptability, and scalability. Tested with massive benchmarked dataset of social media, the proposed model exhibited 97% accuracy and 25% faster response time in contrast to standalone version of existing machine learning model.},
  keywords={Support vector machines;Adaptation models;Social networking (online);Scalability;Predictive models;Depression;Feature extraction;Data models;Random forests;Long short term memory;Early Detection;Depression;Social Media;Support Vector machine;Random Forest;Gradient Boosting;Accuracy},
  doi={10.1109/I2CACIS65476.2025.11100499},
  ISSN={2995-2859},
  month={June},}@INPROCEEDINGS{11172223,
  author={Karmakar, Proloy and Turjo, Chinmoy Modak},
  booktitle={2025 International Conference on Quantum Photonics, Artificial Intelligence, and Networking (QPAIN)}, 
  title={Detecting Suicide Risk Across Social Media Platforms: Comparing Traditional and Deep Learning Approaches}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Suicide is an undeniable threat to our society today. People of all ages are prone to committing suicide. Most of them remain in depression before committing suicide. They often share their posts and thoughts on social networks to express the suffering they are going through. This research focuses on identifying suicide risk through social media content using AI-based approaches. We have collected Twitter and Reddit posts labeled as suicidal or non-suicidal, and Natural Language Processing (NLP) techniques are applied for preprocessing and feature extraction. Various models, including traditional machine learning (SVM, Random Forest, etc.) and deep learning approaches (CNN, ANN, LSTM, BERT) and hybrid(BERTCNN, CNN-LSTM), were trained and evaluated. Our results show that deep learning models, especially BERT and CNNLSTM, outperform traditional classifiers 93.51% in SVM and Logistic Regression), achieving up to 98.12% accuracy. This study demonstrates the potential of AI in real-time mental health monitoring and early suicide prevention through social media analysis. Timely detection of suicidal intent can mean the difference between life and death.},
  keywords={Deep learning;Logistic regression;Social networking (online);Transformers;Feature extraction;Data models;Real-time systems;Natural language processing;Random forests;Tuning;Suicidal Ideation Detection;Machine Learning;Deep Learning;BERT for Text Classification;CNN-LSTM Hybrid Model},
  doi={10.1109/QPAIN66474.2025.11172223},
  ISSN={},
  month={July},}@INPROCEEDINGS{11035901,
  author={Krishna, N. Bala and Lokesh, K. and Sekhar, Chekkera Soma and Kiran, Chittannagari Reddy and Somasekhar, Atmakur Veera and Royal, Gajula Mohanteja},
  booktitle={2025 International Conference on Knowledge Engineering and Communication Systems (ICKECS)}, 
  title={A Hybrid Approach for Predicting Depression Using Deep Learning}, 
  year={2025},
  volume={},
  number={},
  pages={1-7},
  abstract={Depression is a common psychological disorder that negatively impacts individuals as well as society at large. Early recognition and intervention may enhance results and reduce dangers associated with untreated depression. This research proposes a hybrid deep learning approach that combines DistilBERT(Bidirectional Encoder Representations from Transformers), a lightweight generator model incorporating Long Short-Term Memory (LSTM) connections to predict depressive tendencies from large-scale textual datasets. The hybrid architecture leverages DistilBERT’s capacity for capturing contextual and semantic nuances in text, alongside LSTM’s ability to model temporal dependencies and sequential patterns, enabling a comprehensive analysis of depressive signals.The dataset comprises user-generated content annotated to reflect depressive and non-depressive signals, with extensive preprocessing ensuring the quality of features used for training. Evaluation measures show that the DistilBERT-LSTM model outperforms typical machine learning methods. Using Explainable AI(XAI) techniques like Local Interpretable Model-Agnostic Explanations (LIME) promotes transparency and confidence in decision-making for real-world mental health applications. This study demonstrates how sophisticated natural language processing (NLP) approaches can address issues in mental health care by providing scalable, accurate, and interpretable solutions for detecting depression in big text datasets.},
  keywords={Deep learning;Analytical models;Accuracy;Mental health;Predictive models;Depression;Data models;Natural language processing;Long short term memory;Context modeling;LSTM;DistilBERT;NLP;Hybrid Models;Sequence Modeling;Contextual Embeddings;Attention Mechanism;Machine Learning;LIME},
  doi={10.1109/ICKECS65700.2025.11035901},
  ISSN={},
  month={April},}@INPROCEEDINGS{9918805,
  author={Nazir, Nuriffah Izzati and Zainuddin, Nurulhuda and Selamat, Ali},
  booktitle={2022 3rd International Conference on Artificial Intelligence and Data Sciences (AiDAS)}, 
  title={Sentiment Analysis of Depression Illness during Covid-19 in Social Media: A Preliminary Study}, 
  year={2022},
  volume={},
  number={},
  pages={238-242},
  abstract={Depression is now a common mental health condition that must be treated in people, particularly adolescents. Although the issue of mental illness has received more attention in recent years, many cases of depression remain undiagnosed. Traditionally, the diagnosis process involved face-to-face communication between doctors and patients, with the doctors referring to clinical depression criteria. However, there are few and limited resources and facilities for the early detection and treatment of depression and other mental illnesses. Therefore, to reduce the negative effect on public health, it is important to provide a model to classify depression by using sentiment analysis. Sentiment analysis has recently emerged as a hot topic in classifying the opinions expressed in a piece of writing to determine the information insight and the writer's point of view on a specific issue. This paper investigates the method to classify sentiments in the mental health domain. The classical features and sentiment analysis approach is conducted in this preliminary study to detect depression using a sample of data collected from Twitter. By using a combination of the lexical approach and the Naive Bayes model, the highest accuracy is achieved above 69%. The results indicate a combination of lexical and machine learning outperforms several machine learning approaches for classifying depression in individual tweets.},
  keywords={COVID-19;Sentiment analysis;Social networking (online);Blogs;Mental health;Machine learning;Writing;depression;mental health;sentiment analysis;SentiWordNet;Naive Bayes},
  doi={10.1109/AiDAS56890.2022.9918805},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10337013,
  author={Chen, Ziyi and Yang, Ren and Fu, Sunyang and Zong, Nansu and Liu, Hongfang and Huang, Ming},
  booktitle={2023 IEEE 11th International Conference on Healthcare Informatics (ICHI)}, 
  title={Detecting Reddit Users with Depression Using a Hybrid Neural Network SBERT-CNN}, 
  year={2023},
  volume={},
  number={},
  pages={193-199},
  abstract={Depression is a widespread mental health issue, affecting an estimated 3.8% of the global population. It is also one of the main contributors to disability worldwide. Recently it is becoming popular for individuals to use social media platforms (e.g., Reddit) to express their difficulties and health issues (e.g., depression) and seek support from other users in online communities. It opens great opportunities to automatically identify social media users with depression by parsing millions of posts for potential interventions. Deep learning methods have begun to dominate in the field of machine learning and natural language processing (NLP) because of their ease of use, efficient processing, and state-of-the-art results on many NLP tasks. In this work, we propose a hybrid deep learning model (SBERT-CNN) which combines a pretrained sentence BERT (SBERT) and convolutional neural network (CNN) to detect individuals with depression with their Reddit posts. The sentence BERT is used to learn the meaningful representation of semantic information in each post. CNN enables the further transformation of those embeddings and the temporal identification of behavioral patterns of users. We trained and evaluated the model performance to identify Reddit users with depression by utilizing the Self-reported Mental Health Diagnoses (SMHD) data. The SBERT-CNN model achieved an accuracy of 0.86 and an F1 score of 0.86 and outperformed the state-of-the-art documented result (F1 score of 0.79) by other machine learning models in the literature. The results show the feasibility of the hybrid SBERT-CNN model to identify individuals with depression. Although the hybrid model is validated to detect depression with Reddit posts, it can be easily tuned and applied to other text classification tasks and different clinical applications.},
  keywords={Deep learning;Social networking (online);Text categorization;Neural networks;Mental health;Depression;Natural language processing;Sentence-BERT;SBERT;Convolutional neural network;CNN;Deep learning;Natural language processing;NLP;Text classification;Mental health;Depression;Social media;Reddit},
  doi={10.1109/ICHI57859.2023.00035},
  ISSN={2575-2634},
  month={June},}@INPROCEEDINGS{10933098,
  author={Leow, Justin J. D. and Chua, Hui Na and Jasser, Muhammed Basheer and Issa, Bayan and Wong, Richard T.K.},
  booktitle={2025 21st IEEE International Colloquium on Signal Processing & Its Applications (CSPA)}, 
  title={Comparison of Depression Detection Between LLMs and Zero-Shot Learning Using DAD Dataset}, 
  year={2025},
  volume={},
  number={},
  pages={295-300},
  abstract={Early and accurate detection of depression is critical for improving mental health outcomes. Yet, selecting an appropriate machine learning approach remains challenging due to differences in data availability, annotation costs, and computational resources. Fine-tuned Large Language Models (LLMs) and Zero-Shot Learning (ZSL) represent fundamentally distinct paradigms for natural language understanding tasks. Comparing these approaches is crucial because LLMs rely on large, labeled datasets, while ZSL provides a practical alternative in scenarios with limited or no annotated data. Despite their growing application, these methods are often studied in isolation, leaving a gap in understanding their relative advantages and trade-offs. This study addresses this gap by evaluating the performance of a fine-tuned BERT-LLM and a BART-based ZSL model on our custom-made Depression Analysis Dataset (DAD). Our research experiments showed that the fine-tuned BERT-LLM achieved accuracy and F1 scores of 98.94% and 99.24 %, respectively, while the BART-ZSL model attained 76.53% and 81.26%. The findings highlight the suitability of LLMs for high-reliability settings and ZSL for early detection in resource-constrained contexts, providing actionable insights for data scientists and mental health practitioners to design effective and accessible depression detection systems.},
  keywords={Visualization;Accuracy;Explainable AI;Large language models;Zero shot learning;Blogs;Mental health;Writing;Depression;Multilingual;large language models;zero-shot learning;depression detection;machine learning;deep learning;depression analysis dataset (DAD);natural language processing;BERT;BART},
  doi={10.1109/CSPA64953.2025.10933098},
  ISSN={2836-4090},
  month={Feb},}@INPROCEEDINGS{11059038,
  author={Kaushik, Pratham and Sharma, Pooja},
  booktitle={2024 International Conference on Advances in Computing, Communication and Materials (ICACCM)}, 
  title={Enhancing Mental Health Detection via Machine Learning: A Sentiment Analysis Technique Utilizing Social Media Data}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={The rise in the use of social media allows for new avenues for the monitoring of mental health, the automation of analysis requires methods due to the large quantum of data. This paper will review the application of sentiment analysis to detect and classify mental health conditions using data from social media. Three training machine learning models include Bernoulli Naive Bayes, Logistic Regression, and XGBoost (XGB) on wholesome data over seven mental health statuses: normal, depression, suicidal, anxiety, stress, bipolar, and personality disorder. The recent one seems to be the most performing, the XGB Classifier, with an accuracy of about 80%, way more performant than the other tested models when it comes to critical conditions like suicidal thoughts and depression. Then logistic regression significantly follows with an accuracy of 76.54%, and Bernoulli Naive Bayes is the last one, with an accuracy of 64.06%. This paper finally points out that machine learning has the potential to contribute much to sentiment-based mental health analysis and offer a scalable, non-intrusive method for monitoring emotional well-being via social media. Future works may be related to improving feature extraction and dealing with cultural variations in the expression of emotions.},
  keywords={Sentiment analysis;Logistic regression;Accuracy;Social networking (online);Mental health;Machine learning;Depression;Feature extraction;Bayes methods;Monitoring;Sentiment Analysis;Mental Health Detection;Social Media;Machine Learning;Natural Language Processing (NLP);Emotional Well-Being},
  doi={10.1109/ICACCM61117.2024.11059038},
  ISSN={2642-7354},
  month={Nov},}@INPROCEEDINGS{10067346,
  author={Al-Musallam, Norah and Al-Abdullatif, Mohammed},
  booktitle={2022 Fifth National Conference of Saudi Computers Colleges (NCCC)}, 
  title={Depression Detection Through Identifying Depressive Arabic Tweets From Saudi Arabia: Machine Learning Approach}, 
  year={2022},
  volume={},
  number={},
  pages={11-18},
  abstract={Depression is a mental illness that affects a person’s feelings and causes them to be negative. According to the WHO (World Health Organization), 280 million people suffer from depression, and it is a main cause of suicide and carries a great burden of disease. Given that social media is the number one source nowadays for expressing a person’s emotions and feelings, it provides a proper environment to harvest raw data and detect signs of depression by analyzing the content shared by users. In this paper, we proposed a model for the detection of depression using Twitter as a source of information as it is one of the most popular social media platforms. Moreover, we found that research on such topics is lacking for the Arabic language and Arab users even though Arabic is the 4th most used language on Twitter. Therefore, we aimed to detect depression by identifying depressive tweets using natural language processing (NLP) tools and techniques to reveal the sentiments expressed by Arabs in their tweets and the polarity of depression. We have applied machine learning algorithms: Support Vector Machine (SVM), K-Nearest Neighbors (KNN), Logistic Regression (LR) and Naïve Bayes (NB) on tweets that are of the Saudi Dialect of the Modern Arabic Language to identify depressive tweets. Along with a combined Term Frequency - Inverse Document Frequency (TFIDF) and N-gram feature extraction approach, we concluded that combining TF-IDF with N-gram produces better results. We also found that Logistic Regression outperformed the other algorithms with an accuracy of 82%.},
  keywords={Support vector machines;Machine learning algorithms;Social networking (online);Blogs;Organizations;Machine learning;Depression;Sentiment Analysis;Arabic Language;Natural Language Processing;Machine Learning},
  doi={10.1109/NCCC57165.2022.10067346},
  ISSN={},
  month={Dec},}@ARTICLE{11005879,
  author={Li, Yuxin and Kumbale, Sinchana and Chen, Yanru and Surana, Tanmay and Chng, Eng Siong and Guan, Cuntai},
  journal={IEEE Journal of Biomedical and Health Informatics}, 
  title={Automated Depression Detection From Text and Audio: A Systematic Review}, 
  year={2025},
  volume={29},
  number={10},
  pages={7498-7513},
  abstract={Depression is a prevalent mental health disorder that presents significant challenges for timely diagnosis and intervention. Automated Depression Detection (ADD) systems using text and audio offer scalable mental health assessment solutions. This review systematically evaluates 65 studies published between 2018 and 2024, focusing on ADD methods that utilize machine learning models with multimodal data. We examine key methodologies, including data augmentation, multimodal fusion, and feature extraction, along with state-of-the-art ADD systems. The review emphasizes the need for culturally adaptable, high-quality datasets and interpretable models for clinical use. We also identify gaps in longitudinal data and real-world applications. Future research should focus on developing clinically integrated, cross-cultural ADD systems that are interpretable, scalable, and robust. The findings of this review contribute to the research field by providing a comprehensive overview of existing methodologies, identifying gaps in the current literature, and offering insights for future advancements in depression detection using speech and text analysis.},
  keywords={Depression;Mental health;Feature extraction;Deep learning;Systematic literature review;Databases;Biomedical signal processing;Bioinformatics;Biomedical signal processing;deep learning;mental health technology;health informatics},
  doi={10.1109/JBHI.2025.3570900},
  ISSN={2168-2208},
  month={Oct},}@INPROCEEDINGS{10911717,
  author={Jadhav, Ganesh D. and Babar, Sachin D. and Mahalle, Parikshit N.},
  booktitle={2024 IEEE 4th International Conference on ICT in Business Industry & Government (ICTBIG)}, 
  title={Exploratory Data Analysis and Algorithmic Comparison for Early Depression Detection}, 
  year={2024},
  volume={},
  number={},
  pages={1-7},
  abstract={Early depression detection is very significant for timely intervention and treatment in mental health. This study introduced an extensive system for the early detection of depression, utilizing basic experimentation and analysis techniques. The system is built upon the ‘Detailed_PHQ8_Labels.csv’ dataset, derived from the ‘Extended Distress Analysis Interview Corpus (E-DAIC)’. The dataset contains responses to eight key questions from the ‘Patient Health Questionnaire (PHQ-8), covering symptoms such as ‘No Interest’, ‘Depressed’, ‘Sleep’, ‘Tired’, ‘Appetite’, ‘Failure’, 'Concentrating', and ‘Moving’. The proposed methodology used a ‘thresholding technique’ on the PHQ-8 total score to classify depression into four categories: minimal or no depression, early signs of depression, moderate depression, and moderate to severe depression. This study is based on various algorithms of ‘Machine Learning’ and ‘Deep Learning’. Additionally, the study includes advanced technology for multimodal, such as an ‘Ensemble Model (LSRG)’ and late fusion techniques to improve accuracy. This study focused on the ability to combine traditional thresholding methods with advanced ‘Machine Learning’ and ‘Deep Learning’ algorithms for the early detection of depression. It proposed a robust framework for further development in mental health diagnostics in the medical field.},
  keywords={Machine learning algorithms;Government;Mental health;Machine learning;Depression;Prediction algorithms;Classification algorithms;Predictive analytics;Interviews;Medical diagnostic imaging;Advanced Machine Learning;Mental Health Screening;Classification Algorithms Predictive Analytics;Health Informatics},
  doi={10.1109/ICTBIG64922.2024.10911717},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{11022472,
  author={Akhi, Airin Jahan and Rani, Farhana Parvin and Mumenin, Nasirul and Hossain, A.B.M. Kabir},
  booktitle={2024 27th International Conference on Computer and Information Technology (ICCIT)}, 
  title={An Explainable Ensemble Model for Depression Detection from Social Platform Data}, 
  year={2024},
  volume={},
  number={},
  pages={2134-2139},
  abstract={Depression is a mental health condition marked by persistent feelings of sadness and a diminished capacity to enjoy or participate in usual activities. The detection of depression from social network data has attracted considerable interest due to the increasing prevalence of mental health issues and the widespread use of on-line platforms. Artificial Intelligence (AI) methods, leveraging Natural Language Processing (NLP) plays a crucial role in pinpointing potential risks. In this study, a deep integrated hybrid model consisting of Convolutional Neural Network (CNN) and Long-Short Term Memory (LSTM) has been proposed for identifying depression from content shared on social platforms. The model has been trained and tested using a publicly available benchmark dataset consisting of posts from various social media platforms. Experimental evaluation and comparison with existing work and Machine Learning (ML) models has shown that the proposed model outperformed them all, achieving a remarkable accuracy of 97% on a large dataset, showcasing the model’s robustness and efficacy. Furthermore, to enhance interpretability and transparency of our model, we have applied Explainable AI (XAI), incorporating, LIME for local interpretability of the decision-making processes of our model.},
  keywords={Social networking (online);Explainable AI;Computational modeling;Mental health;Depression;Natural language processing;Data models;Robustness;Convolutional neural networks;Long short term memory;Depression Detection;Ensemble Model;Explainable AI;Social Media;Natural Language Processing},
  doi={10.1109/ICCIT64611.2024.11022472},
  ISSN={2474-9656},
  month={Dec},}@INPROCEEDINGS{10212779,
  author={Quader, Adib Wahid and Jamil, Md Shafayet and Uddin, Mohammad Irfan and Patwary, Muhammed J. A.},
  booktitle={2023 International Conference on Next-Generation Computing, IoT and Machine Learning (NCIM)}, 
  title={A Machine-Learning Approach to Classify Depressive Posts from Reddit Social Media}, 
  year={2023},
  volume={},
  number={},
  pages={1-6},
  abstract={Depression leading to suicide has become a major concern in our society. It's high time to investigate the reason behind it. As numerous people are expressing their concerns regarding depression on Reddit, such post can be taken into consideration in order to find the reason behind it. There has been a lot of research work in this field but most of it is done using traditional machine learning approach with NLP techniques. Moreover, recently there's has not been any significant research work regarding depression. In this paper, we found the indicators that could indicate how relevant Reddit users feel about depression using machine learning, ensemble learning, and deep learning techniques. Moreover, we pinpointed the terms that appear more frequently in narratives of depression. To strengthen the research work, we took the dataset over the period from 2017 to 2021. Furthermore, we demonstrated the effectiveness of LSTM & BERT on recent dataset.},
  keywords={Deep learning;Social networking (online);Bit error rate;Depression;Transformers;Feature extraction;Data models;Depression Detection;Reddit;Social Media;Natural Language Processing;BERT;Deep learning},
  doi={10.1109/NCIM59001.2023.10212779},
  ISSN={},
  month={June},}@INPROCEEDINGS{10441398,
  author={Rai, Shanskar and Bhattarai, Sumiran and Dhar, Premjyoti and Upadhyaya, Biraj and Sharma, Kalpana and Gurung, Sandeep},
  booktitle={2023 9th International Conference on Signal Processing and Communication (ICSC)}, 
  title={Analyzing Social Media texts for Suicidal Risk Identification using Natural Language Processing}, 
  year={2023},
  volume={},
  number={},
  pages={227-231},
  abstract={Suicide is a pressing public health concern, with nearly 700,000 people taking their own lives annually, equating to one life lost every 45 seconds as per the World Health Organization. Recognizing that individuals contemplating suicide may exhibit identifiable behavioral patterns prior to their attempts, this work aims to employ Natural Language Processing (NLP) algorithms for prediction of risk of committing suicide by analyzing these patterns in social media posts. The system presented in this study uses machine learning to predict and identify suicidal ideation in online social content. To detect suicidal ideas via digital communication, the framework uses machine learning approaches. In this work, the machine learning algorithms SVM, logistic regression and CNN provide accuracy of 94.02%, 93.7% and 92.09% respectively.},
  keywords={Support vector machines;Logistic regression;Machine learning algorithms;Social networking (online);Signal processing algorithms;Prediction algorithms;Natural language processing;suicide;public health concern;natural language processing;suicide risk prediction;social media posts;mental health surveillance;predictive algorithms;machine learning},
