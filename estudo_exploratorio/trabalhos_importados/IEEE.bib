  booktitle={2024 International Conference on Big Data Analytics in Bioinformatics (DABCon)}, 
  title={Machine Learning Techniques for Identifying Distressed Individuals on Social Media - A Survey}, 
  year={2024},
  volume={},
  number={},
  pages={01-06},
  abstract={The pervasive presence of social media platforms has turned them into reservoirs of human emotions, providing a distinctive perspective into the intricate tapestry of digital sentiments. This research delves into the realm of emotional upheaval prevalent in online spaces, aiming to uncover signs of distress through the utilization of machine learning algorithms. By scrutinizing extensive volumes of social media data, this survey seeks to establish a pioneering framework for predicting the identification of individuals undergoing emotional distress. Many papers are published on machine learning approaches over the past few decades. In this paper, we provide a comprehensive survey of all best machine learning approaches in the current year to study or identify distress calls on social video through sentiment and media analysis. Furthermore, the challenges and benefits of using Machine Learning, along with its shortcomings, are summarized. Finally, open issues and their consequences for further research in the field of identifying individuals who are mentally depressed on social media are presented.},
  keywords={Surveys;Ethics;Machine learning algorithms;Social networking (online);Surge protection;Machine learning;Mental health;Predictive models;Real-time systems;Surges;Machine Learning;social media;Emotional Distress;Predictive Modelling;Natural Language Processing;Sentiment Analysis;Digital Behavior;Emotional Health;Online Communities;Emotional Signals;Mental Health Support;Distress Identification;Digital Well-being},
  doi={10.1109/DABCon63472.2024.10919310},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{11325507,
  author={Soni and Sharma, Dilip Kumar},
  booktitle={2025 IEEE 7th International Conference on Computing, Communication and Automation (ICCCA)}, 
  title={Develop an Enhanced AI-Based Model to Predict Depression in Women}, 
  year={2025},
  volume={},
  number={},
  pages={1-7},
  abstract={As the prevalence of depression in women continues to increase, there is a need to improve early diagnosis and intervention methods. Using a novel multimodal deep learning architecture and combining multiple data sources, this study seeks to develop a better artificial intelligence (AI)-based model for predicting depression in women. Using dedicated deep learning encoders and attention-based synthesis methods, we believe that combining self-report questionnaires, physiological data, social media activity, and environmental factors will create a simpler and simpler, as well as more intuitive, predictive model. This study describes a hybrid deep learning architecture, data collection methods, appropriate behavior engineering procedures, and a robust assessment framework. The potential for this advanced AI model to help provide early diagnosis and tailored treatment and improve mental health outcomes for women is being seriously investigated.},
  keywords={Deep learning;Social networking (online);Computational modeling;Soft sensors;Mental health;Predictive models;Depression;Data models;Physiology;Artificial intelligence;Depression Prediction;Women's Mental Health;Artificial Intelligence;Deep Learning;Multimodal Data Fusion;Attention Mechanisms;Early Detection;Personalized Healthcare},
  doi={10.1109/ICCCA66364.2025.11325507},
  ISSN={},
