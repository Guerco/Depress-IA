  number={},
  pages={207-214},
  abstract={Sentiment Analysis (SA) has become an extremely sought after area of research especially post COVID-19 when people used to spent a lot of time on the social media to interact with each other. This interaction was done through posts having both textual and visual cues and also by participating in online discussions forums. Some of the inherent challenges encountered in the process of SA include discernment of sarcasm, irony, humor, negation, multi-polarity or Aspect-Level Sentiment Analysis (ASA) etc. Researchers are now gradually shifting their focus to the identification and detection of sarcasm and how it can empower SA. Sarcasm expresses a person’s downside feelings by using positive words in an implicit way. It also has an overall impact on increasing the efficiency of the SA models. Eliciting sarcastic statements is tough for humans as well as for machines without the knowledge of the context or background in which it is expressed, body language and/or facial expression of the speaker and his voice modulation. This review paper studies some of the approaches used for sarcasm detection and also guides researchers in exploring the different modalities of data for developing applications like a virtual chat-bot or assistant, depression analysis, stress management system at workplace etc.},
  keywords={Deep learning;Sentiment analysis;Visualization;Discussion forums;Social networking (online);Employment;Sentiment Analysis;Sarcasm Detection;Negation Detection;Multi-Modal;Social Networks},
  doi={10.1109/ICCMC53470.2022.9753981},
  ISSN={},
  month={March},}@INPROCEEDINGS{11211134,
  author={Liu, Hailing},
  booktitle={2025 2nd International Conference on Intelligent Algorithms for Computational Intelligence Systems (IACIS)}, 
  title={Cognitive Framework for Predicting Students' Anxiety Levels Using Optimized Feed Forward Networks}, 
  year={2025},
  volume={},
  number={},
  pages={01-07},
  abstract={Anxiety disorders are one of better frequent issues of mental health issues globally, millions affecting of people, especially students. These disorders significantly impact the quality of life and manifest as moderate psychological discomfort to severe disorders that persist for months or years. The advent of artificial intelligence (AI) demonstrates a new dimension in the continuous anxiety of monitoring symptoms in world of real applications. However, traditional learning frameworks should not effectively reflect the real situations, and also suffer from computational complexity that hinders in reaching the highest performance of detection. In this regard, this proposes the paper proposes the novel cognitive basis that consists of Pelican optimized Feed forward networks for the classification of accurate of anxiety level among the students. The complete experimentation carried that out using Kaggle's Anxiety various and datasets metrices of performance such as accuracy, precision, recall, and F1-score are measured. To prove the efficacy of the suggested model, the performance ha compares with the other machine learning models. Results demonstrate the suggested model has achieved the accuracy of 0.983, precision of 0.982, recall of 0.981, and an F1-score of 0.982, respectively. Furthermore, model building time (MBT) of each learning framework was calculated in which suggested model consumes only 0.222 secs and 50% faster than the other models. The research demonstrates the brighter insights of using artificial intelligence technique in improving the student's caliber by predicting the anxiety levels.},
  keywords={Accuracy;Computational modeling;Anxiety disorders;Mental health;Machine learning;Prediction algorithms;Feeds;Optimization;Monitoring;Computational intelligence;anxiety disorders;artificial intelligence;pelican optimization;feed forward networks},
  doi={10.1109/IACIS65746.2025.11211134},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{11407212,
  author={Sarkar, Shristi and Garud, Ashish and Shinde, Shivani and Bagade, Sejal and Suryawanshi, Sharon and Guthe, Akansha},
  booktitle={2025 IEEE 2nd International Conference for Women in Computing (InCoWoCo)}, 
  title={Predicting Psychological Distress from Twitter Data Using Machine Learning Algorithms}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Higher prevalence of psychological distress underscores the need for computational models to detect early warning signs in addition to traditional tests. Social media platforms like Twitter are rich but untapped behavioral signals, whereby users expose non-intrusive signs of mental well-being problems. Identification of distress is conceived as a multi-label task over depression, anxiety, suicidal ideation, and OCD. A hand-annotated dataset with enriched lexicons was used to compare KNN, Naive Bayes, an ANN on TF-IDF, and a GNN built from similarity graphs of tweets. Results show that the ANN had the best accuracy (96.21%), while relational dependencies were captured by the GNN, highlighting the significance of multi-dimensional, behavior-aware frameworks for large-scale psychological distress monitoring},
  keywords={Social networking (online);Blogs;Psychology;Artificial neural networks;Nearest neighbor methods;Depression;Graph neural networks;Natural language processing;Bayes methods;Monitoring;Psychological Distress Prediction;Twitter;S;Multi-label Classification;Artificial Neural Network (ANN);Graph Neural Network (GNN);K-Nearest Neighbours (KNN);Naïve Bayes;Machine Learning;Natural Language Processing (NLP)},
  doi={10.1109/InCoWoCo68239.2025.11407212},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{11118906,
  author={Akkur, Malatesh and Paikaray, Bijay Kumar and Mukuntharaj, C. and Sharma, Pratibha and Sheril, S and Sidhu, Amritpal},
  booktitle={2025 IEEE International Conference on Emerging Technologies and Applications (MPSec ICETA)}, 
  title={Leveraging Digital Data and Soft Computing Techniques for Advanced Mental Health Analysis and Intervention Strategies}, 
  year={2025},
  volume={},
  number={},
  pages={1-5},
  abstract={Here we look at an LSTM-SVM algorithm that leverages data on movement patterns from actigraph sensors to recognize sadness. Incorporating data from statistics such as mean, standard deviation, and zero-activity fraction, this framework combines high-order LSTM characteristics with other information. Training and testing the algorithm are done using the Depresjon information set, which contains actigraphy information from regular control people and patients with depression. In order to prepare the data for the extraction of features by the LSTM, it was resampled to 24-hour periods and then framed. When paired with the statistical data, such characteristics were fed into SVM for categorization. The model’s success rate was $95.57 \%$ and its F-measure was 0.955, outperforming comparable deep learning techniques like LSTM and CNN. Sliding doors were the game-changer that raised efficiency by $3.65 \%$; however, adding discriminatory statistical features further improved the algorithm’s accuracy by $1.08 \%$. The results validate the suggested hybrid model’s value in improving depressive disorders detection accuracy and provide credence to its applicability in psychological monitoring with respect to sensors worn. Compared to other deep learning approaches, this strategy produces the best identification model.},
  keywords={Deep learning;Support vector machines;Training;Accuracy;Computational modeling;Computer architecture;Feature extraction;Depression;Long short term memory;Standards;LSTM-SVM;Depresjon DB;LSTM;SVM;and CNN},
  doi={10.1109/MPSecICETA64837.2025.11118906},
  ISSN={},
  month={Feb},}@INPROCEEDINGS{10780472,
  author={Wigell, Christopher and Tao, Xiaohui and Li, Lin and Wang, Grace Y and Zhang, Ji and Sun, Yuan},
  booktitle={2024 11th International Conference on Behavioural and Social Computing (BESC)}, 
  title={Sentiment Analysis for Detection of Depressive Users on Social Networks}, 
  year={2024},
  volume={},
  number={},
  pages={1-7},
  abstract={Depression affects approximately 121 million people worldwide and has as significant an influence on patients as it does their carers. Until recently, psychologists used paper based psychological batteries for screening. New developments in Natural Language Processing however have enabled real-time analysis, offering increases in scalability and accessibility. We built on current knowledge by developing and training several Centralised Neural Network models around a pre-labelled Reddit dataset, comparing post-length and the number of words used per post, selecting the model with the highest F1 score. Our results indicated that although some models performed better than others, neither of our metrics significantly influenced model performance, with changes explained by another factor. Our research was able to yield support for it's use within online forums at a very low cost; justifying further exploration into the use of AI tools for the screening of depression and other mood disorders. Due to a lack of publicly available natural language processing models, our study also resulted in the release of a model for further research by others.},
  keywords={Measurement;Knowledge engineering;Training;Technological innovation;Social networking (online);Computational modeling;Neural networks;Collaboration;Mental health;Depression;Depression;Psychological screening;Natural Language Processing;Centralized Neural Network models;Red-dit;Online forums;AI tools;Mood disorders;Computational psychology},
  doi={10.1109/BESC64747.2024.10780472},
  ISSN={2689-8284},
  month={Aug},}@INPROCEEDINGS{10323808,
  author={AlFarah, Meshari Essa and Kamel, Ibrahim and Al Aghbari, Zaher},
  booktitle={2023 International Symposium on Networks, Computers and Communications (ISNCC)}, 
  title={Toward Detection of Arabic Cyberbullying on Online Social Networks using Arabic BERT Models}, 
  year={2023},
  volume={},
  number={},
  pages={1-6},
  abstract={Cyberbullying is one of the serious threats on social networks particularly toward children and teenagers. Cyberbullying can cause many harmful consequences towards victims such as anxiety, depression and even suicide. This research studies cyberbullying detection in Arabic language on online social networks using deep learning techniques to automatically detect and quarantine the cyberbullying messages to safe children from getting exposed to harmful cyberbullying content. In this paper, real Arabic dataset is collected from YouTube and Twitter that is annotated manually to improve the quality of the data. All experiments went through three rounds of trials to make sure that the results are consistent. Many evaluation metrics were used to evaluate the performance of the classifiers such as macro F1 score and AUC. The best model achieves 84.58% and 85.94% in F1 score and AUC respectively.},
  keywords={Deep learning;Measurement;Computers;Video on demand;Computational modeling;Blogs;Anxiety disorders;Cyberbullying;Arabic BERT;Online Social Networks;Arabic cyberbullying;Transformers;Natural Language Processing (NLP)},
  doi={10.1109/ISNCC58260.2023.10323808},
  ISSN={2768-0940},
  month={Oct},}@INPROCEEDINGS{10290688,
  author={Dwivedi, Chitralekha and Rao, Jyoti},
  booktitle={2023 7th International Conference on I-SMAC (IoT in Social, Mobile, Analytics and Cloud) (I-SMAC)}, 
  title={Multilingual Sentiment Analysis for Detecting Mental Health Problems using a Hybrid algorithm combining RNN and Bi-LSTM}, 
  year={2023},
  volume={},
  number={},
  pages={527-534},
  abstract={Sentiment Analysis is gaining traction nowadays owing to its diversified applications, one of them being identifying people’s mental health issues. Researchers have done great work decoding the actual meaning of human sentiments with the help of machine learning and NLP However, multilingual sentiment analysis and detection of depression from the online comments of a user is still demanding the attention of researchers worldwide. This study offers a novel hybrid recurrent neural network (RNN) and bidirectional long short-term memory (Bi-LSTM) architecture for multilingual sentiment analysis to detect mental health issues. RNN captures sequential information, while Bi-LSTM captures bidirectional dependencies, improving performance. The algorithm is comprised of multiple steps. Tokenization and word embeddings are used to preprocess the dataset. Splitting the preprocessed dataset into training and testing sets, sentiment labels are applied to each text sample and encoded numerically. The hybrid RNN and Bi-LSTM model captures sentiment patterns well. The RNN component evaluates sequential information, while the Bi-LSTM component collects forward and backward dependencies to improve contextual knowledge. To train the model, back propagation and gradient descent minimize a loss function like cross-entropy loss.},
  keywords={Training;Sentiment analysis;Recurrent neural networks;Social networking (online);Mental health;Depression;Propagation losses;Sentiment Analysis;Multilingual Sentiment;Mental Health Problems;Lexicon;Deep Learning;Hybrid Approach},
  doi={10.1109/I-SMAC58438.2023.10290688},
  ISSN={2768-0673},
  month={Oct},}@INPROCEEDINGS{10032346,
  author={Shahabikargar, Maryam and Beheshti, Amin and Khatami, Amin and Nguyen, Ricky and Zhang, Xuyun and Alinejad-Rokny, Hamid},
  booktitle={2022 IEEE 9th International Conference on Data Science and Advanced Analytics (DSAA)}, 
  title={Domain Knowledge Enhanced Text Mining for Identifying Mental Disorder Patterns}, 
  year={2022},
  volume={},
  number={},
  pages={1-10},
  abstract={Mental health disorders may cause severe consequences for countries’ economies and health. Identifying early signs of these disorders is vital. The state-of-the-art research in identifying mental health disorder patterns from textual data, uses hand-labeled training sets, especially when a domain expert’s knowledge is required to analyze various symptoms in a patient. This task could be time-consuming and expensive. To address this challenge, in this paper, we study and analyze the various clinical and non-clinical approaches to identifying mental health disorders. We leverage the domain knowledge and expertise in cognitive science to build a domain-specific Knowledge Base for the mental health disorder concepts and patterns. We present a weaker form of supervision by facilitating and generating training data from a domain-specific Knowledge Base. We adopt a typical scenario for analyzing social media to identify depression symptoms from the textual content generated by social users.},
  keywords={Training;Text mining;Social networking (online);Mental disorders;Knowledge based systems;Training data;Mental health;Mental health disorder;Depression;Cognitive analytics;Identification;Textual data-mining;Weakly Supervised Classifier},
  doi={10.1109/DSAA54385.2022.10032346},
  ISSN={},
  month={Oct},}@ARTICLE{10531721,
  author={Park, Dabin and Lee, Geonju and Kim, Seonhyeong and Seo, Taewoong and Oh, Hayoung and Ju Kim, Seog},
  journal={IEEE Access}, 
  title={Probability-Based Multi-Label Classification Considering Correlation Between Labels— Focusing on DSM-5 Depressive Disorder Diagnostic Criteria}, 
  year={2024},
  volume={12},
  number={},
  pages={70289-70296},
  abstract={The incidence of depressive disorder in Korea is the highest among OECD countries. The proportion of patients in their 20s is the highest. However, social gaze and false perception are causing problems such as not visiting the hospital or delaying the visit. Accordingly, we suggest a Korean model for predicting depressive disorders using data from online communities widely used by people in their 20s. In many countries, including South Korea, depressive disorders are diagnosed using DSM-5 (Diagnostic and Statistical Manual of Mental Disorders, Fifth Edition) published by the American Psychiatric Association. We propose a model that predicts the probability of a user’s speech corresponding to nine criteria for diagnosing DSM-5 depressive disorder, following advice obtained through periodic meetings with a psychiatrist. The prediction performance was improved by using the correlation between each criterion in the model implementation stage.},
  keywords={Depression;Social networking (online);Correlation;Blogs;Data models;Predictive models;Artificial intelligence;Natural language processing;Psychiatry;Mental health;Artificial intelligence;correlation;depressive disorder;multi-label classification;natural language processing;psychiatry in AI},
  doi={10.1109/ACCESS.2024.3401704},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{10808285,
  author={A, Jagan. and D, Senthil Kumar and Karunakaran, S. and D, Nageswari and Dass, Regina Shoba and Seetha, J.},
  booktitle={2024 First International Conference on Innovations in Communications, Electrical and Computer Engineering (ICICEC)}, 
  title={Next-Gen Mental Health Detection through Deep Learning and NLP in Social Media}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={Social media proliferation promotes new modalities of understanding and intervening in mental health. This paper presents a new approach to mental health detection using some deep learning and natural language processing techniques over social media data. Enriched by extensive textual content shared across social media platforms such as Twitter, Reddit, and Facebook, we propose to design an automated system that can detect traces of mental health conditions like depression, anxiety, and stress. In line with the proposed methodology, Bi-LSTM networks and attention mechanisms shall be applied to exploit linguistic patterns and semantic features from user posts. Such techniques involve the integration of sentiment analysis and topic modelling, which increase the accuracy and contextual comprehension of detected signals. Either way, the system is trained against a curated dataset of annotated social media posts validated further against clinical assessments for strength and reliability, with quite promising preliminary results— Rubin et al.'s model achieves high precision and recall in mental health indicator detection. The results reinforce that AI-driven tools have an assay of potential in rendering early detection and intervention support, especially for mental illness, which has contributed to improved mental health outcomes globally.},
  keywords={Deep learning;Technological innovation;Sentiment analysis;Accuracy;Social networking (online);Blogs;Semantics;Mental health;Web sites;Synthetic data;Mental Health Detection;Deep Learning;Natural Language Processing;Social Media Analysis;Sentiment Analysis},
  doi={10.1109/ICICEC62498.2024.10808285},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{11343449,
  author={Sakib, Nazmus and Hosen, Mohammad Anwar and Mumu, Sabrina Mostafij and Bin Jamal, Hasan},
  booktitle={2025 IEEE International Conference on Systems, Man, and Cybernetics (SMC)}, 
  title={A Comparative Study of BERT Variants for Detecting Mental Health Disorders in Online Discourse}, 
  year={2025},
  volume={},
  number={},
  pages={418-423},
  abstract={Mental health disorders, including conditions like depression and suicidal ideation, have emerged as critical public health challenges. Leveraging the synergy between human expertise and intelligent systems, this study explores the potential of Bidirectional Encoder Representations from Transformers (BERT) variants for analysing mental health discourse. Using approximately 11,000 text samples collected from social media platforms, a meticulously pre-processed and annotated dataset, called the Mental Health Disorder Detection Dataset, was developed. Comparative evaluations were conducted using baseline models with balanced data across disorder categories. Results revealed that general BERT variants outperformed Clinical BERT, a medical-specific model. This study introduces a novel dataset and presents key findings that not only enhance machine learning model capabilities but also provide insights into behavioral patterns associated with mental health disorders. These contributions pave the way for developing targeted machine-learning solutions tailored to mental health applications.},
  keywords={Training;Adaptation models;Technological innovation;Social networking (online);Mental health;Bidirectional control;Machine learning;Transformers;Encoding;Data models},
  doi={10.1109/SMC58881.2025.11343449},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10912113,
  author={Joshi, Deepak and Kaur, Manpreet},
  booktitle={2024 2nd International Conference on Advances in Computation, Communication and Information Technology (ICAICCIT)}, 
  title={Deep Learning Multimodal Ensemble Techniques for Detecting the Depression Level using Multitudinous Selective Features}, 
  year={2024},
  volume={1},
  number={},
  pages={670-674},
  abstract={In this modern era, massive population of this world is falling prey to mental illness and psychological diseases rapidly along with other physical diseases. Among all, depressive disorder is becoming major challenging and serious psychological problem. Due to a lack of initial treatment options and resources for depression detection, millions of people struggle with mental illness. It is the primary cause of anxiety disorders, bipolar disorders, sleep disorders, depression, and occasionally, it can result in suicide and self-harm. As a result, recognition and prompt treatment of people experiencing mental health illness is an extremely difficult endeavour but it has paramount importance. The whole purpose of research is to propose deep learning-based model that primarily incorporates audio and textual aspects of patient answers to diagnose depression using the Extended Distress Analysis Corpus Wizard of OZ (EDAIC-WOZ) dataset. The inclination towards this work is to help psychologists and people with depressive symptoms with an accurate detection using artificial intelligence methods so that quick and timely remedial steps can be taken. The proposed model classifies the patients into two groups based on depression level such as the group of people with depressive disorder and others who doesn’t have such disorder by making use of speech spectral and temporal features and textual emotional analysis. This model uses the late fusion ensemble method implemented on the resultant of Audio CNN model and textual Bi-LSTM model. By using optimized methods for pulling out the textual and audio features, this work ensures that relevant characteristics of audio and text to be considered for the study. The conclusion of the research derived from the data set demonstrate the effectiveness of the model by complimenting the conventional diagnostic methods in screening the depression. The novel method is considered to be efficient and scalable solution to monitor the mental health based on depression level. Results reveal that the proposed model outperforms the other models with F1 score 0.98.},
  keywords={Deep learning;Analytical models;Computational modeling;Mental health;Depression;Feature extraction;Information and communication technology;Ensemble learning;Monitoring;Diseases;Deep learning;Depression level;audio;Late score fusion;Bi-LSTM;CNN},
  doi={10.1109/ICAICCIT64383.2024.10912113},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{11077244,
  author={M, Hiba Thanzeela and S, Deepak and Madhavan, Manu and S, Sinith M},
  booktitle={2025 6th International Conference on Control, Communication and Computing (ICCC)}, 
  title={Wav2vec-Based Intelligent Music Recommendation from Text Emotions}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Emotion-based music recommendation systems analyze the user’s emotional state to recommend music. They apply artificial intelligence to suggest music that influences the user’s mood. In this paper, the authors consider the problem of recommending music to users in a mental state of depression. Depression is detected in user’s texts using natural language processing techniques. Upon detecting depression, the proposed system suggests music in appropriate ragas that can have a therapeutic influence on the mental state. The paper proposes using a contextual deep learning model, Wav2vec to identify the required ragas alongside the conventional audio features. The proposed method achieves state-of-the-art performance in raga identification, suggesting the significance of such models in other raga classification problems.},
  keywords={Deep learning;Emotion recognition;Speech analysis;Text recognition;Mood;Music;Transforms;Depression;Natural language processing;Recommender systems;Deep learning;Music recommendation;Natural language processing (NLP);Raga classification;Wav2vec},
  doi={10.1109/ICCC64910.2025.11077244},
  ISSN={},
  month={May},}@INPROCEEDINGS{11035211,
  author={Shwetha, S and Manjunath, K. G.},
  booktitle={2025 International Conference on Knowledge Engineering and Communication Systems (ICKECS)}, 
  title={Futuristic Approaches to Suicide Prevention: Deep Learning and Personalized Mental Health Support for Youth}, 
  year={2025},
  volume={},
  number={},
  pages={1-8},
  abstract={Teenage suicidal ideation is becoming more and more common, necessitating innovative yet compassionate remedies. In order to examine the complex interactions between risk factors as social support, anxiety, and depression, our study presents a CNN-LSTM hybrid model. The model identified adolescents at high risk and revealed patterns essential to comprehending suicidal intentions with a remarkable F1-score of $97.8 \%$ using a strong dataset of 3000+ subjects and 24 parameters. In order to identify distress signs in real time, this sophisticated technology analyzes multi-modal input, such as text and behavioral patterns. It tracks behavioral changes and provides personalized suggestions, including counseling, risk-specific interventions, and access to mental health resources, by utilizing algorithms for sentiment analysis, anomaly detection, and emotion recognition. The framework, which was created in cooperation with mental health specialists, places a high priority on explainability, data protection, and ethical issues to guarantee reliable and equitable results.},
  keywords={Deep learning;Sentiment analysis;Social networking (online);Prevention and mitigation;Biological system modeling;Mental health;Predictive models;Transformers;Real-time systems;Monitoring},
  doi={10.1109/ICKECS65700.2025.11035211},
  ISSN={},
  month={April},}@INPROCEEDINGS{10386719,
  author={Akter, Mst Shapna and Shahriar, Hossain and Cuzzocrea, Alfredo and Wu, Fan and Rodriguez-Cardenas, Juanjose},
  booktitle={2023 IEEE International Conference on Big Data (BigData)}, 
  title={A Trustable LSTM-Autoencoder Network for Cyberbullying Detection on Social Media Using Synthetic Data}, 
  year={2023},
  volume={},
  number={},
  pages={5418-5427},
  abstract={Social media cyberbullying has a detrimental effect on human life. As online social networking grows daily, the amount of hate speech also increases. Such terrible content can cause depression and actions related to suicide. This paper proposes a trustable LSTM-Autoencoder Network for cyberbullying detection on social media using synthetic data. We have demonstrated a cutting-edge method to address data availability difficulties by producing machine-translated data. However, several languages such as Hindi and Bangla still lack adequate investigations due to a lack of datasets. We carried out experimental identification of aggressive comments on Hindi, Bangla, and English datasets using the proposed model and traditional models, including Long Short-Term Memory (LSTM), Bidirectional Long ShortTerm Memory (BiLSTM), LSTM-Autoencoder, Word2vec, Bidirectional Encoder Representations from Transformers (BERT), and Generative Pre-trained Transformer 2 (GPT-2) models. We employed evaluation metrics such as f1-score, accuracy, precision, and recall to assess the models’ performance. Our proposed model outperformed all the models on all datasets, achieving the highest accuracy of 95%. Our model achieves state-of-the-art results among all the previous works on the dataset we used in this paper.},
  keywords={Training;Analytical models;Cyberbullying;Bidirectional control;Organizations;Transformers;Data models;Cyber-bullying;Deep Learning;Neural Networks;Natural Language Processing},
  doi={10.1109/BigData59044.2023.10386719},
  ISSN={},
  month={Dec},}@ARTICLE{9760401,
  author={Martínez-Castaáo, Rodrigo and Losada, David E. and Pichel, Juan C.},
  journal={IEEE Access}, 
  title={Real-Time Focused Extraction of Social Media Users}, 
  year={2022},
  volume={10},
  number={},
  pages={42607-42622},
  abstract={In this paper, we explore a real-time automation challenge: the problem of focused extraction of Social Media users. This challenge can be seen as a special form of focused crawling where the main target is to detect users with certain patterns. Given a specific user profile, the task consists of rapidly ingesting Social Media data and early detecting target users. This is a real-time intelligent automation task that has numerous applications in domains such as safety, health or marketing. The volume and dynamics of Social Media contents demand efficient real-time solutions able to predict which users are worth to explore. To meet this aim, we propose and evaluate several methods that effectively allow us to harvest relevant users. Even with little contextual information (e.g., a single user submission), our methods quickly focus on the most promising users. We also developed a distributed microservice architecture that supports real-time parallel extraction of Social Media users. This modular architecture scales up in clusters of computers and it can be easily adapted for user extraction in multiple domains and Social Media sources. Our experiments suggest that some of the proposed prioritisation methods, which work with minimal user context, are effective at rapidly focusing on the most relevant users. These methods perform satisfactorily with huge volumes of users and interactions and lead to harvest ratios 2 to 9 times higher than those achieved by random prioritisation.},
  keywords={Real-time systems;Social networking (online);Task analysis;Crawlers;Computer architecture;Feature extraction;Data mining;Big data;distributed systems;focused user extraction;supervised learning;information retrieval;real-time processing;social media},
  doi={10.1109/ACCESS.2022.3168977},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{11326366,
  author={Ahnaf, Muhammad Fairuz and Santoso, Noviyanti},
  booktitle={2025 International Conference on Computer Engineering, Network and Intelligent Multimedia (CENIM)}, 
  title={Early Detection of Mental Disorders on X (Twitter) using Machine Learning}, 
  year={2025},
  volume={},
  number={},
  pages={165-170},
  abstract={The rise of social media offers new opportunities to study mental health discourse in low-resource languages like Indonesian, but informal language and limited labeled data pose challenges. This study proposes a two-stage, semi-supervised classification system. First, tweets sharing personal mental health experiences are identified; then, they are categorized into Diagnosed, At-risk, Self-diagnosed, and Survivor. From 15,234 collected tweets, 3,000 were manually annotated to train initial models, with semi-supervised learning expanding labeled data through high-confidence predictions. The best relevance model achieved 97.08% accuracy and 96.94% F1-score, while the best category model achieved 88.00% accuracy and 86.70% F1score. Further analysis revealed lexical patterns and misclassification sources, particularly implied diagnoses and temporal references. This work demonstrates the feasibility of mental health classification in Indonesian and contributes a structured dataset for future public mental health monitoring.},
  keywords={Accuracy;Social networking (online);Mental disorders;Pipelines;Blogs;Text categorization;Mental health;Semisupervised learning;Transformers;Context modeling;Mental Disorder;Text Classification;Twitter},
  doi={10.1109/CENIM67940.2025.11326366},
  ISSN={},
  month={Nov},}
@INPROCEEDINGS{11106008,
  author={Patel, Ankit and Lohumi, Pratyush and Shah, Vishank and Dash, Madhumita and Arya, Meenakshi Sumeet},
  booktitle={2025 11th International Conference on Computing and Artificial Intelligence (ICCAI)}, 
  title={Fine-Tuned Mistral Model for Multi-Agent Mental Health Counseling System}, 
  year={2025},
  volume={},
  number={},
  pages={317-324},
  abstract={In today’s digital world, mental health issues such as stress, depression, and anxiety are often expressed through social media. We propose a multi-agent system utilizing the fine-tuned Mistral-7B model to detect and provide personalized counseling for mental health concerns. This paper discusses the development and deployment of a multi-agent system consisting of diagnostic and counseling agents. By fine-tuning Mistral with the Interpretable Mental Health Instruction (IMHI) dataset, the system offers personalized mental health support, improving scalability and accessibility to mental health services.},
  keywords={Employee welfare;Social networking (online);Scalability;Mental health;Medical services;Real-time systems;Safety;Prompt engineering;Multi-agent systems;Testing;Large Language Models (LLMs);Prompt engineering;fine-tuning;mental health illness;social media;interpretability;multi-agent systems},
  doi={10.1109/ICCAI66501.2025.00056},
  ISSN={},
  month={March},}@INPROCEEDINGS{11313209,
  author={Atta, Alwan and El Sayad, Dina and Ezzat, Doaa and Amin, Safaa and El Gamal, Mahmoud},
  booktitle={2025 Twelfth International Conference on Intelligent Computing and Information Systems (ICICIS)}, 
  title={Leveraging Sentiment Analysis and Particle Swarm Optimization for Accurate Mental Disorders' Detection}, 
  year={2025},
  volume={},
  number={},
  pages={532-537},
  abstract={Accurate diagnosis of mental disorders is a prerequisite for the use of effective forms of treatment. The proposed solution highlights the potential of sentiment analysis in assessing a person's emotional status by examining the context of their written words, the precision of the diagnostic process is bolstered by Particle Swarm Optimization (PSO). The use of the PSO algorithm to optimize model parameters ensures best overall performance. Empirical evidence confirms the viability of the proposed approach to identifying the various mental disorders more accurately in contrast to current best practice. This new approach has much promise for the accurate early diagnosis of mental disorders and offers a considerable advantage to clinics through the ability to spot and treat conditions more accurately and reliably. The optimized Support Vector Classification using Particle Swarm Optimization achieved a global F-score of 0.89, showing the advantage of coupling sentiment analysis and swarm intelligence for the diagnosis of mental disorders.},
  keywords={Couplings;Sentiment analysis;Accuracy;Mental health;Depression;Vectors;Reliability;Particle swarm optimization;Best practices;Information systems;Mental Health;Natural Language Processing;Swarm Intelligence;Depression;Suicidal;Anxiety;Stress;Bipolar;Personality Disorder},
  doi={10.1109/ICICIS66182.2025.11313209},
  ISSN={2831-5952},
  month={Nov},}@INPROCEEDINGS{10441163,
  author={Rafi Imam, MD. and Jyoti, Oishi and Afrin, Zakia and Munawar Hossain, Md. and Hossain Mou, Tamanna},
  booktitle={2023 26th International Conference on Computer and Information Technology (ICCIT)}, 
  title={Suicidal Thought Detection Using NLP(Natural Language Processing) on Reddit Data}, 
  year={2023},
  volume={},
  number={},
  pages={1-6},
  abstract={Our study harnesses the power of NLP to contribute to the identification of suicidal ideation in text data. In the realm of mental health, identification of suicidal ideation at an early stage is of paramount importance for suicide prevention efforts. This paper presents a novel approach to suicide ideation detection using Natural Language Processing (NLP) techniques. Faced with a dearth of publicly available datasets for this critical task, we have contributed a valuable resource by curating a dataset from the “SuicideWatch” and “depression” subreddits on the Reddit platform, collected via the Pushshift API. Specifically, we employ the LSTM and a Random Forest classifier separately to achieve promising results in this vital area of research. This work not only advances the field of NLP-based suicide ideation detection but also contributes a valuable dataset for future investigations, potentially saving time and resources for researchers and professionals dedicated to the prevention of suicide and the improvement of mental health. We could achieve up to 93% accuracy in suicidal thought analysis using NLP techniques.},
  keywords={Social networking (online);Mental health;Depression;Natural language processing;Sparks;Task analysis;Random forests;NLP;Reddit;Pushshiftf;API;LSTM;Random Forest Classifier},
  doi={10.1109/ICCIT60459.2023.10441163},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{11234688,
  author={Jain, Hemish and Kashyap, Anukool and Sivakumar, Soubraylu and Chakravarthy, V Deeban and Selvaraju, P and Yakub, Fitri},
  booktitle={2025 3rd International Conference on Recent Advances in Information Technology for Sustainable Development (ICRAIS)}, 
  title={Suicidal Text Detection Using Machine Learning and Large Language Model}, 
  year={2025},
  volume={},
  number={},
  pages={149-154},
  abstract={The growing prevalence of suicidal ideation in online communities calls for robust and accessible early detection systems. This study presents a machine learning-based approach for identifying suicidal intent from user-generated text, specifically Reddit posts. A curated dataset of approximately 348,000 posts—consolidated to 232,074 unique entries—was collected from the r/SuicideWatch, r/depression, and r/teenagers subreddits using the Pushshift API. The aim of classification was to differentiate the suicidal and non-suicidal content. Several types of models were tried Gaussian Naive Bayes (GNB) Logistic Regression, and a fine-tuned BERT transformer. Extraction of features was carried out on CountVectorizer as well as the Term Frequency-Inverse Document Frequency (TF-IDF). In the models, Bidirectional Encoder Representations of Transformers (BERT) recorded the closest results of 97.68 % and 97.66 % accuracy and F1-scores, respectively, as compared to the traditional classifiers. The paper evidence shows the possibility of the NLP and deep learning techniques combination as scalable and accurate mental health support methods.},
  keywords={Logistic regression;Accuracy;Social networking (online);Large language models;Bidirectional control;Mental health;Transformers;Encoding;Natural language processing;Bayes methods;Suicidal text classification;Large Language;Model;Bidirectional Encoder Representations from Transformers;Logistic regression;Gaussian Naive Bayes},
  doi={10.1109/ICRAIS66073.2025.11234688},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10842731,
  author={Shahakar, Nishad and Battuwar, Rutika and Kadu, Renuka and Khandekar, Priyanka and Archana, Jumale and Saoji, Chetan and Mane, Namrata S.},
  booktitle={2024 2nd DMIHER International Conference on Artificial Intelligence in Healthcare, Education and Industry (IDICAIEI)}, 
  title={Efficient Model for Social Behaviour Analysis and Depression Detection in User Tweets}, 
  year={2024},
  volume={},
  number={},
  pages={1-5},
  abstract={Knowing the way individuals engage on social networking platforms has become important in the modern era. The current research discusses the urgent need for advanced methods for analyzing tweets from users In order to analyze social behavior, particularly when it comes to the recognition of sadness. Though sentiment evaluation has advanced, current techniques frequently disregard crucial variables like user age, tweet time, and emotion of users-linked data. precisely a consequence, there remains a shortage in the understanding needs to correctly assess depression-related behaviors based upon social networking content. We offer a novel architecture that combines fuzzy logic constraint algorithms, graph neural network models (GNNs), with the VADER sentiment detection in order to bridge this gap. Our approach takes into account contextual variables including the age of the individual and the date and time of the post so as to determine the mood of the user's tweets via VADER sentiment evaluation. likewise, our team apply GNNs for further sentiment analysis to linked information, allowing for greater understanding of the feelings of users. When integrating these inputs, the fuzzy logic rule generator provides the user with an anxiety class, delivering the detailed viewpoint upon mental wellness assessments. With the incorporation combined specific to users’ characteristics including sentiment assessment of linked data, our model arrives at enhanced accuracy in predicting overall anxiety. furthermore, the incorporation of fuzzy logic improves accessibility as well as flexibility in response to many different user inputs. This work provides significant possibilities regarding specific networks of support as well as mental wellness measures, in addition to developing the area of psychological analysis. In simple terms, the research we performed presents a comprehensive strategy for understanding and fixing emotional wellness problems in today's technological world.},
  keywords={Fuzzy logic;Industries;Sentiment analysis;Social networking (online);Mood;Linked data;Anxiety disorders;Medical services;Predictive models;Graph neural networks;Fuzzy Logic Rule Engine;Graph Neural Networks;VADER Sentiment Analysis;User Tweets;Social Networking Assessment;and Anxiety Identification},
  doi={10.1109/IDICAIEI61867.2024.10842731},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{10841747,
  author={Bharathi, S. T. and Relin Francis Raj, J. and Krishnan, R. Santhana and Rajalakshmi, V. and Kumar, V. Vinoth and Anchitaalagammai, J. V.},
  booktitle={2024 3rd International Conference on Automation, Computing and Renewable Systems (ICACRS)}, 
  title={MentalHealthAI: Utilizing Deep Learning for Accurate Stress Level Prediction}, 
  year={2024},
  volume={},
  number={},
  pages={1705-1712},
  abstract={MentalHealthAI is an advanced deep learning system designed to accurately predict stress levels by integrating various data sources, including user surveys, heart rate metrics, sentiment scores from social media interactions, and demographic information. This innovative approach employs a Fully Connected Neural Network (FCNN) architecture, enabling the model to uncover complex relationships among multiple stress-related factors, such as PHQ-9 and GAD-7 questionnaire scores, heart rate variability, sleep patterns, and calculated sentiment scores. By utilizing Natural Language Processing (NLP) techniques, specifically the VADER model, the system analyzes social media text data to derive sentiment scores, providing insights into users' emotional states. This holistic assessment empowers individuals to understand the interplay between their mental health and daily activities, fostering proactive stress management. The advantages of MentalHealthAI include its capacity to deliver timely and personalized stress assessments, allowing users to make informed decisions about their mental well-being. By combining objective data from wearables with subjective sentiment analysis, the system offers a comprehensive perspective on stress dynamics. Ultimately, MentalHealthAI aims to enhance mental health support, providing valuable insights that encourage healthier lifestyles and improved emotional resilience.},
  keywords={Deep learning;Surveys;Analytical models;Accuracy;Social networking (online);Soft sensors;Neural networks;Mental health;Data models;Wearable devices;Stress Monitoring;Deep Learning;Stress Level prediction;MentalHealthAI;Healthier lifestyle;Stress Score;Sentiment Score;Perceived Stress Scale},
  doi={10.1109/ICACRS62842.2024.10841747},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{10968812,
  author={Sai, T.Sitanshu and Singavarapu, Rohit and Penala, Adithya and Rakesh, Boya and T, Anjali},
  booktitle={2025 International Conference on Machine Learning and Autonomous Systems (ICMLAS)}, 
  title={Cyberbullying Detection Using QDA and LDA Algorithms}, 
  year={2025},
  volume={},
  number={},
  pages={550-557},
  abstract={Detecting cyberbullying is critical in today's digital landscape, where platforms like Twitter, Instagram, and TikTok are integral to communication. These platforms, expose users especially young individuals to harmful interactions, leading to severe consequences such as anxiety, depression, and even self-harm. The anonymity and global reach of the internet often embolden perpetrators, making early detection essential to prevent escalation and ensure community safety. The proposed solution improves upon earlier methods by employing Linear Discriminant Analysis (LDA) and Quadratic Discriminant Analysis (QDA) classifiers, which are effective for smaller, imbalanced datasets. Leveraging preprocessing techniques like stemming, tokenization, and Bag of Words ensures adaptability and efficiency. Unlike computationally intensive models like CNNs, QDA's flexibility and LDA's simplicity balance precision and recall. With accuracies of 81% (QDA) and 79% (LDA), these models provide lightweight, scalable tools for combating harmful online behavior, fostering healthier digital interactions.},
  keywords={Training;Analytical models;Adaptation models;Computational modeling;Cyberbullying;Machine learning;Data models;Linear discriminant analysis;Numerical models;Web sites;Linear Discriminant Analysis;Quadratic Discriminant Analysis;cyberbullying},
  doi={10.1109/ICMLAS64557.2025.10968812},
  ISSN={},
  month={March},}@ARTICLE{10956131,
  author={Hernández-Castañeda, Ángel and García-Hernández, René Arnulfo and Ledeneva, Yulia},
  journal={IEEE Access}, 
  title={Identifying Suicidal Ideation Through Automatic Extraction of Emotional Traces in Suicide Notes}, 
  year={2025},
  volume={13},
  number={},
  pages={62378-62392},
  abstract={Suicide is a critical mental health issue and one of the leading causes of death worldwide. Several studies in suicidology claim that emotional dysregulation is a factor triggering suicidal behavior. In today’s digital age, individuals often express suicidal ideation on social media platforms to seek help, empathy, or advice. The primary objective of this study is to classify suicide notes based on their emotional content using machine and deep learning algorithms. We propose an innovative approach to automatically identify emotional changes in a suicide note’s content, leveraging these shifts as key indicators of suicidal ideation. The goal is to automatically identify the correlation between latent emotional states in suicide notes and their classification as either suicidal or non-suicidal. We employed a long short-term memory (LSTM) neural network to analyze emotional patterns and address various binary classification scenarios. Results demonstrated an F-measure exceeding 80% in all suicide note classification scenarios. Our analysis revealed that the vocabulary used in suicide notes collected from social media often differs from that found in notes written by individuals who have actually completed suicide. Additionally, we observed that suicide attempters typically do not directly express suicidal ideation but instead use non-death-related vocabulary, which presents a greater challenge in identifying genuine suicidal thoughts.},
  keywords={Social networking (online);Vectors;Neural networks;Transformers;Convolutional neural networks;Blogs;Vocabulary;Mental health;Depression;Deep learning;Suicide ideation detection;sentiment analysis neural networks;long short-term memory;suicide notes},
  doi={10.1109/ACCESS.2025.3558693},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{10319594,
  author={Basyouni, Abdallah and Abdelkader, Hatem and Aly, Asma},
  booktitle={2023 3rd International Conference on Electronic Engineering (ICEEM)}, 
  title={Suicidal Ideation Detection on Social Media Using A Hybrid Feature Selection Method}, 
  year={2023},
  volume={},
  number={},
  pages={1-7},
  abstract={Suicide is a major issue in modern communities all around the world. Suicide can be caused by several risk factors such as depression, anxiety, hopelessness, and social isolation. The early discovery of these risk factors can decrease a lot of suicide attempts. In later years, suicidal ideation detection via online social media has risen, and become a hot research topic with significant challenges in both fields of natural language processing (NLP) and psychology. This paper proposes a framework to detect suicidal ideation on social media. The proposed framework consists of four phases, preprocessing, feature extraction, feature selection, and classification. In the feature selection phase, the paper introduces a hybrid feature selection method combining principal component analysis (PCA) with genetic algorithm (GA) to select the best and most important features. Moreover, an expressive feature set was extracted based on context-related and linguistic features. The proposed hybrid feature selection method performs better and achieves an accuracy of 99.05%. This paper shows that a more accurate classification procedure may be obtained by using expressive feature sets and choosing relevant and informative features.},
  keywords={Social networking (online);Anxiety disorders;Text categorization;Mental health;Feature extraction;Depression;Natural language processing;Suicide Ideation;Feature Selection;Natural Language Processing;Principal Component Analysis;Genetic Algorithm},
  doi={10.1109/ICEEM58740.2023.10319594},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10748045,
  author={Farasalsabila, Fidya and Utami, Ema and Raharjo, Suwanto},
  booktitle={2024 4th International Conference of Science and Information Technology in Smart Administration (ICSINTESA)}, 
  title={Multi-Label Classification using BERT for Cyberbullying Detection}, 
  year={2024},
  volume={},
  number={},
  pages={195-200},
  abstract={Cyberbullying is not a new phenomenon in digital issues that even existed before the era of social networks. Cyberbullying has a broad impact, covering a person’s mental and physiological conditions such as sadness, anxiety, and even depression. In the current era of social networks, cyberbullying is increasingly becoming a concern for many groups. Research related to cyberbullying detection is increasingly being carried out. Multi-label datasets are a challenge that must be faced in detecting cases of cyberbullying. Therefore, choosing the right method for the emotion identification process is important. This research analyzes the use of the BERT method on multi-label cyberbullying data. The research uses PyTorch as a machine learning framework to support the research process. The total raw dataset is 47,692 tweets consisting of 6 labels. This algorithm was chosen as a learning solution in the case of sentiment analysis. The results of this study show that BERT can be applied to multi-label classification and achieves the highest accuracy of 94%.},
  keywords={Deep learning;Analytical models;Sentiment analysis;Accuracy;Machine learning algorithms;Computational modeling;Cyberbullying;Depression;Physiology;Information technology;Cyberbullying;Multi-Label Sentiment Analysis;BERT},
  doi={10.1109/ICSINTESA62455.2024.10748045},
  ISSN={},
  month={July},}@INPROCEEDINGS{10835468,
  author={Tang, Jinwen and Guo, Qiming and Zhao, Yunxin and Shang, Yi},
  booktitle={2024 IEEE 6th International Conference on Cognitive Machine Intelligence (CogMI)}, 
  title={Decoding Linguistic Nuances in Mental Health Text Classification Using Expressive Narrative Stories}, 
  year={2024},
  volume={},
  number={},
  pages={207-216},
  abstract={Recent advancements in Natural Language Processing (NLP) have spurred significant interest in analyzing social media text data for identifying linguistic features indicative of mental health issues. However, the domain of Expressive Narrative Stories (ENS)—deeply personal and emotionally charged narratives that offer rich psychological insights—remains underex-plored. This study bridges this gap by utilizing a dataset sourced from Reddit, focusing on ENS from individuals with and without self-declared depression. Our research evaluates the utility of advanced language models, BERT and MentalBERT, against traditional models such as SVM, Naive Bayes, and Logistic Regression. We find that traditional models are notably sensitive to the absence of explicit topic-related words, which could risk their potential to extend applications to emotional expressive narratives that lack clear mental health terminology. Despite MentalBERT’s design to better handle psychiatric contexts, it demonstrated a dependency on specific topic words for classification accuracy, raising concerns about its application in scenarios where explicit mental health terms are sparse (P-value < 0.05). In contrast, BERT(128) exhibited minimal sensitivity to the absence of topic words in ENS, suggesting its superior capability to understand deeper linguistic features, making it more effective for real-world applications that require nuanced text analysis. Both BERT and MentalBERT excel at recognizing linguistic nuances and maintaining classification accuracy even when narrative order is disrupted—a crucial capability in mental health narratives. This resilience is statistically significant, with sentence shuffling showing substantial impacts on model performance (P-value <0.05), especially evident in ENS comparisons between individuals with and without mental health declarations. These findings underscore the importance of exploring ENS for deeper insights into mental health-related narratives, advocating for a nuanced approach to mental health text analysis that moves beyond mere keyword detection. This study paves the way for more sophisticated, context-aware analyses in NLP applications, aiming to enhance the understanding of linguistic patterns associated with mental health conditions.},
  keywords={Support vector machines;Accuracy;Sensitivity;Social networking (online);Terminology;Text categorization;Mental health;Linguistics;Natural language processing;Resilience;NLP;LLM;Artificial Intelligence;Mental Health;Psychiatry;Social Media;Explainability},
  doi={10.1109/CogMI62246.2024.00035},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{9909084,
  author={Kugapriya, Priyanka and Manohara, Mayuriya and Ranganathan, Keerthiga and Kanapathy, Dineshgaran and Gamage, Anjalie and Anzar, Arshad},
  booktitle={2022 2nd Asian Conference on Innovation in Technology (ASIANCON)}, 
  title={UNWIND – A Mobile Application that Provides Emotional Support for Working Women}, 
  year={2022},
  volume={},
  number={},
  pages={1-7},
  abstract={Depression is a common phenomenon affecting more than 264 million people worldwide. It is one of the leading causes of disability and a major contributor to the overall global burden of disease. Around twice as many women are affected by mental illness compared to men. This situation has worsened during the pandemic. The need to balance both work life and personal life has put them under immense pressure. Even though the diagnosis of mental illness almost exclusively depends on doctor-patient communication, it has its own set of disadvantages such as patient denial, recall bias, subjective biases, time-consuming and inaccuracy and it is a long-term health problem that needs to be continuously monitored and managed. Considering this social problem, we have planned to develop an Emotional Support Mobile application UNWIND – using modern technological concepts of machine learning and artificial intelligence. Which focuses especially on working women and would include several functionalities: a Chabot to detect mental health status in real-time and to provide counseling, an internal activities tracker to find the correlation between changes in lifestyle and mental health, an improvement tracker of the user’s current mental state using facial recognition and also Recommendation system with the support group, which recommends the most suitable professional counselors to the user as per their preferences and enabling into the support group to provide with necessary treatments and consultation at greater accuracy.},
  keywords={Technological innovation;Correlation;Pandemics;Mental health;Machine learning;Real-time systems;Mobile applications;Mental Illness;Mental Health;Chat Bot;Internal Activity Tracker;Improvement Tracker;Support Group},
  doi={10.1109/ASIANCON55314.2022.9909084},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{10053943,
  author={Ovidiu-Mihai, Vilceanu and Tudor-Alexandru, Ileni and Petrescu, Manuela},
  booktitle={2022 IEEE 18th International Conference on Intelligent Computer Communication and Processing (ICCP)}, 
  title={Using BERT to extract emotions from personal journals}, 
  year={2022},
  volume={},
  number={},
  pages={89-94},
  abstract={Keeping a journal can prove highly beneficial when it comes to confidence and overcoming psychological issues. There are plenty of applications that aim to help treat depression with the help of machine learning, using chat interfaces. However, little attention has been given to digital journals which take advantage of the latest AI technologies to help users better understand their emotions and track their evolution, for therapeutic purposes. A good understanding of human emotions is essential in the context of identifying, treating, and keeping track of psychological issues. There is extensive research in terms of emotion detection through video, audio, or pictures, and less when it comes to text input, despite the amount of data available publicly. We propose an application that, based on a model specialized in emotion detection, provides the user with meaningful insights which can be used to make informed decisions and take action.},
  keywords={Emotion recognition;Schedules;Mood;Machine learning;Predictive models;Depression;Data models;BERT;emotion detection;machine learning},
  doi={10.1109/ICCP56966.2022.10053943},
  ISSN={2766-8495},
  month={Sep.},}@INPROCEEDINGS{11170766,
  author={Asha, P. and Balaraman, R. and Asha, P. and Prasad, J. and Yadav, Sunita and Srinivasan, C},
  booktitle={2025 5th International Conference on Soft Computing for Security Applications (ICSCSA)}, 
  title={SVM-based Emotion Recognition for Detecting Early Signs of Psychological Distress}, 
  year={2025},
  volume={},
  number={},
  pages={1891-1896},
  abstract={Timely identification of psychological discomfort is crucial for averting serious mental health disorders, including anxiety and depression. This paper presents a Support Vector Machine (SVM)-based emotion identification system that utilizes multimodal data, including facial expressions, voice attributes, and physiological signals, to detect early indicators of distress. The system was trained on a dataset including 5,000 labeled samples, achieving an accuracy of 96.8%, a precision of 95.9%, and a recall of 95.2% in the classification of distress-related emotions. Feature extraction was accomplished using Mel-Frequency Cepstral Coefficients (MFCCs) for speech, Histogram of Oriented Gradients (HOG) for face expressions, and Heart Rate Variability (HRV) for physiological data. The proposed model improves traditional classifiers’ accuracy. Real-time validation on an independent test set of 1,000 samples verified a detection rate of 94.5%, illustrating the system's resilience and dependability. The findings demonstrate that the proposed SVM-based method is very efficient in detecting psychological discomfort and may be included in real-time mental health monitoring systems.},
  keywords={Support vector machines;Emotion recognition;Accuracy;Mental health;Feature extraction;Real-time systems;Security;Biomedical monitoring;Heart rate variability;Monitoring;Psychological Distress Detection;Physiological Signal Processing;Early Intervention;Mental Health Monitoring;Support Vector Machine},
  doi={10.1109/ICSCSA66339.2025.11170766},
  ISSN={},
  month={Aug},}@INBOOK{10830638,
  author={Kumar, Akshi},
  booktitle={Language Intelligence: Expanding Frontiers in Natural Language Processing}, 
  title={Natural Language Processing for Affective, Psychological, and Content Analysis}, 
  year={2025},
  volume={},
  number={},
  pages={159-221},
  abstract={Summary <p>This chapter investigates NLP's role in analyzing affective and psychological aspects of language, focusing on sentiment analysis, emotion recognition, and psychometric NLP. It also delves into specific content analysis tasks like sarcasm detection, humor recognition, and identifying distress indicators such as depression and anxiety. These applications highlight the capability of NLP to interpret human emotions and psychological states from textual data.</p>},
  keywords={Sentiment analysis;Transfer learning;Analytical models;Transformers;Neural networks;Bayes methods;Zero shot learning;Reviews;Psychology;Organizations},
  doi={10.1002/9781394297290.ch7},
  ISSN={},
  publisher={IEEE},
  isbn={9781394297283},
  url={https://ieeexplore.ieee.org/document/10830638},}@INPROCEEDINGS{10651245,
  author={Cui, Xia and Hanley, Terry and Choudhury, Muj and Mu, Tingting},
  booktitle={2024 International Joint Conference on Neural Networks (IJCNN)}, 
  title={Data-Driven or Dataless? Detecting Indicators of Mental Health Difficulties and Negative Life Events in Financial Resilience Using Prompt-Based Learning}, 
  year={2024},
  volume={},
  number={},
  pages={1-8},
  abstract={Financial resilience has been an important area of focus for the business sector since the outbreak of the pandemic. Currently, the assessment of financial resilience is typically completed through the review of financial statements. However, such resilience is commonly linked to negative life events and may be further impacted by the presence of mental health difficulties. As such, identifying and understanding these elements may provide a more complete understanding of an individual’s financial situation. We discuss the development of a challenging automated financial resilience detection system that aims to identify factors that may have negative impacts upon the resilience of individuals. This makes use of textual data to identify elements, such as the occurrence of negative life events or mental health difficulties, that indicate that individuals may be vulnerable to exploitation through the misselling of products. In addition to a traditional data-driven supervised approach, this work also demonstrates applying prompt-based learning to these tasks without the need for the training data (i.e., a dataless approach).},
  keywords={Reviews;Pandemics;Neural networks;Training data;Mental health;Resilience;Business;financial resilience;mental health;natural language processing;prompt-based learning;transfer learning},
  doi={10.1109/IJCNN60899.2024.10651245},
  ISSN={2161-4407},
  month={June},}@INPROCEEDINGS{9820498,
  author={Yan, Jie and Shu, Xin and Shu, Jian},
  booktitle={2022 5th International Conference on Artificial Intelligence and Big Data (ICAIBD)}, 
  title={Depressive Emotion Tendency Detection for Users on Social Platform Based on Fusion of Graph and Text}, 
  year={2022},
  volume={},
  number={},
  pages={337-341},
  abstract={Depression is mainly manifested in negative emotions, physical fatigue, and often suicidal ideation. In recent years, more and more patients with depression have posted on social platform to express their emotions. Based on this, a method is proposed to detect depressive emotion tendency for users on social platform based on fusion of graphic and text features (FGTF-SP-DDET). In the method, the Weibo User Depression Detection Dataset (WU3D) was simplified and preprocessed to fit the model. The main body of the image feature learning module is the improved VGG-16 model, and the main body of the text feature learning module is BERT, BiLSTM combined with Attention. In order to make full use of the emotion feature of different modalities, the extracted features were fused by the method of early fusion. The comprehensive depressive emotion tendency detection was carried out by classifier. Experimental results show that FGTF-SP-DDET outperforms single-feature based detection methods in accuracy, precision, recall and F1. Compared with the single-feature method, the image-text feature fusion method can effectively detect the depressive emotion tendency of social platform users.},
  keywords={Representation learning;Graphics;Blogs;Bit error rate;Big Data;Feature extraction;Depression;depressive tendency test;social platform;multimodal feature fusion},
  doi={10.1109/ICAIBD55127.2022.9820498},
  ISSN={},
  month={May},}@INPROCEEDINGS{10607368,
  author={Wang, Sujing and Dhakal, Sambeg and Upadhyay, Bhuwan Prasad},
  booktitle={2024 9th International Conference on Big Data Analytics (ICBDA)}, 
  title={Sentiment Analysis and Emotion Detection of COVID-19 Geo-Tagged Twitter Data}, 
  year={2024},
  volume={},
  number={},
  pages={180-185},
  abstract={The COVID-19 pandemic has caused significant emotional distress among people worldwide, including anxiety, stress, and depression. This paper presents an analysis of public tweets from various regions of the United States to explore the emotional distress experienced by individuals during the COVID-19 pandemic. By utilizing advanced natural language processing techniques and machine learning algorithms, emotional indicators and anxiety levels were extracted from the COVID-19 Geo-Tagged Tweets. The study revealed significant implications of the pandemic on people's mental health across different regions. Moreover, the findings highlight the association between mental health and the pandemic, suggesting the potential for leveraging this approach to predict mental health outcomes during similar crises.},
  keywords={COVID-19;Sentiment analysis;Emotion recognition;Machine learning algorithms;Pandemics;Social networking (online);Anxiety disorders;Sentiment Analysis;Emotion Detection;Social Computing;COVID-19 Pandemic;Geo-Tagged Tweets},
  doi={10.1109/ICBDA61153.2024.10607368},
  ISSN={},
  month={March},}@INPROCEEDINGS{11410711,
  author={Goyal, Neha and Bansal, Rajiv},
  booktitle={2025 2nd Global AI Summit - International Conference on Artificial Intelligence and Emerging Technology (AI Summit)}, 
  title={Unveiling Sentiment Nuances: Comparative Study on Aspect Based Sentiment Analysis Approaches}, 
  year={2025},
  volume={},
  number={},
  pages={426-431},
  abstract={Aspect based sentiments analysis address the limitation of coarse grained sentiments analysis by providing opinion for specific aspect of entities. A comprehensive review is presented in this paper to review NLP technique to for text processing, classification model for aspect term identification, sentiment polarity detection, and opinion expression classification. Technological advances in neural network based model, specifically transformer-based model have significantly enhanced contextual understanding in ABSA tasks. The paper also shed the light on challenges such as domain adaptation, multilingual limitations, cultural sentiment variation, data sparsity, and computational in-efficiencies. A comparative analysis of ABSA applications across domains including politics ,tourism, healthcare and education is provided. The study concludes with a future roadmap emphasizing scalable models, cultural adaptability, and explainable AI techniques, offering valuable insights for researchers and practitioners.},
  keywords={Adaptation models;Sentiment analysis;Reviews;Computational modeling;Neural networks;Transformers;Multilingual;Cultural differences;Context modeling;Text processing;Aspect-Based Sentiment Classification;Opinion Expression mining;Large Language Models;Aspect Extraction;Scalable Systems},
  doi={10.1109/AISummit66170.2025.11410711},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{11379710,
  author={Thakur, Sakshi and Dhakar, Dinesh Singh and Gupta, Ruchika},
  booktitle={2025 Global Conference on Information Technology and Communication Networks (GITCON)}, 
  title={AI-Driven Prediction of Anxiety Disorders using Physiological and Behavioral Data Fusion}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Anxiety is psychological disorder that affects individuals both mentally and physically, often causing emotional stress, sleep issues, and behavioral changes. Early detection of anxiety can help prevent long-term mental health problems. The current research presents Machine Learning (ML) strategy utilised for identifying whether person is experiencing anxiety by utilizing physiological information (includes heart rate and EEG) along with behavioral data (includes sleep patterns and phone usage). Several hybrid models is developed and tested, including SVM+CNN, RF+CNN, XGBoost+CNN, GA+CNN, and PSO+CNN. The PSO+CNN model attained superior accuracy of 99.35%. The proposed model is evaluated against traditional methods to assess performance. The proposed model is lightweight and real-time anxiety detection in practical applications for emotional health support for emotional health support and improved user experience outcomes and strategies.},
  keywords={Sleep;Anxiety disorders;Data integration;Mental health;Brain modeling;Physiology;Electroencephalography;User experience;Real-time systems;Particle swarm optimization;Anxiety prediction;physiological data;behavioral data;EEG;data fusion;Particle Swarm Optimization},
  doi={10.1109/GITCON65266.2025.11379710},
