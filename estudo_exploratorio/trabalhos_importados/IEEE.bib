  ISSN={},
  month={Aug},}@INPROCEEDINGS{10420945,
  author={Kumari, Parveen and Jijja, Alpana},
  booktitle={2023 International Conference on Communication, Security and Artificial Intelligence (ICCSAI)}, 
  title={Sentiment Analysis on Online Social Networking Data for the Identification of Depression Using Several AI Techniques: A Literature Review}, 
  year={2023},
  volume={},
  number={},
  pages={457-464},
  abstract={Emotional analysis is a growing trend today to recognize the feelings of people in many circumstances in life. Data from online platforms will be used throughout the whole procedure, which involves an analytical and classification-based processes, and is composed of textual data, emoticons, and other types of data. In previous studies, multi-class classification offers more correct information than both ternary and binary classification. In a multiclass classification, information separated in to numerous subcategories depending on polarities. Techniques such as deep learning and algorithms of machine learning will be utilized in the process of categorization. Social media can be used for monitoring and exploring emotional states. This study presents a description of emotional analysis of publicly available data by applying different artificial intelligence approaches to identify anxiety or frustration. The study optically demonstrated that emoticons, social media texts, and data including emoticons were used to determine emotions using various intelligent approaches. Analysis results with multiclass classification using a deep learning techniques or models are more accurate.},
  keywords={Deep learning;Sentiment analysis;Machine learning algorithms;Social networking (online);Market research;Security;Monitoring;NLP;Analysis of data;extracting features;multiclass categorization;emojis and symbols;artificial intelligence methods;a Social Network Analysis;deep learning;depression},
  doi={10.1109/ICCSAI59793.2023.10420945},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{11350406,
  author={Saxena, Samidha and Domadiya, Nikunj and Patel, Pragnesh and Saxena, Rajat},
  booktitle={2025 IEEE International Conference on Intelligent Signal Processing and Effective Communication Technologies (INSPECT)}, 
  title={Machine Learning for Early Detection of Postpartum Depressive Symptoms in Women}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={There are a number of diseases being prevalent which has a deep impact on human civilization. The modernday marvel such as machine learning has a potential of transforming the way diseases are diagnosed and treated. With the available data, the prediction and follow-up of any particular disease is becoming more accurate and precise. This study is focused on Postpartum depression (PPD) detection which affects the mental condition of women after childbirth. The probable causes of PPD can be hormonal imbalance, history of depression, stressful life events, or the lack of support, leading to serious effects on mother and newborn baby’s health and well- being. This study analyses the dataset with 1503 records and applies three ML algorithms, Decision Tree, Random Forest and Light GBM. Synthetic Minority over Sampling Techniques (SMOTE) has been used for balance the dataset. Further the hyperparameter tuning was applied and results were compared. The highest accuracy of 0.9770 was obtained in case of Random Forest followed by 0.9719 with Light GBM Algorithm for hyper tuned models.},
  keywords={Pediatrics;Analytical models;Accuracy;Signal processing algorithms;Predictive models;Depression;Decision trees;Random forests;Wearable sensors;Diseases;Machine Learning;PPD;synthetic minority over sampling technique (SMOTE);Light GBM;Decision Tree;Random Forest},
  doi={10.1109/INSPECT67393.2025.11350406},
  ISSN={},
  month={Nov},}@ARTICLE{11023137,
  author={Chiong, Raymond and Budhi, Gregorius Satia and Cambria, Erik},
  journal={IEEE Transactions on Affective Computing}, 
  title={Detecting Signs of Depression Using Social Media Texts Through an Ensemble of Ensemble Classifiers}, 
  year={2025},
  volume={16},
  number={4},
  pages={2931-2945},
  abstract={Artificial intelligence-based machine learning models have been widely used to explore and address various mental health-related problems in recent years, including depression. In this study, we present an ensemble approach to complement the 90 unique input features that we proposed in a previous study on depression detection using social media texts. Our proposed Ensemble of Ensemble Classifiers (EECs) combines many ensemble models, including Bagging Predictors, Random Forests, Adaptive Boosting and Gradient Boosting, as inner ensembles. These inner ensembles are arranged in a parallel fashion, where each of them is trained using different subsets of data sampled from the training data via bootstrap sampling. After the models are trained, during the testing phase, the results of all inner ensembles are processed using two methods—majority vote or class priority threshold—to get the final result as an output. From the experiments, we find that EECs are accurate in detecting signs of depression in social media users by analysing their posts in social media platforms such as Twitter. Our approach outperforms other ensemble methods on the public datasets we used. Moreover, if set correctly, the parameters of EECs can further improve the performance of the proposed ensemble in detecting signs of depression.},
  keywords={Social networking (online);Depression;Blogs;Feature extraction;Computational modeling;Brain modeling;Predictive models;Boosting;Affective computing;Adaptation models;Depression detection;social media;ensemble models;machine learning},
  doi={10.1109/TAFFC.2025.3571749},
  ISSN={1949-3045},
  month={Oct},}@INPROCEEDINGS{9817373,
  author={Bhardwaj, Tanya and Gupta, Paridhi and Goyal, Akshita and Nagpal, Akanksha and Jha, Vivekanand},
  booktitle={2022 IEEE World AI IoT Congress (AIIoT)}, 
  title={A Review on Suicidal Ideation Detection Based on Machine Learning and Deep Learning Techniques}, 
  year={2022},
  volume={},
  number={},
  pages={027-031},
  abstract={In recent years, the number of deaths due to suicide has increased. Suicide is becoming one of the major causes of death across the whole world. This has led to an alarming situation as it is endangering the human life. A lot of studies have been done to find the reason behind such suicides and its prevention. The literature has suggested that the detection of suicide thoughts at an early stage can help to rescue the life of people. The idea of early detection has led various researchers to carry out research in this direction. Many such studies have used machine learning and deep learning models to predict the idea of suicide. So, this paper reviews the existing study that has been performed towards detection of suicidal thoughts using machine learning and deep learning techniques.},
  keywords={Deep learning;Social networking (online);Anxiety disorders;Psychology;Predictive models;Feature extraction;Depression;suicide;suicidal ideation;machine learning;deep learning},
  doi={10.1109/AIIoT54504.2022.9817373},
  ISSN={},
  month={June},}@INPROCEEDINGS{10245631,
  author={K, Kamalam G and M, Fathima Kadhoon and K, Mithila S and M, Madhu Shiry N},
  booktitle={2023 International Conference on Circuit Power and Computing Technologies (ICCPCT)}, 
  title={A Text-Based Approach for Diagnosing Depression Using Social Media Texts}, 
  year={2023},
  volume={},
  number={},
  pages={181-185},
  abstract={Depression is a mood health issue that can result in persistent feelings of melancholy, a lack of interest in once-enjoyable activities, and physical changes. While many other approaches, like watching facial expressions on video, listening to spoken emotions, reading written responses from the text, and measuring physiology with wearable technology have all been used in past times, multi-modal approaches have also produced encouraging results. This proposed research presents a unique approach for diagnosing depression using social media text data that combines the GloVe word embedding technology with a Long Short-Term Memory (LSTM) neural network model. The method takes advantage of both methodologies strengths to represent social media text data as high-dimensional vectors and capture the temporal connections between words in the text. The work trained a GloVe model on a huge data-set of depression-related social site messages to develop high dimensional numerical vectors to the words. These embedding were then fed into an LSTM model, which classified the text as either depressive or non-depressive. The proposed method was tested on a data-set collected from reddit platform and achieved a classification accuracy of 95%. The findings show that the proposed approach for early diagnosis of depression using social media data is successful, and that it has real-world implications in mental health monitoring and intervention.},
  keywords={Social networking (online);Mood;Neural networks;Mental health;Depression;Data models;Numerical models;GloVe(global vector);word embedding;LSTM (long short term memory)},
  doi={10.1109/ICCPCT58313.2023.10245631},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{11138825,
  author={Wu, Ziteng},
  booktitle={2025 IEEE 3rd International Conference on Image Processing and Computer Applications (ICIPCA)}, 
  title={Multimodal Sentiment Analysis and Depression Detection of Social Media Users Based on MLP}, 
  year={2025},
  volume={},
  number={},
  pages={394-397},
  abstract={Multimodal sentiment analysis and depression detection are two prominent research topics. Multimodal sentiment analysis aims to identify the underlying emotions by analyzing information from different modalities, such as text, images, and audio. Depression detection aims to leverage multimodal sentiment analysis to regress depressive tendencies over an extended temporal sequence. This study focuses on models composed entirely of multilayer perceptrons (MLPs) at the stage of multimodal feature fusion. Such models typically mitigate the high computational complexity associated with attention-based architectures while maintaining efficiency to a certain extent. This study uses CubeMLP, a model entirely composed of MLP, which can be used for multimodal sentiment analysis and depression detection. The experiments are conducted on the MOSI and MOSEI datasets. The model is validated on both datasets, achieving MAE scores of 0.811 and 0.552 on the test sets, respectively. These results demonstrate the model's simplicity and efficiency. The study also conducts a hyperparameter analysis on the architecture of CubeMLP, leading to three key conclusions that enhance the model's interpretability to a certain extent. This study further extends the structure of the fundamental MLP units and conducts experiments incorporating different activation functions. Finally, this study presents two potential application scenarios for the model. This study aims to enhance the understanding of pure MLP-based models and contribute to advancements in multimodal sentiment analysis and depression detection.},
  keywords={Sentiment analysis;Analytical models;Social networking (online);Computational modeling;Time series analysis;Psychology;Computer architecture;Multilayer perceptrons;Depression;Time measurement;Multimodal emotion analysis;Depression detection;MLP;Multimodal fusion},
  doi={10.1109/ICIPCA65645.2025.11138825},
  ISSN={},
  month={June},}@INPROCEEDINGS{11025213,
  author={Cooray, Saumya and Anjana, Irani and Thalagahawaththa, Sandaru and Jayakody, Udani},
  booktitle={2024 International Conference on Advances in Technology and Computing (ICATC)}, 
  title={Machine Learning Approach for Detection of Harassment and Hate Speech in Sinhala Text Messages on Telegram}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={Nowadays, social media platforms have become an important communication method to connect and express messages without geographical limitations. Nevertheless, harassment and hate speech are some of the main negative outcomes of these platforms, poisoning digital spaces online and leading to depression and even suicide. Hate speech and harassment target individuals or groups based on attributes such as gender, religion, race, or sexuality. According to Sri Lanka CERT (National Centre for Cyber Security), hate crime incidents rose 38% in 2021, with 182 reported cases against 70 in 2020. Although, to overcome that concern, specifically in Sinhala text messages on Telegram, there is a lack of relevant studies. Consequently, this study aims to develop a machine learning model to efficiently identify and mitigate a spectrum of harassment and hate speech, within Sinhala Telegram text messages. The initial step involved developing a Telegram API and a Python application using the Telethon library to collect Telegram text messages automatically. Telegram messages were manually annotated into two categories based on different factors. Sinhala language specific data preprocessing NLP techniques such as stemming, and tokenization were utilized for normalization and feature extraction. A vectorizer was utilized to convert textual data into a format that can be understood by a classifier. The study found the Support Vector Machine classifier to be effective since, when compared to other developed machine learning classifiers such as Random Forest, Logistic Regression, Decision Tree, and Linear SVC, it has an F1-Score of 0.87. All these models exhibited success to varying degrees and were tested on a balanced dataset.},
  keywords={Support vector machines;Machine learning algorithms;Prevention and mitigation;Hate speech;Static VAr compensators;Machine learning;Feature extraction;Tokenization;Numerical models;Random forests;hate speech detection;natural language processing;support vector machine;Sinhala text;Telegram},
  doi={10.1109/ICATC64549.2024.11025213},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{10117371,
  author={Mishra, Ajey Shakti and Srivastava, Akanksha and Modi, Aashi Rohit and Pandey, Ashish},
  booktitle={2023 10th International Conference on Signal Processing and Integrated Networks (SPIN)}, 
  title={Cyberbullying and Suicide Ideation Detection via Hybrid Machine Learning Model}, 
  year={2023},
  volume={},
  number={},
  pages={265-270},
  abstract={Increase in Cyberbullying and suicide ideas has led a great need in its ideation detection to prevent it. Since the detection of it is even difficult for human and hence it is much more complicated in terms of automatic detection. Many past efforts in this field were tedious, few lexicon-based methods were functional but later turned out to be scope-limiting. The current requirement emphasizes on the use of Machine learning models for different Natural Language Processing problems. Use of these technology gives the quicker and accurate way in detection. In this paper SVM, Random-forest, BDRNN GRU AND BDRNN LSTM are used as convolutional networks. The model uses pre-trained glove embedding layer and hybrid BiGRU model that gives the accuracy of 92.70% and F-score of 0.9431 for cyberbullying detection and accuracy of 97% for suicide ideation. Based on these results the performance of this model is tested by the analysis of four parameters which are Recall, Precision, $\mathrm{F}_{\mathrm{m}\mathrm{e}\mathrm{a}\mathrm{s}\mathrm{u}\mathrm{r}\mathrm{e}}$ and Accuracy.},
  keywords={Support vector machines;Analytical models;Annotations;Cyberbullying;Machine learning;Signal processing;Depression;Cyberbullying;Suicide;Natural Language Processing;BDRNN GRU;BDRNN LSTM;GloVe Embedding layer;Bi-GRU.},
  doi={10.1109/SPIN57001.2023.10117371},
  ISSN={2688-769X},
  month={March},}@INPROCEEDINGS{10730385,
  author={Ahmad, Zaaba and Mohamed, Azlinah and Conway, Mike and Zakaria, Rozanizam and Teo, Noor Hasimah Ibrahim and Maskat, Ruhaila},
  booktitle={2024 5th International Conference on Artificial Intelligence and Data Sciences (AiDAS)}, 
  title={MyDAS Corpus: Malay Social Media Texts for Detecting Depression, Anxiety, and Stress on Facebook}, 
  year={2024},
  volume={},
  number={},
  pages={111-120},
  abstract={The application of Natural Language Processing (NLP) in mental health monitoring has significantly expanded; however, the specific challenges of interpreting Depression, Anxiety, and Stress (DAS) in Malay language social media texts have not been adequately addressed. This gap underscores the need for NLP solutions that are sensitised to the linguistic and cultural specificities of Malay-speaking populations. This study develops and validates a specialised Malay language corpus from social media content, targeting DAS. Utilising a hybrid ground truth strategy that integrates self-reports with expert assessments, the research offers methodological refinements in the analysis of Malay linguistic patterns and the deployment of machine learning classifiers to efficiently identify mental health indicators. The paper reviews existing methodologies, outlines a novel corpus development strategy, and discusses classifier performance. The Decision Tree classifier achieved the highest F1 score of 0.75, followed by the Support Vector Machine (SVM) with an F1 score of 0.73, and Random Forest with 0.70. Multinomial Naive Bayes (MNB) and K-Nearest Neighbors (KNN) demonstrated lower performances with F1 scores of 0.55 and 0.52 respectively. Comprehensive analyses using bi-gram networks and t-SNE visualisations explore the nuanced linguistic indicators of mental health states, culminating in a discussion of the implications for future NLP applications in mental health monitoring.},
  keywords={Support vector machines;Social networking (online);Mental health;Linguistics;Nearest neighbor methods;Depression;Natural language processing;Decision trees;Cultural differences;Monitoring;Mental Health Detection;Natural Language Processing;Malay Language;Corpus Development;Social Media;Depression;Anxiety;Stress;Decision Tree;Support Vector Machine},
  doi={10.1109/AiDAS63860.2024.10730385},
  ISSN={},
  month={Sep.},}@ARTICLE{10600701,
  author={Ajmal, Sahar and Shoaib, Muhammad and Iqbal, Faiza},
  journal={IEEE Access}, 
  title={RSTFusionX: Leveraging Rhetorical Structure Theory and Ensemble Models for Depression Prediction in Social Media Posts}, 
  year={2024},
  volume={12},
  number={},
  pages={118389-118404},
  abstract={Depression is a common and severe mental disorder that frequently goes undiagnosed and untreated, particularly during its initial phase. However, with the increasing number of people sharing their thoughts and feelings online, social media has become a valuable resource to identify symptoms of mental health problems such as depression. As a result, research on social media-based depression diagnosis has received significant interest but it mainly focuses on the semantics of posts. It cannot detect the implicit ambiguities that lies in the language of the user in an online posting. To address this limitation, a syntactical analysis of each user post is required. The goal of this research is to enhance the identification of individuals at risk of depression by analyzing their language and rhetorical relations using rhetorical structure theory. The rhetorical scores are incorporated into an ensemble machine learning model to classify social media posts as depressive or non-depressive. The model employs a combining multilayer perceptron, extreme gradient boosting and support vector machine algorithms. Therefore we proposed a model named RSTFusionX by linking depression to a social media dataset and using a combination of the rhetorical structure theory framework along with an ensemble machine learning algorithm. To attain more precise prediction models, the research aims to better understand the association between social media language trends and depression. The results of this study are significant, as RSTFusionX achieves 97.1% accuracy, 97.4% precision, 96.7% recall and 96.9% F1-score, exhibiting better results as compared to baseline algorithms. As a result of RSTFusionX, true positive and true negative values are increased while false positive and false negative predictions are reduced. The proposed research findings suggest that the integration of characteristics from the depressive vocabulary improves classification accuracy. The article contributes to the resources for depression detection and provides a technique for future research to further improve depression detection.},
  keywords={Depression;Social networking (online);Accuracy;Semantics;Predictive models;Long short term memory;Analytical models;Mental health;Mental disorders;Depression;ensemble modeling;machine learning;prediction;RR;rhetorical structure theory;RST;rhetorical relation},
  doi={10.1109/ACCESS.2024.3430014},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{11273580,
  author={Chaimaa, Lamharmech and Khadija, Achtaich and Rachida, Ait Abdelouahid and Abdelaziz, Marzak},
  booktitle={2025 International Conference on Intelligent Systems: Theories and Applications (SITA)}, 
  title={Leveraging IBM Tools and Social Media Insights for Postpartum Depression Prediction}, 
  year={2025},
  volume={},
  number={},
  pages={1-8},
  abstract={Postpartum depression (PPD) is a mood disorder affecting women after childbirth. Traditional and clinical approaches and patient hesitancy make it difficult to detect and prevent this disorder, despite its widespread prevalence. This research provides an alternative approach for predicting postpartum depression based on the analysis of online comments using social media text analysis as a way to prevent direct interaction with health care providers, especially in the diagnostic stage. Collection of data from Reddit was performed due to the anonymity of the user, which creates a more closed environment to vent all kinds of emotions and the implementation of a process with IBM Watson Natural Language Understanding helped extract related emotions and sentiments from text data. Classification of users into their state of depression with some classification models based on the sentiments and emotions score percentage was a valuable contribution in understanding the postpartum depression progress. This research provides a new approach to predict, detect, and potentially diagnose the early stages of PPD, possibly providing a path forward for the development of research and resources provided to mothers, referring to mental health-related issues, and how the increase or decrease of some emotions can affect depression more than others. Considering the issue of sarcasm detection and the cost of some tools as some limitations, this study will help encourage more research into the analysis of online texts for a better understanding and treatment of this maternal mood disorder.},
  keywords={Sentiment analysis;Pediatrics;Text analysis;Social networking (online);Mood;Vents;Medical services;Linguistics;Depression;Intelligent systems;Postpartum Depression;Social Network Analysis;Sentiment Analysis;Natural Language Processing},
  doi={10.1109/SITA67914.2025.11273580},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10673358,
  author={Meenakshi, A. and Sivasakthi, M.},
  booktitle={2024 7th International Conference on Circuit Power and Computing Technologies (ICCPCT)}, 
  title={Automated Depressive Disorder Classification using Optimized CNN-LSTM}, 
  year={2024},
  volume={1},
  number={},
  pages={1746-1752},
  abstract={Due to a lack of early treatment options and resources for depression detection, millions of people suffer from mental illness. It is the primary cause of sleep disorders, bipolar illness, anxiety disorders, and occasionally, self-harm and suicide. Therefore, identifying those who are experiencing mental health illnesses and getting them treated as soon as feasible is an extremely difficult endeavour. An improved deep learning Architecture (ODLA) intended for the identification and categorization of major depressive disorders is presented in this paper. The Optimized Convolutional Neural Network—Long Short-Term Memory (O-CNN-LSTM) is the name of this suggested model. The suggested methodology is applied to merge textual and auditory aspects of patient replies. The DAIC-WoZ database is used to verify the behavioural characteristics of patients with depression. The classifier is used to train the features in the proposed model. With Fire Hawks Optimization (FHO), the hyper parameters of the classifier are chosen. The suggested approach is put into practice in MATLAB, and results are assessed. It is then contrasted with traditional methods.},
  keywords={Computers;Databases;Deep architecture;Mental health;Depression;Mathematical models;Convolutional neural networks;fire hawks’ optimization;long short-term memory;deep learning model;and depressive disorder},
  doi={10.1109/ICCPCT61902.2024.10673358},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{10401148,
  author={Sheril Angel, J. and Diana Andrushia, A. and Mary Neebha, T. and Riju Suyesh, S.},
  booktitle={International Conference on Computer Vision and Internet of Things 2023 (ICCVIoT'23)}, 
  title={Comparative analysis of machine learning methods for text based depression detection}, 
  year={2023},
  volume={2023},
  number={},
  pages={357-362},
  abstract={The ability to recognise emotional states is crucial in the modern world when social media and the internet are being used by an unprecedented number of people. The 300 million persons affected by psychological problems are particularly vulnerable. Here is the rationale for using innovative research papers to address the research problem. The first step in potentially reducing the number of people affected by this condition is discovery. This study analyses a text -based depression based on machine learning methods. The machine learning models of support vector machine, decision tree, and Naive Bayes algorithm are used to detect depressed text from hugging face Twitter dataset. Numerous cumulative distribution parameters present in the classification model and dynamically categorised. The features used for this identification are derived from writing, text, and semantic content. The comparative analysis shows that the SVM based detection method produces better comparative results with other machine learning methods. The research's findings may inspire a fresh notion for how to forecast people's various emotions as they are expressed on social media platforms like Twitter.},
  keywords={},
  doi={10.1049/icp.2023.2902},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{9850873,
  author={Aggarwal, Riya and Girdhar, Nancy and Alpana},
  booktitle={2022 International Conference on Machine Learning, Big Data, Cloud and Parallel Computing (COM-IT-CON)}, 
  title={Machine Learning Role in Cognitive Mental Health Analysis amid Covid-19 Crisis: A Critical Study}, 
  year={2022},
  volume={1},
  number={},
  pages={90-96},
  abstract={Coronavirus is a disease caused by SARS-CoV-2, which can cause severe respiratory problems in humans. World Health Organization declared it to be a pandemic, as per the rate of spread and scale of its transmission. The mental health of people is impacted rudely by Covid-19. The influence of the Covid19 virus on psychological health leads to depression, anxiety, posttraumatic stress, dementia, mental stress, helplessness, fear of losing, etc. Machine Learning is performing a critical role in the rapid advancement of the healthcare system in the past few years. Machine Learning techniques are employed to forecast, diagnose disease, evaluate data by studying the earlier data, and construct different patterns of it. Therefore, the purpose of this report is to address the issue of psychiatric illnesses by identifying those who are at an elevated risk of mental conditions, due to increased stress throughout the Covid19 crisis. Due to the current ongoing pandemic, the mental health crisis needs time, and proactive interference to confront and endure the anxiety. In this research, A comprehensive literature survey was undertaken to examine some machine learning predictive models for primitive prediction of a particular type of mental illness using machine learning algorithms. Several existing research papers were reviewed and after evaluation results show that among various algorithms like, Gradient Boosting Machine, Support Vector Machines, Naïve Bayes, K-Nearest Neighbors; Support Vector Machine (98.6%), Random Forest, and Random Forest (97.07%) are the most accurate algorithm for predicting mental illness amid the ongoing pandemic.},
  keywords={COVID-19;Support vector machines;Machine learning algorithms;Pandemics;Mental health;Medical services;Prediction algorithms;machine learning;mental health;Covid-19;cognitive health;depression},
  doi={10.1109/COM-IT-CON54601.2022.9850873},
  ISSN={},
  month={May},}@INPROCEEDINGS{11182958,
  author={Dang, Chenhao and Ma, Jing and Liu, Yueheng and Li, Ziyuan},
  booktitle={2025 5th International Conference on Artificial Intelligence, Big Data and Algorithms (CAIBDA)}, 
  title={Large Language Model–Driven Multimodal Framework for Social Media Depression Detection}, 
  year={2025},
  volume={},
  number={},
  pages={1557-1561},
  abstract={Depression, the second leading cause of disability worldwide, is a prevalent and increasingly widespread mental disorder. Traditional diagnostic methods rely on patient communication and subjective cooperation, incurring significant costs in labor, resources, and time. With the accumulation of user data on social media and advancements in large language models (LLMs), computer-aided diagnosis has become feasible, offering more objective and efficient analysis for depression detection and presenting novel research directions. We propose a novel Large Language Model (LLM)-based multimodal framework integrating textual content from historical social media posts and nonlinguistic user behavioral data. Our method detects depressive tendencies with improved accuracy. Experimental results on a public multimodal Twitter dataset demonstrate substantial performance gains over standalone LLMs, achieving state-of-theart effectiveness.},
  keywords={Costs;Social networking (online);Large language models;Mental disorders;Learning (artificial intelligence);Performance gain;Depression;Transformers;Data models;Labor resources;depression detection;social media;fine-tuning;multimodal learning;transformer;large language model},
  doi={10.1109/CAIBDA65784.2025.11182958},
  ISSN={},
  month={June},}@INPROCEEDINGS{10939983,
  author={Hasan, Syed Md. Ahnaf and Hossain, Md. Tanvir},
  booktitle={2024 International Conference on Innovations in Science, Engineering and Technology (ICISET)}, 
  title={Depression Detection from Social Media Comments Using Deep Learning with Interpretability}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={Depression is one of the most prevalent and serious psychological disorders. If left untreated for a long time, it can lead to serious consequences. Therefore, early intervention can be significantly helpful in this regard. Nowadays, people often express themselves freely on social media, which makes these platforms a very good means for detecting depression among users. Various deep learning models can be used to automate the process of detecting depression from text data as they have proven very effective in text classification tasks. In this work, we have analyzed the performances of deep learning models having RNN layers and that of BERT Base Uncased, which is a pre-trained transformer model, on the Reddit depression dataset available on Kaggle. Results show that the BERT model outperforms the RNN-based deep learning models with accuracy, precision, recall, and f1 score values of 98.02%, 98.06%, 98.02%, and 98.02% respectively. Finally, we analyze the predictions made by the classifier models using the LIME XAI model to gain further insight into the classification mechanism. Implementation of XAI models alongside the deep learning models can assert faith in the predictions made.},
  keywords={Deep learning;Training;Analytical models;Technological innovation;Social networking (online);Text categorization;Predictive models;Depression;Transformers;Robustness;BERT Base Uncased;RNN;GRU;LSTM;LIME},
  doi={10.1109/ICISET62123.2024.10939983},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10079554,
  author={Hayati, Mohamad Farid Mohd and Ali, Mohd Adli Md. and Rosli, Ahmad Nabil Md.},
  booktitle={2022 IEEE-EMBS Conference on Biomedical Engineering and Sciences (IECBES)}, 
  title={Depression Detection on Malay Dialects Using GPT-3}, 
  year={2022},
  volume={},
  number={},
  pages={360-364},
  abstract={The increasing number of depression cases and lack of manpower in mental healthcare services call for alternatives use of Artificial Intelligence. Natural language processing (NLP) can offer help in the form of early detection and frequent assessments. However, such technology is still limited in the local Malaysian context. In this paper we aimed to deploy Malay NLP in the local mental healthcare services. We performed depression detection on dialectal Malay speeches, specifically Kuala Lumpur, Pahang, and Terengganu dialects. Generative Pre-Trained Transformer-3 (GPT-3), a large language model, was used to perform the task. We experimented with different hyperparameters to test the capability of GPT-3 in few-shot learning. The results obtained are promising considering the size of our dataset that is very limited. We hope to see more studies in the field for the better development of Malay NLP in future. Clinical Relevance— This research tests the possibility of using NLP technology in the local setting of Malaysia. The advancement of this technology will be beneficial in mental healthcare especially in term of the availability of services such as early detection and frequent assessment.},
  keywords={Biological system modeling;Medical services;Data collection;Depression;Transformers;Natural language processing;Task analysis},
  doi={10.1109/IECBES54088.2022.10079554},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{10841767,
  author={S J, Manoshika Catherine and Raja, Manicka and C S, Saravana Kumar and Shirley, C P and Venkatesan, R and Angel J, Sheril},
  booktitle={2024 3rd International Conference on Automation, Computing and Renewable Systems (ICACRS)}, 
  title={Deciphering Depression: Linguistic Analysis of Social Media Data}, 
  year={2024},
  volume={},
  number={},
  pages={630-635},
  abstract={In today’s digital age, where social media and the internet play integral roles in the lives of countless individuals, the ability to discern emotional states holds significant importance, especially for the 300 million people affected by psychological issues. To address this pressing concern, innovative research papers offer a promising avenue for exploration. The initial step in mitigating the impact of such conditions involves discovery. This study focuses on analyzing text-based depression using machine learning techniques. By employing a Linear Support Vector Machine SVM, Decision Tree, Random Forest, Logistic Regression, and Naive Bayes algorithms on the Sentiment140 dataset - 1.6 million tweets, The study aims to identify the common words used by a depressive person and the words used by a Non-depressive person. Various parameters from cumulative distributions are incorporated and the model is dynamically categorized. These features utilized for identification have been extracted from textual content for the Twitter dataset and semantic context. Comparative analysis reveals that the Naïve Bayes detection method yields superior results compared to other machine learning approaches. The findings of this research may catalyze a re-imagining of how individuals’ emotions are predicted, particularly as emotional expressions on online applications such as twitter.},
  keywords={Support vector machines;Renewable energy sources;Social networking (online);Blogs;Semantics;Psychology;Pressing;Feature extraction;Depression;Random forests;Natural Language Processing;Emotions;Twitter},
  doi={10.1109/ICACRS62842.2024.10841767},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{10441486,
  author={Tamim, Fahim Shakil and Taheri, Zaima Sartaj and Hoque, Mohammed Moshiul},
  booktitle={2023 26th International Conference on Computer and Information Technology (ICCIT)}, 
  title={Detecting Signs of Depression from Social Media Texts using Generalized Autoregressive Pretraining Transformer Model}, 
  year={2023},
  volume={},
  number={},
  pages={1-6},
  abstract={Recognizing signs or symptoms of depression involves determining subtle linguistic cues and patterns within the textual content to reveal indicators of someone’s potential depressive state. Due to the exponential growth of textual content on the web or social media in recent times, it is a challenging task to identify signs of depression. This paper presents a deep learning-based technique to detect signs of depression from social media texts. The critical objective of the work is to develop an intelligent framework that can accurately identify the level of depression from social media posts in English, categorizing them into three classes: not depression, moderate, and severe. This work exploits several machine learning, deep learning, and transformer-based techniques to address the task. Through extensive experimentation and fine-tuning, we evaluated multiple models, including LR, MNB, SVM, CNN, BiLSTM, CNN+BiLSTM, MBERT, XLM-Rbase, BERTbase, and XLNetbase. Experimental results demonstrate that the XLNet achieved the highest macro F1-score of 0.43. This result highlights the substantial potential of the XLNetbase model in effectively identifying and detecting signs of depression from social media text.},
  keywords={Support vector machines;Social networking (online);Assistive technologies;Depression;Transformers;Pattern recognition;Task analysis;Natural language processing;Text classification;Depression signs detection;Deep learning},
  doi={10.1109/ICCIT60459.2023.10441486},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{10110824,
  author={Zotkina, A. A. and Martyshkin, A. I.},
  booktitle={2023 International Russian Smart Industry Conference (SmartIndustryCon)}, 
  title={Identification of a Depressive State Among Users of the Vkontakte Social Network}, 
  year={2023},
  volume={},
  number={},
  pages={335-339},
  abstract={The article examines the analysis of the depressive state of social network users. It is noted that the VKontakte social network will be used as a social platform for collecting information in the study. It is noted that a combination of vocabulary-based and machine learning methods is used to achieve the highest accuracy. Two methods based on vocabulary are considered: the dictionary-based method and the corpus method. The stages of analysis are considered: collecting data obtained using the VK_API script creation module, preprocessing data through the natural language processing pipeline (deleting raw data that does not carry a semantic role), creating a model and evaluating it. It is noted that the implementation of this task uses a high-level Python programming language with dynamic strict typing and automatic memory management, the syntax of which contains a natural language processing module (NLTK). The paper presents 4 machine learning classifiers: support vector machine (SVM), k—nearest neighbor method (KNN), random forest, logistic regression, LSTM. It is revealed that machine learning algorithms such as decision tree, support vector machine, logistic regression and LSTM demonstrate good accuracy in detecting the depressive mood of a social network user. The LSTM network showed the greatest accuracy during this experiment. In conclusion, the main conclusions on the work done are formulated.},
  keywords={Support vector machines;Analytical models;Vocabulary;Social networking (online);Semantics;Syntactics;Natural language processing;social networks;VKontakte;SVM;NLTK;KNN;depression},
  doi={10.1109/SmartIndustryCon57312.2023.10110824},
  ISSN={},
  month={March},}@INPROCEEDINGS{10541714,
  author={Akhil, Karnam and Sireesha, Jangili and Sai, Gundu Venkata and Reddy, Katanguri Sai Shashidhar and Haripriya, Jonnalagadda},
  booktitle={2023 5th International Conference on Advances in Computing, Communication Control and Networking (ICAC3N)}, 
  title={Harnessing Artificial Intelligence for Preventing and Detecting Addiction in Digital Healthcare and social media among students of age group 12 to 18}, 
  year={2023},
  volume={},
  number={},
  pages={936-942},
  abstract={The comprehensive review explores the application of artificial intelligence (AI) and machine learning techniques in studying and addressing social media addiction in the context of digital healthcare. The review covers a wide range of topics, including the use of affective expressions, like insecurity or withdrawal symptoms and AI to detect mental distress. AI plays a vital role in detecting and preventing mental disorders related to social media usage, AI-based approaches for identifying individuals at risk of developing addictive behaviors on social media platforms, and the utilization of AI for detecting mental illness through social media data. It highlights how AI algorithms can analyze user-generated content on social media platforms to identify signs of mental distress, allowing for timely interventions and support. By detecting early warning signs, AI can facilitate personalized interventions and real-time monitoring to mitigate social media addiction. It showcases the potential of AI algorithms to analyze social media content and identify indicators of mental health conditions, providing valuable insights for early detection and intervention. Additionally, the review emphasizes the integration of AI as a preventive measure for social media addiction. By exploring the application of AI, particularly deep learning algorithms, in detecting depression among Twitter users, highlighting the potential of AI to identify individuals in need of support. Moreover, the review discusses the expanding field of digital psychiatry, the promotion of digital well-being, and the impact of social media addiction. It also examines the role of psychiatric symptoms in predicting internet addiction among adolescents and the importance of understanding contributing factors for the development of preventive measures.},
  keywords={Social networking (online);Reviews;Addiction;Computational modeling;User-generated content;Mental health;Prediction algorithms;social media addiction;machine learning algorithms;user behaviors;preventive strategies;multidimensional approaches;theoretical frameworks;cognitive-behavioral models;socio-ecological models;psychological factors},
  doi={10.1109/ICAC3N60023.2023.10541714},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{10533462,
  author={Remya, K. and Ranjana, P.},
  booktitle={2024 International Conference on Advances in Data Engineering and Intelligent Computing Systems (ADICS)}, 
  title={A Meta-Learning Framework with Model Stacking for Depression Detection Through Sentiment Classification}, 
  year={2024},
  volume={},
  number={},
  pages={1-8},
  abstract={In the proposed system, named AdaptiveSentinel, introduces a cutting-edge approach for depression detection depends on sentiment classification. Leveraging the power of meta-learning frameworks and model stacking, AdaptiveSentinel which aims to automate the intricate process of selecting the most effective machine Learning-Driven models, preprocessing techniques, and featured representations for accurate sentiment analysis in the context of depression disorder. The system will begins by preparing a dataset with labeled textual samples, by emphasizing sentiment distinctions get related to depression severity. It then employs a meta-learning driven framework to autonomously explore a diverse range of machine Learning-Driven models and configurations. Proposed system intelligently will navigates through options such as Gradient supported Boosting simultaneously optimizes hyper parameters through cross-validation. By Following model optimization, the system may engages in feature engineering, extracting of valuable information from the textual data and incorporating meta features such as user demographics and posting patterns. The Core part of AdaptiveSentinel lies in its model stacking mechanism, where it formatted a powerful ensemble by combining of predictions from the selected models. This stacked ensemble not only captures patterns in the data, also mitigates over fitting, resulting in a more robust and accurate depression detection system. The Evaluation metrics may includes accuracy, precision, and recall, validates the effectiveness of the ensemble model. Once get validated, the system can be deployed for real-world applications, continuously get monitored, with periodically retrained to adapt to evolving patterns in sentiment. It will be done by providing a dynamic and reliable tool for depression detection. AdaptiveSentinel also represents a significant stride towards automated, efficient, and precise sentiment-depending depression identification, holding promise for enhancement all health monitoring and support.},
  keywords={Metalearning;Measurement;Adaptation models;Analytical models;Stacking;Mental health;Predictive models;Depression analysis;Sentiment classification;Machine Learning-Driven;Earlier stage identification},
  doi={10.1109/ADICS58448.2024.10533462},
  ISSN={},
  month={April},}@INPROCEEDINGS{11390352,
  author={Sahni, Dev and Rajput, Namita and Meenakshisundaram, K.S. and Singh, Deepankar},
  booktitle={2025 1st IEEE Uttar Pradesh Section Women in Engineering International Conference on Electrical Electronics and Computer Engineering (UPWIECON)}, 
  title={Sentiment Analysis and Psychological Well-Being: A Comprehensive Survey on AI-Driven Detection of Mood Disorders}, 
  year={2025},
  volume={},
  number={},
  pages={657-663},
  abstract={The increase in the worldwide burden of mood disorders, including depression, presents a substantial clinical conundrum, with an estimated prevalence of 970 million affected individuals in the world. Although conventional diagnostic approaches are fairly reliable, being largely based on self-reporting and in-person evaluation, the respective nature has arguably impeded rapid early diagnosis or intervention. As a countermeasure, recent developments in AI, particularly in the field of Natural Language Processing, have offered novel prospects for detecting emotional and psychological distress through the analysis of linguistic and behavioural cues in digital realms. In this paper, we provide a literature review of AI-based sentiment analysis techniques that aim to identify indicators of mood dysregulation. The paper organizes, in a structured manner, the existing literature according to data modalities, model architectures, and contributions from lexical, syntactic, and affective language features. Publicly available datasets, including DAIC-WOZ, eRisk, and CLPsych, are assessed in terms of their clinical relevance and representativeness. In addition, the authors assesses important ethical considerations, such as algorithmic bias, data privacy, and risks of misclassification. By placing computational methodologies in the framework of psychological theory, this work aims toward the design of clinically meaningful, ethically rational, and interpretably sound AI systems for the detection and monitoring of mood disorders.},
  keywords={Ethics;Sentiment analysis;Data privacy;Technological innovation;Mood;Explainable AI;Computational modeling;Linguistics;Depression;Monitoring;Mood Disorders;Sentiment Analysis;Natural Language Processing (NLP);Psychological Well-Being;Depression Detection;Explainable AI (XAI);Clinical Decision Support;Multimodal Assessment;Psycholinguistics},
  doi={10.1109/UPWIECON67212.2025.11390352},
  ISSN={},
  month={Oct},}
@INPROCEEDINGS{9820295,
  author={Xu, Long and Shu, Xin and Shu, Jian},
  booktitle={2022 5th International Conference on Artificial Intelligence and Big Data (ICAIBD)}, 
  title={Research on Depression Tendency Detection Based on Image and Text Fusion}, 
  year={2022},
  volume={},
  number={},
  pages={326-331},
  abstract={The fact that depression tendency detection is not equivalent to sentiment analysis makes it difficult to find a unified standard for depression tendency detection and to accurately mine depression emotions in image and text. A depression tendency detection model based on fusion of image and text is proposed, which is mainly composed of a textual depression tendency detection model and an image depression tendency detection model. These two models extract text emotion feature through a pre-trained BERT model and use pre-trained VGG19 to learn image emotion feature. Then use a BiGRU-based classifier to obtain the corresponding depression tendency polarity probability. Finally, a model fusion formula is designed in order to play the complementary role of text and image, according to the idea of late fusion. The model combines the text depression tendency detection model and the image depression tendency detection model to perform comprehensive depression tendency detection. The experimental results on the simplified WU3D dataset show that the proposed model has better performance in each index evaluation compared with the single-modal depression tendency detection model.},
  keywords={Sentiment analysis;Social networking (online);Blogs;Bit error rate;Big Data;Depression;Feature extraction;depression;multimodality;BERT;image and text fusion},
  doi={10.1109/ICAIBD55127.2022.9820295},
  ISSN={},
  month={May},}@INPROCEEDINGS{10217763,
  author={Helmy, AbdelMoniem and Nassar, Radwa and Ramadan, Nagy},
  booktitle={2023 Intelligent Methods, Systems, and Applications (IMSA)}, 
  title={Depression Detection from Social Media Platforms: A Systematic Literature Review}, 
  year={2023},
  volume={},
  number={},
  pages={387-393},
  abstract={today, there is an increased risk of premature death by mental disorders primarily caused by depression. Depression causes suicidal thoughts, resulting in severe disability in daily life. Mental illnesses vary making it difficult for psychiatrists to detect them early enough to provide proper treatment before it's too late. Social media venues became the voice of people's everyday routines, which expands the use of Internet data to detect their mental problems. This research is conducted as a System Literature Review (SLR). It is established for the purpose of locating and recognizing the resources that are relevant in depression detection from social media platforms to shed light on the answers to a series of research inquiries. From January 2016 to October 2021, article searches in six databases were completed with search strings and filters. The result was 35 articles matching the inclusion criteria. We gained insights into the most effective approach in depression detection to achieve the highest accuracy. Furthermore, the shortcomings of current techniques are underlined.},
  keywords={Training;Support vector machines;Systematics;Social networking (online);Databases;Bibliographies;Computational modeling;depression detection;suicide;social media;mental health},
  doi={10.1109/IMSA58542.2023.10217763},
  ISSN={},
  month={July},}@INPROCEEDINGS{10099629,
  author={Khaparde, Anagha Anil and Das, Rik and Bhargava, Rupal},
  booktitle={2023 15th International Conference on Developments in eSystems Engineering (DeSE)}, 
  title={Transformer Based Approach for Depression Detection}, 
  year={2023},
  volume={},
  number={},
  pages={369-374},
  abstract={Mental health of a person plays equivalent significant role in ensuring their wellbeing as their physical health. A great deal of work and e ffort has gone into increasing awareness of this issue. One su ch effort is made by the discipline of computer science, whic h makes use of social media data to give more information in identifying these mental illnesses. People are increasingly usi ng internet platforms to voice our suicide ideas as technology advances quickly. The purpose of the study is to identify a person's indicators of depression based on their social media postings, where users express their feelings and emotions. The goal of this study is to develop three models-Naive Bayes, Pre-Trained Model BERT, and XLNET-and compare their performance in identifying depression from messages on Twitter. These models are pre-processed using the Tweet preprocessor and BERT embeddings, and then the pretrained models are fine-tuned. With an accuracy of 0.9942, it was found that Bert performed better than the other two models.},
  keywords={Training;Deep learning;Social networking (online);Bit error rate;Transfer learning;Mental health;Depression;Mental Health;Depression Detection;Deep Learning;BERT},
  doi={10.1109/DeSE58274.2023.10099629},
  ISSN={},
  month={Jan},}@INPROCEEDINGS{10808518,
  author={Fersi, Sirine and Mechti, Seifeddine and Belguith, Lamia Hadrich},
  booktitle={2024 International Symposium of Systems, Advanced Technologies and Knowledge (ISSATK)}, 
  title={Detection of Author’s Personalities: Application to Identifying Psychological Disorders on Social Media Based on Transformers}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={The proliferation of social media offers a unique opportunity to analyze user behaviors and personality traits. This paper explores the application of deep learning for detecting author personality traits, with a specific focus on identifying psychological disorders. We present a methodology that integrates advanced natural language processing (NLP) techniques and deep neural networks to analyze texts posted on social media. Using annotated datasets, we train and evaluate various deep learning models to predict indicators of psychological disorders such as depression, anxiety, and bipolar disorder. Our results demonstrate that deep learning approaches outperform traditional text classification methods, offering promising tools for large-scale mental health monitoring. This study highlights the ethical and practical implications of automated psychological disorder detection, while proposing ways to improve the accuracy and reliability of predictive models.},
  keywords={Deep learning;Ethics;Social networking (online);Anxiety disorders;Text categorization;Mental health;Predictive models;Natural language processing;Reliability;Monitoring;Anxiety;Depression;Social media;Social networking;Deep learning;Artificial intelligence;Machine learning;Natural Language Processing;Sentiment Classification},
  doi={10.1109/ISSATK62463.2024.10808518},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{10797102,
  author={Banik, Tuntusree and Asgar, Safa and Hosen, Md.Hamid and Uddin, Altaf and Nawar, Sadia and Saha, Arnob},
  booktitle={2024 IEEE International Conference on Computing, Applications and Systems (COMPAS)}, 
  title={From Social Media to Mental Health Insights: A Hybrid CNN-LSTM Model for Depression Detection in Bangladesh}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={Depression, a pervasive mental disorder, significantly impacts individuals' daily lives, manifesting as persistent sadness, a negative disposition, lack of interest or pleasure, feelings of guilt or worthlessness, and sleep disturbances. Advances in psychological methodologies, including the use of questionnaires and the analysis of social media posts, have facilitated the detection of individuals affected by this mental health issue. While mental health is a priority in many developed countries, it remains primarily neglected in regions like Bangladesh. This neglect is evident in the lack of a standardized corpus for detecting depression in the area. In this paper, we present the annotated data collected by our crawlers and detail the processes undertaken to standardize this corpus. We also propose a novel model for depression analysis and detection, which integrates Convolutional Neural Networks (CNN) and Long Short-Term Memory (LSTM) networks. Our model achieves an accuracy of 90.11%, demonstrating its efficacy. Additionally, we compare the proposed model with various machine learning models, including SVM, Random Forest, Naïve Bayes, KNN, AdaBoost, CNN, LSTM, and Decision Tree with hyperparameter tuning, using several performance metrics to highlight the advantages of our approach.},
  keywords={Support vector machines;Social networking (online);Computational modeling;Mental health;Nearest neighbor methods;Depression;Convolutional neural networks;Long short term memory;Tuning;Random forests;Depression;Deep Learning;LSTM;Machine Learning},
  doi={10.1109/COMPAS60761.2024.10797102},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10739022,
  author={Anjali, Kumari and Negi, Hritik and Nautiyal, Rishabh and Bijalwan, Saksham},
  booktitle={2024 International Conference on Electrical Electronics and Computing Technologies (ICEECT)}, 
  title={Psychological Mental Health Analysis using NLP and Machine Learning}, 
  year={2024},
  volume={1},
  number={},
  pages={1-6},
  abstract={This research explores real-time psychological analysis using pre-store information and Natural Language Processing (NLP). It aims to enhance the precision of psychological evaluation by analyzing language patterns in live conversation, utilizing NLP and machine learning techniques. The study addresses mental health challenges, focusing on stress prediction among university students, workers and introverted individuals. Additionally, it delves into depression identification through version NLP techniques and machine learning algorithms. The comparative analysis evaluates the effectiveness of approaches for discerning depression for discerning depressive states from textual data. The research contributes to understanding live text patterns and has implications for personalized mental health interventions, considering ethical considerations in technological advancements.},
  keywords={Machine learning algorithms;Accuracy;Anxiety disorders;Mental health;Machine learning;Predictive models;Prediction algorithms;Depression;Natural language processing;Real-time systems;NLP (Natural Language Processing);Machine Learning Techniques;Real-time Psychological Analysis;Depression Detection},
  doi={10.1109/ICEECT61758.2024.10739022},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{10009334,
  author={Rajendar, Sivaramakrishnan and Ranganathan, Sanjay and Lakshmanan, Thavamuthubaskaran and Nachimuthu, Vasanth and Paramasivam, Sriram},
  booktitle={2022 6th International Conference on Electronics, Communication and Aerospace Technology}, 
  title={An Extensive Survey on Recent Advancements in Human Stress Level Detection Systems}, 
  year={2022},
  volume={},
  number={},
  pages={1550-1554},
  abstract={The psychological stress has spread to harm all people in recent days. When someone is subjected to high stress continually, it can have a significant impact on their work, academic, and health aspects. To minimize the negative effects of high levels of psychological stress, it is essential to monitor and manage stress systematically. Thus, it is essential to develop reliable techniques for the quick and precise identification of human stress. Though stress detection research has gained worldwide attention by utilizing physiological and social media data, there are still a number of issues that needs to be addressed. This paper aims to discuss the need for Human Stress Level Detection System (HSLDS) focusing on the recent research utilizing human physiology, physical characteristics, social media posts, and micro-blogs. The paper explores a variety of deep learning and machine learning models deployed for stress detection, publicly available datasets based on social media posts and healthcare data, self-reporting surveys, attributes, subjected users, and levels of stress/ emotions categorized. The in-depth investigation in this research reveals new avenues for future research.},
  keywords={Deep learning;Electric potential;Social networking (online);Psychology;Focusing;Human factors;Medical services;Social media;Deep learning;Convolutional neural networks;Microblogging;Stress detection},
  doi={10.1109/ICECA55336.2022.10009334},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{11273720,
  author={Frantzidis, Christos A. and Stravoravdi, Aikaterini S. and Ladas, Aristea I. and Papazisis, Georgios},
  booktitle={2025 IEEE 25th International Conference on Bioinformatics and Bioengineering (BIBE)}, 
  title={SYMPTOM: SYMptom-Level Prediction of Target Outcomes in Major Depressive Disorder (MDD) Using Transformers on Mental Health Narratives}, 
  year={2025},
  volume={},
  number={},
  pages={718-722},
  abstract={Major Depressive Disorder (MDD) is a leading cause of disability worldwide, affecting over 240 million people and placing a substantial burden on patients, carers, and healthcare systems. While recent Natural Language Processing (NLP) advances have enabled promising depression detection models, most focus on binary classification and cannot identify the specific symptom dimensions that guide clinical decisionmaking. This lack of symptom-level resolution limits their direct utility in personalised mental healthcare. To address this gap, we introduce SYMPTOM (SYMptom-level Prediction of Target Outcomes in MDD), a multi-class NLP pipeline designed to classify short mental health narratives into ten (10) Diagnostic and Statistical Manual of Mental Disorders, Fifth Edition (DSM-5) symptom categories plus a recovery / healthy class. We fine-tuned the computationally efficient DistilBERT transformer and employed it on the purpose-built SYMPTOM dataset. This dataset is publicly available and consists of 6,800 expert-labelled, short-form narratives. It was created through participatory design with mental health professionals. The proposed model achieved an accuracy of 80.29 % and a weighted F1-score of 0.804, with top per-class performance for Appetite and Weight Changes $(\mathrm{F} 1=0.93)$, sleep disorders $(\mathrm{F} 1=0.90)$, and Recovery / Healthy $(\mathrm{F} 1=0.91)$. Even symptom categories with high semantic overlap, such as Suicidality & Self-harm (F1 = 0.81), were classified with strong accuracy. The mobile health readiness of the model stems from its low computational footprint: all experiments were conducted on a standard laptop equipped with a single consumer-grade GPU (NVIDIA RTX 3060, 6 GB VRAM) and 16 GB RAM, demonstrating that training and inference can be efficiently performed without high-performance infrastructure. By moving beyond binary detection toward clinically meaningful, symptom-specific classification, SYMPTOM bridges a critical gap between research-grade NLP models and actionable mental health tools. Its scalability, interpretability, and mobile health readiness make it particularly suited for deployment in resource-limited or remote settings, supporting early detection, triage, and personalized intervention in MDD.},
  keywords={Accuracy;Biological system modeling;Computational modeling;Pipelines;Mental health;Medical services;Depression;Transformers;Natural language processing;Standards;Major Depressive Disorder;Symptom Classification;Natural Language Processing;DistilBERT;Digital Mental Health;Multi-Class Classification},
  doi={10.1109/BIBE66822.2025.00124},
  ISSN={2471-7819},
  month={Nov},}@INPROCEEDINGS{11156679,
  author={Arora, Heena and Sachdeva, Rakesh},
  booktitle={2025 12th International Conference on Emerging Trends in Engineering & Technology - Signal and Information Processing (ICETET - SIP)}, 
  title={Al-Powered RLHF LLM for Anxiety & Depression Detection}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Anxiety and depression are mental health disorders that mostly impact daily functioning and routine activities. Anxiety is extreme worry and fear, while depression is loss of interest and sadness. These states often come together and disrupt work and overall quality of life. Their reasons are complicated, involving genomic, Physiological, Cognitive, and External factors. In this research paper, we detect anxiety and depression with the help of the natural language processing and machine learning classifier and our result shows which model is best in terms of precision, F1-score, and recall. According to these parameters results show that RLHF fine-tuned LLM which is Reinforcement Learning with Human Feedback (RLHF) fine-tuned Large Language Model (LLM) is best compared to other classifier models such as decision tree, which gives a Precision of 96.3% and recall of 96.83%.},
  keywords={Logistic regression;High dimensional data;Large language models;Anxiety disorders;Reinforcement learning;Nearest neighbor methods;Depression;Software;Decision trees;Testing;Machine Learning;Reinforcement Learning with Human Feedback;fine-tuned Large Language Model},
  doi={10.1109/ICETETSIP64213.2025.11156679},
  ISSN={2157-0485},
  month={Aug},}@INPROCEEDINGS{11342588,
  author={Haque, Md Rezwanul and Islam, Md. Milon and Taslim Uddin Raju, S M and Altaheri, Hamdi and Nassar, Lobna and Karray, Fakhri},
  booktitle={2025 IEEE International Conference on Systems, Man, and Cybernetics (SMC)}, 
  title={MDD-Net: Multimodal Depression Detection through Mutual Transformer}, 
  year={2025},
  volume={},
  number={},
  pages={6592-6599},
  abstract={Depression is a major mental health condition that severely impacts the emotional and physical well-being of individuals. The simple nature of data collection from social media platforms has attracted significant interest in properly utilizing this information for mental health research. A Multimodal Depression Detection Network (MDD-Net), utilizing acoustic and visual data obtained from social media networks, is proposed in this work where mutual transformers are exploited to efficiently extract and fuse multimodal features for efficient depression detection. The MDD-Net consists of four core modules: an acoustic feature extraction module for retrieving relevant acoustic attributes, a visual feature extraction module for extracting significant high-level patterns, a mutual transformer for computing the correlations among the generated features and fusing these features from multiple modalities, and a detection layer for detecting depression using the fused feature representations. The extensive experiments are performed using the multimodal D-Vlog dataset, and the findings reveal that the developed multimodal depression detection network surpasses the state-of-the-art by up to 17.37% for F1-Score, demonstrating the greater performance of the proposed system. The source code is accessible at https://github.com/rezwanh001/Multimodal-Depression-Detection.},
  keywords={Visualization;Correlation;Social networking (online);Source coding;Mental health;Transformer cores;Feature extraction;Depression;Transformers;Acoustics;Multimodal Depression Detection;Mutual Transformer;Feature Fusion;Vlog Data},
  doi={10.1109/SMC58881.2025.11342588},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10775133,
  author={Varalakshmi, Ch. and Christina, Sowmya and Lakshmi, Macherla Bhagya and R, Parthiban and Basha, Md Shaik Amzad and Sucharitha, M Martha},
  booktitle={2024 IEEE North Karnataka Subsection Flagship International Conference (NKCon)}, 
  title={Harnessing Machine Learning for Mental Health: A Study on Classifying Depression-Related Social Media Posts}, 
  year={2024},
  volume={},
  number={},
  pages={1-5},
  abstract={This study is of particular relevance in the way it identifies depression-related content on social media using a machine learning model to classify posts and comments. This dataset, encompassing around 6500 entries from various platforms including Facebook, was rigorously annotated by four proficient English-speaking undergraduate students together with the final label which is established via majority voting. Data Preprocessing, initial cleaning, normalization and TF-IDF feature creation through vectorization for the output of POS tags. The different machine learning models that were trained and tested are Logistic Regression, Random Forest, SVM (Support Vector Machine), Naive Bayes Gradient Boosting Algorithm K-NN (K nearest Neighbors) AdaBoost Decision Tree. Authors evaluated the models and measured their accuracy, precision score, recall rate (also known as sensitivity) in addition to F1-score. Gradient Boost, Random Forest, and SVM were top performers among which Gradient boosting was found to be an overall best one with almost 98.5%. They show that machine learning model can successfully predict the label of social media posts, as a way for accurately identifying depression from text data. This detailed model performance evaluation is useful in understanding what each approach does well and poorly, shedding light into whether they are / would be actually suitable for real-world applications. This study not only developed discriminative classifiers, but also included detailed analysis of their performance which should hopefully guide future work and help in practical implementations for real-time mental health monitoring. Through this work, this study aim to facilitate timely identification of depression-related posts, ultimately supporting mental health awareness and intervention efforts on social media platforms.},
  keywords={Support vector machines;Social networking (online);Mental health;Nearest neighbor methods;Boosting;Depression;Real-time systems;Random forests;Monitoring;Load modeling;Mental Health;Depression;Social Media Posts;Classification Models},
  doi={10.1109/NKCon62728.2024.10775133},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10990582,
  author={Walia, Chayan Preet and Maheshwary, Priti},
  booktitle={2025 International Conference on Cognitive Computing in Engineering, Communications, Sciences and Biomedical Health Informatics (IC3ECSBHI)}, 
  title={Decoding Depression: An In-Depth Review of Multimedia-Based Detection on Social Media}, 
  year={2025},
  volume={},
  number={},
  pages={480-484},
  abstract={Depression is one of the most common mental illness conditions, affecting millions of people in today's world, which can be generally described by persistent sadness, hopelessness, and loss of interest in daily activities. With the rapid adoption of social media, more and more people now express their feelings through various forms of multimedia, text, images, and audio, thereby creating a vast digital footprint that can be very useful for monitoring mental health with automated systems. This paper analyses the use of multimedia content on social networks in the detection of depressive behaviors. It discusses AI and deep learning techniques that include sentiment analysis, NLP, image recognition, and voice emotion recognition which might be useful to identify depressive signs from such multimedia inputs. The review has covered several issues on challenges that arise in multimedia-based detection, such as data privacy, algorithmic bias, and the ethical repercussions of mental health diagnosis by a system of automation. Its mention of concerns surrounding user confidentiality, reducing bias in AI models, and making proper balances between human oversight and automation is very important. Finally, the paper presents possible future work that could ensure the accuracy, timeliness, and ethical standards of depression detection systems toward more responsible technology-driven mental health care.},
  keywords={Deep learning;Ethics;Emotion recognition;Sentiment analysis;Image recognition;Social networking (online);Reviews;Mental health;Depression;Artificial intelligence;Depression detection;social media;artificial intelligence;deep learning;multimedia content;natural language processing;image recognition;voice emotion recognition;data privacy;ethical consideration},
  doi={10.1109/IC3ECSBHI63591.2025.10990582},
  ISSN={},
  month={Jan},}@INPROCEEDINGS{10796526,
  author={Singh, Kulvinder and Kumari, Akanksha and Sharma, Nakul},
  booktitle={2024 First International Conference on Software, Systems and Information Technology (SSITCON)}, 
  title={Predicting Stress, Anxiety, and Depression from Social Media Comments: A Holistic Multi-Modal Deep Learning and NLP Framework}, 
  year={2024},
  volume={},
  number={},
  pages={1-7},
  abstract={In the current digital era, millions of people are affected by increased levels of stress, anxiety, and desperation making mental health a critical worldwide concern. Proactive approaches to early detection of these illnesses are necessary to address this dilemma. This research aims to create a mental health condition prediction model by utilizing deep learning, machine learning, and natural language processing (NLP) cutting edge methods. We use social media data to identify potential red flags for mental health issues early on. To build a strong framework, our suggested approach combines classic machine learning techniques like Random Forest and SVMs with neural networks, such as CNNs, LSTMs, and GRUs. Through an examination of language patterns and behaviors seen in social media content, our models provide insights into current trends in mental health. Experimental results demonstrate high predictive accuracy, highlighting the potential for early intervention. This research addresses the growing need for innovative, data-driven approaches to mental health care, facilitating timely support, personalized treatment, and improved outcomes for individuals and communities.},
  keywords={Deep learning;Social networking (online);Anxiety disorders;Neural networks;Mental health;Predictive models;Software systems;Natural language processing;Vectors;Random forests;NLP;GRU;LSTM;random forest;support vector machine;mental health prediction},
  doi={10.1109/SSITCON62437.2024.10796526},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10242645,
  author={Gupta, Khushi and Jinad, Razaq and Liu, Qingzhong},
  booktitle={2023 International Conference on Communications, Computing and Artificial Intelligence (CCCAI)}, 
  title={Comparative Analysis of NLP Models for Detecting Depression on Twitter}, 
  year={2023},
  volume={},
  number={},
  pages={23-28},
  abstract={Depression is a serious mental health issue affecting a significant portion of the world’s population. With the widespread use of social media platforms, researchers have explored the possibility of utilizing natural language processing (NLP) techniques to detect signs of depression in users’ posts. In this paper, we present a comparative analysis of six different NLP models, namely BERT, RoBERTa, DistilBERT, ALBERT, Electra, and XLNet, for depression detection on Twitter data. The experiments compare the performance of different models, and the results reveal that the highest-performing models include XLNet, DistilBERT, and RoBERTa with the accuracies over 99%.},
  keywords={Analytical models;Social networking (online);Computational modeling;Blogs;Sociology;Depression;Transformers;Natural language processing;Depression detection;Transformers;Machine learning;Comparative analysis},
  doi={10.1109/CCCAI59026.2023.00013},
  ISSN={},
  month={June},}@ARTICLE{11098834,
  author={Aditra Pradnyana, Gede and Anggraeni, Wiwik and Mulyanto Yuniarno, Eko and Purnomo, Mauridhi Hery},
  journal={IEEE Access}, 
  title={Revealing Depression Through Social Media via Adaptive Gated Cross-Modal Fusion Augmented With Insights From Personality Traits}, 
  year={2025},
  volume={13},
  number={},
  pages={133465-133482},
  abstract={The escalating prevalence of mental health disorders, particularly depression, underscores the urgent need for early and accurate detection systems. The widespread use of social media has produced an extensive repository of user-generated content, offering critical insight into individuals’ emotional and psychological states. This development enables novel approaches for automated depression detection. However, existing multimodal depression detection approaches often adopt rigid fusion strategies and disregard individual differences in expressive behavior by adopting generalized, one-size-fits-all frameworks. To bridge this gap, we introduce DeXMAG, a novel personalized depression detection framework that integrates a Cross-Modal Attention mechanism with an Adaptive Gated Fusion strategy. DeXMAG effectively combines textual content, visual imagery, and user-level personality traits to capture the heterogeneous and individualized patterns of depressive expression across modalities. Leveraging domain-specific transformer-based language models and a convolutional neural networks-based model, we extract modality-specific features and fuse them via a novel adaptive gating mechanism. Unlike traditional fusion techniques, our model leverages modality-aware attention signals and gating coefficients to enable flexible and personalized integration of features. An extensive ablation study reveals that the most substantial performance gain occurs when DeXMAG is augmented with insights from Myers–Briggs Type Indicator (MBTI) personality traits in conjunction with textual and visual features. Comprehensive experiments on multimodal social media datasets demonstrate that DeXMAG consistently outperforms unimodal baselines and state-of-the-art approaches, achieving an accuracy of 95.20% and an F1-score of 95.94%. These results reinforce the effectiveness of adaptive gated fusion and personality-aware modeling in advancing robust and personalized depression detection.},
  keywords={Depression;Social networking (online);Logic gates;Adaptation models;Visualization;Feature extraction;Mental health;Transformers;Linguistics;Data models;Adaptive gated fusion;cross-modal attention;depression;multimodal learning;Myers–Briggs Type Indicator;personalized detection;social media},
  doi={10.1109/ACCESS.2025.3593273},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{11367582,
  author={Sultana, Zinnia and Tanni, Kaniz Fatema and Datta, Anirban and Nandy, Punam and Rahman, Koushik Jamilur},
  booktitle={2025 IEEE 7th International Conference on Sustainable Technologies For Industry 5.0 (STI)}, 
  title={Multiclass Mental Disorder Detection from Social Media Using BERT and Hybrid Data Balancing}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Mental illnesses are complex disorders that significantly affect individuals worldwide. In the digital era, social media has become an important medium for individuals to express their emotions and seek support. Machine learning (ML) and deep learning (DL) approaches have been used to identify mental health problems from online posts, yielding promising results. However, most research focuses on binary classification and often struggles with imbalanced datasets. This study aims to develop a BERT-based multiclass classification model to identify several mental disorders, including Normal, Depression, Suicidal, Anxiety, Stress, Bipolar, and Personality Disorder. To address data imbalance, a hybrid data balancing technique combining Random Oversampling (ROS) and Random Undersampling (RUS) is applied. The model is evaluated on a Mental Health Text Dataset collected from Kaggle and compared with traditional ML algorithms, including Logistic Regression, Random Forest, XGBoost, and Naive Bayes, as well as an LSTMbased DL model. Experimental results show that the baseline BERT model achieved an accuracy of $83 \%$, which improved to $90 \%$ after applying the hybrid balancing technique. The proposed approach demonstrates superior performance compared to traditional ML algorithms and LSTM, highlighting the effectiveness of integrating transformer-based models with data balancing techniques for more accurate and robust multiclass mental illness detection from social media data.},
  keywords={Deep learning;Logistic regression;Accuracy;Social networking (online);Mental health;Transformers;Data models;Bayes methods;Fifth Industrial Revolution;Random forests;Mental Health Detection;Multiclass Classification;BERT;Hybrid Data Balancing;Social Media Analysis},
  doi={10.1109/STI69347.2025.11367582},
  ISSN={2996-170X},
  month={Dec},}@INPROCEEDINGS{11022340,
  author={Austin, Steve and Haider, Shah Nawaz and Shil, Rajib and Lija, Nisrat Sharmin and Rifah Noor, Kazi},
  booktitle={2024 27th International Conference on Computer and Information Technology (ICCIT)}, 
  title={Bi-LSTM-RF based Hybrid Deep Learning Approach to Identify Level of Depression from Bengali Facebook Status}, 
  year={2024},
  volume={},
  number={},
  pages={1750-1755},
  abstract={Depression is a worldwide epidemic and is of special concern due to its impact on mental health and the need for comprehensive studies for better detection and treatment. As the severity of depression grows among the Bengali population, yet the identification is relatively uncommon in this wider community, it appears to be in high demand. In our research, an efficient deep hybrid learning is instituted to identify levels of depression in Bangla text. We gathered 3000 Bengali Facebook posts for our dataset labeled for three levels of depression, mild, moderate, and severe. A bidirectional Long Short-Term Memory (bi-LSTM) architecture and a Random Forest classifier have been applied. We followed some pre-processing steps for these texts, which involved cleaning, correcting mistakes, removing stop words, segmentation, and embedding the text using Word2Vec to turn the text into vectors. The bi-LSTM model performed at an accuracy of 90.5% but this was improved to 93.67% when combined with Random Forest by using Softmax generated class scores as features. The aspects of our proposed hybrid bi-LSTM-RF techniques suggest that it could be more precise and effective for depression detection in the less researched Bangla language. These results provide insight into the application of deep learning with classical classifiers for sentiment classification in the mental health field and enhancing the treatment of depression by early detection.},
  keywords={Deep learning;Accuracy;Social networking (online);Soft sensors;Mental health;Depression;Transformers;Vectors;Real-time systems;Random forests;NLP;Hybrid Deep Learning;Depression;Bi-LSTM-RF;Mental health},
  doi={10.1109/ICCIT64611.2024.11022340},
  ISSN={2474-9656},
  month={Dec},}@INPROCEEDINGS{11013401,
  author={Sajib, Md Habib Ullah and Hasan, Md. Maherab and Arif, Shibbir Ahmed and Jahan, Israt},
  booktitle={2025 International Conference on Electrical, Computer and Communication Engineering (ECCE)}, 
  title={Depression Detection from Bangla Text Using BanglaBERT and Hybrid Deep Learning Techniques}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Emotions such as depression, sadness, happiness are internal feelings that expose the actual behavior of a person. These type of emotions are very important and sometimes it can be difficult to examine them properly. Among them, depression has become a common mental disorder that can affect our mental health and daily activities. Social media like Facebook, Twitter, YouTube are getting a part of the daily activities of people. They often use these platforms to share their personal experiences, beliefs, opinions etc. In this study, we have applied BanglaBERT, CNN-BiLSTM (Convolutional Neural Network with Bidirectional Long Short-Term Memory), BiGRU-CNN (Bidirectional Gated Recurrent Units with Convolutional Neural Networks), and GRU-LSTM (Gated Recurrent Units with Long Short-Term Memory) to detect depression from the Bangla comments of YouTube videos. To accomplish the research, we have utilized three different datasets containing Bangla textual data. Besides, we have applied hyperparameter tuning method to train the models with the best possible parameters. As a result, we have found that the BanglaBERT model has outperformed the CNN-BiLSTM, BiGRU-CNN and GRU-LSTM hybrid models overall in all three datasets in terms of Accuracy, Precision, Recall and F1-Score.},
  keywords={Deep learning;Video on demand;Social networking (online);Computational modeling;Depression;Web sites;Convolutional neural networks;Long short term memory;Tuning;Videos;Depression Detection;Hybrid Deep Learning;Natural Language Processing;Bangla Text;Transfer Learning;BanglaBERT;CNN-BiLSTM;BiGRU-CNN;GRU-LSTM},
  doi={10.1109/ECCE64574.2025.11013401},
  ISSN={},
  month={Feb},}@INPROCEEDINGS{10690017,
  author={Shaik, Shabana and V C, Bharathi},
  booktitle={2024 5th International Conference on Electronics and Sustainable Communication Systems (ICESC)}, 
  title={A Literature Review on the Detection of Mental Illness}, 
  year={2024},
  volume={},
  number={},
  pages={1413-1417},
  abstract={One of the most frequent psychological disorders is depression. The major challenge is a quick and accurate diagnosis of the condition. Self-reporting surveys are the tools that medical professionals utilize to develop a diagnosis. These tests were created by looking at various depressed symptoms. The effectiveness of conventional approaches is, however, adversely impacted by things like societal stigmas. Due to general ignorance and societal stigma, these mental health conditions are costly to detect clinically and frequently go untreated. Presently, using social media websites for expressing and interacting with one's thoughts, emotions, and sentiments is the preferred method of communication. The aim of this study is to assess several methods for non-clinical, predictive early identification and diagnosis of depression, self-harm, and suicide thoughts in online social network material. This study will help for future researcher work.},
  keywords={Surveys;Accuracy;Social networking (online);Communication systems;Bibliographies;Mental health;Predictive models;Depression;Medical diagnostic imaging;Neural Language Models;Social Media;Depression Prediction},
  doi={10.1109/ICESC60852.2024.10690017},
  ISSN={2996-5357},
  month={Aug},}@INPROCEEDINGS{10738929,
  author={Chandil, Nitanshi and Sengar, Ankita and Kushwah, Sapna},
  booktitle={2024 International Conference on Electrical Electronics and Computing Technologies (ICEECT)}, 
  title={A Novel Shuffle Encode Distil Model for Suicide Risk Detection in Social Media}, 
  year={2024},
  volume={1},
  number={},
  pages={1-6},
  abstract={Depression leading to suicidal tendency has become an important issue worldwide. However, a large number of people generally, lose their life undiagnosed and untreated. Here a social media platform with machine learning provides the vital solution to this issue. Many studies have shown that men with depressive disorder tend to post depressive messages on these platforms. This paper proposes a machine learning Shuffle Encode Distil model which can identify and classify the messages and posts as suicidal and non-suicidal. The proposed model was also tested against a few state-of-the art machine learning models like XGBoost, Random Forest, CatBoost, Support Vector Machine Classifier, etc and other proposed models. The Shuffle-Encode Distil-Model was able to classify the messages successfully with accuracy of .999, precision of 0.998, recall of 0.999 and F1 score of 0.999.},
  keywords={Support vector machines;Deep learning;Machine learning algorithms;Accuracy;Social networking (online);Prevention and mitigation;Static VAr compensators;Computer architecture;Random forests;Research and development;suicide prevention;social media;machine learning;sentiment analysis;classification algorithms;distilbert},
  doi={10.1109/ICEECT61758.2024.10738929},
  ISSN={},
  month={Aug},}@ARTICLE{10154134,
  author={Ilias, Loukas and Mouzakitis, Spiros and Askounis, Dimitris},
  journal={IEEE Transactions on Computational Social Systems}, 
  title={Calibration of Transformer-Based Models for Identifying Stress and Depression in Social Media}, 
  year={2024},
  volume={11},
  number={2},
  pages={1979-1990},
  abstract={In today’s fast-paced world, the rates of stress and depression present a surge. People use social media for expressing their thoughts and feelings through posts. Therefore, social media provide assistance for the early detection of mental health conditions. Existing methods mainly introduce feature extraction approaches and train shallow machine learning (ML) classifiers. For addressing the need of creating a large feature set and obtaining better performance, other research studies use deep neural networks or language models based on transformers. Despite the fact that transformer-based models achieve noticeable improvements, they cannot often capture rich factual knowledge. Although there have been proposed a number of studies aiming to enhance the pretrained transformer-based models with extra information or additional modalities, no prior work has exploited these modifications for detecting stress and depression through social media. In addition, although the reliability of a machine learning (ML) model’s confidence in its predictions is critical for high-risk applications, there is no prior work taken into consideration the model calibration. To resolve the above issues, we present the first study in the task of depression and stress detection in social media, which injects extra-linguistic information in transformer-based models, namely, bidirectional encoder representations from transformers (BERT) and MentalBERT. Specifically, the proposed approach employs a multimodal adaptation gate for creating the combined embeddings, which are given as input to a BERT (or MentalBERT) model. For taking into account the model calibration, we apply label smoothing. We test our proposed approaches in three publicly available datasets and demonstrate that the integration of linguistic features into transformer-based models presents a surge in performance. Also, the usage of label smoothing contributes to both the improvement of the model’s performance and the calibration of the model. We finally perform a linguistic analysis of the posts and show differences in language between stressful and nonstressful texts, as well as depressive and nondepressive posts.},
  keywords={Feature extraction;Depression;Human factors;Transformers;Social networking (online);Linguistics;Bit error rate;Calibration;depression;emotion;mental health;stress;transformers},
  doi={10.1109/TCSS.2023.3283009},
  ISSN={2329-924X},
  month={April},}@ARTICLE{11152614,
  author={Thamrin, Syauki Aulia and Chen, Arbee L.P.},
  journal={IEEE Transactions on Affective Computing}, 
  title={Distinguishing Depression and Bipolar Disorder From Social Media Data Utilizing Intensity of Emotions and Interpretable Deep Learning Models}, 
  year={2026},
  volume={17},
  number={1},
  pages={77-91},
  abstract={Depression and bipolar disorder (BD) are mental disorders that are often misdiagnosed as each other because their symptoms often overlap. Depression is characterized by prolonged negative emotion, which is persistent feelings of sadness. In contrast, BD is characterized by repeated extreme changes of emotions, consisting of manic (very happy) and depression (very sad) episodes. Because of overlapping symptoms, changes of emotions indicating depression or BD are difficult to recognize from individual posts. We propose two deep learning models to detect depression and BD from user posts, considering individual posts and multiple posts. A novel method to extract emotion features is designed by fine-tuning a transformer model to extract the intensity of emotions of the posts. Text features are extracted using word embedding models that have been fine-tuned on mental health data, and we further consider topic features by using a topic modeling method. Multiple posts are considered by grouping them based on a time interval between the posts. The features of each group are concatenated, input into a convolution neural network (CNN), and go through a long short-term memory (LSTM). The attention mechanism is used to pay attention to important groups. The most important groups can be observed further to explain why the model classified depression and BD users. Our proposed model outperforms other models, achieving an F1-Score of 0.9589. Based on our experiment, the changes of emotions within four days are necessary for distinguishing depression and BD, which aligns with considerations in diagnosing symptoms of depression and BD.},
  keywords={Depression;Feature extraction;Deep learning;Social networking (online);Data models;Computational modeling;Transformers;Affective computing;Long short term memory;Attention mechanisms;Depression detection;bipolar disorder detection;social media;deep learning;model interpretability},
  doi={10.1109/TAFFC.2025.3606887},
  ISSN={1949-3045},
  month={Jan},}@ARTICLE{9904737,
  author={Ahmad Wani, Mudasir and ELAffendi, Mohammad A. and Shakil, Kashish Ara and Shariq Imran, Ali and Abd El-Latif, Ahmed A.},
  journal={IEEE Transactions on Computational Social Systems}, 
  title={Depression Screening in Humans With AI and Deep Learning Techniques}, 
  year={2023},
  volume={10},
  number={4},
  pages={2074-2089},
  abstract={Social media platforms have been widely used as a communication tool where most of the population expresses their feelings and shares life experiences. Along with general information about the public, these platforms hold an ample amount of content related to depressed users and thus can generate sensitive social signals indicating if a person is suffering from some serious issues, such as self-harm, suicidal thoughts, or intention for an unlawful act. Early depression detection using advanced natural language processing (NLP), deep machine learning, and transfer learning techniques can assist in designing an efficient system to detect major depressive systems at an early stage. The current depression detection models are not enough to capture sensitive social signals indicating the true mood, personality, and behavior of an individual. Thus, making the current systems unsatisfactory. To address this life-threatening human-health problem, we propose an efficient artificial intelligence (AI) and deep learning (DL)-based model for identifying depressed individuals on social media platforms. The model employs hybrid feature-based behavioral-biometric signals captured using Word2Vec, term frequency-inverse document frequency (TF-IDF) models to learn a convolutional neural network (CNN) and long-short term memory (LSTM) models. The data are captured from multiple sources using advanced crawling strategies to have data variety in the corpus. Thus, making the proposed system effective across platforms. The Dataset produced by this study is the first of its kind with a variety of depressive signals from online social network (OSN) platforms including Facebook, Twitter, and YouTube. The experiments have shown that both DL models LSTM and CNN, and the hybrid (CNN + LSTM) models achieved promising results on all individual as well as combined datasets. Out of 24 experiments for Word2Vec LSTM and Word2Vec (CNN + LSTM) models, we achieved the accuracy of 99.02% and 99.01%, respectively, and recorded as best results outperforming all the existing approaches on performance measures such as recall, precision, accuracy, and  ${F}1$ -score. The Word2Vec-based features have been proved optimal features for detecting depressions symptoms on Facebook corpus (FC) and YouTube corpus (YC) by achieving an accuracy of 95.02% (with CNN) and 98.15% (with CNN + LSTM), respectively.},
  keywords={Social networking (online);Depression;Convolutional neural networks;Video on demand;Blogs;Mental health;Linguistics;Artificial intelligence (AI);behavioral-bio-metric signals;convolutional neural network (CNN) and long-short term memory (LSTM);deep learning (DL);depression detection;mental health;social media},
  doi={10.1109/TCSS.2022.3200213},
  ISSN={2329-924X},
  month={Aug},}@INPROCEEDINGS{11280304,
  author={Yuvashree, Mp and Tejeswini, I and Revathi, M and Jenifer, A},
  booktitle={2025 7th International Conference on Innovative Data Communication Technologies and Application (ICIDCA)}, 
  title={Sentiment-Aware BiLSTM–Attention Model for Depression Detection}, 
  year={2025},
  volume={},
  number={},
  pages={1528-1533},
  abstract={Depression is a novel, global mental health condition, and early intervention from social media analysis is a promising avenue for scalable, real-time intervention. In this paper, This paper presents a hybrid deep learning architecture that includes Bidirectional Long Short-Term Memory (BiLSTM) networks, attention, external sentiment polarity features to detect depressive content in Reddit-posted user comments. The model uses BiLSTM contextual word representations for sequential text structure capture, and an attention layer selects emotionally salient words to facilitate interpretability. Sentiment polarity scores from the TextBlob library are also used in the model to give clear emotional signals to learning. This multi-stream model not only enhances classification accuracy but also facilitates transparency in decision-making, making the model more appropriate for sensitive applications in mental health screening. Experimental evaluation on a cleaned Reddit dataset indicates that the proposed model outperforms standard LSTM-based baselines, with robust accuracy in binary classification tasks. The combination of deep contextual features with interpretable sentiment signals gives a strong and explainable framework for automated depression detection.},
  keywords={Attention mechanisms;Accuracy;Social networking (online);Bidirectional long short term memory;Deep architecture;Mental health;Depression;Feature extraction;Libraries;Context modeling;BiLSTM;Attention Mechanism;Sentiment Polarity;Social Media Analysis;Natural Language Processing},
  doi={10.1109/ICIDCA66325.2025.11280304},
  ISSN={},
  month={Oct},}@ARTICLE{10750787,
  author={Almutairi, Sulaiman and Abohashrh, Mohammed and Razzaq, Hasanain Hayder and Zulqarnain, Muhammad and Namoun, Abdallah and Khan, Faheem},
  journal={IEEE Access}, 
  title={A Hybrid Deep Learning Model for Predicting Depression Symptoms From Large-Scale Textual Dataset}, 
  year={2024},
  volume={12},
  number={},
  pages={168477-168499},
  abstract={A significant number of individuals are facing mental health issues due to a lack of timely treatment and support for detecting depression. This lack of early treatment is a primary factor contributing to conditions such as anxiety disorders, bipolar disorders, sleep disorders, depression, and, in severe cases, self-harm and suicide. Consequently, identifying individuals suffering from mental health disorders and offering prompt intervention is an extraordinarily challenging task. Therefore, this research introduced a novel hybrid deep-learning method for predicting depression at an early stage. In this study, we proposed a hybrid deep learning model for depression prediction, which mainly combines a Convolution Neural Network (CNN) and a Long Short-Term Memory (LSTM) model. An enhanced version of the LSTM approach, namely Two-State LSTM (TS-LSTM), is applied based on the feature attention mechanism. The proposed framework incorporates a feature attention mechanism into the TS-LSTM approach, which increases the ability to identify relationships and extract keywords for depression detection using the attention layer. This methodology is employed on a large dataset obtained from a publicly accessible online platform for young people. This dataset consists of text questions asked by young users on the platform. We extracted features through a one-hot encoding method from robust indicators of potential depression symptoms, which were predefined by medical and psychological experts. In comparative evaluations compared to conventional approaches, our system demonstrates superior performance. The experimental outcomes revealed that the proposed approach attained an accuracy of 97.23%, a precision of 98.57%, a recall of 97.13%, an F1-score of 97.84%, and a specificity of 97.93%, respectively. These results highlight the efficiency of the developed methodology that accurately predicts depression.},
  keywords={Depression;Accuracy;Social networking (online);Feature extraction;Long short term memory;Support vector machines;Deep learning;Blogs;Predictive models;Convolutional neural networks;Mental health;Deep learning;convolution neural network;long short-term memory;attention mechanism;depression detection},
  doi={10.1109/ACCESS.2024.3496741},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{10425161,
  author={Raj Shekhar, Ashish and Gupta, Tanya},
  booktitle={2023 2nd International Conference on Futuristic Technologies (INCOFT)}, 
  title={Sentimental Analysis of Social Media Data for Mental Health Monitoring}, 
  year={2023},
  volume={},
  number={},
  pages={1-6},
  abstract={The mental health problem known as depression is a multifaceted and widespread condition that presents a substantial obstacle to global health. Early detection and management are critical to lessen its negative impact on people's well-being. With the rise of social media platforms like Twitter, researchers have become interested in mining their textual content for indicators of depression using deep learning techniques. This paper presents a complete methodology for detecting depression using deep learning models trained on an open-source Kaggle dataset. The proposed method employs the Transformers, i.e., BERT, to retrieve embeddings from the text data (tweets). The embeddings derived from BERT are subsequently utilized as input for the customized Deep Neural Network, which consists of five layers and an LSTM model. The experimental results show that the Deep Neural Network outpaces the LSTM model by achieving 100% and 99.13% training and validation accuracies, respectively. The utilization of deep learning methodologies to detect depression through analysis of tweets demonstrates a potentially advantageous and groundbreaking strategy for tackling the difficulties connected with diagnosing and providing assistance to those who may be undergoing depressive episodes.},
  keywords={Deep learning;Training;Social networking (online);Artificial neural networks;Mental health;Depression;Transformers;Depression;Machine learning;Deep learning;LSTM;RNN},
  doi={10.1109/INCOFT60753.2023.10425161},
  ISSN={},
  month={Nov},}@ARTICLE{10804764,
  author={Mohmand, Ruba and Habib, Usman and Usman, Muhammad and Baili, Jamel and Nam, Yunyoung},
  journal={IEEE Access}, 
  title={A Deep Learning Approach for Automated Depression Assessment Using Roman Urdu}, 
  year={2024},
  volume={12},
  number={},
  pages={193387-193401},
  abstract={Depression is a highly complex and frequently unnoticed mental condition that presents substantial hazards to a person’s well-being. Many people use social media as a means of conveying their emotions in the digital age, creating a potential avenue for depression assessment through these platforms. While English has seen extensive research on depression identification, other languages, like Roman Urdu, which is widely used in South Asia, have received less investigation. The lack of a standardized textual structure in Roman Urdu presents a challenge in evaluating depression levels. Moreover, there is currently no corpus available to assess the severity of depression in Roman Urdu. This is a notable deficiency considering the significance of linguistic resources for tasks involving natural language processing. This study fills this gap by manually categorizing an extensive collection of 25,004 Roman Urdu posts from X(Twitter) into four classes: mild, moderate, severe, and non-depression. Using a pre-trained BERT model with transfer learning, the study achieves a remarkable accuracy rate of 99%, surpassing the performance of other deep models. The findings underscore the capacity of sophisticated natural language processing methods to precisely evaluate the intensity of depression in Roman Urdu text, thereby facilitating more comprehensive mental health assessments.},
  keywords={Depression;Social networking (online);Accuracy;Mental health;Deep learning;Transfer learning;Sentiment analysis;Hate speech;Feature extraction;Transformers;Sentiment analysis;deep learning;transfer learning;health care;text classification},
  doi={10.1109/ACCESS.2024.3519264},
  ISSN={2169-3536},
  month={},}@ARTICLE{10664621,
  author={Mobin, Md. Iftekharul and Suaib Akhter, A. F. M. and Mridha, M. F. and Hasan Mahmud, S. M. and Aung, Zeyar},
  journal={IEEE Access}, 
  title={Social Media as a Mirror: Reflecting Mental Health Through Computational Linguistics}, 
  year={2024},
  volume={12},
  number={},
  pages={130143-130164},
  abstract={The world is grappling with a serious problem: many young individuals are taking their own lives. There is also a challenge in understanding the rising trend of this tendency. It is essential to explore the reasons driving people of all ages to consider suicide and find ways to encourage them to choose life instead. In the modern era, social media acts as a crucial platform where people share their thoughts, activities, and emotional states. This has led to the consideration of whether analyzing social media posts could help discern whether individuals are experiencing joy or sadness, particularly to detect levels of sadness that could indicate suicidal thoughts. This paper employs artificial intelligence and machine learning tools to analyze the social media posts of individuals to gauge their mental state, specifically targeting signs that might indicate a risk of suicide. The study has found a high frequency of suicidal thoughts among those who appear depressed on social media. This research investigated the possibility to identify the likelihood of someone contemplating suicidal through their online behavior. This research demonstrates the potential of utilizing social media analysis to identify and support individuals at risk of suicide, providing new insights into recognizing and assessing suicidal thoughts and representing a significant advancement in suicide prevention efforts.},
  keywords={Social networking (online);Depression;Mental health;Machine learning;Analytical models;Accuracy;Mirrors;Unsupervised learning;Depression;exploratory analysis;feature extraction;LDA;NLP;suicide;unsupervised model},
  doi={10.1109/ACCESS.2024.3454292},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{11157195,
  author={Suhoyo, Duta Razaq and Setiawan, Erwin Budi},
  booktitle={2025 International Conference on Data Science and Its Applications (ICoDSA)}, 
  title={Detecting Depression in Indonesian Social Media: A FastText and GA-Optimized with CNN-RNN Approach}, 
  year={2025},
  volume={},
  number={},
  pages={1166-1171},
  abstract={Depression has become an increasingly pervasive mental health issue in Indonesia, with many individuals expressing emotional distress through social media platforms such as X. The informal, unstructured, and context-dependent nature of social media language presents challenges for automatic detection using natural language processing (NLP). This study proposes a hybrid deep learning model combining Convolutional Neural Networks (CNN) and Recurrent Neural Networks (RNN) to identify depressive indications in Indonesian tweets. A total of 58,115 tweets were collected and manually labeled into two classes: depressed and non-depressed. The text data underwent preprocessing steps including cleaning, case folding, normalization, stopword removal, stemming, and tokenization. Features were extracted using Term Frequency-Inverse Document Frequency (TF-IDF), and semantic relationships were enriched through FastText embeddings. The FastText model was trained on three corpora—Tweet, IndoNews, and a combined Tweet+IndoNews—resulting in a similarity corpus of 339,128 entries. Hyperparameter optimization was conducted using Genetic Algorithm (GA), tuning learning rate, layer size, and dropout rate. The best-performing configuration used three 1D convolutional layers (kernel sizes 3, 5, 7), a SimpleRNN layer with 32 units, a dropout rate of 0.6, and a learning rate of 0.001. This model achieved an accuracy of 85.54%, an increase of 2.13% from the baseline of 83.41%. The results demonstrate that integrating CNN-RNN architecture with semantic feature expansion and GA-based optimization enhances depression detection in informal social media texts. Furthermore, the proposed approach supports long-term sustainability by utilizing open-source tools and lightweight neural architectures, making it adaptable to evolving language patterns and scalable for digital mental health monitoring systems in the Indonesian context.},
  keywords={Social networking (online);Semantics;Mental health;Depression;Feature extraction;Convolutional neural networks;Sustainable development;Optimization;Tuning;Genetic algorithms;depression detection;platform x;CNN-RNN;fasttext;genetic algorithm},
  doi={10.1109/ICoDSA67155.2025.11157195},
  ISSN={},
  month={July},}@INPROCEEDINGS{10724596,
  author={Singh, Vrishank and Gupta, Vishnu Kant and Tripathi, Vansh and Singh, Khushboo and Pandey, Arti},
  booktitle={2024 15th International Conference on Computing Communication and Networking Technologies (ICCCNT)}, 
  title={A Machine Learning based Depression Detection via Questionnaires and Video}, 
  year={2024},
  volume={},
  number={},
  pages={1-7},
  abstract={This study aims to detect depression by integrating machine learning with facial analysis. It features two main components: a ten-question multiple-choice questionnaire (MCQ) to assess depression aspects, and a video analysis module that records participants’ facial and verbal responses. Speech-to-text conversion and attention mechanisms analyze verbal responses, while facial expressions are examined for depressive symptoms. Machine learning techniques such as neural networks, decision trees, and regression analyze data from both segments to identify depression symptoms. Validation against established diagnostic standards and a focus on consent and data confidentiality underscore the system’s promise for early intervention and support.},
  keywords={Data privacy;Attention mechanisms;Neural networks;Depression;Standards;Regression tree analysis;Speech to text;Facial analysis;Speech-to-text conversion;Attention mechanism;LSTM;Bi-LSTM},
  doi={10.1109/ICCCNT61001.2024.10724596},
  ISSN={2473-7674},
  month={June},}@INPROCEEDINGS{10206145,
  author={Soudi, Rowan Basssel and Zaghloul, Mohamed Saad and Badawy, Osama Mohamed},
  booktitle={2022 32nd International Conference on Computer Theory and Applications (ICCTA)}, 
  title={Framework for suicide detection from Arabic tweets using deep learning}, 
  year={2022},
  volume={},
  number={},
  pages={96-103},
  abstract={Major depressive disorder (MDD), is considered as a severe and widespread disease that causes suicide in many cases. This affects the thoughts, conduct, and quality of life of many people around the world. When treatment is not sought, suicide is regarded as the second most common cause of death. Due to people communicating their feelings and ideas on social media (Twitter) regarding a variety of topics in these tweets suicide can be predicted in advance. This study is one of many that advise tracking depression and other mental diseases using social media Arabic data. Arabic is a widely spoken language with difficult grammar; hence depression detection methods have not been widely used. Most of all previous studies were found in English for English language tweets. To deal with Arabic language tweets for the proposed research, tweets are collected in Arabic and then annotated by analytical experts in psychoanalysis. Moreover, different deep learning algorithms were used for training on this dataset. These were used to predict suicide cases in advance. The obtained result has an accuracy greater than 90%.},
  keywords={Deep learning;Training;Sentiment analysis;Social networking (online);Blogs;Depression;Prediction algorithms;Deep Learning (DL);Natural language processing NLP;Machine Learning (ML);Suicide;Twitter;Artificial intelligent (AI);Sentiment analysis (SA);Major depressive disorder (MDD)},
  doi={10.1109/ICCTA58027.2022.10206145},
  ISSN={2770-6575},
  month={Dec},}@INPROCEEDINGS{10153015,
  author={Rachidi, Rabia and Ouassil, Mohamed Amine and Errami, Mouaad and Cherradi, Bouchaib and Hamida, Soufiane and Silkan, Hassan},
  booktitle={2023 3rd International Conference on Innovative Research in Applied Science, Engineering and Technology (IRASET)}, 
  title={Social Media's Toxic Comments Detection Using Artificial Intelligence Techniques}, 
  year={2023},
  volume={},
  number={},
  pages={1-6},
  abstract={Cyberbullying takes its place in social media and has increased throughout the past few years. The damage that cyberbullying has on the users is undeniable they get attacked either on their appearances, ethnicities, religions, and even their thoughts and personal opinion. The attack causes these users anxiety, depression, low self-esteem, and in the worst scenarios suicide. These harmful actions toward the users drive researchers to identify and detect cyberbullying to fight it. Unfortunately, most of the previous approaches were on English texts, hardly any on other languages. This paper presents a cyberbullying detection system in the Moroccan dialect on an Instagram-collected dataset. The experiment results gave accuracies of around 77% to 91% from both the ML and DL algorithms. The LSTM model gave the best outcome by 91.24% outperforming the ML models.},
  keywords={Anxiety disorders;Cyberbullying;Depression;Artificial intelligence;toxicity;social media;deep learning;machine learning;cyberbullying;Instagram;Moroccan dialect;natural language processing},
  doi={10.1109/IRASET57153.2023.10153015},
  ISSN={},
  month={May},}@INPROCEEDINGS{9936811,
  author={Zulkarnain, Nur Zareen and Abd Yusof, Noor Fazilla and Ahmad, Sharifah Sakinah Syed and Othman, Zuraini and Hashim, Azura Hanim},
  booktitle={2022 IEEE International Conference on Artificial Intelligence in Engineering and Technology (IICAIET)}, 
  title={Performance of Content-Based Features to Detect Depression Tendencies in Different Text Lengths}, 
  year={2022},
  volume={},
  number={},
  pages={1-5},
  abstract={Text analytics have been widely used nowadays in the field of mental health to predict onset mental health issues such as depression and anxiety, with the intention to perform early intervention. Most existing works focuses on looking at how such mental health issues can be predicted based on social media data. These texts are often short and straightforward as compared to blogs and journals. In this paper, we are interested in comparing the performance of a classification model in classifying long texts and short texts as having depression tendencies. An existing model that can perform well in classifying short texts using content-based features was adopted and tested on longer texts. From the result, it is found that compared to shorter text, content-based features performed worst in long texts whereby all five classifiers used produced an accuracy of less than 0.65.},
  keywords={Social networking (online);Blogs;Anxiety disorders;Mental health;Writing;Depression;Feature extraction;depression tendencies;depression detection;text length;feature extraction;classification},
  doi={10.1109/IICAIET55139.2022.9936811},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10840779,
  author={Nanditha, S. and Joy, Helen K. and Kounte, Manjunnth R. and Sridevi, R. and Alice Jayarani, A. Electa and Vanusha, D.},
  booktitle={2024 4th International Conference on Technological Advancements in Computational Sciences (ICTACS)}, 
  title={Assessing Social Media's Impact on Mental Health: A Gaussian Naive Bayes Approach}, 
  year={2024},
  volume={},
  number={},
  pages={791-797},
  abstract={In recent times, social media has gained immense popularity. However, there is a growing concern among individuals regarding its impact on mental well-being. Extensive research has been conducted to unravel the intricate connection between the use of social media and mental health. This study thoroughly examines the existing literature by incorporating various studies that cover topics such as machine learning for analysing depression-related sentiments and the effects of social media on specific demographic groups. The aim is to develop a comprehensive understanding of the relationships between these factors. In order to gain a deeper understanding of mental health indicators, a dataset consisting of 481 records was analysed using various techniques including pre-processing, correlation analysis, data visualisation, and Gaussian Naive Bayes predictive modelling. Based on our findings, it appears that individuals who engage with social media may experience negative impacts on their mental well-being. During our investigation, we conducted tests on different machine learning models and discovered that Gaussian Naive Bayes yielded the highest level of accuracy. The presence of multicollinearity among independent variables emphasises the importance of being cautious when interpreting research findings. This study makes a valuable contribution to our understanding of the complexities involved in using social media platforms while managing mental health issues. By focusing on the intersection of technology and psychiatric illnesses, it lays the groundwork for future research and interventions in this important area.},
  keywords={Analytical models;Correlation;Accuracy;Social networking (online);Data visualization;Mental health;Machine learning;Predictive models;Data models;Bayes methods;Social Media;Mental Health;Machine Learning;Depression;Gaussian Naive Bayes},
  doi={10.1109/ICTACS62700.2024.10840779},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{10550961,
  author={Chereddy, Spandana and Geetha, K and Sreedevi, A G},
  booktitle={2024 2nd International Conference on Advancement in Computation & Computer Technologies (InCACCT)}, 
  title={Tweeting the Blues: Leveraging NLP and Classification Models for Depression Detection}, 
  year={2024},
  volume={},
  number={},
  pages={875-880},
  abstract={Depression is a global mental health problem while Twitter is a valuable medium on which content indicating emotional affect is generated. Our research draws upon NLP to analyze tweets by the application of Naive Bayes, Support Vector Machines, and Logistic Regression classifiers. The first objective will be the tweets’ classification into positive and negative sentiment categories with a secondary goal to explore the possibility of the detection of community characteristics including gender, age, and location. We investigate the tweet content by using NLP in an attempt to pinpoint the sensing patterns and the department that can reliably be used to detect depression. Results of the experiments proved comprehensive model accuracy with Support Vector Machines taking a better position on the matter of correctly classifying depression tweets. Especially, Support Vector Machines gave an accuracy of 85%, and values for precision, recall, and f1 were 0.89, 0.63, and 0.63, respectively. Therefore, the remaining ones for attaining higher accuracy and recall are difficult to achieve in models that are depressed but there is still the necessity for more data generation. This research thus clears the way for NLP in the diagnosis of mental health by providing vital assessment data that can be used by psychologists, researchers, health authorities, and policymakers to develop targeted intervention strategies and advancement of public health goals.},
  keywords={Support vector machines;Analytical models;Logistic regression;Social networking (online);Computational modeling;Mental health;Depression;Depression Analysis;Natural Language Processing (NLP);Classification Models;Sentiment Analysis;Machine Learning},
  doi={10.1109/InCACCT61598.2024.10550961},
  ISSN={},
  month={May},}@INPROCEEDINGS{10730329,
  author={Raj, Anuraag and Ali, Zain and Chaudhary, Shonal and Bali, Kavitesh Kumar and Sharma, Anuraganand},
  booktitle={2024 IEEE International Conference on Artificial Intelligence in Engineering and Technology (IICAIET)}, 
  title={Depression Detection Using BERT on Social Media Platforms}, 
  year={2024},
  volume={},
  number={},
  pages={228-233},
  abstract={Depression detection from social media has attracted significant attention for its potential to offer early intervention and support to individuals facing mental health issues. In this study, we present a comprehensive evaluation of deep learning techniques for depression detection, with a specific focus on leveraging BERT, a powerful Natural Language Processing (NLP) Transformer model. Our exploration encompasses tailored preprocessing techniques for social media text, diverse feature extraction methods, and optimized model architectures tailored for depression detection tasks using BERT. Through rigorous experimentation and evaluation, we compare the performance of different BERT-based strategies, considering metrics such as accuracy, efficiency, and scalability. Additionally, we conduct a comparative analysis of labeled and unlabeled data from the same dataset. For labeled data, we employ BERT directly, while for unlabeled data, an autoencoder is utilized following label removal. The findings indicate that BERT outperformed other methods, achieving a high F1-score of 93% on the Reddit dataset. BERT achieved an impressive test accuracy of 91.92%, surpassing the Autoencoder model, which attained 84.84%.},
  keywords={Accuracy;Social networking (online);Soft sensors;Scalability;Mental health;Depression;Feature extraction;Transformers;Natural language processing;Data models;Depression detection;BERT;social media;NLP Transformer;mental health},
  doi={10.1109/IICAIET62352.2024.10730329},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{10464806,
  author={Sharmeen, Rukaiya and Khan, Saima and Sanjana, Tasnia and Sultana, Zinnia},
  booktitle={2023 5th International Conference on Sustainable Technologies for Industry 5.0 (STI)}, 
  title={Suicidal Ideation Detection Using Semi-Supervised Learning Technique: Self-Training Classifier}, 
  year={2023},
  volume={},
  number={},
  pages={1-6},
  abstract={Suicide is now a major cause of death on a global scale. Reportedly, globally almost 800,000 people commit suicide every year. Currently, different types of methods are being used for suicidal ideation detection. As people share their daily activities on social media, they share their depression, stress, anxiety, success, happiness, and all. So, by utilizing these social sites it is possible to detect suicidal texts. Therefore, ideation of suicidal thoughts may significantly reduce unwanted deaths. This paper proposes a semi-supervised learning technique which is a self-training classifier to detect suicidal thoughts. Which utilizes both labeled and unlabeled data to enhance the performance of machine learning models. In this paper, we adapted eight different supervised learning algorithms to work in a semi-supervised manner using a self-training classifier to see which one is best suited for detection. Among all the algorithms Logistic Regression (LR), SVM, and SGD showed the best accuracy and KNN showed the lowest. The early detection of suicidal intention is highly significant to reduce the deaths and our paper proposes the best method of detection.},
  keywords={Support vector machines;Machine learning algorithms;Social networking (online);Anxiety disorders;Supervised learning;Machine learning;Semisupervised learning;Suicide;Suicidal ideation;Semi-supervised learning;Self-training technique;Text classification},
  doi={10.1109/STI59863.2023.10464806},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{10146658,
  author={Gupta, Aakash and Pirzada, Umme Salma M.},
  booktitle={2023 5th Biennial International Conference on Nascent Technologies in Engineering (ICNTE)}, 
  title={LSTM Network for Suicide Detection}, 
  year={2023},
  volume={},
  number={},
  pages={1-5},
  abstract={Depression is a typical and severe mental health condition that can have an adverse effect on a person’s emotions, thoughts, and behaviours. Suicide can result from depression. It could lead to a number of physical and emotional problems as well as a decline in your capacity for both work and home life. More than 264 million people of every age and demographic around the world are affected by depression. Social media post analysis will help in identifying depression because the younger generation is more dependent on it. A system to identify depression has been proposed in this research paper combining Global vectors for word representation (GLOVE) embedding and Long-short term memory (LSTM) network. The proposed method obtained 93% accuracy only in 30 epochs.},
  keywords={Social networking (online);Annotations;Natural languages;Mental health;Depression;Natural Language Processing;LSTM;Depression Detection;Text Processing;Deep Learning},
  doi={10.1109/ICNTE56631.2023.10146658},
  ISSN={},
  month={Jan},}@INPROCEEDINGS{9744689,
  author={Matomela, Vuyokazi and Henney, Andre J},
  booktitle={2022 Conference on Information Communications Technology and Society (ICTAS)}, 
  title={Cyberbullying detection system focusing on the isiXhosa language}, 
  year={2022},
  volume={},
  number={},
  pages={1-6},
  abstract={Due to the Covid19 pandemic, and the restrictions placed in social interactions, there has been an upsurge in the use of social networks, such as Facebook, WhatsApp, Instagram, Telegram, Twitter, and others. As more people turn to the social networks for social interaction, there has been increased occurrences of cyberbullying. Cyberbullying is a type of bullying that occurs through online technology, whereby harmful texts and pictures are shared through social networks. This research project aimed to develop a system that can detect cyberbullying on social networks such as Twitter focusing on the IsiXhosa language. Machine learning algorithms were applied to Twitter feeds in order to detect cyberbullying. The project will help law enforcement to apprehend and prosecute cyberbullies that make threats using isiXhosa. The methodology used incorporated machine learning algorithms to fully implement the cyberbullying detection system. It starts with collecting the data from Twitter using Python, cleaning the data followed by testing the data. The results show that the implementation successfully collected the desired data from Twitter and the data was then pre-processed and prepared to be tested using the different algorithms mentioned in the paper.},
  keywords={Freeware;Machine learning algorithms;Law enforcement;Pandemics;Blogs;Multimedia Web sites;Cyberbullying;Cyberbullying;Covid-19;machine learning;social networks;Twitter;SADAG},
  doi={10.1109/ICTAS53252.2022.9744689},
  ISSN={},
  month={March},}@INPROCEEDINGS{11360871,
  author={Lahuddin, Harlinda and Tawetubun, Siti Safira and Darwis, Herdianti and Ilmawan, Lutfi Budi and Tenripada, Andi Ulfah and Atmajaya, Dedy},
  booktitle={2026 20th International Conference on Ubiquitous Information Management and Communication (IMCOM)}, 
  title={Comparative Analysis of Depression Comment Classification Using Traditional Machine Learning and Transformer-Based Models with Easy Data Augmentation}, 
  year={2026},
  volume={},
  number={},
  pages={1-7},
  abstract={Depressive disorders are a pressing global mental health issue, affecting over 280 million people and requiring early intervention. In the digital age, social media text analysis has become a valuable tool for early symptom detection due to increasing online expressions of depression. However, analyzing social media text is challenging due to inherent characteristics such as informal language, slang, and extensive Indonesian and English code-mixing. This study performs accurate binary classification of social media comments (Depression vs. Normal) on a large-scale multilingual dataset featuring Indonesian and English code-mixing. We rigorously compare four models Multinomial Naïve Bayes (MNB) and Support Vector Machine (SVM) as classic baselines, and IndoBERT and XLM-RoBERTa as contemporary Transformer models. Crucially, all models were tested in two scenarios No-EDA and With-EDA (Easy Data Augmentation). The results show that the XLM-RoBERTa model without augmentation achieved superior performance with an F1-Score of 97.6% and an accuracy of 97.4%. This highlights XLM-RoBERTa's strength in handling cross-lingual complexity. Conversely, simple lexical augmentation (EDA) proved ineffective and caused performance decline in monolingual Transformer models (IndoBERT), indicating limitations in simple lexical augmentation for complex languages. Overall, this research provides strong recommendations for developing an optimal AI-based early depression detection system adaptive to the multilingual (Indonesian-English) context and linguistic diversity of Indonesia.},
  keywords={Support vector machines;Adaptation models;Accuracy;Text analysis;Social networking (online);Depression;Transformers;Data augmentation;Data models;Multilingual;depression detection;social media;IndoBERT;XLM-RoBERTa;easy data augmentation},
  doi={10.1109/IMCOM69009.2026.11360871},
  ISSN={},
  month={Jan},}@INPROCEEDINGS{10616468,
  author={Bhavya, R and Ramani, Roja and Royal, G.Leela Gowtham and Manideep, G. and Sridhar, Gautham},
  booktitle={2024 International Conference on Knowledge Engineering and Communication Systems (ICKECS)}, 
  title={Exploring Depression Through Social Media: A Textual Analysis}, 
  year={2024},
  volume={1},
  number={},
  pages={1-7},
  abstract={Depression, a widespread mental health affliction, profoundly impacts individuals and societies globally. Timely intervention demands early detection, and the burgeoning realm of user-generated social media text presents a valuable avenue for understanding mental health. This thesis aims to harness machine learning techniques to establish a dependable system for identifying depression within social media text. Gathering a diverse corpus of posts from individuals with and without depression, the developed system demonstrates consistent and accurate performance across various evaluation metrics. The thesis culminates in an in-depth exploration of depression diagnosis using machine learning and natural language processing algorithms applied to social media data. Specifically, the study scrutinizes sentiment analysis and artificial intelligence methodologies for predicting emotional distress from a dataset of 20,000 English tweets obtained via the Twitter API. The analysis employs the text blob library alongside classification techniques encompassing Random Forest, KNN, Decision Tree, and Naïve Bayes model.},
  keywords={Ethics;Sentiment analysis;Accuracy;Social networking (online);Blogs;Mental health;Depression},
  doi={10.1109/ICKECS61492.2024.10616468},
  ISSN={},
  month={April},}@INPROCEEDINGS{11071227,
  author={K.Remya and P.Ranjana},
  booktitle={2025 4th OPJU International Technology Conference (OTCON) on Smart Computing for Innovation and Advancement in Industry 5.0}, 
  title={DepressonSense: Advancng Mental Health Dagnostcs through Sentment-Drven Meta-Learnng}, 
  year={2025},
  volume={},
  number={},
  pages={1-8},
  abstract={In this study, current research introduces "DepressionSense," a cutting-edge meta-learning-based framework designed to enhance depression detection through sentiment Classifications. DepressionSense leveraged the strength of model stacking, a technique that combined with multiple machine Learning-Driven models to improve prediction accuracy. At the core of the framework lies the use of Supportive Vector Machines (SVM), a powerful algorithm known for its effectiveness in high-dimensional spaces, like text data derived from social media-based posts, personal diaries-based texts, or clinical interviews. The innovative aspect of DepressionSense is its capability to integrate diverse models through a meta-learner approach, where the primary layer contains various base learners, by including but not limited to decision-based trees, neural networks, and gradient-type boosting machines, which preprocessed the data and predict depressive sentiments. These predictions are then feds into a second layer, which uses an SVM model to consider all the base predictions and calculates a more accurate and refined output. This stacked arrangement is particularly adept at handling the variations of language used by individuals experiencing depression, thus offering a significant improvement over the traditional single-model approach. DepressionSense not only promises to be a valuable tool for the early detection and intervention of depression but also showcases the potential of meta-learning frameworks in mental health diagnostics, making it a step forward in the application of artificial intelligence for societal well-being.},
  keywords={Support vector machines;Metalearning;Technological innovation;Sentiment analysis;Accuracy;Stacking;Mental health;Predictive models;Depression;Vectors;Depression detection event;sentiment classification based;meta-learning driven;model stacking;mental health diagnostics;artificial intelligence-based;early intervention},
  doi={10.1109/OTCON65728.2025.11071227},
  ISSN={},
  month={April},}@INPROCEEDINGS{10989873,
  author={Alhashmi, Saadat M. and Hashim, Saleema and Khedr, Ahmed Mohamed},
  booktitle={2025 IEEE 22nd International Multi-Conference on Systems, Signals & Devices (SSD)}, 
  title={Depression Detection Using a Hybrid CNN-BiGRU-BiLSTM Model With BERT Embedding and Data Augmentation}, 
  year={2025},
  volume={},
  number={},
  pages={340-347},
  abstract={Depression is a mood disorder that causes a persistent feeling of sadness and loss of interest. Also called major depressive disorder or clinical depression, it affects how you feel, think, and behave and can lead to a variety of emotional and physical problems. Automatic detection, as in a clinical interview can be derived from various modalities which includes video, audio, and text. Among them, detection from text data has emerged as a crucial task in mental health monitoring. In this study, we propose a hybrid deep learning model combining Convolutional Neural Networks (CNN), Bidirectional Gated Recurrent Units (BiGRU), and Bidirectional Long Short-Term Memory (BiLSTM) layers to enhance depression detection accuracy. Using BERT embedding for robust feature extraction, the proposed model processes social media or clinical text data to identify signs of depression. Additionally, we incorporate a novel data augmentation technique using synonym replacement to address data imbalance and improve generalization. Evaluations are conducted using key performance metrics, including accuracy, precision, recall, and F1 score. With an accuracy of 86.2 %, the results demonstrate that the combined CNN-BiGRU-BiLSTM architecture, alongside BERT embedding and augmented data, significantly improves classification performance compared to traditional models. This approach shows promise in contributing to more effective automatic depression detection systems.},
  keywords={Deep learning;Accuracy;Social networking (online);Bidirectional long short term memory;Bidirectional control;Depression;Data augmentation;Encoding;Data models;Convolutional neural networks;BERT;deep learning;depression detection;CNN;BiGRU;BiLSTM;DAIC-WOZ Dataset},
  doi={10.1109/SSD64182.2025.10989873},
  ISSN={2474-0446},
  month={Feb},}@ARTICLE{10041797,
  author={Zogan, Hamad and Razzak, Imran and Jameel, Shoaib and Xu, Guandong},
  journal={IEEE Journal of Biomedical and Health Informatics}, 
  title={Hierarchical Convolutional Attention Network for Depression Detection on Social Media and Its Impact During Pandemic}, 
