  number={},
  pages={1-6},
  abstract={Depression is a critical global health challenge, demanding scalable early detection systems aligned with Industry 5.0 principles of human centric and sustainable technology. This study presents a hybrid deep learning architecture that integrates Multi-Head Attention mechanisms with RoBERTa and DistilBERT to classify depression severity into three levels: mild, moderate, and severe. The system processes a curated English language Twitter dataset of 32,542 tweets (Shen et al.), partitioned into 22,779 training, 4,881 validation, and 4,882 test samples. By combining RoBERTa’s contextual comprehension with DistilBERT’s computational efficiency, the framework captures both semantic depth and emotional nuances in user generated text. Severity labeling leverages sentiment scores from the DT12the/distilbert sentiment analysis model, and WordNet based data augmentation enhances linguistic diversity. Optimized with early stopping and learning rate scheduling, the architecture achieves 96.50% training accuracy, 93.96% validation accuracy, and 94.06% test accuracy. These results demonstrate the system’s practical relevance for sustainable real world mental health surveillance, supporting early intervention while minimizing computational footprint, which are key objectives of Industry 5.0’s human centric technological paradigm.},
  keywords={Training;Accuracy;Social networking (online);Computational modeling;Diversity reception;Computer architecture;Depression;Data augmentation;Data models;Fifth Industrial Revolution;Hybrid architecture;Multi-Head Attention;DistilBERT;RoBERTa;Data augmentation},
  doi={10.1109/STI69347.2025.11367576},
  ISSN={2996-170X},
  month={Dec},}@ARTICLE{10036477,
  author={Kumar, Gunjan and Singh, Jyoti Prakash and Singh, Amit Kumar},
  journal={IEEE Transactions on Computational Social Systems}, 
  title={Autoencoder-Based Feature Extraction for Identifying Hate Speech Spreaders in Social Media}, 
  year={2024},
  volume={11},
  number={4},
  pages={4819-4827},
  abstract={Hate speech on social media has become a big problem, making regular users very upset and giving victims depression and suicidal thoughts. Early identification of the user spreading this type of hate speech may be a better solution, allowing hate speech to be stopped at source. In this article, we attempt to identify these hate speech spreaders by finding a representation for each user. Each user’s comments are aggregated and fed to an auto-encoder to train it. The encoder part of the auto-encoder is used to get an encoded vector for each user. The encoded vector is used with different machine learning (ML) classifiers to determine if a user is spreading hate speech. The proposed model was tested using the dataset released by PAN 2021 (https://pan.webis.de/data.html) hate speech spreader profiling competition in English and Spanish. The experimental results show that support vector machine (SVM) with encoded vectors as features outperforms existing models with an accuracy of 92% for both English and Spanish dataset. The proposed features extraction technique is found to be equally effective at identifying fake news spreaders on fake news datasets provided by PAN 2020 yielding accuracy values of 95% and 83% for English and Spanish, respectively.},
  keywords={Hate speech;Social networking (online);Feature extraction;Task analysis;Support vector machines;Data models;Training;Autoencoder;hate speech;hate speech spreader;long short-term memory (LSTM)},
  doi={10.1109/TCSS.2023.3240098},
  ISSN={2329-924X},
  month={Aug},}@INPROCEEDINGS{10874034,
  author={Jose, Joysh Jayaron},
  booktitle={2024 IEEE International Conference on Future Machine Learning and Data Science (FMLDS)}, 
  title={Leveraging Sentiment Analysis and Emotion Detection for Mental Health Insights}, 
  year={2024},
  volume={},
  number={},
  pages={493-498},
  abstract={This paper aims to establish a comprehensive analysis of mental health patient reviews using various NLP models, to derive insights and propose improvements that will lead to the enhancement of various mental health facilities. These NLP techniques were further used to categorize key themes such as doctor behaviour, communication and cost. A thorough correlation analysis was also conducted, understanding the relationship between various themes and how their frequency affects the overall patient satisfaction. The findings indicate that attentive listening, respectful staff behavior, and affordable services are critical to improving patient satisfaction. While speaking of mental health is still a taboo in various places, it is important to understand the frequency of the rising mental health related cases such as depression, anxiety, stress and social stigma associated with it. It is indeed much more important to provide better resources and lend understanding hand to the unaddressed mental health problems that are prevalent in various countries and places.},
  keywords={Hands;Sentiment analysis;Emotion recognition;Technological innovation;Correlation;Reviews;Mental health;Medical services;Machine learning;Market research;Machine Learning;Mental health;Reviews;Analysis;Sentiment},
  doi={10.1109/FMLDS63805.2024.00091},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{9899067,
  author={Xu, Yuanjie and Deng, Kesui and Yao, Qiqi},
  booktitle={CIBDA 2022; 3rd International Conference on Computer Information and Big Data Applications}, 
  title={Application of Big Data in Depression Screening and Early Warning}, 
  year={2022},
  volume={},
  number={},
  pages={1-5},
  abstract={With the development of science and technology, big data technology has become a powerful research tool in psychology. Depression is a kind of common but serious mental illness. The early detection of depression is of great importance for the maintenance of individual mental health. However, the traditional scale screening method has limitations, lag, passivity, and other disadvantages. The addition of big data makes it possible to innovate the screening method of depression. By studying the relevant factors of depression through big data and using artificial intelligence to build a depression screening model, we can improve the screening efficiency, find key groups as soon as possible, provide psychological assistance, establish a complete and mature rescue system, and effectively prevent potential risks.},
  keywords={},
  doi={},
  ISSN={},
  month={March},}@ARTICLE{11223210,
  author={Zhou, Bowen and Fiedler, Marc-André and Al-Hamadi, Ayoub},
  journal={IEEE Access}, 
  title={STCM-Mamba: Multimodal Spatio-Temporal Cross-Modal Mamba for Depression Detection}, 
  year={2025},
  volume={13},
  number={},
  pages={189494-189505},
  abstract={Depression is a prevalent mental disorder with severe physiological symptoms and high diagnosis costs, however, the development of efficient and accurate depression detection systems remains challenging. While deep learning methods leveraging multimodal data have shown promise, existing approaches suffer from two critical limitations. One is the lack of effective spatiotemporal feature integration, and the other is the inability to balance effective long-sequence modeling and computational complexity. To address these challenges, we propose STCM-Mamba, a novel Spatio-Temporal Cross-Modal Mamba (STCM-Mamba) framework for efficient and accurate depression detection. The STCM-Mamba comprises three modules: a Spatio-Temporal Mamba Module (STMM), a Cross-Modal Mamba Module (CMMM), and a Depression Classification Module (DCM). The STMM consists of a Temporal Mamba Block (TMB) and a Spatial Mamba Block (SMB) for capturing spatiotemporal information for each modality, while the CMMM enhances intermodal and intramodal representation learning. Experiments on two multimodal depression datasets demonstrate that STMM and CMMM significantly contribute to performance improvements, and the STCM-Mamba outperforms state-of-the-art methods.},
  keywords={Depression;Feature extraction;Visualization;Spatiotemporal phenomena;Computer architecture;Deep learning;Convolutional neural networks;Computational modeling;Adaptation models;Acoustics;Depression detection;Mamba;multimodal;spatio-temporal modeling},
  doi={10.1109/ACCESS.2025.3627778},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{11258917,
  author={M, Abdul Majeed K and M, Sharmila Kumari},
  booktitle={2025 IEEE International Conference on Distributed Computing, VLSI, Electrical Circuits and Robotics (DISCOVER)}, 
  title={Early Detection of Bipolar Disorder Using Generative Artificial Intelligence: a Systematic Review Aligned with UN SDG 3}, 
  year={2025},
  volume={},
  number={},
  pages={410-414},
  abstract={Bipolar disorder (BD) affects approximately 2.4% of the global population, contributing to significant disability, a 20-30 times higher suicide risk, and a life expectancy reduction of 9-17 years due to diagnostic delays averaging 6.7 years. These delays exacerbate health inequities, particularly in low-resource and marginalized communities, undermining the United Nations Sustainable Development Goal (SDG) 3: Good Health and Well-Being, which prioritizes equitable access to mental health care and a one-third reduction in premature mortality from non-communicable diseases. Generative artificial intelligence (GAI), encompassing large language models (LLMs) like ChatGPT, generative adversarial networks (GANs), and variational auto encoders (VAEs), offers transformative potential for early BD detection by analyzing linguistic, behavioral, and physiological data. This systematic review synthesizes evidence from Q1 journals (2018-2025) to evaluate GAI's role in advancing SDG 3, achieving diagnostic accuracies of 70-94%. By enabling timely interventions and reducing health disparities, GAI supports SDG 3's equity and accessibility goals, but challenges such as dataset biases, ethical concerns, and limited real-world validation must be addressed to ensure scalability and inclusivity.},
  keywords={Ethics;Accuracy;Generative AI;Mortality;Mental health;Transforms;Linguistics;Very large scale integration;Delays;Systematic literature review;Generative AI;Bipolar disorder;LLM;GAI;VAE},
  doi={10.1109/DISCOVER66922.2025.11258917},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{11364002,
  author={Sohail, Aliza and Bazai, Sibghat Ullah and Shahid, Zoha and Batool, Isma and Gafoor, Muhammad Imran and Bhatti, Uzair Aslam},
  booktitle={2025 Horizons of Information Technology and Engineering (HITE)}, 
  title={Detecting Mental Health Signals in Tweets: A Machine Learning and NLP Approach}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Anxiety and depression are major global health challenges. Users’ tweets often reveal authentic emotional states, suggesting potential for early detection of mental distress. This study analyzes a public dataset of 20,000 labeled tweets (depression, anxiety, neutral) using four models— Logistic Regression, Random Forest, ANN, and CNN. CNN achieved the highest accuracy (89.2%, F1 = 88.5%), while Logistic Regression was fastest and most memory efficient. These results show that lightweight models can support mobile screening applications, while deeper architectures are suited for centralized monitoring systems. Identify mental health indicators from social media with high accuracy and real-time integration into social-media–based mental-health monitoring tools.},
  keywords={Logistic regression;Accuracy;Social networking (online);Anxiety disorders;Mental health;Depression;Real-time systems;Multilingual;Monitoring;Random forests;Mental health;tweets;Machine learning;NLP;Deep learning;CNN;Lightweight models},
  doi={10.1109/HITE68444.2025.11364002},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{9820478,
  author={Deng, Tongkun and Shu, Xin and Shu, Jian},
  booktitle={2022 5th International Conference on Artificial Intelligence and Big Data (ICAIBD)}, 
  title={A Depression Tendency Detection Model Fusing Weibo Content and User Behavior}, 
  year={2022},
  volume={},
  number={},
  pages={304-309},
  abstract={Numerous studies on depression have found that tweets from severely depressed users can be used to detect depression. This paper proposes a fusion of text, image, and user behavior model (TPBFM) for depressive tendency detection. To construct user text sequences and user image sequences, TPBFM uses build sequence (BS) and build picture (BP) algorithms to process text and images. TPBFM uses XLNet and ResNet18 networks to extract text and image features. In addition, this paper summarizes and extracts 11 behavioral characteristics from users’ descriptions and posting behaviors, respectively from their Weibo content, social behaviors, and visual characteristics. Finally, the text image and behavior features are aggregated and fed into the recognition layer to achieve the effect of triple model fusion, and then identify the user’s depression tendency. Experimental results show that the TPBFM model can identify depressive tendencies of social network users pretty well. It is superior to single-feature and double-feature detection in terms of precision, recall, and F1, and it has good performance compared with the best methods studied so far under the comparison of equivalent data sets.},
  keywords={Visualization;Image recognition;Social networking (online);Text recognition;Blogs;Neural networks;Feature extraction;depression tendency detection;weibo;user behavior;deep neural network},
  doi={10.1109/ICAIBD55127.2022.9820478},
  ISSN={},
  month={May},}@INPROCEEDINGS{11318218,
  author={Rawat, Shreya and Rawat, Poonam and Memoria, Minakshi},
  booktitle={2025 International Conference on Computational Intelligence and Knowledge Economy (ICCIKE)}, 
  title={Natural Language Processing Model 'Qc-Mindnet' for Queer Sentiment Analysis as an Early Warning System for Suicide Risk}, 
  year={2025},
  volume={},
  number={},
  pages={38-41},
  abstract={Natural Language processing (NLP), a subfield of Artificial Intelligence grants powerful mechanisms to assess linguistic patterns pertaining to psychological distress facilitating predictive identification of self-harm or suicide. However, most NLP models owing to the prejudicial nature of training datasets have been found to be gender biased against non-binary individuals. This limitation defeats the very purpose of implementing the technology and further degrades the position of gender minorities. This study proposes a conceptual model 'Queer Community- Mental Insight and Neurostate Detection Network' (QC-MINDNet) that is particularly customized, fine-tuned on a large curated dataset from Transgender and gender non-conforming (TGNC) individuals, thus tailored to address their unique concerns. TGNC individuals as a part of gender minority face internalized and externalized troubles, that disrupts their mental health, making them much more vulnerable to depression or trauma disorders in contrast to their cisgender counterparts. To seek better support, they often resort to digital communication platforms for sharing their intrusive thoughts and emotions. QC-MINDNet deploys sentiment analysis through NLP that can assist in detecting early symptoms of depression or suicide ideation among TGNC individuals by examining their social media posts or performing real time monitoring of content shares so that in case of massive risk, family or friends can be alerted to ensure prompt intervention. The study expounds working pipeline and built of the proposed model. While the present paper highlights the theoretical premise of the framework, the empirical implementation and data driven assessment are planned for the future research phase.},
  keywords={Sentiment analysis;Ethics;Privacy;Social networking (online);Biological system modeling;Mental health;Transgender issues;Depression;Real-time systems;Artificial intelligence;Queer;Transgenders;Mental Health;Suicide;NLP;Sentiment Analysis;Social media},
  doi={10.1109/ICCIKE67021.2025.11318218},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{10093486,
  author={Pokuri, Bharath Kumar Chowdary and Annamneedi, Satya Sree and Kamani, Anudeep Chowdary and Thalluri, Sai Tharun and Kurra, Sarayu},
  booktitle={2022 International Conference on Recent Trends in Microelectronics, Automation, Computing and Communications Systems (ICMACC)}, 
  title={Mental Illness Detection with Facial Movements using Neural Networks}, 
  year={2022},
  volume={},
  number={},
  pages={82-87},
  abstract={Neuroscience studies mental health and illness extensively, from both clinical and non-clinical viewpoints. Psychiatric diseases, such as anxiety, depression, and stress spectrum disorders, are associated with atypical facial expressions. Emotional expressions and the detection of mental illness can be significant in diagnosing and treating mental health issues. An early diagnosis of an illness can be made using OpenCV facial recognition and CNN feature extraction and classification. With the help of early diagnosis, there would be a lot of benefits. Deep learning algorithms in neural networks like CNN, and RNN plays a huge role in such people's life by diagnosing their illness.},
  keywords={Analytical models;Recurrent neural networks;Computational modeling;Anxiety disorders;Surgery;Mental health;Predictive models;Mental illness;CNN;Open CV;Deep Learning;Neural Networks},
  doi={10.1109/ICMACC54824.2022.10093486},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{11182655,
  author={Zhu, Ya and Huang, Siqing},
  booktitle={2025 5th International Conference on Artificial Intelligence, Big Data and Algorithms (CAIBDA)}, 
  title={Social Text Mental Disorder Identification Framework Integrating Generative Language Model and Psychological Feature Extraction}, 
  year={2025},
  volume={},
  number={},
  pages={1092-1097},
  abstract={With the rapid development of social media as a primary channel for users to express their psychological states, accurately identifying mental disorders from complex social text has become a critical and urgent challenge in both artificial intelligence and mental health domains. However, existing approaches often suffer from insufficient capture of implicit psychological cues, inadequate semantic understanding, and the lack of integration with psychological features, which limits both recognition performance and interpretability. To address these challenges, this paper proposes a novel framework that integrates generative large language models with multidimensional psychological feature extraction for mental disorder identification in social media texts. The proposed framework employs LLaMA 2 to generate deep contextual semantic embeddings and incorporates psychological features extracted from established dictionaries and standardized mental health scales. Through multimodal feature fusion and joint training mechanisms, the framework comprehensively captures latent psychological signals embedded in user-generated content. Extensive experiments conducted on a multi-source dataset containing over 21,000 annotated texts categorized into depression, anxiety, and normal classes demonstrate that our framework significantly outperforms traditional machine learning models, deep learning approaches, and standalone psychological feature-based models in terms of Accuracy, F1-score, and AUC. The key innovation of this work lies in the effective integration of psychologically grounded feature modeling with deep generative language representations, enhancing both the accuracy and interpretability of mental disorder identification. This research offers a promising pathway for building intelligent and explainable mental health monitoring systems, contributing to more effective and timely mental health interventions in real-world scenarios.},
  keywords={Training;Technological innovation;Accuracy;Social networking (online);Large language models;Semantics;User-generated content;Text categorization;Mental health;Feature extraction;Generative large language model;psychological feature extraction;mental disorder identification;social media text;multimodal feature fusion;joint training mechanism},
  doi={10.1109/CAIBDA65784.2025.11182655},
  ISSN={},
  month={June},}@INPROCEEDINGS{11403514,
  author={Chawla, Deven and Chawla, Dipen and Shrivastava, Anurag and Habelalmateen, Mohammed I. and Dixit, Mridul and Dwivedi, Shashi Prakash},
  booktitle={2025 2nd International Conference on Artificial Intelligence for Innovations in Healthcare Industries (ICAIIHI)}, 
  title={Explainable AI for Mental Health Diagnosis: Enhancing Transparency, Trust, and Clinical Decision-Making}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Explainable Artificial Intelligence (XAI) within mental health diagnosis has emerged as a groundbreaking approach to fulfill transparency, trust and interpretability in AI-based health care systems. The present review incorporates the recent advances in applying XAI to detection, diagnosis, and management of mental health through diverse methodologies, such as linguistic analysis and social media mining and wearable biosensors and deep learning models. The studies pinpoint the importance of XAI in the interpretation of opaque AI judgments, the establishment of trust by clinicians, and ethical application in sensitive mental health settings. Most strikingly, the applications can be found in the areas of depression and psychotic disorder prediction, autism spectrum disorder assessment, and suicide risk assessment. Multimodal data fusion, logic-based neural networks, personalization and clinical usability Multimodal data fusion, logic-based neural networks, and human-centered interfaces are the emerging trends. Issues of data quality, model generalizability and understanding of the model by the users still remain to be solved by interdisciplinary efforts. The review emphasizes the importance of XAI in improving the diagnostic accuracy of AI as well as responsible AI usage in psychiatry. With explainability and deep AI growing in popularity as the mental health issues gain importance as a matter of public health, there is an opportunity to explore what explainability can bring to accessible and effective solutions to mental healthcare.},
  keywords={Technological innovation;Explainable AI;Social networking (online);Reviews;Neural networks;Data integration;Mental health;Data models;Risk management;Usability;Explainable Artificial intelligence;Mental health;diagnosis;interpretability;social media analysis;Multimodal data},
  doi={10.1109/ICAIIHI67124.2025.11403514},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{11390550,
  author={Bhagat, Sukesh Kumar and Kumar, Mohit and Kumar, Sanjeev and Bisht, Amita and Vishwakarma, Ajeet Kumar and Kumar, Rahul},
  booktitle={2025 1st IEEE Uttar Pradesh Section Women in Engineering International Conference on Electrical Electronics and Computer Engineering (UPWIECON)}, 
  title={Leveraging AI for Early Detection and Intervention in Mental Health Disorders in the Digital Age}, 
  year={2025},
  volume={},
  number={},
  pages={259-264},
  abstract={The digital era has transformed dramatically how we connect and communicate to the world, but it has also brought many new challenges for mental health. Though the resources are accessible more than ever before, at the same time social media and digital era are more responsible for exacerbating feelings of anxiety, loneliness, depression and sense of isolation. The addictive nature of social media and devices often result in disrupt sleep pattern, also result in increased anxiety and loneliness, it also affects overall performance. Among young generation it has resulted that excessive screen time is directly linked to symptoms of depression. It has hindered the self-esteem and overall happiness as they get overwhelmed by the pressure of being online or making a perfect presence online. They get affected by what other is doing by watching others lifestyle and it put them in the pressure of matching the same lifestyle and making same presence out there. As the technology is evolving, we should promote it in a way that promote mental goodness. at the same time we should examine the potential of negative impacts and its impact on people's mental health. There are lots of potential for technology to offer for mental health cure. The challenges lie in looking for the positive side of the digital era and ensuring that we should prioritize mental wellness.},
  keywords={Ethics;Social networking (online);Anxiety disorders;Mental health;Medical services;Transforms;Depression;Information age;Artificial intelligence;Wearable devices;Artificial Intelligence;Mental Health;Early Detection;Digital Intervention;Natural Language Processing;Wearable Devices;Ethics},
  doi={10.1109/UPWIECON67212.2025.11390550},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10533166,
  author={Alkasassbeh, Mouhammd and Almomani, Ammar and Aldweesh, Amjad and Al-Qerem, Ahmad and Alauthman, Mohammad and Nahar, Khalid and Mago, Beenu},
  booktitle={2024 2nd International Conference on Cyber Resilience (ICCR)}, 
  title={Cyberbullying Detection Using Deep Learning: A Comparative Study}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={Cyberbullying has become a serious issue with the rise in social media usage, especially among adolescents. Victims of cyberbullying often suffer from psychological distress, anxiety, depression and even suicidal tendencies. With the rapid growth of user-generated content online, manual detection of cyberbullying is extremely difficult. Hence, automated cyber-bullying detection systems are needed. In recent years, deep learning models have emerged as a promising technique for cyberbullying detection. This paper provides a comprehensive review of the use of deep learning for cyberbullying detection. The key contributions are: (1) a taxonomy of cyberbullying detection techniques, (2) a review of datasets used for model training and evaluation, (3) a comparative analysis of various deep learning models including CNN, RNN, LSTM, GRU and Transformer- based models, (4) a discussion of key challenges and limitations, and (5) suggestions for future research directions. The paper provides a critical perspective on model performance across multiple datasets. Key findings indicate RNNs and specifically LSTM and GRU models demonstrate state-of-the-art performance for sequential cyberbullying detection. The study concludes that deep ensemble models combining LSTMs and pretrained contextual embeddings show significant promise to advance the field.},
  keywords={Deep learning;Training;Analytical models;Reviews;User-generated content;Taxonomy;Cyberbullying;Cyberbullying;Deep Learning;CNN;RNN;LSTM;GRU;Transformer;social media},
  doi={10.1109/ICCR61006.2024.10533166},
  ISSN={},
  month={Feb},}@ARTICLE{10243022,
  author={Obaid, Mohammed Hussein and Guirguis, Shawkat Kamal and Elkaffas, Saleh Mesbah},
  journal={IEEE Access}, 
  title={Cyberbullying Detection and Severity Determination Model}, 
  year={2023},
  volume={11},
  number={},
  pages={97391-97399},
  abstract={Some teenagers actively participate in cyberbullying, which is a pattern of online harassment of others. Many teenagers are unaware of the risks posed by cyberbullying, which can include depression, self-harm, and suicide. Because of the serious harm it can cause to a person’s mental health, cyberbullying is an important problem that needs to be addressed. This research aimed to develop a technique to identify the severity of bullying using a deep learning algorithm and fuzzy logic. In this task, Twitter data (47,733 comments) from Kaggle were processed and analyzed to flag cyberbullying comments. The comments embedded by Keras were fed into a long short-term memory network, composed of four layers, for classification. After that, fuzzy logic was applied to determine the severity of the comments. Experimental results suggest that the proposed framework provides a suitable solution to detect bulling with values of 93.67%, 93.64%, 93.62% achieved for the accuracy, F1-score, and recall, respectively.},
  keywords={Cyberbullying;Logic gates;Support vector machines;Blogs;Long short term memory;Classification algorithms;Convolutional neural networks;Deep learning;Deep learning algorithm;severity of bullying;LSTM},
  doi={10.1109/ACCESS.2023.3313113},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{11167300,
  author={Rao, R Rakshith and Kumar, C Nithin and Mangalagowri, R},
  booktitle={2025 5th International Conference on Intelligent Technologies (CONIT)}, 
  title={Voice of Help: AI-Driven Mental Health Assessment and Suicide Prevention through Text and Speech}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Suicide exists as a major international health issue because it leads to the death of more than $\mathbf{8 0 0, 0 0 0}$ individuals each year. Social media platforms enable people to show emotional distress in the modern digital period thus presenting an essential time for prevention and quick mental health services. Distinct social media posts along with patient questionnaire responses become the training base data for model development. A detection system integrates five classification algorithms which use Logistic Regression, Random Forest, Naive Bayes and Support Vector Machine (SVM) and Artificial Neural Networks (ANN) to optimize different detection tasks. The system displays high accuracy levels through performance assessments conducted with precision, recall, $\mathbf{F 1}$-score calculation and confusion matrix evaluation methods. A web application based on Flask provides secure implementation of the system to users in a user-friendly manner. Users can access the system through text and speech input along with quiz activities and a chatbot helps users receive assistance from the NLP system. The system offers practical solutions to users based on their mental health conditions by recommending mindfulness techniques and critical hotline services. Users gain better transparency and comprehension from the model through visual representation of accuracy graphs and word frequency data. The end-to-end solution was developed to support both mental wellness professionals and online services that help identify vulnerable individuals before they receive proper care for emotional wellbeing and suicide prevention.},
  keywords={Support vector machines;Logistic regression;Accuracy;Social networking (online);Prevention and mitigation;Mental health;Artificial neural networks;Chatbots;Data models;Bayes methods;Suicide Prevention;Mental Health Detection;Artificial Neural Network (ANN);Sentiment Analysis;Stress Classification;Logistic Regression;Chatbot;Flask Web Application;Social Media Analysis;Speech Input;Depression Detection},
  doi={10.1109/CONIT65521.2025.11167300},
  ISSN={},
  month={June},}@INPROCEEDINGS{10165143,
  author={Qayyum, Rabia and Afzal, Hammad and Mahmood, Khawir and Iltaf, Naima},
  booktitle={2023 International Conference on Communication Technologies (ComTech)}, 
  title={Detection and Analysis of Mental Health Illness using Social Media}, 
  year={2023},
  volume={},
  number={},
  pages={34-41},
  abstract={Recently social media has been a widely used network that connects people around the world. Not only this but people sharing their life events, thoughts through posts, status updates all gather up as a big data resource. This resource is helpful in conducting various researches, analyses including big data and machine learning. In this study, we analyzed six mental health issues using Reddit’s data. The data obtained summarizes; Depression, Anxiety, Bipolar, Bipolar Disorder, Schizophrenia, Autism and Mental Health which is a general class which discusses mental health. Experimentation is done using various deep learning and NLP techniques applied for classification such as Convolutional Neural Network, Long-short term memory network, Gated Recurrent Unit, Bi- Long-short term memory network and Bi-Gated Recurrent Unit. In addition to these traditional techniques, pre-trained BERT model and RoBERTa model have been applied. Finally a hybrid framework is presented using hierarchical classification and pre-trained RoBERTa fine tuned on the respective mental health data. The last phase compares results of the baseline deep learning models with the presented framework. The results show that the average accuracy of the hierarchical classification with two level hierarchy gives 84% of accuracy on test data.},
  keywords={Deep learning;Autism;Social networking (online);Bit error rate;Mental health;Big Data;Logic gates;Flat Classification;Hierarchical Classification;RoBERTa},
  doi={10.1109/ComTech57708.2023.10165143},
  ISSN={},
  month={March},}@INPROCEEDINGS{11096483,
