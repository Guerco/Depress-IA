  month={July},}@INPROCEEDINGS{10828795,
  author={Venkatesan, Mithra and Pawar, Sheetal and Thorat, Priyanka},
  booktitle={2024 International Conference on Intelligent Systems and Advanced Applications (ICISAA)}, 
  title={Depression Level Detection Using AI}, 
  year={2024},
  volume={},
  number={},
  pages={1-5},
  abstract={This project focuses on using the BERT algorithm to stumble on despair tiers in social media threads. We preprocess textual data from social media bills, adapt BERT for despair detection, and combine the version into a person-friendly interface. BERT analyzes linguistic nuances, sentiment, and contextual cues to evaluate the severity of depressive symptoms in the threads. The model is trained on annotated datasets with various despair levels, and its performance is evaluated using metrics together with precision, recollect, and F1-score. The assignment ambitions to make a contribution to AI programs in mental health, supplying a tool for early detection and assist inside the context of various language used on social media.},
  keywords={Measurement;Context;Adaptation models;Accuracy;Social networking (online);Mental health;Linguistics;Depression;Software reliability;Intelligent systems;BERT Algorithm;natural language processing;machine learning},
  doi={10.1109/ICISAA62385.2024.10828795},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10721784,
  author={M, Saranya. and Saxena, Ravi Shankar and Anandan, P and S, Dineshkumar and Dharani, R. and Rajasekaran, Arun Sekar},
  booktitle={2024 International Conference on Intelligent Algorithms for Computational Intelligence Systems (IACIS)}, 
  title={User-Level Emotion Detection Framework for Social Network Data}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={Social media interactions are inherently dynamic, with emotions fluctuating over time based on various events and user engagements. Traditional methods often overlook the temporal aspect of these interactions, limiting the depth of emotional analysis and the insights that can be derived. In this paper, we propose a novel temporal graph framework for detecting and analyzing emotions within social media networks. By leveraging the temporal nature of social media interactions, our framework incorporates both dynamic graph structures and sentiment analysis to track emotional trends over time. Proposed method demonstrate the effectiveness of our approach through empirical experiments on real-world social media data, revealing significant patterns and trends in user emotions. Our results highlight the potential of temporal graph models to enhance emotion detection and provide actionable insights for various applications, including sentiment-driven marketing and crisis management. The framework achieved an accuracy of 89% in detecting user emotions, a significant improvement over traditional static models, which averaged around 76%. Additionally, the temporal model identified emotional trends with a precision of 85% and a recall of 83%, compared to 70% precision and 68% recall achieved by baseline methods. These results indicate that the temporal graph framework not only tracks emotional trends more accurately over time but also provides deeper insights into the evolution of user sentiments within social networks.},
  keywords={Emotion recognition;Sentiment analysis;Privacy;Accuracy;Machine learning algorithms;Social networking (online);Market research;Depression;Prediction algorithms;Optimization;social network analysis;depression;feature extraction;multiclass classification;machine learning},
  doi={10.1109/IACIS61494.2024.10721784},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{11383539,
  author={Madhavi, S. and Alyushra, A. and Baahir Noufel, K. Mohammed},
  booktitle={2025 5th International Conference on Evolutionary Computing and Mobile Sustainable Networks (ICECMSN)}, 
  title={AI-Powered Early Detection of Stress and Mental Health Issues}, 
  year={2025},
  volume={},
  number={},
  pages={1135-1140},
  abstract={The contemporary AI-driven mental health systems have been limited in their ability to detect and analyze emotions over time because the systems are built on primitive text analysis or still image and speech models. To combat this issue and create a system that works in the opposite way, the proposed system processes Reddit posts first through cleaning, tokenization, and lemmatization. Then it uses a combination of TF-IDF and BERT embeddings to reflect both the statistical format and the context of the words, while at the same time, VADER and TextBlob determine the sentiment and subjectivity of the words. The machine learning models, Logistic Regression, Random Forest, and XG-Boost, are trained on the dataset for the purpose of effective mental health classification. This system, through contextual language analysis, sheds light on better precision, as opposed to the static CNN or sequential RNN approaches. A Stream-lit platform provides the facility of real-time and batch predictions thereby assisting in the continually detection and monitoring of mental health problems.},
  keywords={Logistic regression;Text analysis;Social networking (online);Mental health;Depression;Feature extraction;Real-time systems;Tokenization;Monitoring;Random forests;Reddit Posts;Depression Detection;Natural Language Processing (NLP);BERT Embeddings;Logistic Regression;Random Forest;XG-Boost;Mental Health Monitoring;Stream-lit Application},
  doi={10.1109/ICECMSN68058.2025.11383539},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{11187670,
  author={Moby, Merin Mary and Naveen, Soumyalatha},
  booktitle={2025 Third International Conference on Networks, Multimedia and Information Technology (NMITCON)}, 
  title={BERT-LSTM Hybrid Model for Early Detection of Mental Health Risks}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Mental health issues, specifically depression, is an important problem on a global scale. Millions of people around the world suffer from depression due to high-stress living situations, traumatic events, peer pressure and sometimes it may not be detected due to the stigma that follows it. This situation can be improved by early detection and providing the necessary support. This paper proposes a model that combines the contextual understanding of BERT(Bidirectional Encoder Representations from Transformers) with sequential learning in LSTM (Long Short-Term Memory) networks. This hybrid model gave an accuracy of 92.70% with a score of 0.9236 F1 in classifying posts on social media into depressive and non-depressive. Along with this it also gave balanced precision and recall scores for the two labels thus indicating the models robustness across multiple text types. The use of this hybrid model shows the opportunities, text classification applications can gain by combining transformer based models and recurrent neural networks in the mental health field. The high accuracy of this model can play an important role in recognizing severity levels and detecting variations in depression. This research can pave the way for further advancement in online mental health tools and support systems.},
  keywords={Training;Ethics;Accuracy;Social networking (online);Text categorization;Mental health;Depression;Transformers;Robustness;Long short term memory;Depression Detection;Mental Health;Natural Language Processing;Machine Learning;Text classification},
  doi={10.1109/NMITCON65824.2025.11187670},
  ISSN={},
  month={Aug},}@ARTICLE{10960428,
  author={Zhou, Shiwen and Mohd, Masnizah},
  journal={IEEE Access}, 
  title={Mental Health Safety and Depression Detection in Social Media Text Data: A Classification Approach Based on a Deep Learning Model}, 
  year={2025},
  volume={13},
  number={},
  pages={63284-63297},
  abstract={Social media expansion enables real-time mental health monitoring particularly for depression detection through its platforms. Traditional depression detection techniques, however, struggle to handle the informal, often ambiguous nature of language used in social media, including emojis, slang, and context-dependent expressions. To address this limitation, this research proposes a novel framework for depression detection that integrates advanced text preprocessing with a deep learning model. The preprocessing pipeline contains two key components where emojis are converted into text by emoji normalization then slang expressions are replaced through a customized dictionary. Emotion scores serve as additional components to identify depression-related emotional cues within the text. The model combines BERT’s contextual embeddings with BiLSTM’s sequential processing power to effectively represent emotional content in social media posts. The proposed approach demonstrates superior performance compared to traditional baseline models by achieving better results in accuracy, precision, recall, F1-score, AUC and RGA. This approach shows exceptional performance in detecting depression through informal texts which serves as a new benchmark for depression detection in dynamic social media environments.},
  keywords={Depression;Social networking (online);Mental health;Encoding;Bidirectional long short term memory;Bidirectional control;Semantics;Emojis;Accuracy;Deep learning;BERT-BiLSTM;depression detection;social media;mental health;natural language processing (NLP)},
  doi={10.1109/ACCESS.2025.3559170},
