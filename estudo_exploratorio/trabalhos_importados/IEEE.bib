  month={April},}@INPROCEEDINGS{11172053,
  author={Rahman, Mahbubur and Rashid, Fahmida and Tabassum, Nuzhat and Hasan, Md. Manzurul},
  booktitle={2025 International Conference on Quantum Photonics, Artificial Intelligence, and Networking (QPAIN)}, 
  title={A Context-Aware Framework for Depression Detection in Multilingual Social Media Content}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Depression is a mental health-related disorder and a global concern, yet many people remain undiagnosed due to a lack of awareness and limited access to mental health care. With the increasing use of social media for self-expression, there is a growing opportunity to detect signs of depression using automated systems. This study proposes a context-aware multilingual framework for detecting depression in social media text, focusing on both Bangla and English languages. Although the dataset primarily consists of Bangla social media posts, we converted emojis into their corresponding English textual meanings to enhance contextual understanding and introduce multilingual characteristics into the dataset. Three deep learning models—mBERT, Bangla-BERT, and BiLSTM—were implemented and evaluated on a well-curated, balanced dataset labeled as depressive or non-depressive. The results demonstrate that mBERT outperformed the other models, achieving an accuracy score of 90%, while Bangla-BERT and BiLSTM achieved accuracy of 88% and 86%, respectively. These findings highlight the effectiveness of transformer-based models, particularly multilingual ones, in enhancing the early detection of depression from user-generated content.},
  keywords={Adaptation models;Social networking (online);Bidirectional long short term memory;Mental health;Predictive models;Depression;Transformers;Multilingual;Context modeling;Emojis;Mental health;mBERT;BanglaBERT;BiLSTM;social media analysis;deep learning;contextual understanding},
  doi={10.1109/QPAIN66474.2025.11172053},
  ISSN={},
  month={July},}@INPROCEEDINGS{11405380,
  author={Kashyap, Prashant and Rout, Jitendra Kumar},
  booktitle={2025 13th International Conference on Intelligent Systems and Embedded Design (ISED)}, 
  title={Depression Detection Using Stacking Ensemble with Pronoun-Based Linguistic Features}, 
  year={2025},
  volume={},
  number={},
  pages={1037-1041},
  abstract={Depression is a mental health disorder that profoundly affects how a person thinks, feels, and behaves. Depression is a common and serious problem today, and prevention is essential. In today’s digital age, people freely express their feelings on social media. Therefore, depression can be detected by analyzing social media text and emotions using machine learning techniques. The purpose of this paper is to detect depression from Reddit posts. Natural Language Processing (NLP) and Ensemble Learning have been used on a Reddit dataset of 7731 posts to achieve this purpose. Basic preprocessing techniques such as data cleaning, tokenization, stemming, and lemmatization are applied while ensuring that pronouns were preserved due to their linguistic significance. Term FrequencyInverse Document Frequency (TF-IDF) has been applied for feature extraction as well as vectorization. A Stacking Ensemble model is proposed, integrating XGBoost, Support Vector Machine (SVM), and Multinomial Naive Bayes (MNB) as base learners and Logistic Regression (LR) is a meta-learner. The model achieved Accuracy 97.09%, Precision 98.13%, Recall 95.95% and F1-score 97.03% which was better than individual classifiers. The results prove that combining various Machine Learning techniques through stacking significantly reduces both variance and bias, leading to more accurate, stable and consistent predictions. Index Terms-Depression Detection, Ensemble Learning, Machine Learning, Natural Language Processing, Social Media.},
  keywords={Support vector machines;Accuracy;Social networking (online);Stacking;Linguistics;Depression;Feature extraction;Tokenization;Ensemble learning;Space vector modulation},
  doi={10.1109/ISED67359.2025.11405380},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{9744938,
  author={Huang, Xiao},
  booktitle={2022 IEEE International Conference on Electrical Engineering, Big Data and Algorithms (EEBDA)}, 
  title={Ideal Construction of Chatbot Based on Intelligent Depression Detection Techniques}, 
  year={2022},
  volume={},
  number={},
  pages={511-515},
  abstract={Depression detection usually describes the task of recognizing the depression level or tendency from certain articles, posts, or even consult. Such a technique might be widely used in the diagnosis when the psychologists or consulters are present. However, when such a type of diagnosis or service comes online, there would be many types of challenges, such as detection through some amounts of words, detection through pictures or video streaming of patients, and in some cases, how depression could be solved without the participation of a real doctor. This article generally discussed some common methods to solve these challenges and some construction designs that might help depressed patients. Currently, depression detection is still an innovative field to be explored, and many techniques do not seem to be mature. According the investigation on the techniques related to the construction of depression chatbots, we recognized that some tasks-based function can be realized, it would be quite difficult for such chatbot to really understand feelings and emotions, and consequently the chatbot will have many difficulties to produce neither therapies for the patients nor a meaningful conversation to offer assistance. In the future, more advanced methods will come out which can capture more details of the mental movements of the patients, and one day it will no longer be impossible for a computer to understand humans' subtle internal.},
  keywords={Electrical engineering;Emotion recognition;Machine learning algorithms;Conferences;Psychology;Medical treatment;Streaming media;machine learning;deep learning;sentiment analysis;depression detection},
  doi={10.1109/EEBDA53927.2022.9744938},
  ISSN={},
  month={Feb},}@INPROCEEDINGS{11167626,
  author={Singh, Karanbir and Dadwal, Komal and Kaur, Karamveer and Nagpal, Diana},
  booktitle={2025 5th International Conference on Intelligent Technologies (CONIT)}, 
  title={Depression Detection Using Social Media Analysis}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Depression is a psychological disorder which impacts numerous people throughout the globe. In current society, individuals verbalize their emotions on social media, which can serve as a great tool to detect signs of depression through sentiment analysis. A deep learning system designed in this study aims to determine depression in people. The main focus is on preprocessing and feature extraction from a dataset of text messages labeled as “depressed” or “not depressed.” For preprocessing, the text was cleaned, broken into smaller parts (tokenization), removed unnecessary words (stop words), applied lemmatization, and did Part-of-Speech (POS) tagging using NLTK and SpaCy. Things like word usage, sentence length, and how often different types of words appear to understand the language patterns of depressed and not depressed individuals taken into consideration. To make the text data more structured, the TF-IDF transformation was used. To understand the semantic meaning of words in a way that deep learning models, processing of word embeddings with Word2Vec Model was also done. The obtained features moved from the extraction process into both LSTM and GRU computational frameworks. The LSTM produced accuracy results at $\mathbf{0. 9 0 6}$ along with the GRU model reaching 0.9134 accuracy levels. The successful outcome of our method shows how it can effectively identify depression cases in textual information.},
  keywords={Deep learning;Sentiment analysis;Accuracy;Social networking (online);Computational modeling;Writing;Depression;Feature extraction;Long short term memory;Videos;Sentiment Analysis;Depression Detection;Social Media Analysis;Twitter Data Analysis},
  doi={10.1109/CONIT65521.2025.11167626},
  ISSN={},
  month={June},}@INBOOK{10953160,
  author={Adrian, Angelia Melani and Sanger, Junaidy Budi},
  booktitle={Optimized Computational Intelligence Driven Decision-Making: Theory, Application and Challenges}, 
  title={An Analytical Study on Depression Detection Using Machine Learning}, 
  year={2024},
  volume={},
  number={},
  pages={215-228},
  abstract={Summary <p>Worldwide, 264 million people suffer from depression, which is one of the main causes of inefficiency. Poor working environments can cause a variety of physical and mental problems. According to studies, people are afraid to seek help because of the societal stigma associated with mental health issues.</p> <p>Considering the height of machine learning, we can use various machine learning algorithms to predict depression in humans. Depression is a frequent and significant medical condition that adversely affects our thoughts, feelings, and actions. It might be fatal since a person in this mindset has given up hope and only perceives the negative sides of the circumstance. According to a 2019 WHO report, approximately 3 million people globally between the ages of 17&#x2013;25 and 40&#x2013;70 suffer from depression. Thus in such cases, machine learning models can be developed on a training database to determine whether or not a person is depressed. Users can interact with their loved ones and post their ideas, photos, and videos that reflect their sentiments, moods, and emotions on social media, which is a fantastic source of realistic data from online users. This opens up the possibility of analyzing social networking data to detect users&#x2019; emotions and moods in order to investigate their feelings and behavior when interacting on these online platforms. Many researchers have attempted to predict depression using machine learning approaches in the past. The purpose of this paper is to review the effectiveness of ML strategies for the early prediction of depression in humans.</p>},
  keywords={Depression;Anxiety disorders;Social networking (online);Feature extraction;Support vector machines;Accuracy;Face recognition;Random forests;Videos;Machine learning algorithms},
  doi={10.1002/9781394242566.ch11},
  ISSN={},
