@INPROCEEDINGS{10847487,
  author={B, Venkata Sai Laxman and Kulkarni, Sanat Shantanu and Hareesh, Beecha Venkata Naga and Enduri, Murali Krishna},
  booktitle={2024 IEEE 16th International Conference on Computational Intelligence and Communication Networks (CICN)}, 
  title={Explainable Depression Detection in Social Media Using Transformer-Based Models: A Comparative Analysis of Machine Learning}, 
  year={2024},
  volume={},
  number={},
  pages={321-325},
  abstract={The growing use of online platforms like Twitter and Reddit has created new opportunities in the field of mental health by enabling the analysis of language patterns in user-generated content. This study explores how transformer-based models such as Bidirectional Encoder Representations from Transformers (BERT), Generative Pre-trained Transformer (GPT-2), Robustly Optimized BERT Approach (RoBERTa), and Term Frequency-Inverse Document Frequency (TF-IDF) for text feature matrices can be applied to detect depressive symptoms in social media posts. The study utilizes machine learning algorithms, including Logistic Regression (LR), Random Forest, Support Vector Machine (SVM), Decision Tree, Naive Bayes, Multi-Layer Perceptron (MLP), and XGBoost, to improve the detection of depression-related markers in textual data. By leveraging annotated datasets specifically focused on depression, these models are trained to identify depression indicators in the language used by social media users. We employ supervised learning techniques to enhance model performance across various platforms, aiming to achieve greater accuracy and generalizability.},
  keywords={Support vector machines;Analytical models;Social networking (online);Computational modeling;User-generated content;Bidirectional control;Transformers;Depression;Encoding;Bayes methods;Transformer Models;Machine Learning;XGBoost;Navi Bayes;binary Classification;Explainable Depression Detection in Social Media Analysis;Depression detection},
  doi={10.1109/CICN63059.2024.10847487},
  ISSN={2472-7555},
  month={Dec},}@INPROCEEDINGS{10939051,
  author={Markose, Ginoop Chennekkattu},
  booktitle={2025 First International Conference on Advances in Computer Science, Electrical, Electronics, and Communication Technologies (CE2CT)}, 
  title={Leveraging Machine Learning Algorithms for Early Detection of Major Depressive Disorder: A Deep Learning Approach with Twitter Data}, 
  year={2025},
  volume={},
  number={},
  pages={316-319},
  abstract={Social media plays a significant role in daily lives of people where they share the topics and contents to express their feelings, events experiences and thoughts. Due to extensive use of social media, huge volume of data is generated. The data comprised of textual content allows to collect large volume of relevant information using deep learning techniques. The primary aim of the study is early detection of major depressive disorder through extracted data from Twitter platform. The study uses binary classification models for treating the mental disorder and achieved satisfactory results. The proposed methodology includes deep learning technique designed with effective multi class deep learning model to detect major depressive disorder. The well-defined methodology includes tweet analysis by testing wide range of deep learning models such as simple variant such as GRU and LSTM and hybrid variant like CNN-BiGRU. The present work is validated by comparing it with different data sets and existing binary classification models. The Binary class models effectively assume the collected data and utilisation of multi class model. The findings of the study shows that the performance of the proposed model is comparatively high when with other existing models.},
  keywords={Deep learning;Analytical models;Social networking (online);Computational modeling;Mental disorders;Blogs;Depression;Data models;Long short term memory;Testing;Major Depressive Disorder;Deep Learning Approach;Twitter;Multi-class model;social media},
  doi={10.1109/CE2CT64011.2025.10939051},
  ISSN={},
  month={Feb},}@INPROCEEDINGS{10967659,
  author={Shoaib, Haris and Ali, Rashid and Khan, S. M. Shadab and Adil, Mohd},
  booktitle={2025 IEEE 14th International Conference on Communication Systems and Network Technologies (CSNT)}, 
  title={Depression Detection on Social Media Posts Using BERT and Support Vector Machine}, 
  year={2025},
  volume={},
  number={},
  pages={708-712},
  abstract={Depression is a growing mental health challenge, affecting countless individuals worldwide. As people increasingly express their mental states on social media platforms like Twitter and Reddit, there is an opportunity to leverage this data to identify signs of depression. This study investigates the potential of social media text for detecting depression using machine learning techniques. We used Kaggle-sourced Twitter and Reddit datasets, each containing labeled samples of depressive and non-depressive content. After extensive preprocessing such as text cleaning, tokenization, and BERT embedding generation we trained Support Vector Machine (SVM) models with various kernel functions. Our results show Twitter data significantly enhances model performance, achieving 94.4% accuracy with the polynomial kernel while 87.5% on twitter dataset with Radial basis function (RBF). These findings underscore the potential for accurate depression detection, suggesting its value for early intervention and use of social media data for depression detection.},
  keywords={Support vector machines;Accuracy;Social networking (online);Blogs;Mental health;Machine learning;Depression;Tokenization;Polynomials;Kernel;Depression;Depression Detection;BERT;SVM;Kernel;NLP;Social Media;Mental Health},
  doi={10.1109/CSNT64827.2025.10967659},
  ISSN={2473-5655},
  month={March},}@INPROCEEDINGS{9994553,
  author={Putri, Alya Melati and Wijaya, Kevin and Salomo, Owen Albert and Santoso Gunawan, Alexander Agung and Anderies},
  booktitle={2022 IEEE International Conference on Communication, Networks and Satellite (COMNETSAT)}, 
  title={A Review Paper: Accuracy of Machine Learning for Depression Detection in Social Media}, 
  year={2022},
  volume={},
  number={},
  pages={39-45},
  abstract={There are so many health problems that affect humans. One of them is depression. Depression is a mental health disorder that would trigger suicidal tendencies if not treated carefully. People who are depressed tend to have less concentration and productivity. However, detecting depression is not easy due to the self-denial of some patients, and they keep depression untreated and undiagnosed. Some factors of untreated or undiagnosed depression are poor knowledge and recognition in many places the patient is shy to talk to a psychologist, and the stereotypes in public that say people who come to a psychologist are “insane.” Depression symptoms of a user can be shown in social media posts, and these symptoms can be detected using a machine learning algorithm. These Machine learning algorithms can be an alternative for detecting depression or as a supporting document for psychologist diagnoses. The algorithm obtains accurate that varies depending on the dataset. For this reason, we conducted a systematic literature review to find out which machine learning has the best accuracy in detecting depression. We also provide information about stable algorithms to detect a given dataset and the popular dataset used in previous studies based on the most frequent text that is easy to test. In conclusion, the greatest accuracy is obtained from Logistic Regression with an accuracy value of 99.80%. Stable algorithms are obtained by LR and SVM because the machine learning method obtains values above 70%. The most popular dataset used in previous studies is the Twitter dataset.},
  keywords={Support vector machines;Machine learning algorithms;Systematics;Social networking (online);Blogs;Machine learning;Depression;Depression detection;Machine Learning;Social Media;Mental health;Text Classification},
  doi={10.1109/COMNETSAT56033.2022.9994553},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{10940218,
  author={Padmakala, S. and Gopukumar, S. T.},
  booktitle={2025 International Conference on Electronics and Renewable Systems (ICEARS)}, 
  title={Predictive Analytics in Mental Health: Machine Learning Models for Major Depressive Disorder Detection using Sensor Data}, 
  year={2025},
  volume={},
  number={},
  pages={1393-1398},
  abstract={The recent integration of Machine Learning (ML) and sensor technologies in healthcare, particularly for diagnosing Major Depressive Disorder (MDD), has paved the way for advanced predictive analytics in mental health. This study aimed to develop ML models to detect MDD using sensor-derived data, including accelerometer measurements, temperature, pulse rates, and SpO2 levels. The proposed methodology involved collecting and preprocessing a comprehensive dataset, imputing missing values, and splitting the data into training and test sets. Feature scaling and PCA were applied to enhance model efficiency. The performance of various ML models such as Random Forest, SVM, Gradient Boosting, XGBoost, LightGBM, and Logistic Regression was evaluated based on accuracy, precision, recall, and F1-score. Random Forest and XGBoost models performed exceptionally well, with accuracy rates nearing 97%. Ensemble methods, in particular, demonstrated superior predictive power. Logistic Regression showed significantly lower performance, highlighting the complexity of MDD beyond linear classification methods. Future directions include developing real-time analysis models, personalizing predictive algorithms, integrating ML into clinical practice, and conducting longitudinal studies to validate and refine these tools. Ethical and privacy considerations, as well as expanding predictive factors, are critical for advancing this research field. The study concluded that ML models are potent tools for early detection of MDD, which can significantly impact patient outcomes. The potential for these models to be integrated into clinical settings for personalized patient care could revolutionize mental health diagnostics and treatment strategies.},
  keywords={Temperature measurement;Logistic regression;Analytical models;Mental health;Medical services;Predictive models;Depression;Data models;Predictive analytics;Random forests;Machine Learning (ML);Major Depressive Disorder (MDD) detection;Random Forest;healthcare},
  doi={10.1109/ICEARS64219.2025.10940218},
  ISSN={},
  month={Feb},}@INPROCEEDINGS{10441612,
  author={Kabir, Farhan and Hossain, Md. Ali and Minhazur Rahman, A. F. M. and Mishu, Sadia Zaman},
  booktitle={2023 26th International Conference on Computer and Information Technology (ICCIT)}, 
  title={Depression Detection From Social Media Textual Data Using Natural Language Processing and Machine Learning Techniques}, 
  year={2023},
  volume={},
  number={},
  pages={1-6},
  abstract={Depression, a widespread mental health condition with substantial personal and societal impacts, necessitates early detection for effective intervention. The focus of this thesis is crafting a dependable and precise system to identify depression from social media text, employing natural language processing (NLP) and machine learning (ML). Drawing from diverse social media posts, both from individuals with and without depression, the primary aim is to preprocess this textual data effectively. NLP techniques, including tokenization, stemming, N-gram, Countvectorizer analysis, and TF-IDF, convert raw content into meaningful representations capturing linguistic and emotional facets of depression. Utilizing the preprocessed data, machine learning algorithms acquire discriminating patterns through feature extraction. Diverse ML techniques—Stochastic Gradient Descent (SGD), Naive Bayes (NB), Decision Tree (DT), Random Forest (RF), Support Vector Machines (SVM), KNearest Neighbor (KNN), Multi-Layer Perceptron (MLP), etc.—are employed. Trained on annotated data and extracted attributes, these algorithms discern depressive from nondepressive social media posts. Model performance assessment incorporates metrics like accuracy, precision, recall, and F1score. Results underscore the efficacy of this approach in detecting depression from social media text. The system consistently demonstrates high accuracy and performance across various evaluation criteria. This thesis concludes by thoroughly exploring depression diagnosis via NLP and ML algorithms applied to social media content.},
  keywords={Support vector machines;Machine learning algorithms;Social networking (online);Depression;Feature extraction;Vectors;Testing;Depression;Consistently;Stochastic Gradient Descent (SGD);Support Vector Machine (SVM);Natural Language Processing (NLP);Multi-Layer Perceptron (MLP)},
  doi={10.1109/ICCIT60459.2023.10441612},
  ISSN={},
  month={Dec},}@ARTICLE{10843708,
  author={Tahir, Waleed Bin and Khalid, Shah and Almutairi, Sulaiman and Abohashrh, Mohammed and Memon, Sufyan Ali and Khan, Jawad},
  journal={IEEE Access}, 
  title={Depression Detection in Social Media: A Comprehensive Review of Machine Learning and Deep Learning Techniques}, 
  year={2025},
  volume={13},
  number={},
  pages={12789-12818},
  abstract={Depression is a widespread mental health disorder that may remain undiagnosed by conventional clinical methods. The rapidly growing world of social media sites such as Twitter, Reddit, Facebook, Instagram, and Weibo has provided new avenues for depression detection using Machine Learning (ML) as well as Deep Learning (DL), which analyze user behavior patterns and linguistic cues for more accurate detection of depression. Many techniques have been developed for this aim over the years. Identifying relevant publications on this topic using current academic search systems is challenging due to the rapid growth of research publications, unclear or limited search terms, and the complexity of citation networks. Several review papers have been published to ease this task by summarizing the methodologies, key findings, and recommendations for future research. However, most current reviews often do not provide a clear overview of the evolution, latest techniques, and challenges. This paper aims to address that gap by providing a comprehensive review of ML and DL methodologies for detecting depression on social media. We propose a generic architecture for these systems and present a detailed analysis of methodologies and datasets used for evaluation in this field. In addition, we highlight key open research areas, providing a useful starting point for further research and development. By narrowing our focus to social media, this review contributes to advancing the understanding and application of cutting-edge methods for depression detection. While this review highlights advancements in social media-based depression detection, it excludes alternative approaches like graph-based systems and reinforcement learning, and its focus on social media may limit its applicability to other domains.},
  keywords={Depression;Social networking (online);Deep learning;Machine learning;Computer architecture;Linguistics;Blogs;Accuracy;Systematic literature review;Data models;Deep learning;depression detection;machine learning;natural language processing;sentiment analysis;social media},
  doi={10.1109/ACCESS.2025.3530862},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{11384019,
  author={Jonathan and Novika, Andien Dwi and Suhartono, Derwin},
  booktitle={2025 IEEE 2nd International Conference on Cryptography, Informatics, and Cybersecurity (ICoCICs)}, 
  title={Leveraging Machine Learning for Early Detection of Depression Based on Social Media Behavior}, 
  year={2025},
  volume={},
  number={},
  pages={138-142},
  abstract={This research focuses on detecting depression from text based on machine learning algorithms. Depression is a mood disorder that negatively affects one's well-being. With the increase in depression cases worldwide, this research aims to develop an efficient method of detecting depression symptoms based on the words people post on social media. The research uses a dataset of raw text that involves cleaning phases, tokenization, and vectorization. Six machine learning algorithms are used to compare the performance of the algorithms in symptom detection of depression. They are Support Vector Machine, K Nearest Neighbors, Naïve Bayes, Decision Tree, Random Forest, and Neural Network. The result of the research is used for comparison of the accuracy and efficiency levels of each of the algorithms. Experiment outcomes indicate that the Support Vector Machine model achieves the best result, with 0.910 accuracy, establishing its capability for detecting depression. The paper is highly useful for suicide prevention drives, mental health improvement, and provides a technical approach for the detection of symptoms of depression using social media text analysis.},
  keywords={Support vector machines;Training;Machine learning algorithms;Accuracy;Social networking (online);Neural networks;Machine learning;Mental health;Depression;Tokenization;depression;machine learning;accuracy;effectiveness;social media},
  doi={10.1109/ICoCICs68032.2025.11384019},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10425378,
  author={Kaur, Veerpal and Nandy, Aadrita and Choudhary, Jyoti and Fredrick, Joanne and Zacharia, T. S. and Joseph, Tom K. and Kaur, Amandeep},
  booktitle={2023 2nd International Conference on Futuristic Technologies (INCOFT)}, 
  title={Machine Learning for Early Detection of Child Depression: A Data-Driven Approach}, 
  year={2023},
  volume={},
  number={},
  pages={1-5},
  abstract={Children face trauma due to numerous factors such as parental fights, bullied in school, being below average student, racist comments, physical abuse etc. This trauma deteriorates the child's mental health and may lead to depression as well. Medical field is immensely dedicated to combat the depression among children and one of such approaches adapted includes the use Machine Learning models to predict child depression. This research work is focusing on seven different machine learning algorithms, including SVM Poly, K-Nearest Neighbor, SVM RBF, SVM Linear, Decision Tree, Gradient Boosting, Random Forest and Logistic Regression. This research examines the performance of these algorithms in detecting depressive symptoms in a child and adolescent population. In accordance with the outcomes of the research, SVM Linear algorithm emerged as the most accurate method, with an excellent accuracy rate of 95.54%. This algorithm demonstrated higher sensitivity in detecting depression symptoms in children and teens opening the possibility to prompt intervention and assistance.},
  keywords={Support vector machines;Pediatrics;Machine learning algorithms;Sensitivity;Mental health;Depression;Prediction algorithms;Health;Depression;Mental Health;Innovation;Artificial intelligence;Machine Learning;suicide;Children},
  doi={10.1109/INCOFT60753.2023.10425378},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{10486238,
  author={Rajderkar, Viraj and Bhat, Aruna},
  booktitle={2024 2nd International Conference on Computer, Communication and Control (IC4)}, 
  title={Narrative Review on Depression Detection in Online Social Media}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={This narrative review examines the research papers published between 2017 and 2022 that investigate depression detection through the analysis of social media. The review comprises a thorough search of databases of five prominent digital libraries with the goal of identifying high-quality research contributions pertaining to the identification of depression. After that, ten pertinent papers were chosen and carefully examined. In the papers that we have examined, the most common way that data is collected is by using the APIs of social media platforms, with Twitter being the most used platform for this purpose. Term Frequency-Inverse Document Frequency technique was most frequently used to extract speech features. The studies discuss the relationship between mental health issues and public health risks in the setting of depression detection. Additionally, they demonstrate how the use of deep learning and ML algorithms can consistently aid in recognizing and reducing the difficulties presented by psychological disorders such as depression, hence improving public health management.},
  keywords={Deep learning;Machine learning algorithms;Social networking (online);Reviews;Databases;Mental health;Depression;Machine learning;Deep Learning;Sentiment Analysis;Social Media;Anxiety;Mental Illnesses},
  doi={10.1109/IC457434.2024.10486238},
  ISSN={},
  month={Feb},}@INPROCEEDINGS{10561447,
  author={Krishna, N. Bala and Kumar, R.Yaswanth and Bhanu, M Indira and Reddy, P Omprakash and Anjali, R. and Reddy, P Reethu},
  booktitle={2024 International Conference on Smart Systems for applications in Electrical Sciences (ICSSES)}, 
  title={Exploring Machine Learning Algorithms for the Detection of Depression}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={In this digital world, the excessive use of social media is increasing the incidence of mental health problems, especially depression. Due to the widespread usage of online social media platforms, there is now a chance to proactively treat mental health issues by observing and comprehending users’ behavior. Early detection of depression symptoms is essential for prompt assistance and management. By employing advanced artificial intelligence techniques and machine learning algorithms, such as Long Short-Term Memory and Support Vector Machine, this system effectively analyzes users’ social media behavior to determine whether they are experiencing depression and acts as a tool for the early identification of mental health problems, supporting a proactive strategy for enhancing people’s well-being in the digital era. By mining users’ social media interactions and classifying them as potentially depressed or not, this approach helps those in need in a timely manner and delivers insightful information on people’s mental health. Furthermore, the applications of this system extend beyond detecting and preventing online bullying; it can also be used to detect and manage other mental health issues, which in turn helps in emotional well-being. These ideas can be employed in social media applications to check mental stability. This chapter emphasizes the crucial role of textual emotional intelligence in mining users’ social media behavior for detecting depression and other mental health issues. By employing cutting-edge artificial intelligence techniques and machine learning algorithms, this system offers valuable insights and assistance to individuals in need and also helps in maintaining proper e-health.},
  keywords={Sentiment analysis;Machine learning algorithms;Social networking (online);Static VAr compensators;Mental health;Machine learning;Linguistics;Machine Learning;AI Emotion Detection;Emotion Analysis on social media;Predictive Modeling;Depression Detection;Diagnostic Tools;Emotional Well-being;Automatic Health Monitoring;e-Health},
  doi={10.1109/ICSSES62373.2024.10561447},
  ISSN={},
  month={May},}@INPROCEEDINGS{10193515,
  author={Priya, P Lakshmi and Prakash, R Vijaya},
  booktitle={2023 4th International Conference on Electronics and Sustainable Communication Systems (ICESC)}, 
  title={A Broad Survey on Detection of Depression in Societal Platforms using Machine Learning Model for the Public Health Care System}, 
  year={2023},
  volume={},
  number={},
  pages={1643-1649},
  abstract={Anxiety and depression are on the rise, particularly since the COVID-19 epidemic, yet detection rates have not kept pace. There has been a lot of talk about people showing signs of mental health problems on social media sites like Facebook, Twitter etc. The social media anxiety and sadness detected using machine learning algorithms is considered and reviewed in this research. Soon after depression was recognized as a major public health problem around the world, efforts were made to improve its detection. The speed with which technology is developing is changing the way people talk to one another. Standardized scales that rely on patients’ subjective reactions or clinical diagnoses from attending clinicians are typically used to detect depression, despite their limitations. First, the replies patients give on conventional standardized measures may be influenced by factors such as the patient’s current mental state, the nature of the clinician-patient relationship, the patient’s current mood, and the patient’s previous experiences and memory bias. Social media platforms like Twitter, Facebook, Telegram, and Instagram have exploded in popularity as places for people to open up about their innermost thoughts, psyche, and feelings with the proliferation of the Internet. Text is analyzed using psychological analysis to pull out relevant aspects, characteristics, and information from the perspectives of users. Psychological analysts rely on social media for the early identification of depressive symptoms and patterns of behavior. A person’s social network may tell us a lot about the thoughts and actions that precede the start of depression, such as the person’s isolation, the importance they place on themselves, and the hours they spend awake. This research presents a brief review that attempts to synthesize the literature on the use of Machine Learning (ML) techniques on social media text data for the purpose of detecting depressive symptoms and to point the way toward future research in this field.},
  keywords={Surveys;Privacy;Machine learning algorithms;Social networking (online);Blogs;Anxiety disorders;Depression;Mental Health;Anxiety;Depression;Social Media;User Posts;Machine Learning;Technology;Features},
  doi={10.1109/ICESC57686.2023.10193515},
  ISSN={},
  month={July},}@INPROCEEDINGS{11325464,
  author={Kumar, Avinash and Dwivedi, Pragya},
  booktitle={2025 IEEE 7th International Conference on Computing, Communication and Automation (ICCCA)}, 
  title={Enhanced Depression Detection on Social Media: Leveraging Diverse Embedding Techniques with Machine Learning Classifiers}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Depression is a global mental health concern, and early detection is essential for timely intervention. With the rise of social media platforms, users’ posts provide valuable cues that can be analyzed using machine learning (ML). This paper systematically evaluates the performance of five ML classifiers Naïve Bayes (NB), Random Forest (RF), Support Vector Machine (SVM), Logistic Regression (LR), and AdaBoost (AB)-across four feature extraction methods: Bag of Words (BoW), Term Frequency–Inverse Document Frequency (TF-IDF), Word2Vec, and BERT embeddings. Experiments were conducted on two publicly available datasets (Reddit Depression and Mental Health). Results show that traditional feature representations such as TF-IDF and BoW, when paired with classifiers like LR, RF, and SVM, achieved the highest accuracy of 95-96%, outperforming or matching more complex embeddings like Word2Vec and BERT. These findings highlight that lightweight embedding techniques remain competitive for depression-related text classification, particularly in resource-constrained scenarios. This study provides a comparative study of embeddings and classifiers for depression detection and establishes a foundation for future research into transformer-based fine-tuning, ensemble methods, and multimodal approaches for more robust and ethical mental health monitoring.},
  keywords={Support vector machines;Radio frequency;Social networking (online);Text categorization;Mental health;Depression;Transformers;Space vector modulation;Random forests;Monitoring;Depression Detection;Machine Learning;Text Embeddings;TF-IDF;BERT;Social Media Analysis},
  doi={10.1109/ICCCA66364.2025.11325464},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{10696584,
  author={Shinde, Priyanka P. and Desai, V. P. and Oza, Kavita S.},
  booktitle={2024 Second International Conference on Intelligent Cyber Physical Systems and Internet of Things (ICoICI)}, 
  title={A Data Driven Mental Health Analysis Using Machine Learning Techniques}, 
  year={2024},
  volume={},
  number={},
  pages={1665-1670},
  abstract={This research study investigates the significant impact of the COVID-19 pandemic on mental health, focusing on depression. Using a dataset of over 1504 individuals, the study employs Python-based machine learning algorithms (K-NN, Decision Tree, SVM, Random Forest, and Logistic Regression) to predict depression levels and analyze contributing factors. The findings highlight the effectiveness of these classification methods in accurately detecting depression and identify key factors, including lack of communication and feelings of guilt, as major contributors. This research study highlights the increasing need for developing proactive measures for early identification and intervention to address the mental health challenges due to pandemic.},
  keywords={Support vector machines;Accuracy;Machine learning algorithms;Pandemics;Mental health;Predictive models;Depression;Prediction algorithms;Vectors;Decision trees;Pandemic;Stress;Detection;Depression;Naive Bias;K-Nearest Neighbors;Support vector machines;Depression detection},
  doi={10.1109/ICoICI62503.2024.10696584},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{9936814,
  author={Liaw, Aik Seng and Chua, Hui Na},
  booktitle={2022 IEEE International Conference on Artificial Intelligence in Engineering and Technology (IICAIET)}, 
  title={Depression Detection on Social Media With User Network and Engagement Features Using Machine Learning Methods}, 
  year={2022},
  volume={},
  number={},
  pages={1-6},
  abstract={Depression is a complicated mental health disorder with many different forms and symptoms. Traditional methods face barriers when detecting and diagnosing depression, including social stigma and societal labeling. As social media platforms became commonplace for information sharing, their anonymity meant that the barriers had considerably lessened. An alternative method to depression detection being researched is using social media data to build machine learning models for depression detection. To that end, this research uses machine learning models to incorporate new user networks and user engagement features into depression detection on Twitter users. These two features provide an additional understanding of users and may significantly affect depression detection. A Twitter dataset is constructed to include additional data on users' following list and the history of liked tweets not examined in prior studies. Ten machine learning models are constructed using five different machine learning algorithms tested on two sets of features. Models with proposed features outperformed other machine learning models without proposed features, with the best model yielding 82.05% performance for both accuracy and F1 score. This study discovered that the most important feature is the number of depression keywords in liked tweets, with at least twice the gain compared to 88% of other features used. Topic modelling features for liked tweets also have high gain and are important in detecting depression. Additionally, features derived from original tweets, replies, and liked tweets have higher gain and are more important than retweets and quote tweets in detecting depression.},
  keywords={Machine learning algorithms;Social networking (online);Blogs;Information sharing;Machine learning;Mental health;Media;depression detection;social media data analytics;feature extraction;machine learning;data mining;predictive classification},
  doi={10.1109/IICAIET55139.2022.9936814},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{11232614,
  author={Shah, Sanket and Dodiya, Tripti and Prajapati, Nisha},
  booktitle={2025 International Conference on Intelligent Communication Networks and Computational Techniques (ICICNCT)}, 
  title={AI-Based Approaches for Early Detection of Major Depressive Disorder: Technical Roadmap and Future Directions}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Major Depressive Disorder is a highly prevalent and debilitating mental condition, frequently co-occurring with anxiety or sleep disorders and/or suicidal risk. The conventional measures of diagnosis including patient interview and PHQ scores are subjective and ineffective in the early stages of diagnosis. Recent developments in artificial intelligence have introduced the possibility of detecting subtle multimodal biomarkers in EEG, fMRI, speech, facial expressions and Social Media text. The paper provides a survey of the latest AI models-CNN, LSTM, GNN, and multimodal fusion frameworks and outlines a comparative analysis of datasets, methods, and results. Comparative results demonstrate that multimodal methods provide the best accuracy ($94-99.3 \%$), psychosocial models slightly below (99.4 %), and EEG-based models slightly under these ($93-98 \%$) with visual-only performing lowest $(\sim 81 \%)$. The study reviews strengths and limitations and outlines a roadmap for explainable, scalable, and clinically viable AI solutions},
  keywords={Surveys;Systematics;Reviews;Biological system modeling;Brain modeling;Depression;Graph neural networks;Convolutional neural networks;Interviews;Long short term memory;major depressive disorder (MDD);early detection;machine learning (ML);deep learning (DL);convolutional neural networks (CNN);long short-term memory networks (LSTM);graph neural networks;clinical decision support systems (CDSS)},
  doi={10.1109/ICICNCT66124.2025.11232614},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10359295,
  author={Chen, Long-Sheng and Luo, Zi-Jie and Nalluri, Venkateswarlu},
  booktitle={2023 12th International Conference on Awareness Science and Technology (iCAST)}, 
  title={Constructing Depression Prediction Model using ChatGPT and Machine Learning Algorithms}, 
  year={2023},
  volume={},
  number={},
  pages={233-236},
  abstract={Depression is currently one of the main causes of self-harm in human society. However, the insufficient diagnosis of depression has been a long-standing problem. Traditional diagnostic methods heavily rely on the patient’s current emotions, and patients often hesitate to seek help, which frequently delays intervention. With the deep expansion of social media, individuals with suicidal thoughts often express their perspectives and thoughts on these platforms. Relevant studies have also found that people with depression are more likely to disclose their condition. Therefore, there is a potential to enhance the identification of users at risk of suicide by analyzing social media posts. Although machine learning has been successfully applied to build depression prediction models, the brevity of social media posts often affects the classification performance of these models. Hence, this study aims to introduce ChatGPT to automatically generate experimental corpus using information from short comments. Natural language processing (NLP), Support Vector Machines (SVM), and Naive Bayes (NB) classifiers are then employed to enhance the classification accuracy of the depression prediction model. The experimental results validate the effectiveness of the proposed method.},
  keywords={Support vector machines;Machine learning algorithms;Social networking (online);Machine learning;Predictive models;Depression;Chatbots;Depression prediction;Social media;Natural language processing;ChatGPT;Machine learning},
  doi={10.1109/iCAST57874.2023.10359295},
  ISSN={2325-5994},
  month={Nov},}@INPROCEEDINGS{9942363,
  author={Kaseb, Abdelrahman and Galal, Omar and Elreedy, Dina},
  booktitle={2022 4th Novel Intelligent and Leading Emerging Sciences Conference (NILES)}, 
  title={Analysis on Tweets Towards COVID-19 Pandemic: An Application of Text-Based Depression Detection}, 
  year={2022},
  volume={},
  number={},
  pages={131-136},
  abstract={Early depression detection is crucial for both people at risk and the whole society. After the COVID-19 pandemic, the depression level is expected to get higher. Social media is an affluent source of users' opinions and feelings that can be used to detect depression. Depression detection from users' tweets is a challenging task that many researchers have tried to tackle recently as it depends on the whole tweet context. This work introduces a machine learning-based approach for depression detection from tweets. We first obtained a tweets depression detection dataset and use it to train different machine learning and deep learning models for depression detection. We trained some classical machine learning models, then we also fine-tuned the state-of-the-art transformer-based pre-trained language models like BERT, RoBERTa, MobileBERT, and DistilBERT. Our best model was RoBERTa gaining a 78.85 percent F1-score on the test set. This model has then been used to pseudo-label two different datasets of about 4.35 million tweets from about 1 million Twitter users related to COVID-19 and vaccination to gain more deep insights on COVID-19 effect on the depression level of social media users. We show that depression level got doubled from four percent to eight percent from the beginning to the end of March 2020. Depression also increased after nearly two years to reach 15 percent in December 2021. The boosting of the level of depression should be taken into consideration by mental health institutions.},
  keywords={COVID-19;Social networking (online);Pandemics;Mental health;Depression;Transformers;Tag clouds;social media;COVID-19;artificial intelligence;natural language processing;depression detection;sentiment analysis},
  doi={10.1109/NILES56402.2022.9942363},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10990488,
  author={Sood, Tanya and Garg, Punya and Pannu, Husanbir and Dullat, Sonam},
  booktitle={2025 International Conference on Cognitive Computing in Engineering, Communications, Sciences and Biomedical Health Informatics (IC3ECSBHI)}, 
  title={Machine Learning Algorithms and Nlp for Anxiety and Depression Detection Using Twitter Data}, 
  year={2025},
  volume={},
  number={},
  pages={450-455},
  abstract={According to a study published in the Journal of Medical Internet Research, individuals with depression are more likely to use language indicative of sadness, loneliness, and negative emotions on social media platforms. The rise of social media has given us new channels to better understand and combat mental health concerns like depression and anxiety. Many individuals with anxiety or depression may not seek help due to stigma or lack of awareness about their mental health condition. By identifying potential signs through social media, various machine learning methods can facilitate early detection and intervention, potentially preventing the escalation of mental health issues. Here, we apply eight machine learning methods, namely Logistic Regression, K-Nearest Neighbors, Support Vector Machine, Random Forest, Naive Bayes, Decision Tree, Gradient Boosting Machine and AdaBoost for the automated detection of depression and anxiety through Twitter data. We evaluate the performance of different models and compare their accuracies on the task using datasets (DATD_Rand_training and DATD_training) of Twitter posts for depression and anxiety detection. Various model evaluation parameters like precision, accuracy, F1 score, and recall are used to evaluate these machinelearning models. For the first dataset (DATD+Rand_training), the highest accuracy, precision, recall, and F1 scores achieved were 0.926,0.927,0.926 and 0.926, respectively, by the Random Forest Algorithm, and the highest AUC achieved was 0.963 by the Decision Tree Algorithm and Logistic Regression algorithm. For the second dataset (DATD_training) the highest accuracy, recall and F1-score were 0.912,9.12,0.871 by Logistic Regression and Support Vector Machine, precision was 0.871 by K-Nearest Neighbours, AUC was 0.703 was Support Vector Machine. These findings suggest that some models outperform others by a significant margin in detecting depression and anxiety from usergenerated tweets.},
  keywords={Support vector machines;Logistic regression;Accuracy;Machine learning algorithms;Social networking (online);Anxiety disorders;Mental health;Depression;Decision trees;Random forests;Machine learning;social media;anxiety;depression;Twitter;mental health},
  doi={10.1109/IC3ECSBHI63591.2025.10990488},
  ISSN={},
  month={Jan},}@INPROCEEDINGS{10985682,
  author={Gladence, L.Mary and Pranathi, Chukka Saipooja and Raj, Naman and Jenitha, Merlin Mary},
  booktitle={2025 International Conference on Intelligent Computing and Control Systems (ICICCS)}, 
  title={A Comparative Analysis of Depression Detection with and without Natural Language Processing}, 
  year={2025},
  volume={},
  number={},
  pages={726-733},
  abstract={In the recent times, intensifying struggles for sustenance and education, have sharply escalated competitive tensions among individuals, leaving many students especially the adolescents in prolonged states of stress and apprehension, due to the lack of proper guidance, trauma or other aspects leading to a significant surge in mental health issues. The recent advancement in social media like Instagram, Facebook, Twitter, etc. has made the communication easy but also has become something that is offering these teenagers a fresh opportunity or method to release or express their emotions which they might otherwise keep to themselves. This research focuses on analyzing adolescents' Twitter posts for detection of depression. Textual data will be harvested from these posts and transformed into input suitable for machine learning algorithms. Different forms of machine learning algorithms are going to be experimented upon, using and not using NLP— Natural Language Processing, to design a system for the recognition of patterns of depression in individuals.},
  keywords={Support vector machines;Analytical models;Machine learning algorithms;Social networking (online);Blogs;Mental health;Nearest neighbor methods;Depression;Natural language processing;Web sites;Depression recognition;Teenagers;Twitter;Performance measures;Natural Language Processing},
  doi={10.1109/ICICCS65191.2025.10985682},
  ISSN={},
  month={March},}@INPROCEEDINGS{11080903,
  author={Srinivasulu, B. Venkata and Sai Nikhil, P. and Likhitha, G. and Teja, P. Sai},
  booktitle={2025 3rd International Conference on Self Sustainable Artificial Intelligence Systems (ICSSAS)}, 
  title={Identification of Mental Distress in Social Media using Machine Learning}, 
  year={2025},
  volume={},
  number={},
  pages={1003-1008},
  abstract={Mental health related issues like stress, depression and anxiety have risen sharply and this is often shown in the way people interact on social media platforms. Machine learning has been applied to identify such emotional distress in online content, but existing methodologies often suffer from overfitting, reduced accuracy on unseen data, and poor feature representation. In this work, we present an improved machine learning technique for detecting indicators of mental distress from social media posts. We leverage public datasets scraped from Twitter and Reddit that include user-generated posts annotated with degrees of emotional distress. We perform advanced pre-processing, utilize TF-IDF for feature extraction, and classify using SVM, Naive Bayes, and Random Forest algorithms. The Random Forest classifier achieved the highest accuracy (96%), outperforming SVM (92%) and Naive Bayes (89%). Our approach offers significant improvements over earlier studies, including better data cleaning and handling of class imbalance. The proposed system has shown a high degree of reliability and can be scaled for real-time integration into mental health monitoring tools.},
  keywords={Support vector machines;Accuracy;Text analysis;Social networking (online);Blogs;Mental health;Depression;Bayes methods;Reliability;Random forests;Stress detection;Depression analysis;Social media text analysis;Text-based stress detection;Twitter and Reddit datasets},
  doi={10.1109/ICSSAS66150.2025.11080903},
  ISSN={},
  month={June},}@INPROCEEDINGS{9740754,
  author={Begum, Shaik Rasheeda and Sait, Saad Yunus},
  booktitle={2022 International Conference on Computer Communication and Informatics (ICCCI)}, 
  title={Effective Techniques for Depression Detection on Social Media: A Comprehensive Review}, 
  year={2022},
  volume={},
  number={},
  pages={1-9},
  abstract={Currently depression has become one of the common and major public health problems in our society due to changes in lifestyle, high work pressure, persistent illness, loss of beloved ones in life, social and economic crisis due to pandemics, etc. Doctors have traditionally emphasized face-to-face interaction to diagnose depression using clinical depression criteria. Not every patient (less than 30%) would seek medical care in the early stages of depression, and moreover many of them would not accept that they have a mental disorder, leading to delays in remedial measures, and deterioration of symptoms. Failure to detect depression in the early stages has led to suicide in many cases. To address this problem, and take advantage of the abundance of data, machine learning has been used significantly for depression detection in social networks. A variety of machine learning models, features, and media have been used in this area. After data pre-processing, Feature extraction techniques are used to extract psychological factors, Linguistic factors, and emotional factors from Text (LIWC, LDA, word embedding), Image properties, including saturation, color theme, brightness, and color clarity, and transcript text of Audio. Most of the classification algorithms used are supervised learning(SL) algorithms like Support Vector Machines(SVM), Decision Tree(DT), Naïve Bayes(NB), Random Forest(RF), and Neural Networks(NN). The popular metrics considered are ERDE, Precision, Recall, F1-Score, Accuracy, $\boldsymbol{\mathrm{F}_{\text{latency}}}$. This paper presents a study of research for the early identification of depression in social media using machine learning (ML) techniques.},
  keywords={Deep learning;Social networking (online);Image color analysis;Biological system modeling;Text categorization;Support vector machine classification;Depression;Supervised Learning;Depression detection;Social Media;Machine Learning},
  doi={10.1109/ICCCI54379.2022.9740754},
  ISSN={2329-7190},
  month={Jan},}@INPROCEEDINGS{10440733,
  author={Eswar, Thotakura and Varshini, U. Shivani Sri and Kumar, Vishnu and Srinivas, M and Krishna, P. Radha},
  booktitle={2023 IEEE 20th India Council International Conference (INDICON)}, 
  title={FTDD: Representation Learning using Fourier Transformations for Depression Detection in Social Media Content}, 
  year={2023},
  volume={},
  number={},
  pages={1317-1322},
  abstract={Depression is a prevalent and substantial mental health challenge worldwide, and its presence is frequently noticeable through textual posts on various online social media platforms. In the current internet era, text is highly ambiguous and often encompasses various emotions. Current depression detection solutions lack privacy and robustness. We introduce a "Transformation block" that provides the privacy by transforming the embedding of text into different format while holding the actual semantics of the text to analyse the characteristics of depressive posts. Proposed block allows the deep learning models to identify linguistic markers of depression results in significant improvement of the performance of depression detection. The experimental evaluations and comparative analysis demonstrate the potential of the proposed transformation block in enhancing depression detection, thus offering a promising avenue for addressing mental health concerns through online platforms.},
  keywords={Representation learning;Privacy;Social networking (online);Semantics;Mental health;Depression;Robustness;Depression Detection;Text Classification;Social Media;Fourier Transformations;Deep Learning},
  doi={10.1109/INDICON59947.2023.10440733},
  ISSN={2325-9418},
  month={Dec},}@INPROCEEDINGS{10006146,
  author={Jin, Shangzhu and Xue, Run and Peng, Jun and Zhao, Yan and Yin, JieRui},
  booktitle={2022 IEEE 17th Conference on Industrial Electronics and Applications (ICIEA)}, 
  title={Combing TF-IDF with machine learning to detect depression in Microblog}, 
  year={2022},
  volume={},
  number={},
  pages={1454-1458},
  abstract={Aiming at the problem that depression has become severe social problems and most of patients can not be diagnosed early. As social media has become popular in the world like Chinese microblogs and twitters, a large amount of data can be used for the researches, especially the contents published originally can be used to detect whether publisher is depressed. However, depression prediction is not the same as text classification, it is difficult to find a unified standard to determine depression. In this regard, a method combining machine learning and TF-IDF is proposed. The method treats micro-blog contents as a whole to generate features to predict whether the micro-blog users get depressed. The experiment shows that the proposed method can effectively identify potential depressive patients among micro-blog users.},
  keywords={Industrial electronics;Vocabulary;Costs;Social networking (online);Blogs;Text categorization;Machine learning;Depression detection;machine learning;emotional dictionary;text classification},
  doi={10.1109/ICIEA54703.2022.10006146},
  ISSN={2158-2297},
  month={Dec},}@INPROCEEDINGS{10690434,
  author={I V, Chaithra and M R, Sunitha},
  booktitle={2024 Second International Conference on Advances in Information Technology (ICAIT)}, 
  title={An Analysis and Detection of Depression from Textual Data using Deep Learning Methods}, 
  year={2024},
  volume={1},
  number={},
  pages={1-5},
  abstract={Depression is a prevalent sickness, spreading worldwide with potentially serious implications. Timely recognition of emotional responses plays a pivotal function at present. Mental ill health is highly risky, stirring more than 300 million population. Because of this reason more focus of research is on this area. A statement by American Psychiatric Association “6.715 adults (6.70%) is get affected in any given year. One-sixth of people(16.6%) will experience depression in their life.” Studies said that Women are in greater proportion to likely experience depression when compared to men. One among three women will share a significant depressive symptoms in their lifetime. Written text reflects its impact on language usage. The count of afflicted individuals can be lessened, using an advanced machine learning techniques and the availability of test data related to depression. This paper proposes different preprocessing techniques. Feature extraction techniques such as BoW(Bag of Words), Word2Vec, Glove, N-Gram, LIWC and LDA. Classification techniques such as Naive Bayes, SVM, LR, Adaboost and RF},
  keywords={Support vector machines;Deep learning;Emotion recognition;Mental health;Media;Depression;Feature extraction;Bayes methods;Emotional responses;Information technology;Depression;Feature Extraction;Bag of Words;Social Media Data;Naïve Bayes;Adaboost},
  doi={10.1109/ICAIT61638.2024.10690434},
  ISSN={},
  month={July},}@INPROCEEDINGS{10991025,
  author={Yaqub Khan, Furqan and Muzafar Khanday, Danish and Qadir Mir, Abrar and Ayoub Shaikh, Tawseef},
  booktitle={2025 International Conference on Cognitive Computing in Engineering, Communications, Sciences and Biomedical Health Informatics (IC3ECSBHI)}, 
  title={Machine Learning Algorithms for Depression Detection and Their Comparison}, 
  year={2025},
  volume={},
  number={},
  pages={76-80},
  abstract={Depression is one of the most common mental health disorders that afflict people and productivity in society. This paper explores automatic depression detection using user-generated content on social media. Using machine learning and deep learning models, we thus design an efficient classifier system trained on a balanced set of depressive and non-depressive social media posts. We put together in our study techniques that have been learned from the SVM, random forest classifier, multinomial naïve Bayes, and long short-term memory network as well as the advanced methods of word embeddings such as Word2Vec and BERT. The models are classifying with accuracy ranging between 70% and 81.79%, offering scalability for the early stages of identification for depression. This result brings up the potential of AI to help advance diagnostics in mental health.},
  keywords={Deep learning;Support vector machines;Productivity;Machine learning algorithms;Social networking (online);Scalability;User-generated content;Mental health;Depression;Random forests;Emotion Artificial Intelligence;Deep Learning;Machine Learning Algorithms;Word Embedding;Twitter},
  doi={10.1109/IC3ECSBHI63591.2025.10991025},
  ISSN={},
  month={Jan},}@INPROCEEDINGS{10665216,
  author={Jin, Shangzhu and Tang, Zheng and Peng, Jun and Han, Xiaoqi},
  booktitle={2024 IEEE 19th Conference on Industrial Electronics and Applications (ICIEA)}, 
  title={A Novel Improved BILSTM Method for Depression Detection on Social Media}, 
  year={2024},
  volume={},
  number={},
  pages={1-5},
  abstract={Depression has become a serious problem in contemporary society, with the number of affected individuals growing daily. However, although some people are aware that they suffer from depression, there are still many who are not aware of it. On the other hand, keywords such as “depression,” “machine learning algorithms,” “sentiment analysis,” and “social media” frequently appear. The rise of social media has turned into a ‘diary’ for people to share their mental states. Machine learning algorithms are used to categorize data to distinguish between depressed and non-depressed data. The goal is to use the data posted by users on social media to identify their depressive state. This tweet data is then fed into multiple classifiers. In order to find the most suitable algorithm for detecting depression, we will compare the results based on the highest accuracy value. Based on our discussion on depression in this paper, we utilized an improved bi-directional long short-term memory model (BILSTM) approach. One improvement was the addition of a word vector embedding model, which can better resolve the text sparsity issue. The second was the inclusion of an attention mechanism in the model, making it more capable of generalization and able to handle the classification of depression texts.},
  keywords={Sentiment analysis;Machine learning algorithms;Accuracy;Social networking (online);Noise reduction;Depression;Tag clouds;Depression;Machine learning;Deep learning;Text analysis},
  doi={10.1109/ICIEA61579.2024.10665216},
  ISSN={2158-2297},
  month={Aug},}@INPROCEEDINGS{11102166,
  author={Srivastav, Akarsh and Sachdeva, Vrinda and Gera, Anju},
  booktitle={2025 International Conference on Networks and Cryptology (NETCRYPT)}, 
  title={Ensemble Machine Learning for Anxiety, Depression, and Panic Attack Detection: A Stacking-Based Approach}, 
  year={2025},
  volume={},
  number={},
  pages={596-600},
  abstract={Anxiety, sadness, panic attacks and other psychological issues greatly lead to negative conditions pertaining to mental health. Because of the overlapping symptoms, it gets highly difficult to distinguish them from one another. The dataset consists of numerical replies provided by 4,184 people diagnosed by a French university, and the study, addressed to people older than 18 years of age, sees this as its problem. The class imbalance issue was tackled using by the Synthetic Minority Over-sampling Technique (SMOTE) that guarantees all important classes are fairly represented. This was followed by classification performance improvement through a stacking ensemble learning framework that combines Random Forest (RF), Support Vector Machine (SVM), K-Nearest Neighbors (KNN), and AdaBoost classifiers. Results show that the best-performing psychological state predictors are the ensemble one, with highest accuracy against individual classifiers.},
  keywords={Support vector machines;Radio frequency;Accuracy;Anxiety disorders;Stacking;Mental health;Nearest neighbor methods;Depression;Ensemble learning;Random forests;Support Vector Machine;RFE;Random forest;depression;anxiety;Machine learning;SMOTE;cross validation;$KNN$.},
  doi={10.1109/NETCRYPT65877.2025.11102166},
  ISSN={},
  month={May},}@INPROCEEDINGS{11160144,
  author={Absar, Nurul and Siam, Tanvinur Rahman and Islam, Md. Mahbubul and Kayum, Abdul},
  booktitle={2025 2nd International Conference on Next-Generation Computing, IoT and Machine Learning (NCIM)}, 
  title={Transformer and Deep Learning-based Depression Detection from Low-Resource Language}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Depression detection in low-resource languages, such as Bangla, is an emerging challenge in mental health research due to the limited availability of labeled datasets and NLP resources. Bangla, the seventh most spoken language globally, is used by over 230 million people, yet it remains underrepresented in natural language processing (NLP) research compared to high-resource languages like English. In this study, we present a Bangla depression detection dataset collected from social media comprising 18,612 text samples, with 8556 labeled as depressive and the remaining as non-depressive. To effectively classify depressive content, we explore multiple deep learning architectures, including Long Short-Term Memory (LSTM), Bidirectional LSTM (BiLSTM), Gated Recurrent Unit (GRU), and Bidirectional GRU (BiGRU). Additionally, we evaluate state-of-the-art transformer-based models such as BanglaBERT, BanglaBERT-Base, ELECTRA, RoBERTa, and BERT. Machine learning models are also employed as baselines for comparison. Our experimental results show that transformer-based models outperform both deep learning and machine learning approaches, with BanglaBERT achieving the highest accuracy of 89.23%, followed closely by BiLSTM with 88%. These findings highlight the effectiveness of transformer-based architectures in depression detection for Bangla text, contributing to improved mental health analysis in low-resource language settings. This study emphasizes the need for further NLP advancements in Bangla to develop AI-driven solutions for early depression detection and intervention.},
  keywords={Deep learning;Accuracy;Social networking (online);Bidirectional long short term memory;Gated recurrent units;Mental health;Transformers;Depression;Encoding;Next generation networking;Depression detection;Deep learning;Natural Language processing;Bangla;Social Media},
  doi={10.1109/NCIM65934.2025.11160144},
  ISSN={},
  month={June},}@INPROCEEDINGS{11256322,
  author={Sinhal, Arpana and Sinhal, Anay and Sinhal, Amit},
  booktitle={2025 IEEE International Conference on Contemporary Computing and Communications (InC4)}, 
  title={Contrastive Learning and Large Language Models for Depression Detection from Social Media}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Depression is a global mental health concern, often expressed subtly through social media platforms like Reddit and Twitter. This study explores the application of contrastive learning with large language models (LLMs) for depression detection, utilizing annotated data from the DepressionEmo dataset. Advanced computational techniques, including natural language processing (NLP) and machine learning models like SVM, LightGBM, XGBoost, and deep learning models such as GAN-BERT, BERT, and BART, are employed. By leveraging contrastive learning and data augmentation, the models demonstrate improved precision, recall, and F1-scores. This research addresses gaps in data diversity and contextual understanding, offering scalable, ethical solutions for real-time mental health monitoring and intervention.},
  keywords={Sentiment analysis;Translation;Social networking (online);Computational modeling;Large language models;Contrastive learning;Mental health;Depression;Data models;Monitoring;Contrastive Learning;Large Language Models (LLMs);Natural Language Processing (NLP);SVM;LightGBM;XGBoost;GAN-BERT;BERT;BART;Social Media Analysis;Multimodal Emotion Analysis;Mental Health Monitoring;Sentiment Analysis},
  doi={10.1109/InC465408.2025.11256322},
  ISSN={},
  month={March},}@INPROCEEDINGS{11040647,
  author={S, Sreeji and C P, Shirley},
  booktitle={2025 3rd International Conference on Artificial Intelligence and Machine Learning Applications Theme: Healthcare and Internet of Things (AIMLA)}, 
  title={From Data to Diagnosis: A Review of Machine Learning Models for Postpartum Depression Prediction}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={A common mental health condition that affects new mothers, postpartum depression (PPD) has serious repercussions for the health of both the unborn child's and the mother's health. To lessen its effects, early detection and action are essential. By examining a variety of data sources, such as demographic data, electronic health records (EHR), social media activity, wearable sensor data, and genetic markers, machine learning (ML) models have become increasingly effective tools for predicting PPD in recent years. The methodologies, datasets, feature selection strategies, and predictive performance of several ML-based PPD prediction models are all compared in this review. Also examined at the difficulties these models present, such as biases in training datasets, data privacy, and interpretability and compared the Performance (AUC, Accuracy, etc.).},
  keywords={Training;Data privacy;Analytical models;Accuracy;Reviews;Medical services;Predictive models;Depression;Data models;Wearable sensors;PPD Prediction;HER;Machine Learning;AUC},
  doi={10.1109/AIMLA63829.2025.11040647},
  ISSN={},
  month={April},}@INPROCEEDINGS{11309591,
  author={Rochman, Mochamad Yovi Fatchur and Supangat and Saringat, Zainuri Bin},
  booktitle={2025 Tenth International Conference on Informatics and Computing (ICIC)}, 
  title={Optimizing SVM with Particle Swarm and Hybrid Feature Extraction for Enhanced Depression and Suicide Detection from Social Media Data}, 
  year={2025},
  volume={},
  number={},
  pages={1-4},
  abstract={Depression and suicide represent critical mental health challenges, with growing occurrences globally that urgently require accurate, scalable detection methods. Social media, a prevalent platform for emotional expression, provides rich textual data to identify mental health indicators through advanced computational approaches. This study proposes a novel hybrid approach combining Support Vector Machine (SVM) optimized by Particle Swarm Optimization (PSO) and a hybrid feature extraction strategy, integrating Term Frequency-Inverse Document Frequency (TF-IDF), CountVectorizer, and Word2Vec. Using a comprehensive dataset of 233,337 posts labeled for depression and suicide, our optimized model significantly enhanced classification accuracy, outperforming conventional SVM by 0.41% (91.44% to 91.85%). The integration of semantic, frequency, and relevance-based text features demonstrates superior predictive capabilities, highlighting the critical impact of PSO parameter optimization. This research contributes a robust methodological framework for early detection of depression and suicide, offering promising implications for proactive mental health interventions through real-time social media analytics.},
  keywords={Support vector machines;Accuracy;Social networking (online);Computational modeling;Semantics;Mental health;Depression;Feature extraction;Real-time systems;Particle swarm optimization;depression detection;suicide prevention;social media analytics;support vector machine;particle swarm optimization;hybrid feature extraction;tf-idf;countvectorizer;word2vec},
  doi={10.1109/ICIC68054.2025.11309591},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{11089777,
  author={Dadi, Ramesh and Sai, Gaddam and Vamshikirishna, Adapala},
  booktitle={2025 6th International Conference on Inventive Research in Computing Applications (ICIRCA)}, 
  title={Depression Prediction Using Machine Learning: A Comparative Study}, 
  year={2025},
  volume={},
  number={},
  pages={1504-1508},
  abstract={This paper discusses in detail some of the various machine learning models applied in predicting the depression of human. Depression is a widespread and incapacitating mental health condition that impacts individuals globally, resulting in significant personal, social, and economic challenges. The timely identification and effective management of depression are considered crucial in terms of the prevention of its adverse effects and quality of life in general. The paper deals with advanced methodologies of depression analysis and prediction by machine learning models and big data analytics. In our approach, we integrated diverse data sources, such as demographic profiles, socioeconomic factors, behavioral indicators, and patterns of digital activity, for improving the precision of depression forecasting systems. And this paper covers some of the current intense challenges in its areas, including concerns over data integrity, ethical implications, and the enhancement of interdisciplinary collaboration among mental health professionals, data scientists, and policymakers. The study is also exploring innovative strategies such as the incorporation of genetic and genomic data, social media analytics for real-time monitoring, and application of mobile health technologies for personal and intense interventions approaches.},
  keywords={Accuracy;Biological system modeling;Computational modeling;Medical services;Machine learning;Mental health;Predictive models;Depression;Tuning;Genetic algorithms;machine learning;depression prediction;classification;SVM;optimization},
  doi={10.1109/ICIRCA65293.2025.11089777},
  ISSN={},
  month={June},}@INPROCEEDINGS{10421064,
  author={Jha, Manish kumar and Ranjan, Rakesh and Dixit, Gireesh Kumar and Kumar, Krishna},
  booktitle={2023 International Conference on Communication, Security and Artificial Intelligence (ICCSAI)}, 
  title={An Efficient Machine Learning Classification with Feature Selection Techniques for Depression Detection from Social Media}, 
  year={2023},
  volume={},
  number={},
  pages={481-486},
  abstract={The emergence of Facebook, Instagram, and Twitter among other social media sites has profoundly altered our daily routines. With more people online than ever before, it's easy to establish a unique persona in cyberspace. The positive aspects of social media are undeniable, but the negative aspects of its use are also rather evident. More time spent on social media is associated with a higher risk of getting depression, according to recent research. Depressive symptoms include a persistently low mood and a loss of interest in previously enjoyed activities. Distinct mental health issues may have far-reaching effects, and severe depression, sometimes called major depression, is no exception. This research looks at two distinct machine learning classifiers that can tell whether a person is sad based on various demographic and psychological factors. Further, feature selection techniques such as recursive feature elimination with linear regression have select the most important characteristics from the dataset. RFC and GBC were utilized to improve the precision with which depression could be predicted. This technique is a machine learning (ML)-based prediction strategy for diagnosing depression and other mental diseases early. In addition, numerous models have had their F1-score, sensitivity, accuracy, specificity, and AUC calculated to see which is best for identifying episodes of depression. Higher accuracy (96%) was shown in diagnosing of depression using the ML algorithm.},
  keywords={Sensitivity;Social networking (online);Machine learning;Mental health;Depression;Feature extraction;Web sites;Depression Detection;Random Forest;Machine Learning;Gredient Boosting;Recursive Feature Elimination;ADASYN;Linear Regression},
  doi={10.1109/ICCSAI59793.2023.10421064},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{10263004,
  author={Subedy, Aaditya Narayan and Khan, Mohammad Arif and Kuldiloke, Nitiwit and Katarya, Rahul},
  booktitle={2023 IEEE International Conference on Contemporary Computing and Communications (InC4)}, 
  title={Depression Detection Through User’s Social Network Interactions}, 
  year={2023},
  volume={1},
  number={},
  pages={1-6},
  abstract={Depression is a medical condition that causes mood disorders making the person feel sad or have no interest in things they usually liked to do. In our society, depression has become a significant health issue that people typically do not address. A person might fall into depression because of past events, the loss of a loved one, economic problems, or other reasons. For our survey, we needed to choose relevant papers on depression. The selection of the documents was a rigorous process, as the research papers had to undergo a thorough screening to ensure they were relevant to our survey. In this survey paper, various approaches other scholars took toward detecting depression were studied and analyzed. We have prepared a comparative survey between Deep Learning (DL) and Machine Learning (ML) models pinpointing the differentiating factors. After reviewing the shortlisted documents, common limitations are identified in almost all the research work conducted thus far. After completing this survey, we conclude that analyzing a user’s data from their social media platform will help find out whether they are depressed or not. We can see the changes in a person’s behavior over a while through social media interactions. We also found that DL models were superior to ML models when the size of the datasets increased.},
  keywords={Surveys;Economics;Deep learning;Social networking (online);Mood;Biological system modeling;Computational modeling;Deep Learning;Depression;Depression Detection;Machine Learning;Social Media},
  doi={10.1109/InC457730.2023.10263004},
  ISSN={},
  month={April},}@INPROCEEDINGS{11340553,
  author={Tharun, E. and Mohebbanaaz and Reddy, P Sandeep Kumar},
  booktitle={2025 International Conference on Electrical, Electronics, and Computer Science with Advance Power Technologies - A Future Trends (ICE2CPT)}, 
  title={Emotion Aware AI Techniques for Identification Depression via Social Media Platforms}, 
  year={2025},
  volume={},
  number={},
  pages={1-4},
  abstract={There are more than 300 million people suffering from depression worldwide. More people are utilizing social networks to convey their thoughts, sentiments, and emotions as they have risen in popularity. If a person's depression can be identified early by the analysis of their post and by taking the required precautions, they can be prevented from depression-related diseases or, in the best-case scenario, from suicide. Artificial intelligence-based emotion recognition is an emerging field in text mining especially in the detection of mental illnesses such as depression in the social networks. The data has both balanced and imbalanced samples, which allows the comparative analyses of different clustering methods to be carried out. In this paper, three machine learning classifiers, including Naive Bayes (NB) and Random Forest (RF) and Long Short-Term Memory (LSTM) were used to classify depression on Twitter data. The LSTM model was the best performing among them as it achieved better results with respect to accuracy, precision, recall and F1-score on both balanced and imbalanced datasets.},
  keywords={Radio frequency;Text mining;Performance evaluation;Accuracy;Social networking (online);Depression;Market research;Bayes methods;Long short term memory;Random forests;Depression;Emotion Artificial Intelligence;LSTM;RF;NB;social network},
  doi={10.1109/ICE2CPT66440.2025.11340553},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10089342,
  author={Vahdati, Farahnaz and Atif, Amara and Saberi, Morteza},
  booktitle={2022 IEEE Asia-Pacific Conference on Computer Science and Data Engineering (CSDE)}, 
  title={A machine learning-based depression detection on social media platforms for adolescents: A work in progress narrative review}, 
  year={2022},
  volume={},
  number={},
  pages={1-6},
  abstract={A rise in depression episodes has prompted an increased focus on depression detection. This research paper aims to review the literature to discover the pros and cons of proposed solutions for this critical social problem. In this narrative review, specifically, we looked at machine learning (ML) based techniques that analyse text data from social media to diagnose depression symptoms. A thorough search technique across several databases for relevant articles, specifically Google Scholar, PubMed, Medline, ERIC, PsycINFO, and BioMed databases, were used to perform a narrative evaluation. Terms and definitions were used to filter the article titles, abstracts, and full texts. Approaches based on machine learning and text data from social media may be helpful in the diagnosis of depression and might be used in conjunction with other mental health services.},
  keywords={Emotion recognition;Machine learning algorithms;Social networking (online);Databases;Mood;Machine learning;Mental health;adolescent;deep learning;depression detection;machine learning;social media;teenagers},
  doi={10.1109/CSDE56538.2022.10089342},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{9763147,
  author={Gupta, Gaurav Kumar and Sharma, Dilip Kumar},
  booktitle={2022 9th International Conference on Computing for Sustainable Global Development (INDIACom)}, 
  title={A Review of Overfitting Solutions in Smart Depression Detection Models}, 
  year={2022},
  volume={},
  number={},
  pages={145-151},
  abstract={Overfitting is a common issue in machine learning-based depression detection model. Overfitting occurs when a machine learning model uses garbage data in the training datasets to the amount that deleteriously impacts on the concert of the model on new data. To predict depression level, most of the model uses machine learning and deep learning approaches. In this paper, a survey is conducted on the solution of overfitting in machine learning-based depression detection models. The survey covers the latest research articles and thesis published in the years 2020 and 2021. The findings of the survey reveal that the early stopping methodology, also called Control the Iteration as is better as compared to the penalty methodology, as it can avoid overfitting problems in the machine learning-based depression detection model. We have listed down other methods also to reduce overfitting like regularization methods, applying ensemble learning, training with more data, cross-validation, etc.},
  keywords={Training;Deep learning;Machine learning algorithms;Pandemics;Social networking (online);Soft sensors;Predictive models;Artificial Intelligence;Machine Learning;Depression Analysis;Text Analysis;Overfitting},
  doi={10.23919/INDIACom54597.2022.9763147},
  ISSN={},
  month={March},}@INPROCEEDINGS{11376912,
  author={Asthana, Yashvardhan},
  booktitle={2025 Global Conference on Information Technology and Communication Networks (GITCON)}, 
  title={Comparative Analysis of Centralized and Federated Logistic Regression for Depression Detection Using Twitter and Reddit Data}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Depression, a pervasive mental health disorder, increasingly manifests through linguistic patterns on social media platforms. This study presents a comparative evaluation of centralized and federated learning frameworks for depression detection, utilizing logistic regression on two curated textual datasets—Twitter and Reddit. After meticulous analysis, data preprocessing, and a stratified 4:1 train-test split, models were trained under both paradigms. Centralized learning leveraged pooled data, while federated learning across decentralized clients without transmitting raw data, thereby enhancing privacy preservation. Empirical results show that centralized models outperform federated counterparts across both platforms, particularly on the smaller and noisier Twitter dataset. However, federated learning achieves competitive accuracy on the Reddit dataset and offers a compelling alternative where data confidentiality is paramount. These findings highlight the trade-off between model performance and data confidentiality, reinforcing the potential of federated learning in scalable, privacy-aware mental health monitoring systems.},
  keywords={Data privacy;Logistic regression;Sentiment analysis;Social networking (online);Federated learning;Blogs;Mental health;Depression;Data models;Monitoring;Federated Learning;Centralized Learning;Logistic Regression;Comparative Analysis;Depression Detection;Mental Health;Social Media;Twitter;Reddit;Natural Language Processing;Machine Learning;Sentiment Analysis;Data Privacy},
  doi={10.1109/GITCON65266.2025.11376912},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{11258944,
  author={K, Ranganatha and Rananavare, Laxmi B.},
  booktitle={2025 IEEE International Conference on Distributed Computing, VLSI, Electrical Circuits and Robotics (DISCOVER)}, 
  title={A Comprehensive Survey on Depression Detection Through Social Media Using Machine Learning and NLP Techniques}, 
  year={2025},
  volume={},
  number={},
  pages={421-426},
  abstract={Depression is an enormous worldwide mental illness challenge that impacts tens of millions of individuals in their daily activities. As social media becomes a way of life, Digital interactions on social media have become fertile grounds for observing emotional patterns and behavioral inclinations. Here, scientists are increasingly applying machine learning (ML) and natural language processing (NLP) techniques to identify symptoms of depression from social media posts. This paper provides an exhaustive review of such strategies, discussing their value in promoting mental health research. It discusses the application of deep learning, sentiment analysis, and data-oriented approaches on various datasets, emphasizing their advantages and disadvantages. The research also assesses prevailing models and performance measures, highlighting computational complexity, data privacy, and lack of generalizability as issues. Through an identification of the main gaps in prevailing methods, this survey offers guidance for building more robust, ethical, and interpretable systems for detecting depression.},
  keywords={Surveys;Deep learning;Sentiment analysis;Ethics;Social networking (online);Reviews;Mental health;Very large scale integration;Depression;Robots;Depression Detection;Machine Learning;Natural Language Processing;Deep Learning;Social Media Analysis;Sentiment Analysis},
  doi={10.1109/DISCOVER66922.2025.11258944},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10718376,
  author={Begum, Shaik Rasheeda and Yunus Sait, Saad},
  booktitle={2024 Third International Conference on Electrical, Electronics, Information and Communication Technologies (ICEEICT)}, 
  title={Machine Learning-Based Depression Detection via Twitter Metadata}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={Depression, a common and major disorder is affecting a large number of individuals and has emerged as the main cause of a public health problem that needs the most attention. Serious emotional disorders, behavioral problems, and physical health issues brought on by depression can have a worse and costlier impact on a person’s health and also lead to suicide. In today’s modern era, everybody is having access to social Networks through which users share their feelings, thoughts, ideas, emotions, and struggles in life on a daily basis. Thus, the content generated by the user such as posts from social networking sites (SNSs) may be used to detect the depressive disorder in a non-intrusive manner using Natural Language Processing (NLP) and Machine Learning (ML). In this work, metadata information that Twitter offers about its users, such as the user's description can provide important details about the individuals' mental health. The dataset considered here is a benchmarked depression dataset. Here we develop different machine-learning models such as LR, RC, SVM, KNN, NB, DT and RF to detect depression using Twitter’s metadata and Sentiments. SVM offers the best performance with 71.14 % Accuracy using GLOVE embedding.},
  keywords={Support vector machines;Sentiment analysis;Accuracy;Machine learning algorithms;Social networking (online);Blogs;Metadata;Nearest neighbor methods;Depression;Public healthcare;Depression detection;Twitter Metadata;Supervised Learning;Natural Language Processing},
  doi={10.1109/ICEEICT61591.2024.10718376},
  ISSN={},
  month={July},}@ARTICLE{10757425,
  author={Angskun, Thara and Tipprasert, Suda and Thippongtorn, Atitthan and Angskun, Jitimon},
  journal={IEEE Access}, 
  title={D₂X: Depression Detection System Through X Using Hybrid Machine Learning}, 
  year={2024},
  volume={12},
  number={},
  pages={172820-172831},
  abstract={Currently, there is an increasing prevalence of depression among Thai people, often expressed through social media. Unfortunately, many individuals suffering from depression are unaware of their condition. This article introduces a depression detection system through  $\mathbb {X}$  called  $D_{2}\mathbb {X}$ , which utilizes sentiment analysis of  $\mathbb {X}$  users’ tweets to predict their level of depression. The  $D_{2}\mathbb {X}$  processes various types of tweets, including text messages, emoticons, and images, using a hybrid machine learning approach that combines support vector machine and random forest techniques. The study showed that combining text with emoticons resulted in the highest performance. Additionally, the research revealed that the most crucial feature for predicting levels of depression is the text tweets. Emoticon and image tweets were also found to enhance the effectiveness of detecting depression. The  $D_{2}\mathbb {X}$  model, utilizing all types of tweet data, achieved the highest F-measure compared to other machine learning techniques. However, when using only the text messages from tweets, the  $D_{2}\mathbb {X}$  model showed marginally lower performance than DistilBERT but outperformed other deep learning techniques. The  $D_{2}\mathbb {X}$  also had the least model construction and usage time.},
  keywords={Depression;Social networking (online);Predictive models;Data models;Sentiment analysis;Accuracy;Support vector machines;Machine learning;Solid modeling;Bayes methods;Depression detection;hybrid machine learning;sentiment analytics;tweet},
  doi={10.1109/ACCESS.2024.3502241},
  ISSN={2169-3536},
  month={},}@ARTICLE{10540133,
  author={Abdullah, Mohammed and Negied, Nermin},
  journal={IEEE Access}, 
  title={Detection and Prediction of Future Mental Disorder From Social Media Data Using Machine Learning, Ensemble Learning, and Large Language Models}, 
  year={2024},
  volume={12},
  number={},
  pages={120553-120569},
  abstract={Social media platforms are used widely by all people to express their feelings, opinions, and emotional states. Billions of people worldwide use them daily to share what they think and feel in their posts. Amongst all social media available platforms, Facebook only contains around three billion personal accounts. In this work Reddit dataset is used to automatically detect mental illness from social media posts. This study is not only limited to early detection of already existing mental illness or disorder like depression and anxiety from social posts, but also and most importantly the study is extended to predict successfully potential mental illness that would happen in future. This study deploys Nineteen different models to study the capability of them in detecting and predicting mental disorders from social media posts. Some of the deployed models are classical machine learning classifiers, some are ensemble learning models, and the rest are large language models (LLMs). Six machine learning classifiers were used in this work for the automatic detection and prediction of mental illness and logistic regression proved to be the best amongst other classifiers in this task. Nine Ensemble methods were also used and examined. Amongst the Nine ensemble learning models VC2, Light GBM, Bagging estimator, and XGBoost proved to be superior in this task. Four large language models were also used and examined for the same task. RoBERTa and OpenAI GPT proved to outperform the rest of models in this task. All those models were built, trained, tested, and compared with previous work in literature to get the best possible results. The study covers the main four mental disorders which are ADHD, Anxiety, Bipolar, and Depression. The work proposed in this paper succeeded in outperforming the results in literature in terms of number of addressed mental disorders, number of models used and tested, and dataset size used to validate results. The proposed work also outperformed the only attempt in literature that addressed all mental disorders in results of detection and prediction noticeably. This work achieved the detection of already existing mental disorders F1-score of 0.80 from clinical data and of 0.52 from non-clinical data, and it achieved a prediction of future mental disorder F1-score of 0.43 from non-clinical data.},
  keywords={Social networking (online);Depression;Anxiety disorders;Support vector machines;Mental health;Ensemble learning;Predictive models;ADHD;anxiety;bipolar;mental illness classification;depression detection;depression prediction;Reddit},
  doi={10.1109/ACCESS.2024.3406469},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{10581373,
  author={Saleem, Maryam and Afzal, Hammad},
  booktitle={2024 International Conference on Engineering & Computing Technologies (ICECT)}, 
  title={A Review of Mental Health Analysis Through Social Media Using Machine Learning and Deep Learning Approaches}, 
  year={2024},
  volume={},
  number={},
  pages={1-7},
  abstract={Artificial intelligence has the potential to transform health care. For that purpose, machine learning (ML) and deep learning (DL) algorithms have been used in the prediction and diagnosis of many diseases. Many people across the world use social media platforms like Twitter, Facebook, Reddit, etc, more often to express their feelings. Mental health has become a big concern after the COVID-19 pandemic and many researchers have applied various ML and DL algorithms to social media data for mental health prediction and analysis. The purpose of this study is to provide a comprehensive analysis of ML and DL algorithms that have been used in the prediction of various mental disorders. This study provides a diverse review of 37 selected research papers. From the selected literature, an accuracy table of ML and DL algorithms for four mental disorders (Depression, Anxiety, Bipolar& ADHA) has been analyzed and created. This study aims to help researchers and practitioners in the future by providing a baseline of the performance of various ML and DL algorithms. Furthermore, we provide a list of publicly available datasets that will act as a knowledge base for future researchers.},
  keywords={Deep learning;Machine learning algorithms;Systematics;Social networking (online);Reviews;Mental disorders;Mental health;Machine Learning(ML);Deep Learning (DL);Mental Disorders;BERT;RoBERTa},
  doi={10.1109/ICECT61618.2024.10581373},
  ISSN={},
  month={May},}@INPROCEEDINGS{10939483,
  author={Rahman, Nuzhat and Jashim, Fariha Binta and Sultana, Zinnia},
  booktitle={2024 International Conference on Innovations in Science, Engineering and Technology (ICISET)}, 
  title={Exploring Machine Learning Approaches for Stress Detection in Reddit Content: An Evaluation of Performance and Effectiveness}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={Depression is a serious mental health condition that is difficult to diagnose, particularly in social media settings. The goal of this research is to enhance early intervention and prevention efforts by creating a machine learning model for identifying depression in Reddit posts. Evaluating the efficacy of various machine learning methods in stress detection is the aim of this research project. By examining Reddit Contents, this assessment seeks to advance the creation of an automated system for the early diagnosis of depression. ‘clean text’ is the raw text data from Reddit posts, and ‘is depression’ is the target variable in this dataset that was gathered for the study. To extract features, count vectorization is used in this instance. Using the training and testing sets, four machine learning algorithms-SVM, Random Forest, Naive Bayes, and KNN are trained and assessed. By utilizing a VotingClassifier with hard voting, an ensemble model is constructed. With 99.93% accuracy on the training set and ${9 5. 5 4 \%}$ accuracy on the test set, the Random Forest model proved to be the most accurate of all the models. This study shows how machine learning algorithms and ensemble approaches can be used to identify depression in Reddit posts. The ensemble model offered a marginally improved accuracy, although the Random Forest and SVM models fared the best. These findings suggest that machine learning is a useful technique for helping mental health professionals recognize and treat depression in virtual environments.},
  keywords={Support vector machines;Training;Accuracy;Machine learning algorithms;Social networking (online);Virtual environments;Mental health;Depression;Ensemble learning;Random forests;Depression;Reddit Posts;ensemble technique;SVM;Random Forest;early intervention;mental health},
  doi={10.1109/ICISET62123.2024.10939483},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10397610,
  author={Salunkhe, Yash and Yeole, Shruti and Suryawanshi, Siddhesh and Belhe, Adityaraj and Wade, Riddhi and Ainapure, Bharati},
  booktitle={2023 6th International Conference on Contemporary Computing and Informatics (IC3I)}, 
  title={Detecting Depression Level Scale from Social Media Text and Images Using Machine Learning Algorithms}, 
  year={2023},
  volume={6},
  number={},
  pages={912-918},
  abstract={Millions of individuals worldwide struggle with depression, which is a serious mental health issue. The quality of life of those with depression can be greatly enhanced by early detection and management. The objectives of this study were:(i) Develop a machine learning and deep learning approach to identify depression levels from social media text and images. (ii) Use the Hamilton Rating Scale for Depression as the classification tool for detecting the extremity of depression. (iii) Collect data from social media platforms through web scraping and pre-process the data for feature extraction. (iv) Utilize a combination of text-based and image-based features to train and evaluate the model. This method integrates data from many sources and makes use of cutting-edge machine learning techniques in an effort to increase the precision and effectiveness of depression identification. The positive outcomes of our trials, which achieved high accuracy and F1-score, highlight the promise of our method for identifying depression levels from social media data. The proposed solution suggests that by using this approach, depression can be identified and treated earlier, leading to better mental health outcomes for both individuals and society as a whole.},
  keywords={Privacy;Machine learning algorithms;Social networking (online);Mental health;Depression;Feature extraction;Object recognition;Depression;Hamilton Rating Scale;Web scraping;Precision;F1-score;Accuracy},
  doi={10.1109/IC3I59117.2023.10397610},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10059773,
  author={Korti, Shreyas S and Kanakaraddi, Suvarna G},
  booktitle={2022 Fourth International Conference on Emerging Research in Electronics, Computer Science and Technology (ICERECT)}, 
  title={Depression detection from Twitter posts using NLP and Machine learning techniques}, 
  year={2022},
  volume={},
  number={},
  pages={1-6},
  abstract={Depression is the one of the most seviour mental issue that the people of world-wide are irrelevant of their ages gender caste and races‥etc. In this modern communication world peoples are more comport to express their thoughts in front of social media almost every day. The main agenda of this paper is to propose the data-analytics based model to detect depressed tweeter tweets of the peoples. In this paper then data is going to collect from different user's posted tweets from most popular social-media website like twitter. The depression level can be identified based on the tweets of the users in social-media. The standard methods to detect depression of the users via tweets which is in the form of structured, these methods needs a larger amount of the data from the users. Now a day's social media platform like twitter. Twitter has become more popular to express their views and their emotions in the form of tweets. The data screening can be done based on tweets it shows depressive symptoms of the users. By using machine learning technique we are going to do pre-processing of the data collected from the users. And even using Recurrent neural network (RNN) and NLP techniques, LSTM Deep-learning techniques to identify the depressed tweets in a more convenient manner.},
  keywords={Computer science;Recurrent neural networks;Social networking (online);Blogs;Machine learning;Depression;Standards;LSTM;RNN;NLP;Machine learning;CNN;SVM},
  doi={10.1109/ICERECT56837.2022.10059773},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{10670781,
  author={Philip, Anju Thankam and Radhakrishnan Iyer, Reshma and L, Nitha},
  booktitle={2024 Third International Conference on Smart Technologies and Systems for Next Generation Computing (ICSTSN)}, 
  title={Analysing Depression in Social Media: A Study of Basic Deep Learning Algorithms and Transformer Model with a Comparative Approach}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={Depression is a psychological issue characterized by lingering feelings of despair, gloom, and a diminished engagement or pleasure in undertakings. It surpasses normal emotional fluctuations, casting a profound impact on an individual’s daily life. The rise of diverse messaging applications and online platforms has provided everyone with the means to easily express, share, and communicate their opinions, emotions, deepest thoughts, accomplishments and fears with the global audience. Every day, substantial volumes of text data are generated. Effectively handling the expanding text data requires the utilization of suitable tools. This study delves into the field of depression detection, exploring various methodologies that utilize advanced Deep Learning algorithms. The study focuses on utilizing data from internet forums to spot depression, taking into account the global occurrence and impact of depressive disorders. Notably, the research implements Deep Learning models, specifically RNN and Transformer variants, including GRU, LSTM, BiGRU, BiLSTM, and the Switch Transformer. Highlighting the importance of quickly identifying depression for effective intervention and treatment, the paper emphasizes the challenges and significance of analysing social media content for depression identification. The research seeks to contribute to mental healthcare by utilizing advanced Deep Learning models to attain optimal outcomes in identifying depression within social media.},
  keywords={Deep learning;Social networking (online);Computational modeling;Psychology;Switches;Medical services;Depression;Social Media;NLP;Sentiment Analysis- SA;Deep Learning;RNN;Transformer},
  doi={10.1109/ICSTSN61422.2024.10670781},
  ISSN={},
  month={July},}@INPROCEEDINGS{11064030,
  author={Yadav, Sanjana and Bharadwaj, Shruti and Varshney, Yuvika and Gupta, Sachi},
  booktitle={2025 3rd International Conference on Communication, Security, and Artificial Intelligence (ICCSAI)}, 
  title={Emotion Mining: A Framework for Depression Detection}, 
  year={2025},
  volume={3},
  number={},
  pages={1089-1094},
  abstract={Depression is a widespread mental health issue, and the continuous rise in mental health issues has fueled our search for new and innovative detection methods. Sentiment analysis combined with machine learning is a scalable and efficient approach to detect and categorize human emotions from text taken from sources such as social media. This paper reviews recent progress in depression detection using sentiment analysis and machine learning models, with emphasis on various steps in the process – data extraction, data preprocessing, feature selection, model training, and sentiment categorization. The main machine learning methodologies, challenges faced by researchers, and the future direction are discussed, we have focused on existing studies that utilized both traditional machine learning algorithms and advanced deep learning algorithms such as BERT and LSTM. This may be used for early mental health issue detection, continuous mental health monitoring, and personalized interventions for a more impactful treatment by analyzing textual data. This is a new and accessible approach that would improve access to mental health care reduce the stigma surrounding it and improve clinical decision making but providing additional screening methods using automated systems.},
  keywords={Deep learning;Sentiment analysis;Machine learning algorithms;Social networking (online);Mental health;Depression;Feature extraction;Data models;Monitoring;Long short term memory;BERT;Deep Learning;Depression Detection;LSTM;Machine Learning;Mental Health Monitoring;Sentiment Analysis;Social Media Analysis},
  doi={10.1109/ICCSAI64074.2025.11064030},
  ISSN={},
  month={April},}@INPROCEEDINGS{10990523,
  author={Walia, Chayan Preet and Maheshwary, Priti},
  booktitle={2025 International Conference on Cognitive Computing in Engineering, Communications, Sciences and Biomedical Health Informatics (IC3ECSBHI)}, 
  title={Comprehensive Examination of Depression Detection Through Multimedia Content on Social Media Platforms}, 
  year={2025},
  volume={},
  number={},
  pages={221-226},
  abstract={Depression is a mental health disorder that causes persistent feelings of sadness, hopelessness, and a loss of interest or pleasure in activities that one used to enjoy. It can be caused by a combination of genetic, biological, environmental, and psychological factors. Identifying depression causes in social media involves the use of data mining and natural language processing techniques to analyze user-generated content and behavior. Depression analysis is a popular research topic in the natural language processing field, and researchers are increasingly publishing papers on this subject. This review paper aims to explore the use of machine learning techniques for depression analysis using social media text, audio, and video data. The paper provides an overview of the different machine learning techniques used for depression analysis and their effectiveness. The review paper can help researchers understand the current state of knowledge on depression analysis using social media text, images, and videos along with machine learning techniques and identify potential areas for future research.},
  keywords={Analytical models;Social networking (online);Reviews;Computational modeling;Biological system modeling;User-generated content;Mental health;Depression;Natural language processing;Data models;machine learning;deep learning;model;depression detection;sentimental analysis;social media;image recognition},
  doi={10.1109/IC3ECSBHI63591.2025.10990523},
  ISSN={},
  month={Jan},}@INPROCEEDINGS{10711029,
  author={Balcı, Emirhan and Saraç, Esra},
  booktitle={2024 8th International Artificial Intelligence and Data Processing Symposium (IDAP)}, 
  title={Automated Depression Detection from Tweets: a Comparison of NLP Techniques}, 
  year={2024},
  volume={},
  number={},
  pages={1-5},
  abstract={This paper aims to classify suicidal ideation as a symptom of depression from social media posts by applying the state-of-the-art classification model BERT (Bidirectional Encoder Representations from Transformers) and three traditional machine learning algorithms for binary classification. Since depression is one of the most prevalent mental health disorders amongst psychiatric disorders, the authors intended to present an experimental analysis of the machine learning classifier results as a comparison of novel depression detection techniques. We utilized undiagnosed user posts from Twitter as our dataset and tested the fine-tuned BERT model by applying hold-out and 10-fold cross-validation techniques. Since the dataset is highly unbalanced, Support Vector Machine (SVM), Naive Bayes, and Random Forest algorithms were employed on the same dataset with and without the oversampling method SMOTE (Synthetic Minority Oversampling Technique). The results demonstrate that traditional machine learning classifiers cannot infer sentiment from data containing various linguistic cues, such as depression symptoms. On the other hand, the state-of-the-art model BERT achieves 99.29% and 99.56% macro and micro-F-measure values, respectively, surpassing traditional machine learning algorithms in terms of these metrics. As a robust solution to depression detection from textual data, the BERT model is more trustworthy than the traditional machine learning classifiers to detect specific cues related to depression and similar mental disorders. This study contributes to the relevant research areas of natural language processing by indicating the performance difference between the BERT model and several traditional machine learning algorithms as a generalized approach for classification tasks.},
  keywords={Support vector machines;Measurement;Machine learning algorithms;Social networking (online);Bidirectional control;Mental health;Linguistics;Depression;Encoding;Natural language processing;Sentiment Analysis;BERT;Transformer Based Learning},
  doi={10.1109/IDAP64064.2024.10711029},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{11331569,
  author={Takdenti, Amina and Mazari, Ahmed Cherif},
  booktitle={2025 International Conference on Intelligent Computer Systems, Data Science and Applications (IC2SDA)}, 
  title={Multi Aspect Detecting Mental Disorders using Machine and Transfer Learning Models on Reddit Posts}, 
  year={2025},
  volume={},
  number={},
  pages={1-7},
  abstract={People usually feel more comfortable sharing their true feelings when they're behind a screen. That's why platforms like Reddit can be valuable for understanding mental health struggles. This work focuses on using Reddit posts to detect serious conditions such as depression, anxiety, and post-traumatic stress disorder (PTSD). The selected posts are lightly cleaned and prepared to ensure the text is ready for analysis. Then using BERT (Bidirectional Encoder Representations from Transformers), to extract embeddings to represent the data. These embeddings are fed into both traditional ML (Machine Learning) models-such as Support Vector Machines (SVM), Random Forest (RF), and Logistic Regression (LR)- and transfer learning models, including BERT,RoBERTa (Robustly Optimized BERT Pretraining Approach) and DistilBERT (Distilled BERT). Out of all the models, RoBERTa gave the highest accuracy, reaching 0.9009. Based on these results, it appears that transfer learning models are more effective for mental health classification tasks using social media data.},
  keywords={Support vector machines;Social networking (online);Transfer learning;Anxiety disorders;Mental health;Bidirectional control;Depression;Feature extraction;Encoding;Data models;Reddit;Mental health detection;BERT;RoBERTa;DistilBERT;Machine learning models;depression and anxiety and PTSD},
  doi={10.1109/IC2SDA68097.2025.11331569},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{11351016,
  author={Bobhate, Grishma and Bhaladhare, Pawan},
  booktitle={2025 IEEE International Conference on Intelligent Signal Processing and Effective Communication Technologies (INSPECT)}, 
  title={Decoding Human Behavior for Depression Detection: Explainable Learning Models with Internet of Behavior Approach}, 
  year={2025},
  volume={},
  number={},
  pages={1-7},
  abstract={Internet of behavior is an eminent and promising extensive methodology in the domain of Internet of Things and described as primitive approach to study behavior analysis and predictive learning system to understand user experience and interpret their psychological patterns for betterment of the society. Detecting depression through the Internet of Behavior (IoB) expand the statistical analyzing of data extracted from different platforms, such as online sites, wearable smart devices, and digital interactions. Various learning paradigm have been implemented to detect depression through fusion modalities applied on different parameters such as visual, textual and gaze movement. Depression detection using artificial intelligence (AI) has gained significant traction, particularly through social media analysis and deep learning methodologies. Explainable Artificial Intelligence (XAI) into this process enhances the functionality and compatibility of AI models to construct the strategy in mental healthcare domain. As considering this system, still the issue with the explainability in AI models has hindered their adoption in clinical settings. Therefore, this study explores recent advancements in Explainable AI (XAI) for depression detection with highlighting key methodologies. Classical machine learning classifiers and deep learning models were reviewed and integrated with XAI frameworks on Reddit dataset. This approach integrated LIME and SHAP to offer explainability in predictions and includes hyperparameter tuning deep learning model to understand user behavioral patterns and improving model interpretability and enhance transparency. Additionally, we discuss the ethical considerations, potential biases, and extended research to grow in AI domain. This experimentation outlines the strategies to adopt the behavioral analysis for effective learning of depression detection model.},
  keywords={Deep learning;Analytical models;Visualization;Explainable AI;Social networking (online);Medical services;Predictive models;Depression;User experience;Artificial intelligence;Internet of behavior;Explainable AI;SHapley Additive Explanations;Local Interpretable Model-Agnostic Explanations;Artificial Intelligence;Healthcare;Machine Learning;Deep Learning},
  doi={10.1109/INSPECT67393.2025.11351016},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{11382798,
  author={Deepa and Shenoy, Aman and Deepthi and Rao, Dhanvi and Dharsandia, Harsh},
  booktitle={2025 9th International Conference on Electronics, Communication and Aerospace Technology (ICECA)}, 
  title={Automated Mental Health Assessment using Machine Learning}, 
  year={2025},
  volume={},
  number={},
  pages={833-837},
  abstract={Machine learning has been used in various fields of science for its transformative capabilities. Machine learning algorithms have also been incorporated into the healthcare industry, but some sectors are still lagging behind in implementing these cutting-edge technology. One such area is the field of mental health treatment and diagnosis. The traditional practice of in person evaluation by psychologists is still practiced till date. This can delay the process of diagnosis and treatment. Also, in society there is a stigma around people who go to seek help regarding mental health. This often leads to suppression and delay in the process. To address this gap this study focuses on using Machine learning techniques for prediction and diagnosis of depression and anxiety. By using standardized questionnaires like Patient Health Questionnaire and General Anxiety Disorder this study aims to produce a simple, basic user-friendly application. This will help individuals in assessing their mental well-being. Ultimately this paper aims at early intervention in mental healthcare through involvement and integration of technology.},
  keywords={Sentiment analysis;Anxiety disorders;Mental health;Machine learning;Medical services;Predictive models;Depression;Market research;Delays;Videos;Anxiety;Diagnosis;Machine Learning;Mental health},
  doi={10.1109/ICECA66444.2025.11382798},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{11341160,
  author={Naik, Ashitha V. and Sheelam, Goutham Kumar and Panchakatla, Nagalakshmi and Muthukumaran, K and Saranya, K.},
  booktitle={2025 International Conference on Communication, Computer, and Information Technology (IC3IT)}, 
  title={Comprehensive Analysis on Depression Detection From Social Media Using Deep Learning and Transformer Architectures}, 
  year={2025},
  volume={},
  number={},
  pages={1-8},
  abstract={In recent times, Depression is a complex emotional illness that intensely affects the mental state, cognition, and daily life. Depression extends beyond temporary sadness and often lasts for weeks or months, disrupting personal relationships, work, and overall well-being. Depression extremely disturbs emotional balance, clouds judgment, and reduce motivation by reshaping relationships, routines, and one's sense of purpose. Social media, though expressive, complicates detection due to informal language, emoji's, and fragmented grammar. However, modern tools when thoughtfully applied offer hope for earlier recognition and personalized support. Advancements in Artificial Intelligence (AI) enabled the early detection of depression through social media analysis and improved involvement strategies. Recent studies introduced Deep Learning (DL) methods that integrate transformer models, Convolutional Neural Networks (CNNs), Bi-Long Short-Term Memories (BiLSTM) and Attention Mechanisms to analyze sentiment and mental biases. Hybrid architectures utilizing pre-trained embedding, feature engineering, and Multi-Model methods significantly enhance the classification accuracy. Federated Deep Learning (FDL) is developed as a privacy-preserving technique that allows decentralized model training across institutions while maintaining data security. Additionally, Clinical Decision Support Systems integrated depression assessments with electronic health records (EHR) to personalize treatment recommendations. However, DL methods face difficulties in Social media posts which contain slang, abbreviations, emoji's, and inconsistent grammar, making the text preprocessing difficult.},
  keywords={Deep learning;Training;Attention mechanisms;Social networking (online);Computer architecture;Depression;Transformers;Data models;Grammar;Electronic medical records;attention mechanisms;bi-long short-term memories;convolutional neural networks;depression;electronic health records;multi model},
  doi={10.1109/IC3IT66137.2025.11341160},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10939409,
  author={Ahmed, Faisal and Alam, Mohammed Shamsul and Dey, Piyal and Rahaman, Saifur},
  booktitle={2024 International Conference on Innovations in Science, Engineering and Technology (ICISET)}, 
  title={Depression Detection from Social Media Posts using Ensemble Machine Learning}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={Depression is a significant global health concern, especially among social media users who experience mental pressures. It is a vital mental health issue due to undiagnosed and untreated that can lead to chronic mental disease and even suicide. In the recent decade, depression has increased day by day. It needs early detection and treatment to improve people’s mental health. This paper proposed an ensemble machine learning approach to detect human depression from social media posts efficiently. The proposed method is an ensemble solution to sentiment analysis in textual data combining LSTM networks with a BERT-embedded layer. The model can capture the contextual nuances and sequential patterns of language. This paper employed two different social sentiment analysis textual datasets of depression and self-harm respectively. The proposed method gives an accuracy of $\mathbf{9 8. 4 \%}$ for the depression dataset and $\mathbf{9 2. 3 \%}$ for the self-harm dataset. Those datasets also used other machine learning approaches such as LSTM with a convolutional layer, BERT, Logistic Regression, and combined LSTM and BERT. The proposed method significantly improves accuracy compared to existing state-of-the-art methods and models. To ensure immediate action and quick recovery and minimize possible serious instances like suicide, this research attempts to identify early indicators of depression.},
  keywords={Sentiment analysis;Visualization;Technological innovation;Accuracy;Text analysis;Social networking (online);Mental health;Depression;Reliability;Long short term memory;depression detection;ensemble;LSTM;BERT;sentiment analysis;social media;machine learning},
  doi={10.1109/ICISET62123.2024.10939409},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10421313,
  author={Johri, Prashant and Tyagi, Anant and Sharma, Meghna and Bhardwaj, Durgesh},
  booktitle={2023 International Conference on Communication, Security and Artificial Intelligence (ICCSAI)}, 
  title={Depression Detection and Accuracy Analysis Using Various Machine Learning Algorithms on Twitter}, 
  year={2023},
  volume={},
  number={},
  pages={46-52},
  abstract={Depression, also known as major depressive disorder, is a widespread psychological condition that has a negative influence on how somebody thinks, feels, as well as the way they behave. The good news is that it can also be treated. Depression is characterized by a lack of pleasure in formerly pleasurable activities as well as by emotions of despair. It often leads to diverse emotional and physical challenges and a reduction in the capacity to operate normally both at work and at home. As a result, there is a need for an automated system that is capable of assisting in the diagnosis of depression in individuals of all ages. Researchers have been exploring different ways to properly recognize depression in order to improve their ability to diagnose it. In this context, a variety of studies are being done. Techniques from the discipline of machine learning are currently being used to predict the possibility of psychological illnesses and subsequently produce potential treatment as well. The detection of depression was addressed in this research using various ML classifiers. A wide variety of ML methods, including SVM, Logistic Regression, CART, KNN, Random Forest, and Transfer Learning, were used in the process of depression detection. This paper provides a number of different AI and ML algorithms that can aid in the identification and analysis of emotions, and consequently depression along with the accuracy of these ML techniques.},
  keywords={Support vector machines;Machine learning algorithms;Social networking (online);Transfer learning;Psychology;Depression;Random forests;Depression;Suicide;Machine Learning;Artificial Intelligence;Twitter;Social Media;SVM;Logistic Regression},
  doi={10.1109/ICCSAI59793.2023.10421313},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{10912404,
  author={Kalra, Arman and Gill, Kanwarpartap Singh},
  booktitle={2024 2nd International Conference on Advances in Computation, Communication and Information Technology (ICAICCIT)}, 
  title={A Neural Approach to Mental Health: LSTM RNNs for Depression Detection}, 
  year={2024},
  volume={1},
  number={},
  pages={813-816},
  abstract={Depression is a common mental health condition affecting both developed and developing nations, but it is often challenging to diagnose accurately and promptly. Traditional diagnostic methods can be time-consuming and may lead to delays in providing necessary treatment. This study addresses the need for a reliable and efficient machine learning approach to detect depression. It explores the use of deep learning techniques, specifically long-short-term memory (LSTM) recurrent neural networks (RNN), for identifying signs of depression. After extensive testing, the algorithm demonstrated a remarkable 96% accuracy in detecting depressive symptoms from text data. This research presents an effective approach for depression detection using LSTM RNNs, which excel at identifying temporal patterns in sequential data. The proposed model offers timely assistance and intervention for individuals at risk while also contributing to mental health research, thanks to its high accuracy and potential for improving mental health outcomes.},
  keywords={Deep learning;Technological innovation;Recurrent neural networks;Accuracy;Computational modeling;Mental health;Depression;Reliability;Long short term memory;Testing;Artificial Intelligence;Deep Learning;Long Short Term Memory;Recurrent neural Networks (RNN);Depression Detection Model},
  doi={10.1109/ICAICCIT64383.2024.10912404},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{10245441,
  author={Nanavati, Jay and Patel, Unnati},
  booktitle={2023 International Conference on Data Science and Network Security (ICDSNS)}, 
  title={Hybrid Model for Analysis of Social Media Posts for Identification of Depression and Measuring Its Severity}, 
  year={2023},
  volume={},
  number={},
  pages={1-5},
  abstract={Amongst vast variety of mental health disorders one of the most common is Depression. Depression is characterized by feeling sad, empty-minded and complete lack of interest. The time period of depression ranges from a few hours up to even a fortnight or even more. Depression, in turn, also results into feeling low self-esteem, guilty, inability to concentrate, seeing no hope, sleep disorders and even thoughts of committing suicide. Thus, depression is one of the greatest challenges to the individual in particular and society at large in general. Depression has also made it to the list of high-priority conditions under by Mental Health Gap Action Programme of the World Health Organization. Use of social media has been an integral part of modern lifestyle. Vast majority of people from developing and developed countries have cheaper access to Internet and they prioritize engaging themselves in social media for sharing every minute detail of their personal life and express their feelings on multiple social media platforms. As a result of this, their posts on social media are nearly true reflections of their state of mind. In this research work, we proposed a hybrid model for sentiment analysis which aims at identifying depression along with its severity levels. The proposed model employs pre-trained language model and makes use of information available through day-to-day social media posts by various users. The proposed model was built around the principles of contrastive learning. The results showed significant improvement achieved by the proposed approach. Thus, it can be concluded that the hybrid ensemble approach does offer better and competitive performance over usage of single model.},
  keywords={Analytical models;Sentiment analysis;Social networking (online);Mental health;Predictive models;Depression;Prediction algorithms;Mental health disorders;Depression;ML algorithms;Depression detection;Deep learning;Text Analysis;Affective Computing;Emotion AI Introduction},
  doi={10.1109/ICDSNS58469.2023.10245441},
  ISSN={},
  month={July},}@INPROCEEDINGS{10725639,
  author={Singh, Nongmeikapam Thoiba and Dhiman, Richa and Wadhwa, Manoj and Mishra, Aditya Mohan and Singh, Ankit and Poonia, Himanshu},
  booktitle={2024 15th International Conference on Computing Communication and Networking Technologies (ICCCNT)}, 
  title={Computational Psychiatry: Leveraging Deep Learning for Depression Detection in Social Media Text Analysis}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={Millions of people worldwide suffer from depression, a common psychiatric disorder that has a significant impact on both individuals and society. For management and treatment to be effective, timely detection and intervention are essential. Recent developments in machine learning techniques have demonstrated potential for enhancing conventional diagnostic approaches. This work presents an extensive overview and analysis of current studies devoted to applying machine learning methods for depression identification. The review starts off by looking at the different approaches and data sources used in studies on depression identification, such as voice recordings, social media texts, electronic health records, and physiological signals. It then examines the various machine learning approaches employed, such as supervised, unsupervised, and deep learning, and discusses their advantages and disadvantages. In addition, the research addresses interpretability problems, algorithm bias, and data privacy, as well as the difficulties and ethical dilemmas involved in using machine learning models for depression identification. Proposals are made for strategies to deal with these issues, stressing the significance of multidisciplinary cooperation between computer scientists, psychologists, and medical experts. This work identifies promising directions for future research through a critical examination of previous findings. These include the creation of interpretable machine learning models, the integration of multimodal data sources, and the investigation of novel biomarkers for depression. In the end, this paper’s insights are meant to support ongoing efforts to improve depression diagnosis techniques and mental healthcare outcomes through the use of machine learning technologies.},
  keywords={Deep learning;Text analysis;Social networking (online);Reviews;Soft sensors;Computational modeling;Psychology;Depression;Data models;Recording;text analysis;deep learning;natural language processing;computational psychiatry;sentiment analysis;neural networks},
  doi={10.1109/ICCCNT61001.2024.10725639},
  ISSN={2473-7674},
  month={June},}@INPROCEEDINGS{10101258,
  author={Anusha and Shenoy, Savitha A and Harish, S V},
  booktitle={2023 2nd International Conference for Innovation in Technology (INOCON)}, 
  title={A Study To Detect Emotions From Twitter Text Using Machine Learning Algorithms}, 
  year={2023},
  volume={},
  number={},
  pages={1-4},
  abstract={One of the main factor contributing to mental illness, which has been linked to an increased risk of dying young is depression. Additionally, it significantly contributes to suicide ideation. Although there are many underlying reasons of depression, social networking sites play a key part in raising the likelihood of depression. In recent years social media has become the integral part of our daily lives. User reflects his internal life in the content he shares in his social media platform like twitter. People share happy incidents, joyful memories and sad moments through tweets. Thus it is possible to forecast depression in people using Twitter data. Various machine learning techniques have been employed to analyze these data. The algorithms employed are Naïve Bayes and Logistic Regression. Those algorithms will produce intended outcomes.},
  keywords={Technological innovation;Machine learning algorithms;Social networking (online);Blogs;Machine learning;Depression;Information exchange;Depression analysis;Machine Learning;Sentiment Analysis;Twitter;Tweets;Naïve Bayes;Logistic Regression},
  doi={10.1109/INOCON57975.2023.10101258},
  ISSN={},
  month={March},}@INPROCEEDINGS{11013592,
  author={Chathli, Raghav and Sachin and Rohan and Shambharkar, Prashant Giridhar},
  booktitle={2025 8th International Conference on Trends in Electronics and Informatics (ICOEI)}, 
  title={A Comparison of Machine Learning Depression Detection Models on Diverse Datasets}, 
  year={2025},
  volume={},
  number={},
  pages={1189-1194},
  abstract={Depression identification via social media monitoring is an important step toward early intervention, providing a means to detect those at risk through their online behavior. This study uses machine learning methods to label depression posts on Reddit and Twitter. The datasets were thoroughly preprocessed, with text cleaning, removal of stopwords, and TF-IDF vectorization, providing high-quality input features. Three models- Naive Bayes, Logistic Regression, along with Random Forest which were trained and tested. Among them, Random Forest showed the best accuracy with 94.96% on the Reddit test set and 68.80% on the Twitter test set. These outcomes indicate the difficulty of cross-platform generalization owing to varying writing styles, lengths of posts, and user participation. Furthermore, a real-time prediction function was implemented to classify user-input text in real time. The research confirms that although machine learning models efficiently identify depressive content, the performance is heavily reliant on dataset properties. Future work will investigate more sophisticated deep learning strategies like BERT to increase the accuracy of classification and ensure platform robustness. In addition, continuous learning mechanisms will be incorporated to enable the model to retrain on fresh data and learn over time. This contribution is part of the expanding body of research on AI-based mental health evaluation, with potential uses in psychological screening and early intervention systems.},
  keywords={Accuracy;Social networking (online);Blogs;Mental health;Writing;Depression;Real-time systems;Robustness;Random forests;Monitoring;Depression;Machine Learning;Twitter;Reddit;Random Forest},
  doi={10.1109/ICOEI65986.2025.11013592},
  ISSN={},
  month={April},}@INPROCEEDINGS{10092317,
  author={Mishra, Praveen and Devi, G. Uma},
  booktitle={2023 11th International Conference on Internet of Everything, Microwave Engineering, Communication and Networks (IEMECON)}, 
  title={Performance investigation for analysis of Predicting and understanding human depression behavior from social network analysis using SVM model: A Review}, 
  year={2023},
  volume={},
  number={},
  pages={1-6},
  abstract={Many disciplines may benefit from social network data, including sociology and psychology. However, technological aids fall far short, and targeted strategies are required immediately. In order to identify unhappy social network users, this article uses data mining to the field of psychology. To begin, we offer a vocabulary-and rule-based sentiment analysis technique to determine the microblog’s depression propensity. A depression detection model is then built using the suggested approach and 10 traits of depressed users gleaned from the a for mentioned psychological literature. The model is then validated using data from 180 individuals and three distinct classifier types, all of which achieve accuracy levels around 80%. The importance of each factor is also considered. As a final step, an online mental health monitoring application is built using the suggested framework. Some psychologists have given their blessing to this research, which helps them in a data-centric way.},
  keywords={Support vector machines;Sentiment analysis;Social networking (online);Sociology;Predictive models;Depression;Microwave theory and techniques;data mining;Machine learning;depression},
  doi={10.1109/IEMECON56962.2023.10092317},
  ISSN={},
  month={Feb},}@INPROCEEDINGS{11203366,
  author={Sahoo, Somya Ranjan and Kumar, Anisha and Pinisetty, Chakrika Anousha and Kummari, Eeshitha and Gogada, Ashrita and Shankar, Yadavalli Uday},
  booktitle={2025 International Conference on Artificial Intelligence and Machine Vision (AIMV)}, 
  title={Enhancing Depression Detection in Online Social Networks with Explainable AI (XAI)}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={This study enhances depression detection through social media text analysis using a BERT-based approach. Traditional ML/DL models struggle to interpret nuanced language and emotions in online interactions. BERT’s contextual embeddings improve sentiment understanding, while Explainable AI (XAI) techniques like LIME and SHAP ensure interpretability. Among tested models, MentalBERT achieved the highest accuracy (96.08%), effectively capturing mental health-related language patterns. This combination of accuracy and transparency makes it a promising tool for real-world mental health applications, enabling better detection and interpretation of psychological cues in social media text for early intervention and support.},
  keywords={Privacy;Ethics;Accuracy;Text analysis;Explainable AI;Social networking (online);Federated learning;Machine vision;Mental health;Depression;Depression detection;BERT;MentalBERT;XAI;LIME and SHAP},
  doi={10.1109/AIMV66517.2025.11203366},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{10276373,
  author={Prasad, Madhura G and Jamadagni, Suresh},
  booktitle={2023 International Conference on Network, Multimedia and Information Technology (NMITCON)}, 
  title={Detection of Depression Using Data Collected from Social Media}, 
  year={2023},
  volume={},
  number={},
  pages={1-7},
  abstract={In recent times, detecting depression using data collected from social network, like audio, video, image or text data, is a growing research field in emotion processing. Data from social media, which includes text data and gifs, emojis, etc., would be used for the analysis and classification processes. An autonomous depression detection system is required due to the complexity of conventional methods based on clinical diagnosis. Using data collected from social media, sentiment levels can be identified and monitored. In this paper, we aim to research on using machine learning/deep learning techniques combined to make a hybrid model. CNN is a technique proven to be efficient in feature extraction combined with Bidirectional LSTM, for contextual learning, both used to apply on the data collected from social media, train the data and obtain efficient results on the level of depressional traits in an individual. It has also been possible to get a reasonably high value of accuracy of 93% upon evaluation. The use of AI and machine learning in such systems has greatly assisted in many fields of medical science including psychology analysis.},
  keywords={Training;Support vector machines;Social networking (online);Text categorization;Supervised learning;Machine learning;Depression;Sentiment analysis;Depression detection;Machine learning;Deep learning;SVM;LSTM;BiLSTM;CNN;social media},
  doi={10.1109/NMITCON58196.2023.10276373},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{11327090,
  author={Zabdi, Dianeluoxy and Liu, Grace Natal and Meiliana and Jingga, Kenny},
  booktitle={2025 International Conference on Informatics, Multimedia, Cyber and Information System (ICIMCIS)}, 
  title={A Comparative Study of BiLSTM and Machine Learning Models for Depression Detection from Twitter and Reddit with SHAP Explanations}, 
  year={2025},
  volume={},
  number={},
  pages={604-609},
  abstract={It is undeniable that the trend of using social media platforms as a means of self-expression for mental health conditions, such as Twitter and Reddit, is very high. In this case, there is a need for a detector of mental health conditions, one of which is depression. To meet this need, we compared traditional machine learning models (Logistic Regression (LR), Support Vector Machines (SVM), Naive Bayes (NB), and Random Forest (RF)) with the deep learning model Bidirectional Long Short- Term Memory (BiLSTM). We also performed SHapley Additive exPlanations (SHAP) analysis with shap.LinearExplainer and shap.KernelExplainer according to the model. After the training and evaluation process, it was found that SDG achieved the highest recall of 0.9468 compared to the deep learning model, making it the most optimal choice to predict cases of depression. It can be proven that currently machine learning models are still relevant to be discussed amidst the advancement of deep learning models. Meanwhile, the BiLSTM deep learning model continues to demonstrate its sophistication in the SHAP analysis, which shows that the most influential feature is the user’s name, whereas the machine learning model focuses more on emotional aspects. With these findings, we hope to improve early detection of depression.},
  keywords={Support vector machines;Deep learning;Training;Analytical models;Social networking (online);Blogs;Bidirectional long short term memory;Mental health;Depression;Space vector modulation;Machine learning;BiLSTM;Depression detection;SHAP},
  doi={10.1109/ICIMCIS68501.2025.11327090},
  ISSN={2837-5203},
  month={Dec},}@INPROCEEDINGS{10270579,
  author={Rachh, Rashmi and Kavatagi, Sanjana},
  booktitle={2023 3rd Asian Conference on Innovation in Technology (ASIANCON)}, 
  title={Performance Evaluation of Various Embedding Techniques for Identification of Depressive Contents in Social Media}, 
  year={2023},
  volume={},
  number={},
  pages={1-6},
  abstract={Depression has emerged as the most common mental disorder in today's world, causing experts to concentrate on early detection in order to minimize its long-term consequences, including the likelihood of suicidal thoughts leading to suicide. As societal dependence on social media as an essential means of interaction expands, it has evolved into a significant platform for individuals to interact and engage with others, surpassing conventional interactions in person. Understanding this transition, researchers have shifted their focus to using social media data to detect indicators of depression. There is a rising opportunity of identifying and tackling depression more effectively, potentially preventing its damaging repercussions, by using the large volume of information provided on these platforms. To provide a solution, we propose a model that can effectively identify depression in social media data. Considering three different embedding techniques such as TF-IDF, Word2Vec, and BERT model classified using conventional machine learning algorithms, we compare the performance of each embedding technique on two different datasets. Context-aware sentence embedding method BERT has achieved better accuracy compared to hand-crafted feature extraction and static word embedding methods.},
  keywords={Performance evaluation;Technological innovation;Machine learning algorithms;Social networking (online);Mental disorders;Depression;Feature extraction;Depression;embedding;static word embedding;context-aware embedding},
  doi={10.1109/ASIANCON58793.2023.10270579},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{10083576,
  author={Das, Arnab and Debbarama, Mrinal Kanti and Barik, Rabindra K.},
  booktitle={2023 International Conference on Intelligent Systems, Advanced Computing and Communication (ISACC)}, 
  title={Learning Techniques for Depression Detection: A Comparative Studies}, 
  year={2023},
  volume={},
  number={},
  pages={1-7},
  abstract={Depression is a common mental problem that can fundamentally affect individuals' emotional wellness as well as their everyday lives. After COVID-19 other pandemics and subsequent social isolation this issue is more potent than ever. Numerous research works have been going on searching for methods that effectively recognize depression in order to detect depression. In this regard, a number of studies have been proposed. In this study, it examines a number of previous ones utilizing various Machine Learning (ML) and Artificial Intelligence (AI) methods for depression detection. In addition, various methods for determining an individual's mood and emotion are discussed. This study also discusses how facial expression, voice, gesture can be understood by chatbot and classified it as a depressed person or not. Addition to this, it reviews all the related research works and evaluates their methods to detect depression.},
  keywords={Support vector machines;Mood;Neural networks;Bit error rate;Depression;Chatbots;Feature extraction;depression;detection;machine learning;artificial intelligence},
  doi={10.1109/ISACC56298.2023.10083576},
  ISSN={},
  month={Feb},}@INPROCEEDINGS{9941219,
  author={Kumar, Shruthi K and Dinesh, Nanditha and L, Nitha},
  booktitle={2022 Second International Conference on Interdisciplinary Cyber Physical Systems (ICPS)}, 
  title={Depression Detection in Twitter Tweets Using Machine Learning Classifiers}, 
  year={2022},
  volume={},
  number={},
  pages={81-86},
  abstract={Users are increasingly using social media to share their thoughts and feelings. One of the primary causes of higher suicide rates is 'depression.' A user’s social media status recently revealed information on their mental health, as well as their current circumstances and actions. Various studies have been conducted to determine how social media may be used to assess a user’s mental health, and the results have been impressive. This is accomplished by the examination of expressed views, images, attitudes, language style, and other activities. The uploaded tweets from Twitter users will be used in this study to detect depressions. Five machine learning algorithms were employed to discriminate between depressed and non-depressed tweets. Support Vector Machine, Decision Tree, Random Forest, CNN, and Naive Bayes are all examples of machine learning algorithms. Finally, with 85.00 percent accuracy, 81.25 percent precision, 90.00 percent recall, and 82.90 percent f1-factor, Decision Tree Classifier exceeds all of the examined and evaluated approaches. This research can serve as a foundation for intelligent system developers working in the field of detecting user mental states.},
  keywords={Machine learning algorithms;Social networking (online);Blogs;Support vector machine classification;Mental health;Depression;Decision trees;Support Vector Machine;Decision Tree;CNN;Naive Bayes;Line Kernel Convolutional Neural Network},
  doi={10.1109/ICPS55917.2022.00023},
  ISSN={},
  month={May},}@ARTICLE{10496991,
  author={Abbas, Muhammad Asad and Munir, Kashif and Raza, Ali and Samee, Nagwan Abdel and Jamjoom, Mona M. and Ullah, Zahid},
  journal={IEEE Access}, 
  title={Novel Transformer Based Contextualized Embedding and Probabilistic Features for Depression Detection From Social Media}, 
  year={2024},
  volume={12},
  number={},
  pages={54087-54100},
  abstract={Depression constitutes a significant mental health condition, impacting an individual’s emotional state, thought processes, and ability to carry out everyday tasks. Depression is defined by ongoing feelings of sadness, diminished interest in previously enjoyed activities, alterations in hunger, sleep disturbances, decreased vitality, and challenges with focus. The impact of depression extends beyond the individual, affecting society at large through decreased productivity and higher healthcare costs. In the realm of social media, users often express their thoughts and emotions through posts, which can provide insightful data for identifying patterns of depression. This research aims to detect depression early by analyzing social media user content with machine learning techniques. We have built advanced machine learning models using a benchmark depression database containing 20,000 tagged tweets from user profiles identified as depressed or non-depressed. We are introducing an innovative BERT-RF feature engineering method that extracts Contextualized Embeddings and Probabilistic Features from textual input. The Bidirectional Encoder Representations from Transformers (BERT) model, based on the Transformer architecture, is used to extract Contextualized Embedding features. These features are then fed into a random forest model to generate class probabilistic features. These prominent features aid in enhancing the identification of depression from social media. In order to classify tweets using the features derived from the BERT-RF features selection step, we have used five popular classifiers: Random Forest (RF), Multilayer Perceptron (MLP), K-Neighbors Classifier (KNC), Logistic Regression (LR), and Long Short-Term Memory (LSTM). Evaluation experiments show that our approach, using BERT-RF for feature engineering, enables the Logistic Regression model to outperform state-of-the-art methods with a high accuracy score of 99%. We have validated the results through k-fold cross-validation and statistical T-tests. We achieved 99% k-fold accuracy during the validation of the proposed approach. This research contributes significantly to computational linguistics and mental health analytics by providing a robust approach to the early detection of user depression from social media content.},
  keywords={Depression;Social networking (online);Feature extraction;Probabilistic logic;Blogs;Data models;Random forests;Mental health;Medical conditions;Deep learning;Transformers;Depression detection;machine learning;deep learning;text mining;BERT;transformer},
  doi={10.1109/ACCESS.2024.3387695},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{10294421,
  author={Gupta, Chetna and Khullar, Vikas},
  booktitle={2022 IEEE International Conference on Service Operations and Logistics, and Informatics (SOLI)}, 
  title={Exploring the Role of Conventional and Non-Conventional Technologies in Identifying MDD}, 
  year={2022},
  volume={},
  number={},
  pages={1-6},
  abstract={The most prevalent mental health condition is known as major depressive disorder (MDD), which is characterized by low mood, loss of interest, anxiety as well as hopelessness, cognitive decline, and even suicidal ideation. By 2020, depression is expected to surpass all other disorders in terms of medical burden and functional impairment at work, according to the World Health Organization (WHO). Unfortunately, the characteristics of depression vary, making an accurate and timely diagnosis challenging. To diagnose MDD, both conventional and non-conventional methods are frequently used. Conventional methods that use brain waves to detect depression include electroencephalography (EEG) and functional magnetic resonance imaging (fMRI), among others. Non-conventional methods include text, audio, and image-based. However, a significant amount of cutting-edge research is being done to develop additional possible tools and technologies by fusing other algorithms with ML/DL algorithms, as this provides a variety of unique applications and opens the door to more research.},
  keywords={Mood;Mental health;Organizations;Medical services;Functional magnetic resonance imaging;Depression;Electroencephalography;Major Depressive Disorder;Conventional;Non-conventional;Machine Learning;Deep Learning},
  doi={10.1109/SOLI57430.2022.10294421},
  ISSN={2768-1890},
  month={Dec},}@INPROCEEDINGS{10838637,
  author={Vidya, S and Swamy, Nagalambika and Lalitha, H},
  booktitle={2024 IEEE 6th PhD Colloquium on Emerging Domain Innovation and Technology for Society (PhD EDITS)}, 
  title={Leveraging Machine Learning Algorithms for Depression Prediction in College Students Using PHQ-9 Scores}, 
  year={2024},
  volume={},
  number={},
  pages={1-2},
  abstract={Depression among college students significantly affects their well-being and academic performance. Using PHQ-9 responses and Questionnaire, this study uses models of machine learning - including Logistic Regression, XGBoost, Support Vector Machine and Random Forest in detecting depression. Key indicators were extracted to evaluate the models using recall, accuracy, precision, and F1-score showing that the Random Forest model attained the highest performance with an accuracy of 98.00% and an F1-score of 98.68%. XGBoost closely follows with 97.00% accuracy and 97.00% F1-score, while SVM also performed well at 96.59% accuracy. In contrast, Logistic Regression lagged significantly at 80.68% accuracy. These findings illuminate the effectiveness of advanced machine learning models in the early detection of depression among college students, suggesting their potential integration into campus mental health service.},
  keywords={Support vector machines;Logistic regression;Technological innovation;Accuracy;Machine learning algorithms;Mental health;Forestry;Depression;Random forests;Depression Detection;PHQ-9 Assessment;XGBoost;SVM;Random Forest;Logistic Regression},
  doi={10.1109/PhDEDITS64207.2024.10838637},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{11012332,
  author={Mythili, K. and R, Nandhini and B, Trishla and S, Vasantha Kumar},
  booktitle={2025 3rd International Conference on Advancements in Electrical, Electronics, Communication, Computing and Automation (ICAECA)}, 
  title={Cognitive Flux Detection and Adaptive Emotional Modulation}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={The rapid rise of social networking sites has led to unusual usage patterns that contribute to various social network-related mental disorders, including Cyberrelationship Addiction, Information Overload, and Net Compulsion. These disorders often go unnoticed until they reach advanced stages, resulting in delayed intervention. To address this issue, this project introduces a new depression detection model that identifies signs of depression based on users' online social behavior, particularly through the analysis of tweets. Unlike traditional methods that depend on surveys completed by respondents, this model employs machine learning techniques to analyze social media data, facilitating the early detection of depressive tendencies.Additionally, the model incorporates a classification technique that utilizes Term Frequency-Inverse Document Frequency (TF-IDF) for feature extraction. The tweets undergo preprocessing, which includes the removal of Unicode characters, and both KNN and SVM models are utilized to achieve accurate classification. Developed in Python 3.7, the system enhances the detection of depression, serving as an early intervention tool to initiate personalized mental health care. This approach introduces a new method that could serve as a regular and non-intrusive way to identify depressed states and related social network mental disorders by analyzing social media activity.},
  keywords={Support vector machines;Analytical models;Frequency modulation;Social networking (online);Mental disorders;Mental health;Machine learning;Nearest neighbor methods;Depression;Data models;Depression Detection;Social Network Mental Disorders;Machine Learning;K-Nearest Neighbor;Support Vector Machine;Term Frequency-Inverse Document Frequency;Social Media Analysis;Data Preprocessing;Feature Extraction;Twitter Sentiment Analysis;Natural Language Processing;Early Intervention;Mental Health Monitoring;Text Classification;Predictive Modeling},
  doi={10.1109/ICAECA63854.2025.11012332},
  ISSN={},
  month={April},}@ARTICLE{10108975,
  author={Hasib, Khan Md and Islam, Md Rafiqul and Sakib, Shadman and Akbar, Md. Ali and Razzak, Imran and Alam, Mohammad Shafiul},
  journal={IEEE Transactions on Computational Social Systems}, 
  title={Depression Detection From Social Networks Data Based on Machine Learning and Deep Learning Techniques: An Interrogative Survey}, 
  year={2023},
  volume={10},
  number={4},
  pages={1568-1586},
  abstract={Users can interact with one another through social networks (SNs) by exchanging information, delivering comments, finding new information, and engaging in discussions that result in the production of vast volumes of data daily. These data, available in various forms, such as images, text, and videos, may be interpreted to reflect the user’s activities, including their mental state regarding depression. For example, depression is a chronic disease from which the vast majority of users suffer, and it has emerged as a significant issue relating to mental health on a global scale. However, because these data are scant, unfinished, and sometimes given inaccurately, it is challenging to make an accurate automated diagnosis from them. Even though several procedures have been utilized over the past few decades to diagnose depression, machine learning (ML) and deep learning (DL) techniques supply superior insights. Thus, in this study, we review several state-of-the-art ML and DL techniques in terms of the systematic literature review (SLR) approach for depression detection. We also highlight some critical challenges from the existing literature that may help to explore for future study. Finally, we believe this survey will help readers and researchers in ML and DL to understand critical solutions in diagnosing depression.},
  keywords={Depression;Diseases;Social networking (online);Libraries;Deep learning;Computer science;Videos;Deep learning (DL);depression;machine learning (ML);sentiment analysis;social networks (SNs)},
  doi={10.1109/TCSS.2023.3263128},
  ISSN={2329-924X},
  month={Aug},}@INPROCEEDINGS{11013436,
  author={Kansara, Nirav and Vala, Brijesh and Shaikh, Mohammad Shahnawaz},
  booktitle={2025 Eleventh International Conference on Bio Signals, Images, and Instrumentation (ICBSII)}, 
  title={Machine Learning in Mental Health: Bridging Gaps in Diagnosis and Intervention}, 
  year={2025},
  volume={},
  number={},
  pages={1-9},
  abstract={Mental health disorders, such as depression, anxiety, and bipolar disorder, represent a relevant public health challenge affecting close to 970 million people globally. Classical assessments include highly subjective self-reports and clinical assessments, leading often to latency in receiving care, and inaccuracy in care provision. The ML model could avail a good outlook derived from several data sources, including electronic health records, social media information, and sensor data from wearables to improve detection and intervention approaches. This study systematically reviewed 32 seminal works of the ML application in mental health involving algorithms such as SVM, RF, CNN, and deep learning models. In the bicameral model, CNN exhibited about $99 \%$ accuracy in detecting bipolar occurrence, and another, involving RF and CNN approaches also yielded 99% precision in PTSD diagnosis. Beyond these breakthroughs, challenges concern data privacy, model interpretability, and the generalizability of the numerous populations. Addressing these through explainable AI (XAI) approaches with measurements of ethical data collection greatly facilitate contributions of ML in mental health diagnostics. The review identifies current development, limitations, and future directions for more reliable, interpretable, and scalable MLbased mental health assessments.},
  keywords={Support vector machines;Radio frequency;Ethics;Machine learning algorithms;Accuracy;Anxiety disorders;Mental health;Depression;Data models;Wearable devices;Machine Learning;Mental Health;PTSD (PostTraumatic Stress Disorder);ADHD (AttentionDeficit/Hyperactivity Disorder);Anxiety;Depression;SVM;Random Forest},
  doi={10.1109/ICBSII65145.2025.11013436},
  ISSN={2768-6450},
  month={March},}@INPROCEEDINGS{11101534,
  author={Jangra, Rahul and Sangal, A L},
  booktitle={2025 International Conference on Electronics, AI and Computing (EAIC)}, 
  title={Optimized Framework for Mental Health Detection Using Deep Learning Technique}, 
  year={2025},
  volume={},
  number={},
  pages={1-5},
  abstract={Psychological stress and mental health issues are growing concerns worldwide, requiring accurate and efficient detection methods. An optimized framework for mental health detection using a DL approach is proposed. The ECG5000 dataset was utilized for analysis, with the Weka Dl4jMlpClassifier employed to classify ECG signals. To categorize data into binary and multiple categories, the neural network structure has an input layer, two hidden layers, and an output layer. Important methods like ReLU activation, the Softmax function, cross-entropy loss, and the Adam optimiser were used to improve training accuracy and efficiency. With an accuracy of 90.8%, the new model exceeded the MDDBranchNet model’s accuracy of 76.0% on the same dataset. The enhanced accuracy of 14.8% shows the effectiveness of the proposed framework. The neural network showed good performance for the most common categories in the ECG5000 dataset. More effort needs to be done to improve the categorisation accuracy for less frequent categories. These results validate the ongoing development of effective deep learning-based approaches for the detection of mental health disorders.},
  keywords={Deep learning;Training;Solid modeling;Accuracy;Neural networks;Mental health;Electrocardiography;Solids;Artificial intelligence;Monitoring;Mental Health Detection;Deep Learning;ECG Signal Classification;Neural Network Optimization},
  doi={10.1109/EAIC66483.2025.11101534},
  ISSN={},
  month={June},}@INPROCEEDINGS{11156233,
  author={R, Raksha and Pushpalatha, M P},
  booktitle={2025 International Conference on Innovations in Intelligent Systems: Advancements in Computing, Communication, and Cybersecurity (ISAC3)}, 
  title={Advancements in AI-Driven Detection and Monitoring of Depression and Anxiety using Multimodal Digital Biomarkers and Behavioural Data}, 
  year={2025},
  volume={},
  number={},
  pages={1-5},
  abstract={Depression and anxiety are two of the world's most common mental health disorders, commonly underdiagnosed because conventional evaluation is largely based upon patient self-report and clinical observations. With growth in intelligent computing technologies, artificial intelligence (AI) and multimodal sensing, new avenues for accurate, non-invasive, and scalable mental health evaluation have opened. This paper delves into a technology environment that utilizes digital biomarkers, facial expression, voice, physiological signals, textual behavior, and wearable sensors—and machine learning and deep learning methodologies for bolstering early detection and real-time monitoring of depression and anxiety. Based on IEEE-indexed research, this paper considers various AI models such as convolutional neural networks, LSTM networks, ensemble models, and transformers for various datasets from social media, remote interviews, EEG signals, speech from smartphones, and physiology logs. All these methods have been proven to have classification accuracies ranging up to 99% and AUROC scores higher than 0.80 across various experiments. The survey involved systematizing more than 20 prominent papers, comparing model performance, datasets, and multimodal features employed. The analysis result indicated that multimodal integration between behavioral and physiological modalities provides stronger predictive performance compared to unimodal systems. Speech analysis from smartphones, eye movement entropy measures, and wearables-based HRV analysis were found useful for real-time mental health tracking. This article puts AI-based multimodal platforms forward as instrumental for future clinical and community-based mental health interventions, lowering bias, increasing adoptability, and enabling timely interventions.},
  keywords={Speech analysis;Anxiety disorders;Mental health;Biomarkers;Depression;Brain modeling;Real-time systems;Biomedical monitoring;Smart phones;Monitoring;Depression Detection;Anxiety Monitoring;Artificial Intelligence;Machine Learning;Multimodal Biomarkers;Wearable Technology;Speech Analysis},
  doi={10.1109/ISAC364032.2025.11156233},
  ISSN={},
  month={July},}@INPROCEEDINGS{10083981,
  author={Agrawal, Anupam and Dey, Sharmistha and Jana, Gopal Chandra},
  booktitle={2023 International Conference on Intelligent Systems, Advanced Computing and Communication (ISACC)}, 
  title={Depressive and Non-depressive Tweets Classification using a Sequential Deep Learning Model}, 
  year={2023},
  volume={},
  number={},
  pages={1-6},
  abstract={Nowadays, depression is one of the most predominant mental health ailments, even causing demise of many lives, especially among the youngsters and middle-aged persons. Use of social media and posting individual expression on it is very much use to for the people. So, social media posts are very useful for detecting a person is in depression or not. In this paper, we have considered depressive and non-depressive tweets classification. We have proposed a sequential Deep learning model with three layers: Embedded, lD-Convolutional and LSTM Layer. The performance of the proposed model has been compared with three traditional Machine Learning models Naïve Bayes, KNN, Random Forest for depressive and non-depressive tweets classification. Our proposed approach of sequential Deep Learning model has achieved 98.47% accuracy, which is better than other models we have compared with.},
  keywords={Deep learning;Social networking (online);Computational modeling;Mental health;Media;Depression;Intelligent systems;Depression Detection;Sequential Deep Learning Model;ID-Convolution;LSTM;Social Media},
  doi={10.1109/ISACC56298.2023.10083981},
  ISSN={},
  month={Feb},}@INPROCEEDINGS{9786922,
  author={Kushwaha, Richa and Kaur, Parmeet},
  booktitle={2022 1st International Conference on Informatics (ICI)}, 
  title={Depression Detection on Social Media}, 
  year={2022},
  volume={},
  number={},
  pages={153-158},
  abstract={The paper presents a comprehensive approach for the detection of symptoms of depression in individuals based on their data from a social media network, Twitter. This data is combined with a historical labelled data set for gaining proper insights about users. Apart from its large size, data of user tweets is of an unstructured form and hence, the work employs a MongoDB based Big Data framework for storing and processing this data. Naïve Bayes' and Long Short-Term Memory (LSTM) classifiers are used to classify tweets as belonging to depressed users or not. Subsequently, topics are extracted from the tweets using Latent Dirichlet Allocation (LDA) to understand the key terms in depressed users' tweets. Lastly, a chatbot based solution is presented for helping the depressed users.},
  keywords={Social networking (online);Blogs;Big Data;Depression;Chatbots;Resource management;Informatics;Depression Detection;Social-Media;Topic Model;Naïve Bayes;LSTM;Chatbot},
  doi={10.1109/ICI53355.2022.9786922},
  ISSN={},
  month={April},}@INPROCEEDINGS{9892210,
  author={Kumar, Sachin and Nisha, Zairu},
  booktitle={2022 International Joint Conference on Neural Networks (IJCNN)}, 
  title={Does Social Media Feed Tell about Your Mental State? A Deep Randomised Neural Network Approach}, 
  year={2022},
  volume={},
  number={},
  pages={1-8},
  abstract={Depression is one of the most severe issues in the present-day technology-driven world. Digital transformation and its offerings have penetrated our life. Social media platforms such as Facebook, Twitter, Instagram etc have enabled the masses to express their opinions/experiences and information instantly to large audience. In the expression of their opinions/experiences and information, Social media users also intensely express their deep feelings/reflections/emotions in the form of text/video/images and emoji etc. These shared emotions/feelings and experiences and used words have a deep connection with their mental health and depression etc and can be used to get insights and early detection of their mood, mental health and depression. Previously detection of depression and mental health has a standard procedure involving a fully structured interview method(SID) or semi-structured interview method (SSDI) to collect a large amount of data to analyse depression. Present-day, social media feed and other associated metadata show the manifestation of depressive disorder symptoms of the user. The proposed research work experiments on social media posts and analyses the mental state of social media users. The model proposes a hybrid Frequency-Inverse Document and a deep learning model Deep Random Neural Networks(DRNNs) and compared with other state of art models such as random forest(RF), support vector machine(SVM) and other deep learning approaches. The proposed model reports an accuracy of approximately 91 cent and takes significantly less computational time as compared to other classification approaches. The proposed experiment can be useful for the individuals, parents, and psychologists to get intelligent assistance about the mental state/depression of persons through their social media posts and content for future course of action.},
  keywords={Deep learning;Social networking (online);Computational modeling;Neural networks;Support vector machine classification;Mental health;Forestry;Depression;Social Media;Machine Learning;Detection;Natural Language Processing;Deep Randomised Neural Network},
  doi={10.1109/IJCNN55064.2022.9892210},
  ISSN={2161-4407},
  month={July},}@INPROCEEDINGS{11200772,
  author={Muthu, D. and Elakkia, G. and Tamilselvi, B.},
  booktitle={2025 4th International Conference on Innovative Mechanisms for Industry Applications (ICIMIA)}, 
  title={DeepMindWatch: A Multi Modal AI Framework for Early Detection of Depression and Anxiety from Digital Bio Markers}, 
  year={2025},
  volume={},
  number={},
  pages={1974-1978},
  abstract={Mental health disorders affect approximately 1 billion people worldwide, yet early detection remains challenging due to limited access to healthcare resources and stigma associated with seeking help. This paper presents DeepMindWatch, a novel multimodal artificial intelligence framework for early detection of depression and anxiety disorders through analysis of digital biomarkers. The framework employs a hierarchical attention network that processes these heterogeneous data streams and generates interpretable predictions with supporting evidence. We trained our models on a dataset combining anonymized clinical records (n = 1,850), consented social media data (n = 5,200), and passive sensing data (n = 3,400) collected through our custom smartphone application. The proposed framework achieves 87.3% accuracy in identifying depression markers and 82.6% accuracy for anxiety markers, outperforming existing unimodal approaches by 14.2% on average DeepMindWatch demonstrates robust performance across diverse demographic groups with a reduced false positive rate of 8.4% compared to clinical screening tools. A six-month longitudinal validation study confirms the framework's efficacy in early detection, identifying potential mental health concerns an average of 63 days before clinical diagnosis. This research offers promising directions for developing scalable, privacy-preserving digital mental health screening tools that could significantly improve early intervention strategies and accessibility of mental healthcare resources globally.},
  keywords={Accuracy;Social networking (online);Anxiety disorders;Industry applications;Mental health;Biomarkers;Linguistics;Depression;Sensors;Artificial intelligence;Mental Health Detection;Deep Learning;Multimodal Analysis;Digital Biomarkers;Artificial Intelligence;Depression;Anxiety;Early Detection},
  doi={10.1109/ICIMIA67127.2025.11200772},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{11320683,
  author={Kaur, Manpreet and Shukla, Anand Kumar and Attri, Vikas and Kavita and Kumar, Mukesh and Pindal, Sourav},
  booktitle={2025 International Conference on Digital Innovations for Sustainable Solutions (ICDISS)}, 
  title={Artificial Intelligence in Mental Health: A Focus on Student Depression Diagnosis and Intervention}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Student depression is now a serious concern, impacting academic achievement, interpersonal relationships, and overall health. Though conventional diagnostic techniques have been imperfect but effective to some extent, they have limitations of delays, narrow observation, and dependence on human judgment, which is also subjective. To address this, Artificial Intelligence (AI) has stepped forward as a potent technique to identify student depression at an early stage with precision. Artificial intelligence technologies like machine learning, natural language processing (NLP), and behavioral analytics are able to study speech, text, class participation, and online activity to identify the subtle signs of depression in a more effective manner. These tools improve the capacity to spot patterns which may be missed using conventional measurement, making way for early and specific interventions. Besides, AI-based platforms such as mobile applications, chatbots, and virtual counselors provide stigma-free, accessible mental health care designed for students. Regardless of these benefits, AI poses ethical issues like privacy of data, bias, and the potential for overdependence on machines. This research paper considers the prospects of AI in diagnosing and treating depression among students, balancing its strengths and weaknesses. It calls for the careful incorporation of AI technology into educational mental health initiatives to enhance early intervention and enhance student wellness.},
  keywords={Ethics;Technological innovation;Privacy;Explainable AI;Medical treatment;Mental health;Depression;Mobile applications;Artificial intelligence;Monitoring;Artificial Intelligence;Mental Health;Depression Diagnosis;Machine Learning;Natural Language Processing},
  doi={10.1109/ICDISS68238.2025.11320683},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{11064586,
  author={Sharma, Rashi and Prakash, Ayushi},
  booktitle={2025 3rd International Conference on Communication, Security, and Artificial Intelligence (ICCSAI)}, 
  title={AI Enhanced Depression Detection Using Chatbot and Facial Data Analysis}, 
  year={2025},
  volume={3},
  number={},
  pages={2133-2140},
  abstract={Depression affects countless millions and requires early detection and intervention. The approach employed in this study builds an AI driven system for depression detection by integrating, chatbot technology, live video facial analysis and machine learning algorithms that have been trained on a dataset of depression related Twitter tweets. Depression levels are analysed in real time by facial expressions of users and users are engaged through conversations with a chatbot on a platform for expression of emotion. This study will be aimed at gathering and treating analysed referenced dataset from the Twitter and processing it employing deep learning and machine learning techniques which includes supervised techniques, such as, support vector machines (SVM), and neural networks. The performance is evaluated via cross validation in order to guarantee highest accuracy. Besides, the accuracy, precision, recall, and F1score for SVM model are 88.5%, 85.2%, 84.6%, and 84.9%, respectively. At Naive Bayes model, the accuracy of 95.6%, precision of 95.7%, recall of 95.6% and F1 score of 95.6% were attained. Logistic Regression model was best, and it achieved 97.7% accuracy, 97.7% precision, 97.7% recall and 97.7% F1 score.},
  keywords={Support vector machines;Accuracy;Machine learning algorithms;Data analysis;Social networking (online);Mental health;Depression;Chatbots;Real-time systems;Data models;Depression Detection;Chatbot Technology;Facial Data Analysis;Machine Learning;Mental Health AI},
  doi={10.1109/ICCSAI64074.2025.11064586},
  ISSN={},
  month={April},}@INPROCEEDINGS{10340782,
  author={Kowalewski, Mateusz and Stroinski, Maciej and Kwarciak, Kamil and Laptiev, Volodymyr and Hemmerling, Daria},
  booktitle={2023 45th Annual International Conference of the IEEE Engineering in Medicine & Biology Society (EMBC)}, 
  title={End-to-end multimodal system for depression detection from online recordings}, 
  year={2023},
  volume={},
  number={},
  pages={1-4},
  abstract={Depression is one of the most occurring civilizational diseases. In this paper, we propose a new approach for detecting depression through the analysis of social media content using face analysis, emotion recognition neural networks, and speech processing. We utilized audio-visual analysis and acquired more than 605 features in the time domain. Those are fed to machine learning and deep learning models for depression classification. Our approach outperforms the other state-of-the-art models, achieving the F1-score 0.77. The results have the potential to provide valuable insights for mental health professionals, offer early detection and intervention, and serve as a resource for individuals seeking help with their mental health. This study enables real-time analysis and represents a significant advancement in mental health and technology and has the potential to impact society.Clinical relevance—The system aims to provide a fast and accurate way to detect depression in individuals through online recordings. The use of multimodal information (e.g. audio, image) enhances the performance of the non-verbal behavioral analysis. The end-to-end system reduces the need for manual analysis by mental health professionals and increases the efficiency of depression screening. The system can potentially help identify individuals who are at risk for depression, enabling early intervention and treatment. The results from the system can complement traditional assessments and support mental health professionals in making a diagnosis. The system can be used in real-time processing, f.e. during online calls, and provide objective measurements summarizing the overall behavior based on computer vision and audio analysis.},
  keywords={Emotion recognition;Mood;Neural networks;Mental health;Depression;Feature extraction;Real-time systems;speech processing;computer vision;feature extraction;biomarker},
  doi={10.1109/EMBC40787.2023.10340782},
  ISSN={2694-0604},
  month={July},}@INPROCEEDINGS{10730099,
  author={Alexander and Lim, Mei Kuan and Lai, Weng Kin},
  booktitle={2024 IEEE International Conference on Artificial Intelligence in Engineering and Technology (IICAIET)}, 
  title={A Multi-Modal Approach for Predicting Depression Risk Using Social Media Data}, 
  year={2024},
  volume={},
  number={},
  pages={557-561},
  abstract={Depression affects many people and can disrupt people from functioning normally in their daily lives. Treatment for depression is lengthy and expensive, especially in its late stages. Social media is widely used and studied to recognize users' mental health through information shown in posts. There is a lack of research on multi-modality in this field, with many studies focusing on text modality processing alone. This paper proposes a multi-modal approach to predict depression using social media data. Utilizing and combining text and image modality posted by social media users allows for a better and more accurate prediction. Preliminary results show that our method has performed better than the current multi-modal state-of-the-art with an F1-score of 97.9 %. Furthermore, our experiments have shown that accurate prediction can be made with minimal number of posts, highlighting the potential of predicting early risks of depression.},
  keywords={Accuracy;Correlation;Social networking (online);Focusing;Mental health;Depression;Feature extraction;Artificial intelligence;Mental health;Multimodal learning;Early fusion;Social media;Depression detection},
  doi={10.1109/IICAIET62352.2024.10730099},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{10112572,
  author={Jadhav, Ganesh and Babar, Sachin and Mahalle, Parikshit},
  booktitle={2023 10th International Conference on Computing for Sustainable Global Development (INDIACom)}, 
  title={A Survey: Performance-aware Depression Detection}, 
  year={2023},
  volume={},
  number={},
  pages={1242-1249},
  abstract={Depression is the most common health problem in the world. According to the World Health Organization (WHO), more than 350 million people are affected by it. There are many causes of depression, like business down and down, social life, economic life, and relationships. Depression is one of the leading causes of mental illness in humans and also affects an individual's thoughts, behavior, emotions and well-being. This survey is useful to the clinical understanding of mental health for patients. The main goal of the survey was to study the different learning techniques to find out the research gap. In this survey we studied the different existing research work with their systems, and different types of datasets (Image data, Audio data and textual data). The final results are based on different parameters like accuracy, precision, and recall etc. This paper explores the learning techniques to learn the different learning techniques for the depression detection system.},
  keywords={Economics;Organizations;Mental health;Depression;Behavioral sciences;Depression Detection;Machine learning;Deep learning;Multimodal Technique},
  doi={},
  ISSN={},
  month={March},}@INPROCEEDINGS{10169826,
  author={Sudhishna, K S and Sanjay Kumar, C and Kishore, B S and Arun, A},
  booktitle={2023 International Conference on Sustainable Computing and Smart Systems (ICSCSS)}, 
  title={Comparative Analysis of Different Machine Learning Algorithms to Predict Depression}, 
  year={2023},
  volume={},
  number={},
  pages={148-153},
  abstract={Depression affects people globally and requires early treatment. If a depressed individual isn’t given proper attention it leads to complications. Complications can be avoided by detecting depression earlier. To address this, Information from social media platforms and wearable technology can offer useful insights into a person’s behavior and mental condition. ML algorithms are efficient for people with depression. The study aims to compare the performance of three algorithms— Logistic Regression, Multinomial Naive Bayes and Support Vector Machine are the methods to detect depression. Any machine learning model’s accuracy is highly dependent on the quality of the training data. Collecting trustworthy and representative data may be difficult when attempting to forecast depression. The models’ performance may be impacted by the data’s potential for being incomplete, erroneous, or biased. A variety of measures, such as precision, recall analysis and F1-score comparison, will be utilized in order to evaluate the effectiveness of the algorithms. By training these models on a similar dataset and comparing them based on accuracy and other criteria like sensitivity rates, it can determine which algorithm performs better at predicting depression. The SVM tends to be more effective compared to other two algorithms.},
  keywords={Support vector machines;Logistic regression;Machine learning algorithms;Social networking (online);Training data;Machine learning;Mental health;Depression;Logistic Regression(LR);Multinomial Naive Bayes (MNB);Support Vector Machine (SVM)},
  doi={10.1109/ICSCSS57650.2023.10169826},
  ISSN={},
  month={June},}@INPROCEEDINGS{9995184,
  author={Zhang, Yazhou and He, Yu and Rong, Lu and Ding, Yijie},
  booktitle={2022 IEEE International Conference on Bioinformatics and Biomedicine (BIBM)}, 
  title={A Hybrid Model for Depression Detection With Transformer and Bi-directional Long Short-Term Memory}, 
  year={2022},
  volume={},
  number={},
  pages={2727-2734},
  abstract={Failure to diagnose and treat depression in a timely manner causes more than three hundred million people suffering from this mental health disorder worldwide. Depression, a global problem, affects not only people’s emotions, but also their physical and mental states. Early detection of depression is very important for the treatment of patients, so we need to achieve excellent accuracy and practicability of depression detection, among which the most important and challenging problem is to design an effective and robust depression detection model. To solve this problem, we propose a hybrid deep learning model, RoBERTa-BiLSTM, to extract features from depression text sequences. We know that the sequence models require a longer computation time as the processing is done sequentially. However, the Transformer models require less execution time with parallelized processing. This model consolidates the strengths of sequence model and Transformer model while suppressing the limitations of sequence model. Specifically, the model maps the words into a compact meaningful word embedding space through the Robustly optimized BERT approach, and then effectively captures the long-distance contextual semantics using the Bidirectional Long Short-Term Memory model. On the DAIC-WOZ and EATD-Corpus benchmark, our experiments demonstrate that our model outperforms state-of-art methods by a substantial margin.},
  keywords={Deep learning;Computational modeling;Biological system modeling;Semantics;Mental health;Depression;Transformers;depression detection;RoBERTa-BiLSTM;sequence model;deep learning;Transformer},
  doi={10.1109/BIBM55620.2022.9995184},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{11063648,
  author={Li, Wang and Kaur, Wandeep and Wangmei, Chen},
  booktitle={2024 16th International Conference on Knowledge and System Engineering (KSE)}, 
  title={Detecting Emotional State of Depression in Social Media Posts Using Logistic Regression-Recursive Feature Elimination}, 
  year={2024},
  volume={},
  number={},
  pages={289-296},
  abstract={With the rise of global mental health issues and the growing use of social media, detecting depression through social media text data has become increasingly crucial. Although many studies have focused on identifying depression by analyzing social media texts, most of these studies mainly focus on a single feature extraction technique. However, the effective combination of multiple feature extraction techniques for depression detection remains underexplored. This study aims to explore how various feature extraction methods can be effectively combined to enhance depression detection and to develop an optimized feature selection method that improves model performance without losing essential information. Advanced feature extraction methods—TFIDF, N-gram, SentiWordNet, and BERT—were combined with machine learning algorithms to analyze social media texts using the eRisk dataset. Three experiments were conductedthe first evaluated individual feature extraction methods across models such as Logistic Regression (LR), Random Forest (RF), and Support Vector Machine (SVM); the second assessed the effectiveness of combining multiple features; and the third applied Logistic Regression-Recursive Feature Elimination (LR-RFE) to optimize feature sets. The results indicated that combining TFIDF, N-gram, SentiWordNet, and BERT significantly enhanced performance, particularly in the LR model. Additionally, applying LR-RFE further enhanced model accuracy and reliability across all tested machine learning modelsachieved an accuracy of 0.800 and an F1 score of 0.7969, which demonstrating improved generalizability and robustness. These findings underscore the importance of comprehensive feature extraction and feature selection for effective depression detection through social media text data.},
  keywords={Support vector machines;Radio frequency;Analytical models;Accuracy;Machine learning algorithms;Social networking (online);Mental health;Feature extraction;Depression;Logistics;Machine Learning;Sentiment Analysis;Feature Extraction;Depression Detection;Feature Selection},
  doi={10.1109/KSE63888.2024.11063648},
  ISSN={2694-4804},
  month={Nov},}@INPROCEEDINGS{11211656,
  author={Jain, Ayush and Shrivastava, Vineeta},
  booktitle={2025 International Conference on Engineering Innovations and Technologies (ICoEIT)}, 
  title={Enhancing Depression Detection on Social Media Using TF-IDF, Sentiment Analysis, and Deep Neural Network}, 
  year={2025},
  volume={},
  number={},
  pages={958-963},
  abstract={Depression detection using public broadcasting facts has developed an essential study area, applying technical knowledge (TK) and Neural network (NN) systems to analyze linguistic and behavioral patterns. Communal broadcasting platforms like as Facebook, Reddit, Twitter, and Instagram deliver a vast dataset for identifying depression indicators. This study evaluates multiple ML and DL models for depression detection based on accuracy. Among ML models, Support Vector Machine (SVM) realized a performance of 0.9644, Random Forest 0.9619, and Gradient Boosting Decision Tree 0.9438. Logistic Regression achieved an accuracy of 0.9573. Deep learning models demonstrated superior performance, with Convolutional Neural Networks (CNN) achieving 0.98 accuracy and Long Short-Term Memory (LSTM) achieving the highest accuracy of 0.99. Feature extraction systems like as TF-IDF, sentiment analysis, and topic modeling were working to enhance model performance. The results indicate that deep learning, mainly LSTM, outperforms traditional ML approaches, showcasing its potential for automated depression detection using social media data.},
  keywords={Deep learning;Support vector machines;Analytical models;Sentiment analysis;Accuracy;Social networking (online);Depression;Convolutional neural networks;Long short term memory;Random forests;Deep learning;Depression Detection;Social media;Sentiment Analysis;machine learning},
  doi={10.1109/ICoEIT63558.2025.11211656},
  ISSN={},
  month={July},}@INPROCEEDINGS{9823761,
  author={Singh, Prithvipal and Singh, Gurvinder and Bharti, Sarveshwar},
  booktitle={2022 2nd International Conference on Advance Computing and Innovative Technologies in Engineering (ICACITE)}, 
  title={The Predictive Model of Mental Illness using Decision Tree and Random Forest classification in Machine Learning}, 
  year={2022},
  volume={},
  number={},
  pages={01-05},
  abstract={Ministry of HFW, Government of India ordered the NIMNS - National Institute of Mental Health and Neuro Sciences, Bengaluru, in alliance with 15 institutions from across India and made a survey on mental health issues. This commission covered 12 states, one among that is Punjab from Northern region. As per the report, 15% of the adults in India need treatment for mental disorder. Machine Learning is one of the most substantial proportions of Artificial Intelligence. Machine Learning is widely used in many fields like online fraud detection, speech recognition, and social media. It plays a vital role in healthcare sector. This boosts the interest on the detection of the mental illness using machine learning algorithm. The big challenge is to predict the state of mind. Psychologists impose assessment and therapy to their patients by one to one physical interactions. There are multiple causes to put the person into critical situation like depression, pressure etc. Hence, this research paper proposes an ideal solution to identify the sickness in the person by checking with the recorded dataset. The most preferred Supervised Machine Learning algorithm, Decision Tree Classifier is used for this purpose. The initial goal of the Decision Tress is to create training ideal which is used to forecast the target variable class. The parameters considered here are anxiety disorder, depression disorder and the stress. Random Forest algorithm is applied to predict the illness in the people. The result obtained is to have accurate prediction level compared to the existing model.},
  keywords={Training;Machine learning algorithms;Social networking (online);Mental health;Speech recognition;Predictive models;Depression;Mental Illness;Machine Learning;Decision Tree},
  doi={10.1109/ICACITE53722.2022.9823761},
  ISSN={},
  month={April},}@INPROCEEDINGS{11137552,
  author={Ricoida, Desy Iba and Muklason, Ahmad and Vinarti, Retno Aulia and Tjahyanto, Aris},
  booktitle={2025 International Seminar on Intelligent Technology and Its Applications (ISITIA)}, 
  title={Predicting Depression via Text Analysis: A Design Science Research Approach}, 
  year={2025},
  volume={},
  number={},
  pages={692-696},
  abstract={Social media platforms generate vast amounts of textual data, offering a potentially rich source for detecting early indicators of mental health conditions like depression, a disorder with significant global impact on well-being. The challenge lies in accurately interpreting subtle linguistic cues within this unstructured data. This study employs a Design Science Research (DSR) methodology to systematically develop, refine, and evaluate machine learning artifacts for predicting depression from text. Specifically, we compare the performance of two prominent models: Support Vector Machine (SVM) and Bidirectional Long Short-Term Memory (BiLSTM). Utilizing a publicly available dataset from Kaggle, the models undergo rigorous text pre-processing, feature extraction, and hyperparameter optimization to maximize their predictive capabilities. Evaluation results demonstrate that the optimized BiLSTM model achieves superior performance across key metrics, including accuracy (97.84 %), precision (99.11 %), and recall (96.52 %), compared to the optimized SVM model (Accuracy: 96.98%, Precision: 98.91%, Recall: 94.96%). These findings highlight the enhanced ability of deep learning models like BiLSTM to capture complex sequential patterns in text relevant to depression. This research underscores the significant potential of integrating carefully designed machine learning techniques into real-world mental health monitoring systems, contributing to innovative, scalable solutions for early depression detection and intervention.},
  keywords={Support vector machines;Ethics;Accuracy;Text analysis;Social networking (online);Bidirectional long short term memory;Mental health;Depression;Hyperparameter optimization;Monitoring;Bidirectional Long Short-Term Memory (BiLSTM);Design Science Research (DSR);Depression Prediction;Machine Learning;Mental Health Informatics;Natural Language Processing;Support Vector Machine (SVM);Text Analysis},
  doi={10.1109/ISITIA66279.2025.11137552},
  ISSN={2769-5492},
  month={July},}@INPROCEEDINGS{9953811,
  author={Mann, Paulo and Matsushima, Elton H. and Paes, Aline},
  booktitle={2022 10th International Conference on Affective Computing and Intelligent Interaction (ACII)}, 
  title={Detecting Depression from Social Media Data as a Multiple-Instance Learning Task}, 
  year={2022},
  volume={},
  number={},
  pages={1-8},
  abstract={Major Depression Disorder (MDD) is a mental condition that causes severe impairments in a person's life. Early detection of such a condition is imperative, especially to detect cases where the person does not even know that they are affected by it. Social media provide a ubiquitous platform with self-generated data that Machine Learning models enhanced with Natural Language Processing mechanisms can extensively explore. Nonetheless, we advocate that previous Machine Learning approaches to early detection of MDD do not adequately model the problem at hand. Most assume that the isolated publications on social media are enough for early detection. This paper proposes a new problem formulation for this task using the multiple-instance learning paradigm. Furthermore, we include a theoretical and experimental analysis of the method on a dataset of Brazilian university students using the transformer and LSTM architectures. The results indicate that the proposed approach yields better accuracy and explanation capabilities than previous studies that do not rely on multiple-instance learning.},
  keywords={Affective computing;Social networking (online);Machine learning;Computer architecture;Depression;Transformers;Natural language processing;Depression;Deep Learning;Transformers;Multiple Instance Learning;University Students},
  doi={10.1109/ACII55700.2022.9953811},
  ISSN={2156-8111},
  month={Oct},}@INPROCEEDINGS{10390499,
  author={Satpute, Babasaheb S. and Rahane, Wasudeo P. and Bharati, Rajesh},
  booktitle={2023 3rd International Conference on Technological Advancements in Computational Sciences (ICTACS)}, 
  title={Examining Social Media Posts for Identification of Anxiety and Depression Utilizing Machine Learning Techniques}, 
  year={2023},
  volume={},
  number={},
  pages={295-300},
  abstract={The prevalence of mental diseases like depression and anxiety among students has become a growing concern in recent years. With the widespread use of social media platforms, individuals often express their emotions, thoughts, and experiences through posts and interactions. This paper investigates the feasibility of classifying students' anxiety and depression based on the content of their social media posts. Recently, some research communities in various domains have shown enthusiasm for investigating the potential of leveraging social media platforms for extracting valuable insights for decision-making and creative knowledge. Social media has been utilized to aid software development activities, analyze cryptocurrency trends, identify network communities, and make recommendations, among others. Apart from other fields within the eHealth domain, the application of social media platforms and the sophisticated analysis of extensive datasets to anticipate mental health disorders like depression, schizophrenia, eating disorders, anxiety, and addictive tendencies has garnered substantial attention and interest. However, one of the challenges lies in either having enough historical data or regular monitoring of a patient's activities to identify a person's mental health condition using traditional methods. To tackle this concern, we introduce an approach aimed at categorizing individuals with past mental health conditions through the utilization of information sourced from a widely-used social media platform such as Facebook.},
  keywords={Social networking (online);Anxiety disorders;Mental health;Depression;Feature extraction;Software;Monitoring;Social media;artificial intelligence;machine learning;mental health;depression and anxiety},
  doi={10.1109/ICTACS59847.2023.10390499},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{10911777,
  author={Subuhi, Afreen and Vadlamudi, Muniraju Naidu},
  booktitle={2024 IEEE 4th International Conference on ICT in Business Industry & Government (ICTBIG)}, 
  title={Advancements in AI for Depression Detection: A Survey of Machine Learning and Deep Learning Applications}, 
  year={2024},
  volume={},
  number={},
  pages={1-12},
  abstract={This survey paper delves into the sophisticated applications of machine learning (ML) and deep learning (DL) techniques in the realm of depression detection. By leveraging a variety of analytical methods, including text analysis, speech analysis, social media monitoring, and image and video analysis, the research highlights the role of advanced algorithms such as Recurrent Neural Networks (RNN), Long Short-Term Memory (LSTM) networks, Convolutional Neural Networks (CNN), Ensemble Methods, Random Forests, Gradient Boosting Machines (GBM), and Graph Neural Networks (GNN) in identifying depressive symptoms. The study conducts a thorough review of existing literature, showcasing the efficacy of these techniques while pinpointing critical gaps and challenges, such as data quality and integration with clinical practice. This comprehensive examination underscores the necessity for robust, generalizable models capable of real-world application. Ultimately, the survey aims to demonstrate how ML and DL technologies can significantly enhance early detection and intervention strategies in mental health management, paving the way for improved patient outcomes.},
  keywords={Deep learning;Surveys;Visualization;Recurrent neural networks;Social networking (online);Mental health;Depression;Data models;Psychiatry;Long short term memory;Depression detection;social media;deep learning dataset algorithm},
  doi={10.1109/ICTBIG64922.2024.10911777},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{11344504,
  author={Usha, R. and Krishna, N. Bala and Mounika, Midigesi and Sowmya, Pemmana and Vineetha, Sedji and Teja, Palukuri Venkata Sai Surya},
  booktitle={2025 Second International Conference on Networks and Soft Computing (ICNSoC)}, 
  title={Early Detection of Student Depression Using Deep Learning Algorithms}, 
  year={2025},
  volume={},
  number={},
  pages={778-783},
  abstract={This endeavor is designed to build a more advanced system. that applies deep learning techniques to detect early-stage depression in students. Growing concern exists for depression in educational settings and early identification facilitates timely intervention and support. The system looks at much data from students' responses to standardized questionnaires, behavioral factors like mood, sleep, social interaction, and school performance. For this purpose, the system applies Convolutional Neural Networks (CNN), Long Short-Term Memory (LSTM) and Recurrent Neural Networks (RNN) are deep learning algorithms. To automatically recognize complex and subtle patterns in the data that can inform about depression. Traditional methods fail to notice these patterns which makes this approach more efficient in detecting students at risk. The dataset is trained on a wide and complete dataset that integrates fully various emotional and behavioral factors to offer a sturdy and exact model. We measure these systems using important factors like how often they are right, how many relevant cases they get right, how few they miss, and their combination of both precision and recall to make sure they work well. We want to help schools get a tool that can find signs of depression in students early and reliably, to act more quickly and provide timely support. The system is trying to detect mental health issues in students and shed off the effect that depression negatively has on student's academic performance and personal development. An important contribution to the ever-growing need for mental health monitoring in educational settings for facilitating anything that boosts the happiness and achievements of students.},
  keywords={Deep learning;Recurrent neural networks;Accuracy;Mental health;Depression;Prediction algorithms;Convolutional neural networks;Reliability;Long short term memory;Monitoring;CNN;LSTM;RNN;early detection;student depression;sleep patterns;social interactions;academic performance;early intervention;mental health monitoring},
  doi={10.1109/ICNSoC66817.2025.00141},
  ISSN={},
  month={June},}@ARTICLE{10108970,
  author={Guo, Zhihua and Ding, Nengneng and Zhai, Minyu and Zhang, Zhenwen and Li, Zepeng},
  journal={IEEE Transactions on Computational Social Systems}, 
  title={Leveraging Domain Knowledge to Improve Depression Detection on Chinese Social Media}, 
  year={2023},
  volume={10},
  number={4},
  pages={1528-1536},
  abstract={Depression is a prevalent and severe mental disorder that often goes undetected and untreated, particularly in its early stages. However, social media has emerged as a valuable resource for identifying symptoms of depression and other mental disorders as people are increasingly willing to share their experiences and emotions online. As such, social media-based depression detection has become an important area of research. Unfortunately, despite the growing number of cases in China, there are few Chinese social media-based resources for depression research. To address this gap, this article presents a dataset collected from Sina Weibo and approaches depression detection as a binary classification problem. A depression lexicon is developed based on domain knowledge of depression and the Dalian University of Technology Sentiment Lexicon (DUT-SL), which facilitates better extraction of lexical features related to depression. Then the lexical features are fused using a correlation-based metric. The effectiveness of this approach is verified using five classical machine learning methods and two boosting-based models, both on a public dataset and our dataset. Experimental results indicate that the depression domain lexicon features improve classification performance and fusing these features based on their correlations can further enhance prediction effectiveness. This study provides a method for future research in social media-based depression detection and contributes to the development of Chinese depression detection resources.},
  keywords={Depression;Feature extraction;Social networking (online);Blogs;Machine learning;Task analysis;Support vector machines;Depression detection;domain knowledge;ensemble learning;natural language processing (NLP);social media},
  doi={10.1109/TCSS.2023.3267183},
  ISSN={2329-924X},
  month={Aug},}@INPROCEEDINGS{11380284,
  author={Divya, A. and Lakshmi, D. Sree and Nikitha, P. and Roshini, R. Sai and Reddy, V. Keerthi and Sahira, Sk.},
  booktitle={2025 5th International Conference on Ubiquitous Computing and Intelligent Information Systems (ICUIS)}, 
  title={Multi-Model Framework for Assessing Depression, Anxiety and Sleep Disorders}, 
  year={2025},
  volume={},
  number={},
  pages={879-885},
  abstract={Psychological health disorders like depression, anxiety and sleep disorders are the growing problems around the world. To overcome these issues, diagnosis methods are needed. Existing research relied mostly on self-reported questionnaires like SCL-90, but these assessments are relatively subjective and often are limited to single disorders which lead to lesser accuracies. This study proposes a machine learning approach that helps in the detection of depression, anxiety and sleep disorders and also helps in classifying them individually. The dataset contains 783 subjects with PHQ score, GAD score, BMI, age, gender and Epworth scale score as the attributes. Preprocessing include imputation, categorical encoding and normalization before classifying. Several Machine Learning methods show their usefulness in the healthcare field. The study examines how classification algorithms like Logistic Regression, Support Vector Machine and Random Forest perform to detect multiple psychological health disorders with respect to performance and accuracy. The results show that SVM achieved the highest accuracy of 97.45% for sleep disorder detection, while Logistic Regression and Random Forest achieved 96.82% and 96.80% respectively. The proposed methods are reliable to support the psychological health screening.},
  keywords={Support vector machines;Logistic regression;Accuracy;Anxiety disorders;Psychology;Depression;Ubiquitous computing;Real-time systems;Reliability;Random forests;Depression;Anxiety;Sleep;Machine Learning;Psychological Health;Multi Classification;Severity Score;Multi-disorder Detection;Clinical Data Analysis;Logistic Regression;Support Vector Machine;Random Forest},
  doi={10.1109/ICUIS67429.2025.11380284},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{10290160,
  author={Annadurai, Amrutha and Anand, Philip and Madhavan, S. Rohit and M, Vergin Raja Sarobin},
  booktitle={2023 7th International Conference on I-SMAC (IoT in Social, Mobile, Analytics and Cloud) (I-SMAC)}, 
  title={Deep Learning for Detecting Depression: Unveiling Emotional Distress from Tweets}, 
  year={2023},
  volume={},
  number={},
  pages={848-855},
  abstract={In the age of social media, detecting depression through user messages poses challenges due to recognition and trends. However, this project focuses on constructing a deep learning model using Twitter data to predict depression based on users' tweets. The current approaches like RNNs, LSTMs are inefficient in extracting contextual and sequential information from data in low compute environments. The solution proposed aims to incorporate the upsides from both CNNs and LSTMs to better extract features. Firstly, Twitter data is collected to identify relevant linguistic features for depression detection. Carefully characterized features are selected to capture subtle nuances in the content. Secondly, a comprehensive analysis is conducted, considering correlation significance, hidden topics, and word frequencies extracted from the text, which play a vital role in depression detection. These analyzed features are then fed into pre-trained CNN, LSTM, and RNN models. The results indicate that the RNN model outperforms the CNN-LSTM model, achieving an exceptional accuracy rate of 99.29% in detecting depression from posted tweets. By utilizing remembering networks and deep learning classifiers, the model can effectively classify, analyze, and predict data, providing insights into users' mental health. This research highlights the potential of using social media data and deep learning techniques to gain valuable insights into individuals' emotional well-being, ultimately leading to better mental health support and intervention strategies.},
  keywords={Deep learning;Analytical models;Sentiment analysis;Social networking (online);Blogs;Depression;Feature extraction;Depression Detection;Deep Learning;Residual Neural Network (RNN);Convolutional Neural Network (CNN);Long Short-Term Memory (LSTM);Exploratory Data Analysis (EDA)},
  doi={10.1109/I-SMAC58438.2023.10290160},
  ISSN={2768-0673},
  month={Oct},}@INPROCEEDINGS{10941649,
  author={Goyal, Shivansh and Sriram, Ajay and S, Abirami and T, Nathezhtha},
  booktitle={2024 International Conference on Integration of Emerging Technologies for the Digital World (ICIETDW)}, 
  title={Detecting Depression in Social Media using Machine Learning Algorithms}, 
  year={2024},
  volume={},
  number={},
  pages={1-7},
  abstract={Social media platforms such as Facebook, Twitter, and Instagram drastically change our world. After the Covid-19 outbreak, people become more inclined to discuss their sentiments and emotions on social media. Every year, over 300 million individuals worldwide suffer from depression, a prevalent mental condition that can lead to suicide. Early detection of depression on social media can help save lives. The proposed work aims to identify depressive qualities in tweets. The main challenge of this task is performing feature engineering and modeling to classify tweets as depressed or not. Additionally, estimating both depressive and non-depressive traits in a tweet is essential for fully understanding its content, which is crucial for determining how best to assist the user. We propose a probabilistic machine learning (ML) approach that provides not only a binary classification but also a probability estimate for the classification. This approach allows us to capture the uncertainty and varying degrees of depressive traits in tweets, leading to more nuanced insights. The proposed model is tested using datasets generated from mining depressive tweets and an equal number of random tweets, totaling 39,111 tweets. By improving data collection with precise keywords and enhancing feature engineering through proper tweet cleaning, the proposed model’s accuracy increases by 3%. The probabilistic approach further enhances the model's ability to assess the likelihood of depressive characteristics.},
  keywords={Support vector machines;Accuracy;Machine learning algorithms;Uncertainty;Social networking (online);Blogs;Probabilistic logic;Depression;Vectors;Web sites;Social media;Machine learning;Depression detection;Probabilistic approach},
  doi={10.1109/ICIETDW61607.2024.10941649},
  ISSN={},
  month={Sep.},}
@INPROCEEDINGS{11374711,
  author={Patnaik, Sneha and Sharma, Khemraj and Mohanty, Itishree and Pradhan, Himanshu Sekhar},
  booktitle={2025 Tenth International Conference on Science Technology Engineering and Mathematics (ICONSTEM)}, 
  title={AI-Powered Sentiment Analysis for Early Detection of Mental Health Disorders in Social Media Communications}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={The investigation of novel, scalable, and non-intrusive methods for early identification and intervention has been spurred by the rising incidence of mental health issues. Real-time psychological evaluation is made possible by social media platforms, where people often share their ideas, feelings, and actions. This study compares the effectiveness of the CNN, XGBoost, BRDT, and NB models and uses sentiment analysis on Reddit data to try and identify mental illness. The CNN model was found to have the best overall performance with an F1 Score, accuracy, recall, and precision of 95.7%, making it highly effective in detecting depression based on text post data from both the pre- and post-pandemic periods. Despite having a somewhat lower accuracy of 95.6%, the XGBoost model actually has the lowest error rate, at 0.052734. The BRDT and NB model had the highest error rate and the lowest accuracy. These results demonstrate the potential of machine learning and sentiment analysis in detecting mental health problems on social media, and they imply that improved models can enhance early detection and intervention initiatives.},
  keywords={Sentiment analysis;Analytical models;Accuracy;Social networking (online);Error analysis;Mental health;Machine learning;Data models;Real-time systems;Mathematical models;Mental Health;Machine learning;Artificial intelligence;Social media;Sentiment Analysis},
  doi={10.1109/ICONSTEM65670.2025.11374711},
  ISSN={2996-2986},
  month={Nov},}@INPROCEEDINGS{10919310,
