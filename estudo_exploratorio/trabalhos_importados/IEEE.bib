  isbn={9781394242559},
  url={https://ieeexplore.ieee.org/document/10953160},}@INPROCEEDINGS{10305889,
  author={Vasconcelos, Arthur B. and Drummond, Lúcia Maria de A. and Brum, Rafaela C. and Paes, Aline},
  booktitle={2023 International Symposium on Computer Architecture and High Performance Computing Workshops (SBAC-PADW)}, 
  title={Exploring Federated Learning to Trace Depression in Social Media with Language Models}, 
  year={2023},
  volume={},
  number={},
  pages={24-30},
  abstract={Due to the rising numbers of depression cases in recent years, many initiatives have investigated the use of Machine Learning models to detect depressive symptoms from the individual's presence on social media. To train these models, a dataset is needed. An adequate way of collecting reliable data is to elicit volunteers to agree to share their posts for research. Usually, the volunteer is also requested to answer a depressive inventory to provide the required depression label. However, this data is often sensitive and cannot be shared between research groups, harming reproducibility and collaboration. To address that problem, in this manuscript, we investigate Federated Learning techniques to train a classifier depression method while still preserving the data privacy of individuals. Since social media posts are primarily text-based, we fine-tune language models induced by the Transformer architecture to our task. In our experiments, we simulate the common heterogeneity across clients. Our experiments show that Federated Learning achieves competitive models compared to the centralized version.},
  keywords={Social networking (online);Federated learning;Computational modeling;Computer architecture;Media;Depression;Transformers;Federated Learning;Machine Learning;BERT;Transformers;Depression Classifier;Social Media},
  doi={10.1109/SBAC-PADW60351.2023.00014},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10725304,
  author={Chandu, Janakiram and Dhanush, Svs and Rohith, D and Kumar, Tsaliki Satya Ganesh and Soman, Kp and Sachin Kumar, S},
  booktitle={2024 15th International Conference on Computing Communication and Networking Technologies (ICCCNT)}, 
  title={Detection of Mental illness from social media Text}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={This project aims how social media impacts on mental health, specifically focusing on depression, anxiety, and borderline personality disorder (BPD). A massive dataset from Reddit posts was used it was available in kaggel for download and to analyze signs of these mental health issues. Using various computational techniques like Natural Language Processing(NLP), machine learning(ML), deep learning(DL) and transformers we dug deep into the data to uncover meaningful insights. our initial literature study indicate a concerning trend on many social media users seem to be struggling with feelings of depression and anxiety. This highlights the need for proactive measures to promote healthier online behavior and support mental well-being. Understanding these patterns is crucial for developing effective intervention strategies and advancing our knowledge in computer science and engineering.},
  keywords={Knowledge engineering;Social networking (online);Anxiety disorders;Natural languages;Mental health;Forestry;Depression;Transformers;Market research;Vectors;Global Vectors for Word Representation;Borderline personality disorder;Random Forest;K-Nearest Neighbors},
  doi={10.1109/ICCCNT61001.2024.10725304},
  ISSN={2473-7674},
  month={June},}@INPROCEEDINGS{10008283,
  author={Garg, Tejaswita and Gupta, Sanjay Kumar},
  booktitle={2022 14th International Conference on Computational Intelligence and Communication Networks (CICN)}, 
  title={A Hybrid Stacked Ensemble Technique to Improve Classification Accuracy for Neurological Disorder Detection on Reddit posts}, 
  year={2022},
  volume={},
  number={},
  pages={256-260},
  abstract={Sentiment analysis helps in the early detection of depression as identify unpleasant mental states in people who are at risk for developing mental disorders. By utilizing both syntactic and semantic information, modelling approaches for sentiment analysis rely on machine learning algorithms. In this paper, a hybrid stacked ensemble learning approach has been used for the detection of depression as a neurological disorder. With the help of pre-trained word embeddings, the Word2Vec, GloVe and Fasttext are chosen for data preprocessing and feature extraction. Then, to identify depressed and non depressed identities, we integrate a hybrid stacked ensemble learning approach over Random Forest (RF), Support vector machines (SVM), K-Nearest Neighbor (KNN) and Catboost classifier (CBC) as base models whereas logistic regression (LR) as meta model classifier. The results of the experiments show that suggested model performs best with our proposed model than individual models. It is also found that with Word2Vec word embedding model, the proposed model achieved the higher accuracy as 99% in comparison to GloVe and Fasttext that categorizes depressed over non depressed users on the social media platforms.},
  keywords={Support vector machines;Neurological diseases;Sentiment analysis;Social networking (online);Computational modeling;Syntactics;Depression;Depression;Word2Vec;GloVe;Fasttext;Stacked ensemble learning;Deep learning;Reddit},
  doi={10.1109/CICN56167.2022.10008283},
  ISSN={2472-7555},
  month={Dec},}@INPROCEEDINGS{11013454,
  author={Balakrishna, N. and Krishnan, M.B.Mukesh and Ganesh, D.},
  booktitle={2025 Eleventh International Conference on Bio Signals, Images, and Instrumentation (ICBSII)}, 
  title={Mindchrono: A Comparative Study of Deep Learning Models for Eeg-based Depression Detection}, 
  year={2025},
  volume={},
  number={},
  pages={1-7},
  abstract={Clinical depression is a widespread mental health disorder that significantly impacts an individual’s quality of life and societal productivity. Traditional diagnostic approaches primarily rely on subjective assessments, including selfreported symptoms and clinical interviews, which can lead to inconsistencies and delayed interventions. To address these challenges, this study explores an EEG-based deep learning framework that automates depression detection, ensuring objective, scalable, and real-time assessment. This study utilizes the EEG Psychiatric Disorder Dataset, which includes EEG recordings from X depression patients and Y healthy controls, ensuring a well-balanced dataset for model evaluation.. The dataset contains 1149 EEG features, including Power Spectral Density (PSD), Hjorth parameters, coherence, and quantitative EEG (qEEG) variables, capturing brainwave activity across multiple frequency bands. EEG signals undergo a comprehensive preprocessing pipeline, incorporating band-pass filtering, independent component analysis (ICA), and normalization to enhance signal clarity and reduce noise artifacts. Three state-of-theart deep learning models-Transformers, Recurrent Neural Networks (RNNs), and Long Short-Term Memory Variational Autoencoders (LSTM-VAEs)-are employed to analyze the processed EEG signals. Transformers, leveraging self-attention mechanisms, achieve the highest classification accuracy of $95 \%$, outperforming RNNs (91%) and LSTMVAEs ($89.95 \%$). The superior performance of Transformers is due to their ability to capture long-range dependencies in EEG sequences, improving feature representation and classification accuracy. This study underscores the critical role of model selection in EEG-based depression detection, demonstrating that deep learning techniques can significantly improve diagnostic reliability, automation, and scalability. By reducing reliance on subjective clinical evaluations, the proposed approach paves the way for real-time, data-driven mental health diagnostics, improving accessibility and early intervention strategies.},
  keywords={Deep learning;Accuracy;Recurrent neural networks;Mental health;Brain modeling;Transformers;Depression;Electroencephalography;Data models;Real-time systems;EEG;deep learning;depression detection;Transformers;RNNs;LSTM-VAEs;neuropsychiatric diagnostics;automated mental health assessment},
  doi={10.1109/ICBSII65145.2025.11013454},
  ISSN={2768-6450},
  month={March},}@ARTICLE{9903477,
  author={Skaik, Ruba S. and Inkpen, Diana},
  journal={IEEE Access}, 
  title={Predicting Depression in Canada by Automatic Filling of Beck’s Depression Inventory Questionnaire}, 
  year={2022},
  volume={10},
  number={},
  pages={102033-102047},
  abstract={The risk for depression and anxiety increased as people adjusted to a new normal after the COVID-19 pandemic. Early detection and appropriate onset treatment and support can reduce the consequences of depression. Automatic detection of depression in social media has recently become an important area of investigation. However, because of the lack of extensive annotated data, we propose a method for using a model that learns to answer a depression questionnaire and apply it to make population-level predictions. We used the eRisk 2021 Task 3 training dataset to build an automated model to fill the Beck’s Depression Inventory (BDI) questionnaire. We selected the best performing model for each group of questions based on predefined metrics and consolidated those models into one model (called the  $BDI\_{}Multi\_{}Model$ ). The  $BDI\_{}Multi\_{}Model$  achieved better performance than the state-of-the-art for this challenging task. Then, we used this model for inference on a Canadian population dataset and compared its predictions with the statistics of the most recent mental health survey conducted by Statistics Canada. The correlation between the inference of the answered questionnaire based on our  $BDI\_{}Multi\_{}Model$  and the official statistics showed a strong Pearson correlation of 0.90.},
  keywords={Deep learning;Text classification;Depression;Medical treatment;Mental health;COVID-19;Behavioral sciences;Psychology;Predictive models;Deep learning;beck depression inventory;text classification;mental health;depression detection},
  doi={10.1109/ACCESS.2022.3208470},
  ISSN={2169-3536},
  month={},}@ARTICLE{10749991,
  author={Dalal, Sumit and Jain, Sarika and Dave, Mayank},
  journal={IEEE Transactions on Computational Social Systems}, 
  title={Review of Advancements in Depression Detection Using Social Media Data}, 
  year={2025},
  volume={12},
  number={1},
  pages={77-100},
  abstract={A large population embraced social media to share thoughts, emotions, and daily experiences through text, images, audio, or video posts. This user-generated content (UGC) serves various purposes, including user profiling, sentiment analysis, and disease detection or tracking. Notably, researchers recognized the potential of UGC for assessing mental health due to its unobtrusive and real-time monitoring capabilities. Recent reviews on depression identification from textual UGC using AI models covered tools and techniques but overlooked critical components such as datasets, lexicons, features, and subtasks, which are essential for understanding the progress and tasks undertaken. This survey adopts a systematic approach and formulates five research questions to examine the relevant literature concerning these elements. Additionally, it organizes machine learning and deep learning (ML/DL) training features from textual UGC in a hierarchical manner and maps the literature on depression detection into various subtasks. The review highlights that despite the prevalence studies, datasets are limited in both quantity and size, with many relying on less reliable ground truth collection methods such as self-reported diagnosis statements (SRDS). Furthermore, the review identifies an overemphasis on certain textual features, such as n-grams and affective elements, while others, such as life events, egocentric graphs, and intervention/coping style, remain largely unexplored. It is crucial for practical AI depression detection systems to develop expertise in tasks such as severity, symptom detection, and explainable/interpretable depression analysis to instill confidence and trust among users.},
  keywords={Social networking (online);Depression;Reviews;Surveys;Mental health;Feature extraction;Blogs;Sentiment analysis;Organizations;Media;Deep learning (DL);depression;machine learning (ML);mental health;psycholinguistics;sentiment analysis;textual features},
  doi={10.1109/TCSS.2024.3448624},
  ISSN={2329-924X},
  month={Feb},}@INPROCEEDINGS{11013276,
  author={Symoom, Farhana and Tanzil Islam, Kazi Md and Hossain, Jawad and Imam Bijoy, Md. Hasan and Haque, Aminul},
  booktitle={2025 International Conference on Electrical, Computer and Communication Engineering (ECCE)}, 
  title={The Unspoken Words: Leveraging Transformer-based Approaches for Detecting Depression from Social Media}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Mental health issue is a topic of great concern in the present world, yet in spite of being so widely spoken language in Bengali, there are not many notable works addressing this problem. This paper focuses on detecting and classifying depressive content in Bengali text by leveraging linguistic patterns and emotional cues. A dataset of 3,002 Bengali social media texts has been created to identify signs of depression. The dataset is categorized into two classes: Depressive and Non-Depressive, enabling the detection of depression from social media content. This paper presents a comprehensive evaluation of detecting depression for Bengali text, encompassing five machine learning techniques, three deep learning models, and five transformer-based approaches. Among the evaluated models, Bangla-BERT, our proposed transformer-based method, achieved the highest accuracy of 0.96. The model demonstrates exceptional capability in detecting depression by effectively understanding the contextual nuances of sentences. The findings highlight the potential of transformer-based architectures, particularly Bangla-BERT, in advancing sentiment analysis tasks for low-resource languages (LRLs) like Bengali.},
  keywords={Deep learning;Sentiment analysis;Accuracy;Text analysis;Social networking (online);Mental health;Streaming media;Transformers;Depression;Context modeling;Natural Language Processing;Mental Health;Bengali Text Analysis;Depressive Content Detection;Deep learning;Transformer;Low-Resource Languages (LRLs)},
  doi={10.1109/ECCE64574.2025.11013276},
  ISSN={},
  month={Feb},}@INPROCEEDINGS{9937358,
  author={Anzum, Fahim and Asha, Ashratuz Zavin and Gavrilova, Marina L},
  booktitle={2022 International Conference on Cyberworlds (CW)}, 
  title={Biases, Fairness, and Implications of Using AI in Social Media Data Mining}, 
  year={2022},
  volume={},
  number={},
  pages={251-254},
  abstract={Online social media (OSM) has become an integral part of an individual’s daily life. The extensive computational power and decision-making ability of artificial intelligence (AI) and the proliferation of user-generated data on OSM have made the opinion one of the key emerging research areas. However, the ease of accessing, manipulating, and mining such user-generated data raises concerns about privacy and security, data and algorithmic biases and fairness. Nevertheless, their personal and societal implications are barely addressed. In this paper, we discuss the limitations, fairness, and biases introduced in data mining and the AI model development. Moreover, we describe the possible implications of using AI systems on users’ privacy and address future research directions to mitigate potential biases.},
  keywords={Data privacy;Privacy;Systematics;Social networking (online);Decision making;Data models;Classification algorithms;online social media;cyberworld;trust;artificial intelligence;machine learning;bias;fairness;privacy},
  doi={10.1109/CW55638.2022.00056},
  ISSN={2642-3596},
  month={Sep.},}@INPROCEEDINGS{9930596,
  author={Fang, Cangnai and Dianatobing, Gracia and Atara, Talia and Edbert, Ivan Sebastian and Suhartono, Derwin},
  booktitle={2022 6th International Conference on Informatics and Computational Sciences (ICICoS)}, 
  title={Feature Extraction Methods for Depression Detection Through Social Media Text}, 
  year={2022},
  volume={},
  number={},
  pages={117-121},
  abstract={The high number of depressed people and the fatal effect it can cause raise the urgency to detect a depressed person as soon as possible. Social media as a platform to express oneself can help us do this job. By properly extracting user-created content in social media, we can detect those who are depressed. This paper compares four feature extraction methods to find the best one. The combinations of TF-IDF, LIWC, Word2Vec, and weighted Word2Vec paired with Naïve Bayes or Linear Support Vector Machine classifiers are used on the Reddit Mental Health dataset. Word2Vec paired with the SVM classifier proved to be the best combination with 95.68% accuracy, 92.58% precision, 93.10% recall, and 92.84% F1- score. However, the weighted Word2Vec failed to improve the performance of averaging the basic Word2Vec, obtaining only 95.15% accuracy. Another finding is that SVM performed better than NB for classification though it takes significantly longer to train. This experiment shows that choosing suitable feature extraction methods will benefit the model's performance.},
  keywords={Social networking (online);Computational modeling;User-generated content;Support vector machine classification;Mental health;Feature extraction;Depression;Depression Detection;Naïve Bayes;Support Vector Machine;Feature Selection;Word2Vec},
  doi={10.1109/ICICoS56336.2022.9930596},
  ISSN={2767-7087},
  month={Sep.},}@INPROCEEDINGS{11039547,
  author={Hassan, Esraa and Bhatnagar, Roheet and El-Hafeez, Tarek Abd and Shams, Mahmoud Y.},
  booktitle={2025 7th International Conference on Signal Processing, Computing and Control (ISPCC)}, 
  title={Detection of Suicide and Depression for Early Intervention and Initiative-taking Mental Healthcare}, 
  year={2025},
  volume={},
  number={},
  pages={99-104},
  abstract={This study presents an AI-based Suicide and Depression Detection system for early mental health intervention. Using advanced deep learning algorithms, particularly Convolutional Neural Networks (CNNs), the system aims to identify subtle facial cues that may signal mental health issues. By combining traditional techniques such as Histogram of Oriented Gradients (HOG) and Local Binary Patterns (LBP) with CNNs, the model effectively recognizes crucial facial features and textures linked to depression and suicide risk. This integration of HOG and LBP’s interpretability with CNN’s ability to learn complex patterns enhances the system’s accuracy and reliability, while also providing valuable insights into the specific features associated with mental health concerns. The system’s performance metrics demonstrate the effectiveness of this approach, with HOG and achieving an accuracy of 0.9695, precision of 0.95235, recall of 0.96123, and an F1-score of 0.9712, while LBP outperforms with an accuracy of 0.9949, precision of 0.9819, recall of 0.9901, and an F1-score of 0.9956.},
  keywords={Histograms;Accuracy;Signal processing algorithms;Mental health;Medical services;Signal processing;Depression;Convolutional neural networks;Reliability;Facial features;Suicide;Depression;Mental Health Care;CNN;HOG;LBP},
  doi={10.1109/ISPCC66872.2025.11039547},
  ISSN={2643-8615},
  month={March},}@INPROCEEDINGS{11296241,
  author={Sharma, Renuka and Gupta, Shilpa and Adhikari, Pitamber and Kumar, Deepika and Jamil, Akhtar},
  booktitle={2025 3rd International Conference on Artificial Intelligence, Blockchain, and Internet of Things (AIBThings)}, 
  title={Depression Detection using FastText-BiLSTM Model on Social Media Posts}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Today, many people suffer from mental health problems, especially depression, due to a lack of early identification and adequate treatment, and resources. Depression is recognized as a major contributor to global disability and a significant factor in self-harm and suicide. With the increased use of the internet, people have become more comfortable sharing their mental state so that they can get emotional support. Still, identifying depression from text messages on social media is much more difficult than from other mediums such as images, audio, or video.In this study, we propose a stacked Bi-LSTM model for depression detection, using FastText embeddings for contextual analysis, TF-IDF vectors for word relevance, and a Bi-LSTM deep learning classifier to identify the nature of posts, i.e. depressive or non-depressive. The results demonstrate that the proposed FastText bi-directional LSTM (FT-BiLSTM) model detects depressive content more effectively than other models from Reddit English posts, achieving an improvement of up to 2% in the F1-score. Finally, the confusion matrix is used to display the true labels and predicted labels of the proposed FTBiLSTM model for depression detection.},
  keywords={Deep learning;Social networking (online);Text categorization;Mental health;Predictive models;Depression;Vectors;Blockchains;Internet of Things;Context modeling;Depression Detection;Text Classification;FastText;DeepLearning;Bi-LSTM;TF-IDF;Machine Learning},
  doi={10.1109/AIBThings66987.2025.11296241},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10989455,
  author={Baalawi, Akram H. and Ghanem, Sakher and Alqahtani, Mohammad M.},
  booktitle={2025 4th International Conference on Computing and Information Technology (ICCIT)}, 
  title={Detecting Depression in Arabic Texts Using AI Techniques}, 
  year={2025},
  volume={},
  number={},
  pages={584-591},
  abstract={In Arabic-speaking communities, mental health issues often go unrecognized due to cultural stigma and a lack of awareness, making early diagnosis challenging. Social media platforms and online forums provide a rich source of data that can be used to identify early signs of depression through analysis of user-generated content. This study aimed to develop a reliable method for detecting depressive tendencies in Arabic texts using artificial intelligence techniques. To achieve this, we collected approximately 19,000 posts from the Arabic forum “Nafsany,” using Python's BeautifulSoup library to scrape data based on keywords related to depression. The data were annotated with the help of an expert psychologist and classified according to the DSM-5 guidelines. Our study employed lexicon-based, machine learning, and deep learning approaches. An ensemble model combining various deep learning techniques was developed to enhance the accuracy of depression detection. The ensemble model achieved superior performance, with an accuracy of 93.03% and an F1-score of 92.93%, which demonstrates its effectiveness. This research is significant as it contributes to the early detection of depression in Arabic-speaking populations, potentially reducing stigma and barriers to mental health care. By improving the diagnostic methods, this study supports better mental health outcomes and provides a foundation for future research in the field.},
  keywords={Deep learning;Sentiment analysis;Accuracy;Text analysis;Social networking (online);User-generated content;Mental health;Depression;Libraries;Reliability;Text Analysis;Depression;Sentiment Analysis;Natural Language Processing;Machine Learning;Deep Learning},
  doi={10.1109/ICCIT63348.2025.10989455},
  ISSN={},
  month={April},}@INPROCEEDINGS{10651873,
  author={Saraswat, Pavi and Beniwal, Rohit},
  booktitle={2024 IEEE Symposium on Wireless Technology & Applications (ISWTA)}, 
  title={BERT-based RNN for Effective Detection of Depression with Severity Levels from Text Data}, 
  year={2024},
  volume={},
  number={},
  pages={52-56},
  abstract={Due to a lack of early and accurate treatment, a large number of populations are suffering from depression. The posts available on online digital platforms play major role in providing useful signs concerning mind state of a user. The traditional depression methods involve a large amount of time, budget, and expertise, thus, making depression detection a complicated task. Therefore, there is a critical need to propose a computer-assisted system to analyze and detect depression efficiently at different severity levels. Focusing on such concerns, this study performed multi-class classification utilizing a publicly available text dataset to categorize users into non-depressed, moderately, and severely depressed. This study presented a hybrid technique that robustly combines Bidirectional Encoder Representations from Transformers (BERT) with two versions of Recurrent Neural Network (RNN) i.e. Long Short-Term Memory (LSTM) and Gated Recurrent Unit (GRU). The BERT model is implemented to extract useful word embeddings which are then fed to RNN comprising LSTM, dropout, and GRU layers. The findings revealed that the employed approach outperformed all other employed models and techniques in the past studies by attaining an accuracy of 95.0%. Thus, the presented strategy is expected to be beneficial for clinicians to perform depression detection at different stages accurately.},
  keywords={Accuracy;Recurrent neural networks;Bidirectional control;Medical services;Media;Depression;Transformers;Depression Detection;BERT;LSTM;GRU;RNN;social media text},
  doi={10.1109/ISWTA62130.2024.10651873},
  ISSN={2324-7851},
  month={July},}@ARTICLE{10182389,
  author={Cui, Weigang and Sun, Mingyi and Dong, Qunxi and Guo, Yuzhu and Liao, Xiao-Feng and Li, Yang},
  journal={IEEE Transactions on Computational Social Systems}, 
  title={A Multiview Sparse Dynamic Graph Convolution-Based Region-Attention Feature Fusion Network for Major Depressive Disorder Detection}, 
  year={2024},
  volume={11},
  number={2},
  pages={2691-2702},
  abstract={Detecting and diagnosing major depressive disorder (MDD) is greatly crucial for appropriate treatment and support. In recent years, there have been efforts to develop automated methods for depression detection using machine learning techniques, which mainly analyze various data sources such as text, speech, and social media posts. However, the effectiveness and reliability of these methods may vary and more importantly, they fail to provide timely intervention and treatment to MDD patients. To address these challenges, we propose a novel electroencephalogram (EEG)-based MDD detection framework, which is named as multiview sparse dynamic graph convolution-based region-attention feature fusion network (MV-SDGC-RAFFNet). Specifically, we first design a multiview (MV) feature extractor to concurrently characterize EEG signals from temporal, spectral, and time-frequency views, providing rich semantic information on the emotional status of patients. Secondly, we introduce a sparse dynamic graph convolution network (SDGCN) to map the multidomain features into high-level representations, which avoids the limitation of over-smoothing and redundant edges existing in the conventional graph neural networks (GNNs). Finally, to efficiently fuse multidomain features, we propose a region-attention feature fusion network (RAFFNet), which applies different attention weights for brain regions and is greatly beneficial to boost the accuracy (ACC) of MDD detection. We validate the efficacy of the proposed MV-SDGC-RAFFNet framework on two public MDD datasets, and it achieves more promising detection performance against the state-of-the-art methods, indicating that our method has a prospect on clinical MDD detection.},
  keywords={Feature extraction;Electroencephalography;Depression;Data mining;Graph neural networks;Electroencephalogram (EEG);graph neural network (GNN);major depressive disorder (MDD);multidomain feature extraction},
  doi={10.1109/TCSS.2023.3291950},
  ISSN={2329-924X},
  month={April},}@INPROCEEDINGS{10722555,
  author={Bhuria, Ruchika and Gupta, Sheifali},
  booktitle={2024 5th International Conference on Smart Electronics and Communication (ICOSEC)}, 
  title={Empowering Mental Health Awareness: Naive Bayes Analysis of Social Media Interactions}, 
  year={2024},
  volume={},
  number={},
  pages={525-529},
  abstract={This article investigates the efficiency of a Naïve Bayes algorithm for depression identification. We evaluate the model’s performance using a confusion matrix, correctly identifying 1248 members of the “Not Depressed” class, free from false positives, with a precision of 1.00. Although the recall for the “depressed” class is 0.37, it precisely identifies only 54 cases and misclassifies 92 as “not depressed.” This implies that there are rather many false negatives among sad individuals. Still, given its overall accuracy of $93.4 \%$, the model demonstrates remarkable sensitivity to identify non-depressed individuals. Given that the “depressed” class scores significantly lower than the “not depressed” class, the F1-score highlights even more variation. This difference suggests the need for improved feature selection, dataset rebalancing, alternative algorithm investigation, and model tuning to better capture the traits of depressed people. Even though the model performs well at identifying non-depressed cases and increases its accuracy in diagnosing depression, there is still more work to be done, particularly in reducing false negatives. This paper compares the Naive Bayes and Random Forest algorithms for depression diagnosis. Naive Bayes exhibits remarkable accuracy for non-depressed individuals, but it suffers with recall for depressed ones. Random Forest emphasizes the need for dataset rebalancing and model adjustment because it preserves outstanding overall accuracy, delivers improved balance, and boosts recall in depressed conditions.},
  keywords={Analytical models;Accuracy;Sensitivity;Social networking (online);Mental health;Depression;Feature extraction;Stability analysis;Bayes methods;Tuning;Mental health;Social inclusion;Algorithm;Data analysis;Classification;Well-being;Equity;Machine Learning},
  doi={10.1109/ICOSEC61587.2024.10722555},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10863118,
  author={Ghaswala, Maariyah and Gomes, Chrisanne and Kumar, Shyam M and Sweta, Soni},
  booktitle={2024 First International Conference for Women in Computing (InCoWoCo)}, 
  title={Depression Detection from Social Media Text Using NLP and Deep Learning Techniques}, 
  year={2024},
  volume={},
  number={},
  pages={1-7},
  abstract={Depression is a prevalent psychological disorder with potentially serious implications, spreading worldwide. Moreover, that is why research is focused on this subject. Individuals experiencing depression often suffer from anxiety and insecurity in their daily lives, which can impact their relationships and work. In severe cases, this may also lead to various health issues and, tragically, even suicide. We are in the digital age. With the surge in the growth of social media usage, people utilize it as a platform to voice out their emotions, feelings and thoughts. Having machine learning improve and sample data being available regarding depression, there is potential for producing an early depression diagnosis system that would be crucial to reduce the victims number. A machine learning-based model to predict depression is showcased by this paper, based on extracting text data from one of the most common social media outlets: Twitter. We'll use NLP technique through user posts and classify them as indicative or not of depression. We use a bidirectional LSTM model trained on datasets from Twitter to detect depressive tendencies. Our model demonstrates excellent precision in distinguishing between a depressive text and a non depressive text achieving a precision rate of 98% and a recall rate of 99%. and really helps in opening horizons for artificial intelligence to more precisely identify mental health conditions based on an individual's online behavior. This research contributes to the expanding field of depression detection using AI and provides a framework for future mental health analytics research and development.},
  keywords={Deep learning;Social networking (online);Blogs;Mental health;Predictive models;Depression;Information age;Data models;Surges;Research and development;Depression;Social Media;Twitter;BiLTSM;Sentiments;NLP;Deep Learning},
  doi={10.1109/InCoWoCo64194.2024.10863118},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{11167052,
  author={Abishek, M and Vimal Dharshan, N and S, Sachin Kumar and Mohan, Neethu},
  booktitle={2025 5th International Conference on Intelligent Technologies (CONIT)}, 
  title={Mental Health Data Analysis using Deep learning based Methods}, 
  year={2025},
  volume={},
  number={},
  pages={1-5},
  abstract={Social media is rapidly reflecting mental health issues, hence offering useful yet unstructured data for early detection and intervention. Based on social media material, this paper offers an AI-powered framework for multi-class sentiment analysis to address mental health issues. From several mental healthrelated sources on Kaggle, a thorough dataset of $\mathbf{5 3, 0 4 3}$ tagged entries spanning seven emotion categories-Normal, Depression, Suicidal, Anxiety, Stress, Bi-Polar, and Personality Disorder-was assembled. Extensive preprocessing designed for loud, informal social media language was applied to the data. Using different embedding approaches including TF-IDF, GloVe, FastText, and BERT, we assessed a broad spectrum of Transformer-based models, Deep Learning (DL), and Machine Learning (ML). Multi-Class Multi-Level approach is also implemented using ML and DL models. While DL models employing GRU with FastText reached 73.63% accuracy and an F1-score of 0.66, classic ML models with TF-IDF showed up to 75% accuracy. Of all methods, the BERT-based Transformer model beat others with a test accuracy of $\mathbf{7 9. 3 7 \%}$ and an F1-score of $\mathbf{0. 7 6}$. These results highlight the possibility of using Transformer structures for complex sentiment categorization in the mental health field, hence providing smart and scalable early-warning systems for emotional well-being.},
  keywords={Deep learning;Sentiment analysis;Accuracy;Data analysis;Social networking (online);Anxiety disorders;Mental health;Transformers;Depression;Mental Health;Sentiment Analysis;Social Media;Natural Language Processing;Machine Learning;Deep Learning;Transformers;BERT;Emotion Classification;Text Embeddings},
  doi={10.1109/CONIT65521.2025.11167052},
  ISSN={},
  month={June},}@INPROCEEDINGS{11136260,
  author={Debnath, Debjit and Majumder, Tirtha},
  booktitle={2025 International Conference on Intelligent Computing and Knowledge Extraction (ICICKE)}, 
  title={Optimizing AI and Machine Learning for Early Detection of Mental Health Disorders: Comparative Analysis of Algorithms}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Mental health disorders, such as stress, anxiety, and depression, have become increasingly prevalent, necessitating early detection and intervention. This study presents a machine learning-based approach to identify mental health issues by analyzing social media text data. Utilizing a dataset comprising labeled tweets, applied various classification algorithms, including Logistic Regression, Random Forest, and Support Vector Machines. The models were evaluated using metrics such as accuracy, precision, recall, and F1-score. Among the tested models, Logistic Regression achieved the highest accuracy of 94.89%, hence demonstrating its effectiveness in detecting mental health-related content. The findings underscore the potential of leveraging social media data and machine learning techniques for early identification of mental health concerns, which can aid in timely support and treatment.},
  keywords={Support vector machines;Logistic regression;Accuracy;Social networking (online);Anxiety disorders;Mental health;Depression;Transformers;Natural language processing;Context modeling;ML;AI;Natural Language Processing (NLP);Confusion Matrix;Term Frequency- Inverse Document Frequency (TF-IDF)},
  doi={10.1109/ICICKE65317.2025.11136260},
  ISSN={},
  month={June},}@INPROCEEDINGS{10143026,
  author={J, Alphonsa Sini P. and K, Sherly K.},
  booktitle={2023 2nd International Conference on Computational Systems and Communication (ICCSC)}, 
  title={Early Detection of Anxiety, Depression and Stress among Potential Patients using machine learning and deep learning models}, 
  year={2023},
  volume={},
  number={},
  pages={1-7},
  abstract={Depression, anxiety and stress are the three important mental health conditions. Only a small portion of the millions of people who experience depression, anxiety and stress each year receives a prompt treatment. The development of technology that helps clinicians detect various types of mental diseases has greatly benefited from the progress of Machine Learning (ML) techniques over the past few decades. This study presents a comparison of three important mental health issues (Depression, Anxiety, and stress) using machine learning and Deep Learning (DL) algorithms. The proposed work also investigates about how the ML and DL techniques might help with the detection, diagnosis, and management of mental health diseases with a better effective and novel approach. As a result, three different algorithms (SVM, ANN and XgBoost) has been implemented in which Support vector machine (SVM) has achieved the better accuracy in detecting the mental health. The accuracy achieved in detecting depression, anxiety and stress are 99.32%, 99.80% and 98.44% respectively. Henceforth the proposed study was able to achieve a satisfactory result that helps to improve the decision-making and clinical practice.},
  keywords={Support vector machines;Deep learning;Machine learning algorithms;Anxiety disorders;Decision making;Medical treatment;Mental health;Mental health issues;Depression;Anxiety;Stress;psychiatric issues},
  doi={10.1109/ICCSC56913.2023.10143026},
  ISSN={},
  month={March},}@INPROCEEDINGS{10582212,
  author={Deulkar, Khushali and Narvekar, Meera and Gandhi, Priya and Gada, Dhruv and Kamath, Sahil},
  booktitle={2024 International Conference on Advances in Modern Age Technologies for Health and Engineering Science (AMATHE)}, 
  title={Evaluating the Influence of Text Representation techniques on Diverse Machine Learning Algorithms for Stress Detection in Social media users}, 
  year={2024},
  volume={},
  number={},
  pages={1-7},
  abstract={Over the past few years, there has been a notable surge in social media usage like Twitter, Facebook, Instagram. Due to the anonymity of the internet, people's mental health is frequently reflected in their social media activity. Through such activities, psychiatric problems are frequently discovered and can be treated in their early stages, potentially preventing the effects of untreated mental disorders like depression and anxiety. The present study aims to examine the potential consequences of utilising two commonly used methods for text representation, namely Term Frequency-Inverse Document Frequency(TF-IDF) and Bag-of-Words(BoW). The specific focus of this investigation is on the application of these techniques to the task of stress detection. The aim is to comprehend how these methods influence the effectiveness of different classifiers in identifying stress patterns within textual data. By assessing the impact of TF-IDF and BoW, this research seeks to enhance our understanding of their roles in shaping the performance of various algorithms. This study encompasses various machine learning algorithms, including Support Vector Machines(SVM), Random Forest, Logistic Regression, and Naive Bayes. In the case of deep learning techniques, Recurrent Neural Network(RNN), Long Short Term Memory(LSTM), RoBerta, and implementation of BERT embeddings in Recurrent Neural Networks was studied. The experimentation involves extensive datasets taken from two social media platform, Reditt and Twitter to ensure the robustness and generalizability of findings. The results shed light on the varying effects of TF-IDF and BoW, offering insights into which techniques are better suited for stress detection and contributing to the optimization of future stress detection systems.},
  keywords={Support vector machines;Logistic regression;Machine learning algorithms;Recurrent neural networks;Social networking (online);Blogs;Vectors;Social media;Machine learning;Deep neural network;Bert;RNN;Twitter;Reddit;Stress;Anxiety;Depression;RoBerta;LSTM},
  doi={10.1109/AMATHE61652.2024.10582212},
  ISSN={},
  month={May},}@INPROCEEDINGS{10763754,
  author={Goswami, Chahak and Goswami, Niyati and Israni, Dippal},
  booktitle={2024 IEEE International Conference on Communication, Computing and Signal Processing (IICCCS)}, 
  title={An Amalgamation of RNN and Transformers for Identifying Depression at the Preliminary Stage}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={The emergence of social media platforms has facilitated the effortless dissemination of individuals’ thoughts, emotions, concerns, and accomplishments to a global audience. The utilization of deep learning techniques to analyze social media data for early identification of depression has the potential to drastically transform the field of depression detection since a significant number of individuals express their emotions through social media platforms. This paper proposes a novel method for detecting depression at an early stage using transformer-based models. The data utilized for the experimentations is the publicly available dataset from Kaggle, consisting of 10,314 tweets. The tweets are pre-processed to clean the text, and then tokens are generated using the transformer-based models. The generated tokens are provided as input to the proposed transformer-based models like bidirectional encoder representations from Transformer (BERT), the robustly optimized BERT approach (Roberta), and the hybrid model, which combines BERT with Recurrent neural networks (RNN) and Roberta with RNN. The embeddings are extracted using the pre-trained models, and classification layers for the initial layers are added. Among the four models, it is observed that the hybrid models perform well by achieving a validation accuracy of 99.9%. This study adds to the expanding area of user-generated content analysis by providing essential visions into the possibility of early depression detection and monitoring through Internet platforms.},
  keywords={Deep learning;Accuracy;Social networking (online);User-generated content;Training data;Bidirectional control;Transforms;Depression;Transformers;Encoding;BERT;Deep learning;Machine learning;Artificial Intelligence;LSTM;Neural networks},
  doi={10.1109/IICCCS61609.2024.10763754},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10057898,
  author={Aldhafer, Shahad Hathal and Yakhlef, Mourad},
  booktitle={2022 6th International Conference on Information Technology, Information Systems and Electrical Engineering (ICITISEE)}, 
  title={Depression Detection In Arabic Tweets Using Deep Learning}, 
  year={2022},
  volume={},
  number={},
  pages={1-6},
  abstract={In today's globalizing world, depression has become a serious mental problem that effects a great number of people. Substantial efforts have been conducted by countries and health professionals around the world to help detect this illness and provide necessary treatments. However, in Arab contexts, de-pression is not taken seriously and people who suffer from it are ashamed to seek help. Therefore, this research aims to use deep learning to detect depression from Arabic texts posted on twitter. Moreover, twitter was chosen as the platform in which data will be collected for three main reasons, namely, it allows public access for research purposes, it is extremely rich in data and lastly, it is used as a main social media network for Arabs. Different deep learning models were tested using a dataset of 18 K tweets and compared to SVM model. According to the findings, CNN model perform better at detecting depressed tweets than the SVM and RNN models.},
  keywords={Deep learning;Support vector machines;Electrical engineering;Social networking (online);Mental disorders;Blogs;Depression;Depression Detection;Arabic tweets;Deep learning;Machine learning},
  doi={10.1109/ICITISEE57756.2022.10057898},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{10993773,
  author={Elankavi, R and Geethavani, B. and Meghana, S.C. and Rekha, Vemula and Priya, J. Sai and Lookmaan, Kommaddi Mohamad},
  booktitle={2024 International Conference on Communication, Computing and Energy Efficient Technologies (I3CEET)}, 
  title={Identification of social media cyberbullying with the aid of machine learning}, 
  year={2024},
  volume={},
  number={},
  pages={1020-1025},
  abstract={The internet, a vast platform for communication and idea-sharing, hosts around 4 billion users on social media platforms. Unfortunately, this widespread digital landscape has witnessed a surge in online abuse, harassment, trolling, and cyberbullying. These issues have far-reaching consequences, including depression, self-harm, and, tragically, suicide. Cyberbullying, involving negative, false, or harmful content targeting individuals, has severe implications, especially for the mental health of the younger generation. We propose the CBSA (Cyberbullying with Sentiment Analysis) model, which leverages a range of features to enhance cyberbullying detection.},
  keywords={Sentiment analysis;Analytical models;Computational modeling;Cyberbullying;Mental health;Machine learning;Feature extraction;Telecommunication computing;Internet;Surges;Internet;Cyberbullying;Natural Language Processing (NLP);Bullying;CBSA (Cyberbullying with Sentiment Analysis) model},
  doi={10.1109/I3CEET61722.2024.10993773},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10837869,
  author={Bhuria, Ruchika and Gill, Kanwarpartap Singh and Malhotra, Sonal and Singh, Mukesh},
  booktitle={2024 4th Asian Conference on Innovation in Technology (ASIANCON)}, 
  title={Enhanced Diagnosis of Gestational Diabetes through Machine Learning and Logistic Regression}, 
  year={2024},
  volume={},
  number={},
  pages={1-4},
  abstract={A persistent illness Diabetes might become an international health emergency. Diabetes mellitus, also known as diabetes, is typified by high blood sugar levels. Being among the worst diseases in the world, it is also spreading more and more. Diabetes can be diagnosed by a variety of traditional techniques as well as chemical and physical testing. Techniques used in data science may benefit other scientific disciplines since they throw new insight on pressing problems. Machine learning is a contemporary area of data science that focuses on how computers learn from experience. This paper develops and assesses a machine learning model to predict gestational diabetes using a large set of data of physiological markers and health features This study uses 768 examples to create and test a binary classification model to predict gestational diabetes utilizing characteristics including pregnancy, blood pressure, insulin levels, BMI, age, and family history. Class '1' diabetes has 0.72 accuracy, while class '0' has 0.79. However, diabetic recall is substantially poorer (0.55) than non-diabetic (0.89), indicating many missed positives. F1-scores (0.83 for class '0' and 0.63 for class '1') indicate the model's diabetes detection shortcomings and the need for prediction improvement.},
  keywords={Pregnancy;Machine learning;Predictive models;Data science;Data models;Blood pressure;Skin;Gestational diabetes;Glucose;Insulin;Good Health and Well-being;Quality Education;Machine Learning;Logistic Regression Classifier;Classifier Evaluation;Artificial Intelligence;Predictive Modelling Techniques;Diseases;Population;Resources;Reduced Inequalities;Innovation},
  doi={10.1109/ASIANCON62057.2024.10837869},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{10574935,
  author={Singh, Kartik and Gupta, Utkarsh and Renukadevi, P.},
  booktitle={2024 3rd International Conference on Applied Artificial Intelligence and Computing (ICAAIC)}, 
  title={Psychological Analysis using Social Media Tweets}, 
  year={2024},
  volume={},
  number={},
  pages={917-924},
  abstract={This study utilizes social media platforms to extract and analyze pertinent data for gaining a complete understanding of the psychological dimensions of depression, employing Long Short-Term Memory (LSTM) and Convolutional Neural Networks (CNNs) for enhancing the motor skills. With a focus on language and temporal context, tweets are scrutinized to unearth the underlying dynamics within the Twitter network, shedding light on the social processes influencing the concept of depression. This research study intends to enhance the understanding of mental health professionals and decision-makers in this domain. The proposed methodology encompasses tweet tokenization, followed by LSTM and CNN models to identify significant features. The primary objective is to develop a system capable of conducting psychological analysis and supporting psychotherapy, achieving a classification accuracy of up to 99.02%. This high accuracy enables the detection of changes in behavioral patterns, offering promising avenues for intervention and support in mental health care.},
  keywords={Accuracy;Social networking (online);Soft sensors;Natural languages;Mental health;Depression;Motors;Psychological analysis;Social media;Depression;Machine learning;NLP (Natural Language Processing);Data preprocessing},
  doi={10.1109/ICAAIC60222.2024.10574935},
  ISSN={},
  month={June},}@INPROCEEDINGS{10774652,
  author={Khan, Adeeb and Sachdev, Devanshu and Verma, Abhinay and Kumar, Divya},
  booktitle={2024 3rd International Conference for Advancement in Technology (ICONAT)}, 
  title={Early Identification of Suicide-Susceptible Students using Computational Techniques}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={In college life, pressure is the main cause of student suicides, highlighting a significant societal and academic challenge that demands urgent attention for early detection systems and support mechanisms. Addressing this issue proactively is crucial. To tackle this, we introduce machine learning models designed to identify suicidal tendencies in students. These models analyze various data points such as depression levels and experiences of discrimination to predict suicide risk levels—high, medium, or low, in the near future. By using predictive analytics, our approach aims to identify those in need so that they can receive the necessary support promptly, thereby reducing the risk of student suicides and promoting a safer, more supportive environment in academic institutions.},
  keywords={Analytical models;Machine learning;Predictive models;Depression;Data models;Predictive analytics;Suicide Detection;Machine Learning;DELM;Dual SVM;Depression;Academics},
  doi={10.1109/ICONAT61936.2024.10774652},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10940817,
  author={U, Ragavee. and P, Niranjan and J, Rohit S. and A, Yuvan Sriram M and G, Sanjana Lakshmi R. and M, Jayasaraswathi M.},
  booktitle={2025 International Conference on Electronics and Renewable Systems (ICEARS)}, 
  title={Empirical Evaluation of Social Networking Data to Classify Depressed Users based on Hybrid Deep Learning Stagey}, 
  year={2025},
  volume={},
  number={},
  pages={847-854},
  abstract={The rising incidence of depression coupled with the increasing use of social media represents an opportunity to leverage user generated material to identify depression earlier and intervene earlier. However, this technique raises serious ethical as well as methodological issues that require careful considerations. This research addresses the issues of the intricacies of human language and the ethical issues of personal data utilization by building an advanced AI model for detecting depression on social media platforms. We annotated manually a depression dataset to annotate both implicit and explicit elements of depressive sentences as well as non-depressive sentences and then proceeded to data preprocessing, feature extraction using N-grams and pre trained word embedding algorithms and implementing various classification techniques. The dataset was partitioned into training and evaluation subsets in an 80:20 ratio. A novel hybrid model of deep learning (H-DLS) combined with an attention mechanism is introduced by research. Categorizing normal sentences accuracy of 98.9% and depressive sentences accuracy of 95.2% were found. The accuracy is overall 97.6%. This study demonstrates the power of using social media data and trained machine learning models for early identification of depression and notes that these problems, while important, must be addressed.},
  keywords={Deep learning;Training;Ethics;Renewable energy sources;Accuracy;Social networking (online);Supervised learning;Depression;Data models;Real-time systems;Detecting Depression;N-grams pre-training;SpaCy's tokenize;word embedding techniques with GloVe},
  doi={10.1109/ICEARS64219.2025.10940817},
  ISSN={},
  month={Feb},}@INPROCEEDINGS{10206148,
  author={Long, Xinping and Zhang, Yifan and Shu, Xin and Shu, Jian},
  booktitle={2023 6th International Conference on Artificial Intelligence and Big Data (ICAIBD)}, 
  title={Image-text Fusion Model for Depression Tendency Detection Based on Attention}, 
  year={2023},
  volume={},
  number={},
  pages={730-734},
  abstract={Social media information can be used for monitoring multiple mental health issues, including depression. Aiming to detect users with depression tendency on social network, this paper proposes a depression tendency detection model, using image and text posts by Sina Weibo users. In this model, ALBERT and VGG16 are applied to extract text and image features, respectively. Considering that the information in short text is limited, the model utilizes Biterm Topic Model (BTM) to obtain topic distribution, then concatenates it into the original text. In addition, the paper proposed an image-text fusion method based on attention mechanism, which enabled text and images to interact. Finally, the fused features are applied to the task of depression detection. Experimental results indicate that the proposed model outperforms the unimodal detection model in terms of precision, recall and F1 score, and the fusion method based on the attention mechanism is better than concatenating.},
  keywords={Social networking (online);Blogs;Mental health;Media;Depression;Feature extraction;Routing;depression tendency detection;social media information;image-text fusion;attention mechanism},
  doi={10.1109/ICAIBD57115.2023.10206148},
  ISSN={2769-3554},
  month={May},}@INPROCEEDINGS{9824931,
  author={Dessai, Sukanya and Usgaonkar, Soniya Shakil},
  booktitle={2022 3rd International Conference for Emerging Technology (INCET)}, 
  title={Depression Detection on Social Media Using Text Mining}, 
  year={2022},
  volume={},
  number={},
  pages={1-4},
  abstract={Depression is regarded as the major cause of disability and a leading cause of suicide. Social media has recently risen to prominence as a leading means of disseminating information online. The majority of people use the internet to express their opinions, ideologies, and personal experiences. Depression has an effect on how people communicate on social media as evidenced by the language they use. The detection of mental illness has become a major concern as a result of the massive increase in mental health awareness. In this paper, we examine Twitter users’ tweets to detect any factors that may reveal depression. For this purpose, we use Text Mining and Natural Language Processing techniques. We employed CNN + LSTM classification technique and obtained an accuracy of 92%. We have also compared our model with Logistic Regression and TF-IDF classifiers.},
  keywords={Text mining;Social networking (online);Blogs;Mental health;Depression;Natural language processing;Logistics;Depression;Twitter;Text Mining;Natural Language Processing},
  doi={10.1109/INCET54531.2022.9824931},
  ISSN={},
  month={May},}@INPROCEEDINGS{9777181,
  author={Victor, Debasish Bhattacharjee and Raza, Dewan Mamun},
  booktitle={2022 6th International Conference on Trends in Electronics and Informatics (ICOEI)}, 
  title={Depression Detection from Facebook using Machine Learning Techniques}, 
  year={2022},
  volume={},
  number={},
  pages={1447-1454},
  abstract={Depression is a chronic ailment and a critical disease that affects day-to-day human activities, feelings, and thoughts. Depression causes sadness or a lack of interest in any day-to-day activities. Today, depression affects more than 200 million individuals worldwide. It may become better if the affected person can avoid the sentiments of desolation, hopelessness, and worthlessness for few days to weeks. To carry out a further research on depression analysis, this research study. As a result, makes use of Facebook data. From the research literature, the proposed research study has observed that there is no lengthy studies have been written for Bengali Facebook. Hence, the proposed research work has compiled a list of Bengali Facebook comments, status updates, and posts. Recently, different supervised learning techniques are used to estimate different kinds of problem and corresponding solutions. The proposed research study has attempted to predict the depression from depression data. Here, the state-of-the-art algorithms like Supporting Vector Machine [SVM], Random Forest, Decision Tree, K-Nearest Neighbors, and Naïve Bayes [NB] are applied and the results are then compared. According to the comparative results, different algorithms deliver similar results and outcomes for all classifiers applied on the proposed research study by analyzing the depression and non-depression data with an accuracy close to 90%.},
  keywords={Machine learning algorithms;Social networking (online);Supervised learning;Support vector machine classification;Depression;Prediction algorithms;Market research;Facebook;Machine Learning Techniques;Prediction;Depressed;Non- Depressed},
  doi={10.1109/ICOEI53556.2022.9777181},
  ISSN={},
  month={April},}@INPROCEEDINGS{11324000,
  author={Yanyan, Yang and Daud, Siti Norbaya and Asma Sulaiman, Nor Anis},
  booktitle={2025 11th International HCI and UX Conference in Indonesia (CHIuXiD)}, 
  title={Detection of Depression in Social Media through an Improved Hybrid Deep Learning Architecture with Attention Mechanism}, 
  year={2025},
  volume={},
  number={},
  pages={113-118},
  abstract={This study introduces the BERT-BiGRU-Attention model for automated depression detection on social media, designed to capture deep semantic representations of users' complex emotions and implicit depressive tendencies. Social media text is often brief, ambiguous, and semantically complex, posing challenges for accurate detection. To address these issues, the proposed model integrates contextualized embeddings from BERT with bidirectional sequence modeling via BiGRU, enabling effective capture of both local and long-range dependencies in social media text. An attention mechanism is further incorporated to adaptively highlight key semantic features associated with depressive tendencies, allowing the model to focus on subtle emotional cues while filtering out irrelevant information. Extensive experimental evaluations conducted on multiple real-world social media datasets demonstrate that the model consistently outperforms existing benchmark methods across several evaluation metrics, including accuracy, precision, recall, and F1-score. The results confirm the model's effectiveness, robustness, and practical applicability, highlighting its potential for reliable and scalable depression detection in noisy and highly unstructured social media environments. This approach provides a promising framework for early identification of depressive tendencies and may facilitate timely mental health monitoring and intervention on online platforms.},
  keywords={Adaptation models;Attention mechanisms;Accuracy;Social networking (online);Semantics;Mental health;Depression;Feature extraction;Monitoring;Context modeling;depression detection;social media;bert;bigru;attention mechanism},
  doi={10.1109/CHIuXiD68326.2025.11324000},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{10073980,
  author={Satya, Siddhant and Jindal, Rajni},
  booktitle={2022 4th International Conference on Advances in Computing, Communication Control and Networking (ICAC3N)}, 
  title={Social Media Mining For Suicidal Ideation}, 
  year={2022},
  volume={},
  number={},
  pages={1466-1471},
  abstract={Recent exponential rise of social media impact has resulted in significant changes in how people conduct their lives. Sharing one’s ideas, thoughts, and feelings on a social platform like Facebook, Twitter and Reddit reveal a lot about a person's mental state, which is referred to as online behavior. Online behavior has been the subject of several studies and evaluations. Nowadays, people have begun to express their sentiments more on social media than in person with the introduction of social networking sites. This online accumulating data that users leave behind may be exploited to glean insights about their actions and mental state using machine learning. Different machine learning approaches have been employed, examined, and evaluated for suicidal inclination identification in this study to establish that Machine Learning Algorithms can properly identify a Social Media user's dwelling Suicidal Tendency.},
  keywords={Machine learning algorithms;Social networking (online);Process control;Machine learning;Predictive models;Depression;Data models;Depression;Suicide;Natural Language Processing Machine Learning;Logistic Regression},
  doi={10.1109/ICAC3N56670.2022.10073980},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{10957310,
  author={Vats, Prashant and Kshirsagar, Pravin R. and Upreti, Kamal and Lalit, Keshav and Tak, Tan Kuan and Mahajan, Shubham},
  booktitle={2025 International Conference on Intelligent Control, Computing and Communications (IC3)}, 
  title={Behavioral Analytics for Predictive Modeling of Mental Health Disorders: A Review of Machine Learning Techniques and Challenges}, 
  year={2025},
  volume={},
  number={},
  pages={376-381},
  abstract={Mental health issues, including anxiety, stress, and depression, may remain untreated until they escalate to a severe level. The issues significantly impact an individual's overall well-being and productivity. Timely identification is crucial for the effectiveness of both intervention and therapy. The application of machine learning techniques makes behavioral analytics a powerful tool for mental health disease prediction modeling. By analyzing behavioral data, this technology facilitates the early detection of various illnesses. This work aims to provide a thorough overview of the use of machine learning techniques, including models that employ Deep structured learning as well as both unsupervised as well as supervised learning, to behavioral data, including activity levels, speech patterns, and facial movements, in order to identify signs of mental health. The benefits and drawbacks of a broad range of machine learning algorithms are examined, with a focus on how these computer algorithms may be applied to identify patterns linked to illnesses like stress, anxiety, and emotional depression. This study looks into the problems that this business encounters as well. These difficulties include combining behavioral data with extra environmental issues and physiological features from the immediate surroundings, the necessity for large and diverse datasets, the need for security of information, and the capacity to understand models.},
  keywords={Deep learning;Analytical models;Machine learning algorithms;Computational modeling;Anxiety disorders;Mental health;Predictive models;Depression;Physiology;Long short term memory;Mental Health Disorders;Behavioral Analytics;Machine Learning;Predictive Modeling;Depression;Anxiety;Stress Detection;Early Detection;Speech Analysis;Facial Expression Recognition;Deep structured learning;Convolutional neural networks (CNNs);Recurrent neural networks (RNNs);Long short-term memory (LSTM)},
  doi={10.1109/IC363308.2025.10957310},
  ISSN={},
  month={Feb},}@INPROCEEDINGS{11140291,
  author={Mandal, Debangan and Himanshu, Himanshu},
  booktitle={2025 6th International Conference for Emerging Technology (INCET)}, 
  title={Harnessing Deep Learning for Mental Health: A Comparative Study of BERT, LSTM, and GPT-2}, 
  year={2025},
  volume={},
  number={},
  pages={1-7},
  abstract={Mental health disorders in particular depression threaten the lives of millions of people worldwide, making early detection vital for timely intervention. With the emergence of social media, user-generated posts present an extensive repository of data for studying mental health disorders.The present study examines various deep learning models including BERT, LSTM and GPT-2 for detecting depressive symptoms in social media text. A Mental Health Social Media Dataset made available by Kaggle was used to carry out binary classification of the posts, as either depressed or not depressed.The models were fine-tuned and evaluated based on the metrics of accuracy, precision, recall, F1-score and AUC-ROC.From the experimental results, BERT performed the best, achieving an accuracy of 91.38% and AUC-ROC of 0.97 compared to 90.15% for GPT-2 and 81.72% for LSTM.BERT was excellent in understanding context where GPT-2 could analyze conversation well, and LSTM was best in computational efficiency.This study emphasizes deep learning techniques for mental health prediction and discusses challenges with respect to model interpretability, dataset bias, and real-time deployment. Future work should focus on multimodal learning, bias reduction, and Explainable AI (XAI) for enhanced transparency and ethical deployment within mental health diagnosis.},
  keywords={Deep learning;Accuracy;Social networking (online);Computational modeling;Mental health;Computer architecture;Predictive models;Depression;Long short term memory;Context modeling;Mental Health Detection;Depression Prediction;Deep Learning;BERT;LSTM;GPT-2;Social Media Analysis;Natural Language Processing (NLP)},
  doi={10.1109/INCET64471.2025.11140291},
  ISSN={2996-4490},
  month={May},}@INPROCEEDINGS{11254907,
  author={Zade, Sujal and Potdukhe, Nayan and Verma, Prateek and Bhadane, Satish N and Rewatkar, Rajendra and Ruthvika, Jampana},
  booktitle={2025 3rd International Conference on Intelligent Cyber Physical Systems and Internet of Things (ICoICI)}, 
  title={Comparative Assessment of Machine Learning Models for Detection of Mental Health of Students: A Case Study of Undergraduate Students}, 
  year={2025},
  volume={},
  number={},
  pages={2129-2134},
  abstract={Early identification of anxiety and depression in college students is essential for timely intervention, yet conventional screening methods often rely on subjective reporting and consume considerable resources. This study administered a 20-item Likert-scale questionnaire to 142 undergraduates from a rural engineering institution in Maharashtra, India, covering aspects such as sleep quality, social engagement, and academic stress. The data were normalised and split into training (80%) and testing (20%) sets. Six classifiers—Logistic Regression, Support Vector Machine (SVM), Naïve Bayes, Decision Tree, Random Forest, and K-Nearest Neighbours—were trained and evaluated using accuracy, precision, recall, and F1-score metrics. Logistic Regression and SVM achieved the highest performance with 96.6% accuracy and an F1-score of 0.964, followed by Naïve Bayes (93.1%), Decision Tree (86.2%), Random Forest (82.8%), and K-Nearest Neighbours (79.3%). These results demonstrate that interpretable algorithms like Logistic Regression and SVM can reliably screen for mental health risks using self-reported data, offering a scalable, cost-effective approach for campus health services in resource-limited rural settings. The significance of this work lies in addressing the growing mental health crisis among students, where untreated issues contribute to substantial economic losses projected at $16 trillion globally by 2030, by enabling early detection and reducing barriers like stigma and access to care.},
  keywords={Support vector machines;Logistic regression;Accuracy;Biological system modeling;Anxiety disorders;Mental health;Depression;Data models;Bayes methods;Random forests;Mental Health;Machine Learning;SVM;Random Forest;Decision Tree},
  doi={10.1109/ICoICI65217.2025.11254907},
  ISSN={},
  month={Sep.},}@ARTICLE{10738819,
  author={Xin, Cao and Zakaria, Lailatul Qadri},
  journal={IEEE Access}, 
  title={Integrating Bert With CNN and BiLSTM for Explainable Detection of Depression in Social Media Contents}, 
  year={2024},
  volume={12},
  number={},
  pages={161203-161212},
  abstract={Depression is a prevalent mental health condition that significantly impacts individuals’ lives. Early detection of depression is crucial for timely intervention and improved outcomes. However, traditional machine learning approaches are constrained by the limited amount of annotated data and lack of model transparency. This study aims to address these challenges by leveraging social media data and advanced natural language processing techniques to develop effective and explainable models for depression detection. The study focuses on two main objectives. The first objective is to develop and evaluate fine-tuned Bidirectional Encoder Representations from Transformers (BERT), BERT with Bidirectional Long Short-Term Memory (BERT-BiLSTM), and BERT with Convolutional Neural Network (BERT-CNN) models, and compare their performance with MentalBERT, a state-of-the-art model for mental health detection. The second objective is to observe the key features used by the BERT models to make the decision-making using Transformer Interpretability Beyond Attention Visualization and Average Attention Weight methods. The study utilizes three publicly available datasets: the Depression Reddit Dataset, the Sentiment Analysis for Tweets Dataset, and the Mental Health Corpus. The results demonstrate that the proposed models, especially BERT-BiLSTM and BERT-CNN, achieve superior performance compared to MentalBERT, particularly regarding accuracy and F1-score. Notably, BERT-CNN achieved exceptional accuracy scores of 0.982, 0.961, and 1.0 on the Depression Reddit Dataset, the Mental Health Corpus, and the Sentiment Analysis for Tweets Dataset, respectively, demonstrating its robust performance across different social media contexts. The attention map visualizations provide valuable insights into the language patterns and key features associated with depression in social media posts. This study contributes to the mental health field by presenting novel and explainable models for depression detection using social media data. The proposed approaches have the potential to assist mental health professionals in early identification and intervention, ultimately improving the lives of individuals affected by depression.},
  keywords={Depression;Social networking (online);Data models;Adaptation models;Mental health;Training;Encoding;Bidirectional control;Predictive models;Transformers;Automatic depression detection;BERT;CNN;BiLSTM;MentalBERT;deep learning;Explainability AI},
  doi={10.1109/ACCESS.2024.3488081},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{11008193,
  author={Oulahbib, Idriss and Benhaddi, Meriem and El Hadaj, Salah},
  booktitle={2025 5th International Conference on Innovative Research in Applied Science, Engineering and Technology (IRASET)}, 
  title={Gender, Age, and Depression detection with BERT-based multitask model}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={The Author Profiling (AP) task mainly focuses on predicting the demographic and the socio-cultural information of a particular author from his writing; this information could be the gender, age, language variety, religion, etc. Meanwhile, the Depression Detection (DP) task generally aims to identify the depressive content, by classifying a textual document in two categories: depressive or not. The works in the literature treat the two tasks separately, as they construct a model for predicting each information solely; Instead in this work, we propose a new multi-task model based on BERT to predict simultaneously the gender and the age of the author from his publication and the depressive publications. For the training of the model, we have constructed a dataset with publications from the Reddit platform published within 2005-06 and 2017-02 timespan, by adopting an automatic approach for the author gender and age annotation based on Regular Expression (REGEX), and the depression label we considered the publications in a preselected depressive subreddits. Regarding our approach performances, it has demonstrated a competitive result with the State Of The Art (SOTA) models for AP and DP tasks. The results of our model were 0.72, 0.50, and 0.92 with the accuracy metric on the gender, age, and depression detection respectively.},
  keywords={Training;Measurement;Deep learning;Accuracy;Social networking (online);Annotations;Predictive models;Writing;Depression;Multitasking;Author Profiling;Depression Detection;Deep Learning;BERT},
  doi={10.1109/IRASET64571.2025.11008193},
  ISSN={},
  month={May},}@INPROCEEDINGS{11367594,
  author={Rahman, Md. Abdur and Ali, Hazrat and Hossen, Md. Ferdaus and Palas, Md. Rajibul and Hossen, Md. Tamim},
  booktitle={2025 IEEE 7th International Conference on Sustainable Technologies For Industry 5.0 (STI)}, 
  title={Early Prediction of Depression and Suicidal Risk in Bangla Social Media Using Deep Learning}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Mental disorders such as depression, anxiety, and suicidal ideation are rising rapidly among young people in Bangladesh, with social media providing a prominent platform for expressing oneself and emotions. Early identification of these through automatic systems can provide timely intervention and even save lives. To address this problem, we propose a hybrid CNN-BiGRU model that combines linguistic, psychological, and sentiment attributes to model semantic meaning along with longterm contextual relations in Bangla text with a 94% accuracy. Our method, trained on a well-curated dataset, is more precise and has superior generalization compared to standard machine learning methods like Logistic Regression, Support Vector Machines, and Multinomial Naive Bayes. These results indicate the potential of deep learning towards effective mental health detection in low-resource languages.},
  keywords={Deep learning;Support vector machines;Accuracy;Social networking (online);Anxiety disorders;Mental health;Linguistics;Depression;Standards;Context modeling;Deep learning;NLP;Sentiment-Analysis;CNN;BiGRU},
  doi={10.1109/STI69347.2025.11367594},
  ISSN={2996-170X},
  month={Dec},}@INPROCEEDINGS{10397710,
  author={Matías-Cristóbal, Obed and Padilla-Caballero, Jesús and Gonzales-Rivera, Rosa and Benavente-Ayquipa, Rosa and Pérez-Saavedra, Segundo and Cardenas-Palomino, Frans},
  booktitle={2023 6th International Conference on Contemporary Computing and Informatics (IC3I)}, 
  title={Enhancing Sentiment Analysis In Text Of Social Media Texts Using Hybrid Deep Learning Model And Natural Language Processing}, 
  year={2023},
  volume={6},
  number={},
  pages={1776-1780},
  abstract={Sentiment analysis (SA) is a mechanized strategy for finding and understanding the feelings depicted in text. Over the most recent decade, SA has altogether expanded in ubiquity in the Natural Language Processing (NLP) people group. One emotion that has a negative effect on people's daily life is depression. Every year, more people around the world report having long-lasting feelings. Finding persons with depression as early as possible is one of the most difficult difficulties. Researchers are analyzing text content posted on social media using Natural Language Processing (NLP) techniques, which helps to develop methods for Depression detection. This study examines various earlier investigations that employed learning strategies to recognize depression. The current approaches have issues with better model representation that make it difficult to accurately identify depression from literature. Fast message in the ongoing undertaking to address an answer for these issues, Fast text Convolution Neural Network with Long Momentary Memory (FCL), an original hybrid deep learning brain network plan with improved message portrayals, is made. Real-world datasets that were used in the literature were used to implement the current study. The suggested method achieves higher accuracy in detecting depression than the state-of-the-art.},
  keywords={Deep learning;Sentiment analysis;Social networking (online);Text recognition;Blogs;Depression;Brain modeling;deep learning;NLP;LSTM;sentiment analysis},
  doi={10.1109/IC3I59117.2023.10397710},
  ISSN={},
  month={Sep.},}@ARTICLE{11062735,
  author={Li, Qiong and Liu, Xiaotong and Hu, Xuecai and Rahman Ahad, Md Atiqur and Ren, Min and Yao, Li and Huang, Yongzhen},
  journal={IEEE/CAA Journal of Automatica Sinica}, 
  title={Machine Learning-Based Prediction of Depressive Disorders via Various Data Modalities: A Survey}, 
  year={2025},
  volume={12},
  number={7},
  pages={1320-1349},
  abstract={Depression, a pervasive mental health disorder, has substantial impacts on both individuals and society. The conventional approach to predicting depression necessitates substantial collaboration between health care professionals and patients, leaving room for the influence of subjective factors. Consequently, it is imperative to develop a more efficient and accessible prediction methodology for depression. In recent years, numerous investigations have delved into depression prediction techniques, employing diverse data modalities and yielding notable advancements. Given the rapid progression of this domain, the present article comprehensively reviews major breakthroughs in depression prediction, encompassing multiple data modalities such as electrophysiological signals, brain imaging, audiovisual data, and text. By integrating depression prediction methods from various data modalities, it offers a comparative assessment of their advantages and limitations, providing a well-rounded perspective on how different modalities can complement each other for more accurate and holistic depression prediction. The survey begins by examining commonly used datasets, evaluation metrics, and methodological frameworks. For each data modality, it systematically analyzes traditional machine learning methods alongside the increasingly prevalent deep learning approaches, providing a comparative assessment of detection frameworks, feature representations, context modeling, and training strategies. Finally, the survey culminates with the identification of prospective avenues that warrant further exploration. It provides researchers with valuable insights and practical guidance to advance the field of depression prediction.},
  keywords={Surveys;Neuroimaging;Training;Reviews;Pandemics;Prediction methods;Organizations;Mental health;Electrophysiology;Depression;Audiovisual data;brain imaging;depression prediction;electrophysiological signals;machine learning;text},
  doi={10.1109/JAS.2025.125393},
  ISSN={2329-9274},
  month={July},}@INPROCEEDINGS{11171098,
  author={Y, Joel Rozario and S, Sophia},
  booktitle={2025 5th International Conference on Soft Computing for Security Applications (ICSCSA)}, 
  title={Depression and Anxiety Monitoring using Intelligent Neural Detection}, 
  year={2025},
  volume={},
  number={},
  pages={2026-2032},
  abstract={Identifying mental disorders such as depression and anxiety remains a major challenge, especially in the era of social media and digital communication. Conventional methods are lengthy, subjective, and inaccessible. To address these, the current study introduces a new Multilayer Steerable Dense Net-Spiking Transformers Neural Network with Meerkat Optimization Algorithm (MSDSTN2Nets+MOA) framework for Detection of Depression and Anxiety (DDA) in Social Media and Voice Data. The input voice and social media data, obtained from the DAIC-WOZ and RSDD datasets, are initially preprocessed using the Quasi-Cross Bilateral Filtering (QCBF) method. After preprocessing, the Inverse Z-transform and Wiener-Hopf Factorization (IZ-WHF) method is utilized for feature extraction. Depression and Anxiety Detection relies on Multilayer Steerable Dense Net-Spiking Transformers Neural Network (MSDSTN2Nets) and optimization via the Meerkat Optimization Algorithm (MOA). DAIC-WOZ and RSDD datasets are applied to assess the performance of the proposed MSDSTN2Nets+MOA model, which depicts an accuracy rate of 99.9% andan F1-score of 99.8%. The developed model is implemented using the Python programming language. The created model successfully identifies anxiety and depression from voice and social media data showing good accuracy, strong feature extraction, effective optimization, and solid performance on a variety of benchmark datasets},
  keywords={Accuracy;Social networking (online);Filtering;Anxiety disorders;Neural networks;Mental health;Depression;Transformers;Nonhomogeneous media;Optimization;Detecting Depression and Anxiety;Inverse Z-transform and Wiener-Hopf Factorization;Multilayer Steerable Dense Net-Spiking Transformers Neural Network;Meerkat Optimization Algorithm;Quasi-Cross Bilateral Filtering},
