  booktitle={2025 4th International Conference on Computational Modelling, Simulation and Optimization (ICCMSO)}, 
  title={Leveraging Nlp for Mental Health Detection: a Machine Learning Approach to Suicide Risk Classification}, 
  year={2025},
  volume={},
  number={},
  pages={292-297},
  abstract={Psychiatric disorders such as depression, panic, and others continue to be a significant global issue that requires prompt identification and intervention approaches. In this research, machine learning methods are utilized to categorize suicide-related textual data, drawing from a dataset obtained from online platforms. Data preprocessing is performed through text cleaning and TF-IDF vectorization before applying five machine learning models-logistic regression (LR), naïve bayes (NB), random forest (RF), support vector machine (SVM), and XGBoost-for classification. The results emphasize the efficiency of traditional linear models in analyzing mental health data for text classification tasks. This study adds to the field of suicide risk detection through artificial intelligence, offering valuable insights into computational methods for identifying early signs of mental health issues.},
  keywords={Support vector machines;Radio frequency;Logistic regression;Computational modeling;Text categorization;Mental health;Data models;Natural language processing;Random forests;Optimization;Classification;Logistic Regression;Machine Learning;Mental health classification;Natural Language Processing;TF-IDF;Textual data},
  doi={10.1109/ICCMSO67468.2025.00059},
