  abstract={Social media triggered intellectual issues like social network mental disorders (SNMD) also are on the upward push cyber dependence, statistics overload and network crush have emerge as not unusual I noticed currently. The signs of these mental disorders at the moment are normally seen inside the passive this may put off clinical intervention. In this text we discuss social media mining this affords a sensible opportunity for early detection of SNMD at an early level. It’s far since intellectual factors are taken into consideration stable, SNMD is less difficult to diagnose. Diagnostic criteria (questionnaires) for anti-social conduct cannot be located on-line. Our method, new and modern, does not depend on the usage of SNMD detection self-diagnosis of those intellectual troubles through questionnaires. We would really like to present a vehicle regulatory frame, particularly social network Mental Disorders Detection (SNMDD), which using capabilities extracted from social media facts to correctly pick out ability incidents SNMD. We practice multi-supply getting to know in SNMDD and suggest a just out of the plastic new SNMD-based totally tensor variation (STM) for higher in general execution. Our machine assessed by means of a person survey of 3,126 social media users. We are on submit analysis, and the use of SNMDD for big-scale facts analysis and evaluation three types of SNMD. The outcomes display that SNMDD is promising for online character. Interpersonal organization clients with viable SNMD},
  keywords={Surveys;Tensors;Social networking (online);Mental disorders;Signal processing algorithms;Mental health;Data science;Interpersonal organization;Emotions;Depression;Sentiment Analysis},
  doi={10.1109/ICCSP60870.2024.10543555},
  ISSN={2836-1873},
  month={April},}@INPROCEEDINGS{10872671,
  author={Ibrahim, Izzah Maisarah Binti and Maskat, Ruhaila and Aminordin, Azmi Bin and Teo, Noor Hasimah Ibrahim},
  booktitle={2024 IEEE 22nd Student Conference on Research and Development (SCOReD)}, 
  title={Classification of Mental Health Conditions in Reddit Post using Multinomial Naïve Bayes Algorithm}, 
  year={2024},
  volume={},
  number={},
  pages={658-663},
  abstract={Mental health plays a pivotal role in well-being, yet mental health challenges such as depression, anxiety, and stress (DAS) often remain underdiagnosed or misclassified. This paper introduces a novel chatbot-based classification system leveraging the Multinomial Naïve Bayes algorithm to analyze Reddit posts and assess users’ mental health conditions. Using the DASS-21 questionnaire as a framework, the chatbot converts traditional multiple-choice queries into open-ended questions, allowing for richer expression and deeper insight into user emotions. The project achieved an improved classification accuracy of 83% following hyperparameter tuning and K-fold cross-validation. Exploratory data analysis, including word cloud visualizations, revealed recurring themes associated with DAS, highlighting the system’s interpretative capabilities. The chatbot’s seamless integration into a web and mobile application further enhances its accessibility and user engagement. While demonstrating significant progress in mental health classification, the research acknowledges limitations in dataset diversity and conversational capabilities. Future work aims to expand coverage to additional mental health conditions and improve mental health detection.},
  keywords={Accuracy;Social networking (online);Anxiety disorders;Mental health;Depression;Chatbots;Tag clouds;Bayes methods;Classification algorithms;Tuning;Multinomial Nïve Bayes;Depression;Anxiety;Stress;Classification;Mental health;DAS-21},
  doi={10.1109/SCOReD64708.2024.10872671},
  ISSN={2643-2447},
  month={Dec},}@INBOOK{10710430,
  author={Martinez, David R. and Kifle, Bruke M.},
  booktitle={Artificial Intelligence: A Systems Approach from Architecture Principles to Deployment}, 
  title={8 Responsible Artificial Intelligence}, 
  year={2024},
  volume={},
  number={},
  pages={259-284},
  abstract={Artificial intelligence (AI) is a wide-ranging tool that is revolutionizing technology across industries. Advancements in computing and the proliferation of data have enabled significant improvements to the quality of products and services through performance gains and more tailored user experiences. From personalized Netflix and YouTube recommendations to self-driving cars, conversational virtual assistants like Siri and Alexa, and AI-powered medical diagnoses that are capable of outperforming doctors, AI is transforming the way that we live. However, these benefits have come paired with increasing concerns about the unintended consequences of AI on people and society [1]. For example, recent studies have uncovered increased rates of anxiety and depression among teens as a result of the increasing role that AI-powered social media platforms like Instagram play in worsening body image issues for teenage girls and mental health among young adults [2]. Moreover, the widespread adoption and application of AI- powered decision-making systems in highly consequential domains such as law enforcement, financial services, and medicine have raised concerns around the adherence of AI to key value-based principles such as fairness, accountability, safety, transparency, ethics, privacy, and security (FASTEPS). These concerns have become a pervasive topic of recent public discussion as the stakes of AI grow higher. In this chapter, we emphasize the importance of responsible AI (RAI) to ensure that the benefits of AI are realized while minimizing unintended harm.},
  keywords={},
  doi={},
  ISSN={},
  publisher={MIT Press},
  isbn={9780262378703},
  url={https://ieeexplore.ieee.org/document/10710430},}@ARTICLE{9810926,
  author={Guo, Teng and Zhao, Wenhong and Alrashoud, Mubarak and Tolba, Amr and Firmin, Selena and Xia, Feng},
  journal={IEEE Access}, 
  title={Multimodal Educational Data Fusion for Students’ Mental Health Detection}, 
  year={2022},
  volume={10},
  number={},
  pages={70370-70382},
  abstract={Mental health issues can lead to serious consequences like depression, self-mutilation, and worse, especially for university students who are not physically and mentally mature. Not all students with poor mental health are aware of their situation and actively seek help. Proactive detection of mental problems is a critical step in addressing this issue. However, accurate detections are hard to achieve due to the inherent complexity and heterogeneity of unstructured multi-modal data generated by campus life. Against this background, we propose a detection framework for detecting students’ mental health, named CASTLE (educational data fusion for mental health detection). Three parts are involved in this framework. First, we utilize representation learning to fuse data on social life, academic performance, and physical appearance. An algorithm, named MOON (multi-view social network embedding), is proposed to represent students’ social life in a comprehensive way by fusing students’ heterogeneous social relations effectively. Second, a synthetic minority oversampling technique algorithm (SMOTE) is applied to the label imbalance issue. Finally, a DNN (deep neural network) model is utilized for the final detection. The extensive results demonstrate the promising performance of the proposed methods in comparison to an extensive range of state-of-the-art baselines.},
  keywords={Mental health;Social networking (online);Depression;Representation learning;Registers;Feature extraction;Anxiety disorders;Educational data mining;mental health;network embedding;decision making},
  doi={10.1109/ACCESS.2022.3187502},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{11378627,
  author={Wang, Ying and Huang, Lijun},
  booktitle={2025 6th International Conference on Information Science and Education (ICISE-IE)}, 
  title={Random Forest with SMOTE Oversampling for Undergraduate Mental Health Crisis Early Warning and Employment Anxiety Risk Factor Identification}, 
  year={2025},
  volume={},
  number={},
  pages={247-253},
  abstract={Mental health crises among college students have become a critical public health concern, with employment anxiety emerging as a significant yet underexplored risk factor in the Chinese higher education context. This study develops a machine learning-based early warning system to predict mental health crises by integrating employment anxiety with traditional psychological and behavioral indicators. We collected survey data from $\mathbf{1, 5 0 0}$ undergraduate students across three universities, encompassing standardized mental health assessments (PHQ-9, GAD-7), a custom-designed Employment Anxiety Subscale, and behavioral metrics including social media usage patterns and academic performance. To address the severe class imbalance (crisis rate: 8.0%), we employed Synthetic Minority Over-sampling Technique (SMOTE) combined with Random Forest classification. The proposed SMOTE-RF model achieved superior performance with an AUC of 0.903 and recall of 0.867, representing a 17.5 percentage point improvement over baseline methods. Feature importance analysis revealed that employment anxiety ranked as the second most influential predictor (Gini importance $=0.187$), contributing 17.7% to the model's predictive power and validating its status as an independent risk dimension. Partial Dependence Plot analysis identified critical risk thresholds: students with moderate-to-severe employment anxiety (scores $\geq 11$) exhibited over six times higher crisis probability, while excessive social media usage ($>4$ hours/day) demonstrated significant synergistic effects with employment concerns (interaction $\beta=0.34, \mathrm{p}=0.003$). SHAP value decomposition and decision path visualization ensured model interpretability, providing clinically actionable insights for intervention prioritization. These findings demonstrate that incorporating employment anxiety into crisis prediction models significantly enhances early identification accuracy, offering a scalable framework for campus mental health screening systems. The transparent decision-making process addresses ethical concerns in algorithmic risk assessment, facilitating practical deployment in university counseling services.},
  keywords={Surveys;Analytical models;Social networking (online);Employment;Anxiety disorders;Education;Mental health;Predictive models;Alarm systems;Random forests;Mental health crisis prediction;employment anxiety;machine learning;Random Forest;SMOTE;college students;early warning system;feature importance;model interpretability;SHAP analysis},
  doi={10.1109/ICISE-IE68873.2025.11378627},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{10714257,
  author={Nanda, Mehul and Inkpen, Diana and Dargel, Aroldo},
  booktitle={2024 28th International Conference Information Visualisation (IV)}, 
  title={Detecting Multiple Mental Health Disorders with Large Language Models}, 
  year={2024},
  volume={},
  number={},
  pages={252-257},
  abstract={Artificial Intelligence systems have become useful in many sectors, including healthcare. In this paper, we focus on detecting signs of mental health disorders from social media texts. This can be used to direct patients to consult a healthcare professional, while on waiting lists, or for post-monitoring. The performance of the current algorithms for detecting multiple disorders is limited. We propose a new method to increase performance by including target-domain knowledge for each type of mental health disorder (for nine disorders). We used this information to select the best training examples to include in our carefully engineered prompts for performing few-shot learning. We show that the results improved when compared to zero-shot learning based on Large Language Models and when compared to state-of-the-art results on the same test set.},
  keywords={Training;Visualization;Social networking (online);Large language models;Zero shot learning;Mental health;Medical services;Few shot learning;AI and Healthcare;Predictions;Natural Language Processing;Transformers;BERT;Large Language Models;Domain Knowledge},
  doi={10.1109/IV64223.2024.00051},
  ISSN={2375-0138},
  month={July},}@INPROCEEDINGS{10884478,
  author={Sadasivuni, Sudha Tushara and Sadasivuni, Sudarsan},
  booktitle={2024 IEEE International Conference on Intelligent Systems, Smart and Green Technologies (ICISSGT)}, 
  title={Similarity of Depressive/Anti-Depressive Tweets with Happiness Index Parameters}, 
  year={2024},
  volume={},
  number={},
  pages={150-152},
  abstract={People practiced social network use in recent days because of availability, technology and low-cost data availability. Approximately 200 billion tweets are being posted in each year, leads to consider that the tweets echo reflects the emotions of the people. Happiness Index derived from the World Happiness Report imitates a worldwide demand for more attention to happiness and well-being as criteria for government policy and therefore, its importance is increasing day by day. There is always a correlation between the social network posts and happiness/depressiveness and hence, the tweets from Twitter are considered for our study. Happiness Index is computed with several parameters and finding the dependency was not studied earlier. Three million tweets (depressive and anti-depressive) and information from the Happiness Index reports were studied and they exhibited a good coherence between “Social support and Freedom of life” with depressive tweets. Similar relationship was observed between Anti-depressive tweets with “GDP and Generosity”. Since the tweets are available continuously, the policy makers can study and get advantage from these tweets of an area before actually implanting any scheme for the people.},
  keywords={Government policies;Correlation;Social networking (online);Economic indicators;Blogs;Coherence;Indexes;Intelligent systems;Non-governmental organizations;Depressive tweets;Happiness Index;Social Networks},
  doi={10.1109/ICISSGT58904.2024.00040},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{10729940,
  author={Ahmad, Zaaba and Mohamed, Azlinah and Conway, Mike and Maskat, Ruhaila},
  booktitle={2024 5th International Conference on Artificial Intelligence and Data Sciences (AiDAS)}, 
  title={Enhancing Mental Health Detection in Malay Social Media: A Comparative Study of RNN Architectures and Attention Mechanisms}, 
  year={2024},
  volume={},
  number={},
  pages={121-131},
  abstract={Mental health detection using Natural Language Processing (NLP) is increasingly crucial with the vast data accessible from social media platforms. Despite the abundance of research on high-resource languages, there remains a sub-stantial gap for underrepresented languages such as Malay. This paper aims to bridge this gap by deploying a combination of Recurrent Neural Networks (RNNs), specifically Bidirectional Long Short-Term Memory (BiLSTM) and Bidirectional Gated Recurrent Unit (BiGRU), integrated with attention mechanisms, to detect mental health symptoms in the Malay language. The methodology utilises the MyDAS Corpus, a specialised dataset derived from Facebook, which includes various Malay-language interactions related to mental health. The models were enhanced with Word2Vec embeddings, meticulously fine-tuned for Malay, leading to significant performance improvements. Systematic experimentation yielded F1 scores of 0.83 and 0.82 with BiL-STM paired with Self and Multi-Head attention mechanisms, respectively, markedly surpassing the baseline F1 score of 0.78 via TF-IDF and Decision Tree classifier. The results highlight the efficacy of leveraging pre-trained embeddings with RNN-attention configurations to enhance the discrimination between psychological classes, particularly notable in ‘Depression,’ ‘Anxiety,’ and ‘No DAS Signal’ classes. The findings underscore the potential of these advanced NLP techniques for real-world mental health applications in languages with limited digital resources.},
  keywords={Recurrent neural networks;Attention mechanisms;Systematics;Social networking (online);Soft sensors;Transfer learning;Mental health;Natural language processing;Data models;Long short term memory;Mental Health;Natural Language Processing;Malay;BiLSTM;BiGRU;Attention},
  doi={10.1109/AiDAS63860.2024.10729940},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{11368583,
  author={Maheshwari, Reetika and Pradhan, Rahul and Sharma, Dilip Kumar},
  booktitle={2025 IEEE 6th Global Conference for Advancement in Technology (GCAT)}, 
  title={Hyperparameter-Tuned Neural Networks for Binary Text Classification in Mental Health Detection}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={The significance of robust and scalable computational approaches to early detection has been underscored by the increasing prevalence of depression and associated mental illness. We present a two-class binary text classification model for finding content in user-generated text that is related to mental health. Text cleaning, normalization, and feature extraction via Count Vectorization were implemented during the initial preprocessing of the dataset. Subsequently, a train–test split of 80:20 was implemented to facilitate a meaningful evaluation. Using Keras, a feed-forward neural network was created. It has dense layers with ReLU activation, dropout regularization, and a sigmoid output layer for binary classification. To optimize model performance, hyperparameter tuning was implemented through the Hyperband algorithm with Keras Tuner, with validation accuracy serving as the objective function. The model's high precision, recall, and F1 scores, along with its 96.15% classification accuracy on the test dataset, demonstrated its strength and generalizability. When optimized methodically, even light neural structures can achieve state-of-the-art performance in text-based mental health analysis, as indicated by experimental results.This approach not only provides a useful way to find people who are depressed, but it could also be used for other clinical and social natural language processing tasks.},
  keywords={Accuracy;Tuners;Computational modeling;Text categorization;Mental health;Linear programming;Feature extraction;Depression;Natural language processing;Feedforward neural networks;Text classification;natural language processing;mental health detection;neural networks;hyperparameter tuning},
  doi={10.1109/GCAT66372.2025.11368583},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10276304,
  author={Chawla, Kunal and Kaul, Vanshika and Singh, Baljap and Soni, Shiv Sahil and Kumar, Anubhav and Gupta, Shikha},
  booktitle={2023 4th International Conference on Smart Electronics and Communication (ICOSEC)}, 
  title={MOODIFY: Web Application to Detect Human Emotions}, 
  year={2023},
  volume={},
  number={},
  pages={1689-1694},
  abstract={Human Emotions are very complex psychological responses to various events and stimuli that are experienced subjectively. These Human Emotions are often influenced by cultural, social, and individual factors. There are a lot of emotions that are recognized and some of them are Happiness, Sadness, Anger, Fear, Disgust, Surprise, Love, Excitement, Guilt, Shame, Jealousy, Empathy and many more. Recently, emotion detection is a popular topic due to a vast potential application such as marketing, psychology, human-computer interaction, political science and curing diseases such as depression, anxiety disorder, chronic pain, eating disorders, etc. According to World Health Organization (WHO) depression, anxiety, etc. are common metal disorder and it is estimated that almost 5% of the adult suffer from it. One out of every Eight people in the world is living with a mental disorder. There is a need of a comprehensive system, which can detect human emotion which are showcased by his/her text. In world of Internet, social media platforms have become very essential means of communication for the entire world. However, sometimes while communicating using text chats people get confused because they are unable to understand the emotions showcased by the messages. This paper aims at providing a sustainable, robust and efficient web application using which anybody can understand the human emotions behind the text.},
  keywords={Emotion recognition;Social networking (online);Pain;Anxiety disorders;Psychology;Metals;Organizations;Natural Language Processing (NLP);Neattext;Logistic Regression;Multinomial Naïve Bayes;Pre-processing;Tokenizing},
  doi={10.1109/ICOSEC58147.2023.10276304},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10463396,
  author={Jain, Bhawna and Goyal, Gunika and Sharma, Mehak},
  booktitle={2024 14th International Conference on Cloud Computing, Data Science & Engineering (Confluence)}, 
  title={Evaluating Emotional Detection & Classification Capabilities of GPT-2 & GPT-Neo Using Textual Data}, 
  year={2024},
  volume={},
  number={},
  pages={12-18},
  abstract={Mental health has emerged as a pressing global health public concern due to the rising prevalence of mental illnesses and the notable gap in the detection and diagnosis of these conditions. With the widespread use of text as a means of communication, analysing mental health conditions from text has become essential. Artificial intelligence (AI) for healthcare has seen rapid growth and substantial research. In recent decades, the field of emotion recognition through AI has witnessed a notable shift from statistically shallow models to deep neural networks-based models, but they often grapple with challenges related to data scarcity, interpretability, and context-awareness, which has prompted the use of Large Language Models (LLMs) as a viable alternative. However, the introduction of LLMs like Generative Pretrained Transformer (GPT)-2 & GPT-Neo has astounded the research community with its unprecedented capabilities, which were previously unseen in traditional deep models. This work evaluates the effectiveness of LLMs-based GPT-Neo-125M and GPT-2 in 3 binary textbased mental health 2-class classification tasks: stress, depression, and suicidality which is, to our knowledge, the first attempt of the kind. This paper demonstrated that GPT-2 delivered higher overall accuracy, notably achieving an accuracy score of over 0.98 across all datasets.},
  keywords={Emotion recognition;Mental health;Pressing;Medical services;Transformers;Depression;Data models;Mental Health;Emotion Recognition;Large Language Model;GPT-2;GPT-Neo},
  doi={10.1109/Confluence60223.2024.10463396},
  ISSN={2766-421X},
  month={Jan},}@INPROCEEDINGS{10941491,
  author={Kuchoor, Santhosh Kumar and Kukreti, Sanjeev and Battula, R.S.S. Raju and Singh, Suruchi and Panchbhai, Ashutosh and L, Natrayan},
  booktitle={2024 International Conference on Distributed Systems, Computer Networks and Cybersecurity (ICDSCNC)}, 
  title={Blockchain-Enhanced Access Control for IoT Systems in Smart Cities}, 
  year={2024},
  volume={},
  number={},
  pages={1-9},
  abstract={With the exponential growth of smart gadgets and the technologies that connect them, the Internet of Things (IoT) has emerged as the most promising new technology of the last decade. This is true from both a business and academic standpoint. Deployment in smart-home and smart-city initiatives throughout the globe has increased IoT's popularity. Regrettably, the processing power, storage capacity, and bandwidth of IoT network devices are severely constrained. So, compared to other endpoint devices like PCs, tablets, and smartphones, they are more susceptible to assaults. The development of a safe and reliable model for commonly used operations is booming, including data collection, processing, storage, and communication. It isn't easy to build such a model since there are so many obstacles to overcome. New cybersecurity risks emerge on a regular basis, while old ones remain dormant and ready to be exploited. Sadly, these cyber dangers also serve to safeguard the IoT. Due to recent developments, research into cyberphysical systems, the internet of things (IoT), and blockchain is more important than ever. In Internet of Things (IoT) systems, where security breaches compromise the centralised system's ability to function, blockchain technology has shown remarkable promise. Distributed ledgers powered by blockchain technology may enhance the security of the Internet of Things (IoT) and its user access management systems, making them more reliable. Following the safe vehicle authorization, the suggested model presents the idea of a branching blockchain that considers the most recently utilized block. This allows low-powered devices to also benefit from the blockchain's security. The needs of the IoV at the physical layer are beyond the capabilities of present-day mining technology. The suggested architecture has many important aspects, such as a decentralized ledger system, load balancing, scalability, and a lightweight blockchain for the physical layer and above. The comparison investigation, which takes computation and transmission costs into account, shows that our proposed framework performs better than the ones that are presently in use. If anybody is interested in a lightweight blockchain variation that can be applied to the physical layer of the IoV, this model may serve as the foundation for new research areas.},
  keywords={Authorization;Costs;Social networking (online);Distributed ledger;Authentication;Physical layer;Blockchains;Internet of Things;Security;Reliability;machine learning;depression detection;twitter;natural language processing;sentiment analysis;mental health;digital psychiatry;social media analytics;neural networks;data privacy},
  doi={10.1109/ICDSCNC62492.2024.10941491},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10401840,
  author={Farag, Nadine and Ghoniemy, Samy and Karam, Omar H.},
  booktitle={2023 International Conference on Computer and Applications (ICCA)}, 
  title={Enhanced Semantic-based Chaotic System for Cyber-grooming Classification and Harassment Detection}, 
  year={2023},
  volume={},
  number={},
  pages={1-10},
  abstract={In recent years, cyber-grooming and cyber-harassment have become increasingly prevalent issues across social media, posing significant challenges for their detection. The UN reports that cyber-harassment can have severe consequences, including mental health issues like depression and anxiety, and in extreme cases, suicide. In this paper, we propose a novel approach to address the problem of cyber-grooming and cyber-harassment. Our approach involves classifying the 6 stages of grooming and detecting instancs of harassment using a semantic-based chaotic model that leverages the Luring Communication Theory (LCT). The proposed model is unique in its ability to incorporate the principles of chaos theory, which enables it to capture the underlying complexity and non-linearity of the text data. This feature provides a more effective approach to prevent and address online harassment by accurately identifying predatory behavior. The results show that the GRU-Semantic Chaotic model significantly outperformed the CNB-TFIDF-count based model by 23.7%. Specifically, the GRU-Semantic Chaotic model achieved high accuracy and F1-scores of 0.982 and 0.973 for harassment and non-harassment classes, respectively, using a stacked GRU. The overall accuracy of the GRU-Semantic Chaotic model was 97.9%, which is significantly higher than the overall accuracy of the CNB-TFIDF-count based model of only 74.2%. These findings highlight the effectiveness of our proposed model in enhancing the analysis of complex cyber-grooming and harassment conversations and providing a more effective approach to prevent and address online harassment.},
  keywords={Analytical models;Chaotic communication;Social networking (online);Semantics;Text categorization;Feature extraction;Behavioral sciences;chaos theory;semantic-based chaotic model},
  doi={10.1109/ICCA59364.2023.10401840},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{10867341,
  author={Murase, Senju and Andritsch, Jarutas},
  booktitle={2024 2nd International Conference on Computing and Data Analytics (ICCDA)}, 
  title={Integrating Sentiment Analysis to Enhance Mental Health Support Chatbots}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={Mental health conditions have adverse effects on an individual's quality of life. Between 2017 and 2019, there were 52.9 emergency department visits per 1,000 adults for mental health disorders. The rising popularity of artificial intelligence prompted its use in depression detection or mental condition diagnosis, establishing its prominent role in the mental health sector. In this research, we developed an AI chatbot with enhanced contextual intelligence using sentiment analysis to support individuals experiencing mental distress. For this research, we utilized a dataset of text data from 1.6 million posts on the social media platform X (formerly Twitter) due to its open-source availability and accessibility. The collected dataset was cleaned of repetitive characters, special characters, URLs, and numbers. NLP techniques, including tokenization, lemmatization, and stemming, were used for pre-processing. The application identifies sentiments, generates responses, and suggests basic support remedies. We used the Rasa framework to create a hybrid chatbot with customizable configurations. An LSTM model for sentiment analysis was integrated into the Rasa chatbot as a custom action component. A batch size of 32 and an optimal maximum sequence length were selected for balanced training efficiency and accuracy. The LSTM model achieved 76% accuracy in training and validation, enhancing the chatbot text comprehension. Future improvements will include adding personal features and expanding the user base.},
  keywords={Training;Sentiment analysis;Analytical models;Accuracy;Social networking (online);Training data;Mental health;Chatbots;Artificial intelligence;Long short term memory;Deep learning;Natural language processing;Sentiment analysis;Chatbot;Long Short-Term Memory},
  doi={10.1109/ICCDA64887.2024.10867341},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{9972564,
  author={M, Nandhagopal S and Saranya, D. and R, Devi Priya and Daniel Shadrach, Finney and Kalshetty, Jagadevi. N.},
  booktitle={2022 IEEE 2nd Mysore Sub Section International Conference (MysuruCon)}, 
  title={Convolutional Neural Networks for Analysis and Recognition of Facial Expressions}, 
  year={2022},
  volume={},
  number={},
  pages={1-7},
  abstract={Facial expression recognition is one of the foundations that gives enormous aid and simplicity for people working in the fields of artificial intelligence, gaming, marketing, and healthcare; it is also one of the foundations that is at the centre of many recent advancements. People are able to communicate their feelings to one another primarily through their facial expressions, which is significant given the significance of emotions as a tool for effective communication. Facial expressions are the primary means through which people convey their sentiments to one another. The process of identifying the feelings that are being sent on a person's face during social encounters is one that is both necessary and challenging. It is feasible to utilise the identification of facial expressions in conjunction with other security measures in order to raise the level of protection that is given to an individual. In the case that a consumer uses an automated teller machine and displays indicators of anxiety, it is possible that the computer will be programmed to refuse to dispense cash to that person. A person who is blind may also benefit from this since it may assist them in understanding the sentiments and facial expressions of the person who is standing in front of them. Discovering others on social media who are experiencing depression via their accounts might also be useful. This may be used in games to assess a player's strong and weak places, and the difference between the two can be formed by analysing the player's expressions at various moments throughout the game. This can be used in games to analyse a player's strengths and weaknesses. The technique known as "feature extraction" was used so that the areas of the faces that were determined to be the most important may be concealed.},
  keywords={Training;Waste materials;Social networking (online);Face recognition;Games;Medical services;Sparks;artificial intelligence;gaming;marketing;and healthcare;facial expression recognition},
  doi={10.1109/MysuruCon55714.2022.9972564},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{11273691,
  author={Amine, Ikram and Lmati, Imane and Anoun, Houda and Ammor, Fatimazahra},
  booktitle={2025 International Conference on Intelligent Systems: Theories and Applications (SITA)}, 
  title={Use, Performance, and Limitations of Large Language Models in Mental Health: A Systematic Review}, 
  year={2025},
  volume={},
  number={},
  pages={1-8},
  abstract={Mental disorders are being increasingly prevalent globally due to social, environmental and digital causes. Despite this increase, availability of specialized clinical care has not kept pace in most parts of the world. Fortunately, this is occurring at the same time of the advancement of large language models (LLMs), a form of artificial-intelligence, which have demonstrated intriguing potential for screening, diagnostic support, and therapeutic interactions. To examine this potential in more depth, we described and analyzed 41 studies that used transformer-based LLMs across psychiatry and clinical psychology that we located in the published literature between January 2022 and May 2025. We retrieved the literature through five open-access databases: Scopus, arXiv, Google Scholar, JMIR, and the ACM Digital Library. We extracted the following key variables from each article: Task type, target condition, model used, reported performance, and observed limitations. The most frequent tasks studied were detection of disorders and screening, decision-support and prevention. Reviewed papers mainly focused on depression and suicidality. GPT-4 and GPT-3.5 were the two most used models. Reported performance metrics, including overall accuracy and robustness, showed significant variability across tasks and datasets. Commonly described limitations were small or synthetic datasets, limited external validation, no real-world trials yet identified, and varying levels of transparency when reporting models' internal functioning. While LLMs may have promising capabilities, their full integration into clinical environments will have to contend with concerns about reliability, generalizability, and ethical use. Future research studies must conceptualize longitudinal studies, develop tools with the input of mental health professionals, and provide clarity in how safety, fairness, and data management are measured.},
  keywords={Training;Ethics;Large language models;Prevention and mitigation;Mental health;Transformers;Robustness;Safety;Systematic literature review;Synthetic data;Large language models;generative artificial intelligence;transformers;mental health},
  doi={10.1109/SITA67914.2025.11273691},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10577908,
  author={Bensalah, Nouhaila and Ayad, Habib and Adib, Abdellah and Farouk, Abdelhamid Ibn El},
  booktitle={2024 IEEE 12th International Symposium on Signal, Image, Video and Communications (ISIVC)}, 
  title={MindWave app: Leveraging AI for Mental Health Support in English and Arabic}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={The global concern regarding mental health, especially amidst crises like stress, burnout or depression, necessitates accessible platforms catering to diverse populations, including Arabic speakers. This paper introduces “MindWave,” a pioneering web application for English and Arabic-speaking communities. It is an innovative web application designed to offer support and early detection for individuals experiencing or at risk of mental health. The app uses advanced Natural Language Processing (NLP) and Sentiment Analysis (SA) to analyze user-generated text to detect signs of mental health, providing personalized insights, resources, and support for users in need. Its innovation lies in seamlessly integrating text and voice to comprehensively assess emotional well-being. The app fosters a supportive community where users can connect, share experiences, and provide mutual support. Users can engage in discussions, join support groups, or share coping strategies in a safe and anonymous environment. To address the absence of Arabic sentiment datasets for mental health, this study explores the effectiveness of fine-tuning various pre-trained Machine Translation (MT) models from English to Arabic using our parallel dataset of 945,383 sentences. Furthermore, the study delves into training different variants of Bidirectional Encoder Representations from Transformers (BERT) models on two distinct datasets: the original English dataset and the translated Arabic dataset. The classifiers’ performance trained on the source English dataset is juxtaposed with the results achieved when trained on the translated Arabic dataset. Moreover, we conduct a comparative evaluation of diverse tokenization techniques for Arabic, including Stochastic tokenizer, Disjoint-letter tokenizer, and Morphological tokenizer.},
  keywords={Training;Technological innovation;Stochastic processes;Mental health;Bidirectional control;Transformers;Tokenization;Arabic Machine Translation;Arabic/English Sentiment Analysis;mBART;mT5;AraT5;Decoding settings;Tokenization settings;BERT variants},
  doi={10.1109/ISIVC61350.2024.10577908},
  ISSN={2832-8337},
  month={May},}@ARTICLE{10993359,
  author={Hossain, Md. Mithun and Sanjara and Hossain, Md. Shakil and Chaki, Sudipto and Rahman, Md. Saifur and Ali, A. B. M. Shawkat},
  journal={IEEE Access}, 
  title={Revolutionizing Mental Health Sentiment Analysis With BERT-Fuse: A Hybrid Deep Learning Model}, 
  year={2025},
  volume={13},
  number={},
  pages={85428-85446},
  abstract={Mental health disorders profoundly affect intellectual ability, emotional resilience, and social stability, leading to lasting effects on both individuals and society. Increasing global concern over mental health calls for innovative solutions, with sentiment analysis emerging as a promising approach for early diagnosis and intervention. Traditional methods are limited by the complexity of mental health-related texts, which contain specialized terminology and domain-specific nuances. To address these challenges, we propose BERT-Fuse, a hybrid deep learning model combining traditional feature extraction techniques (TF-IDF and Bag-of-Words) with advanced neural architectures, including Bidirectional Long Short-Term Memory (LSTM), Gated Recurrent Unit (GRU), Transformer blocks, and Convolutional Neural Networks (CNN). We evaluated three word embedding techniques-BERT, GloVe, and FastText within BERT-Fuse and found that BERT embeddings achieve the highest performance in terms of accuracy, precision, recall, and F1-score. The model was trained on a balanced dataset of text samples representing seven mental health conditions. An ablation study highlights the contributions of key model components to its performance. BERT-Fuse shows promise as a scalable, high-precision system for mental health detection with an impressive average test accuracy of 97.05%. Our model bridges the gap between deep learning and psychological text analysis, paving the way for future mental health assessment tools that are more intelligent and easily accessible.},
  keywords={Mental health;Sentiment analysis;Deep learning;Accuracy;Feature extraction;Depression;Convolutional neural networks;Analytical models;Encoding;Bidirectional control;Sentiment analysis;BERT-fuse;hybrid model;hybrid BERT;mental health sentiment analysis},
  doi={10.1109/ACCESS.2025.3568340},
