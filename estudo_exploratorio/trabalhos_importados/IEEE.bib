  number={},
  pages={539-546},
  abstract={Today, humans seek opportunities to grow professionally and improve their mental health. As a result, anxiety and depression are now prominent to the point that people often accept them as part of their usual regular life routine. According to the World Health Organization (WHO), more than 300 million people around the world are suffering from depression and anxiety disorder. Therefore, being able to detect risk factors that lead to depression can be beneficial to the healthcare system. We use machine learning techniques to detect depression risk factors using a medical survey dataset, the Behavioral Risk Factor Surveillance System (BRFSS), available from the Centers for Disease Control and Prevention (CDC). This survey is obtained explicitly through telephone calls from adults 18 years and older who live in the United States of America. Oversampling and undersampling techniques and eight machine learning techniques are used to evaluate further and examine the data set. Among all, the SMOTE oversampling techniques show enhanced performance over the undersampling and no sampling techniques, and the deep neural network generates the best outcome compared to other techniques.},
  keywords={Surveys;Surveillance;Prevention and mitigation;Anxiety disorders;Organizations;Mental health;Medical services;Depression;Telephone sets;Feature extraction;Depression;Machine learning;Neural network;Feature selection;Resampling techniques},
  doi={10.1109/ICMLC63072.2024.10935065},
  ISSN={2160-1348},
  month={Sep.},}@INPROCEEDINGS{10840917,
  author={Kaur, Navneet and Ahlawat, Prashant},
  booktitle={2024 4th International Conference on Technological Advancements in Computational Sciences (ICTACS)}, 
  title={Predicting Stress, Anxiety, and Depression: A Multi-Modal Approach}, 
  year={2024},
  volume={},
  number={},
  pages={669-675},
  abstract={With respect to research, our focus addresses the streamed and growing area of the effects of common mental health conditions such as stress, anxiety, and depression on people and societal wellbeing. Our study has designed a multi layered framework, using deep learning, machine learning and natural language processing to build a set of generalized predictive models. These models are capable of finding early indications of mental health problems, which include; The models consist of various neural networks such as CNNs, LSTMs, BiLSTMs, GRUs, and dense models alongside ML algorithms such as the Random Forest and Support Vector Machine. Analyzing social media content with the help of NLP, we got more detailed views on all the factors influencing mental health. It highlights the necessity of the simple and accurate mental health prediction to face the rates of these disorders by underlining it. The research on multiple model structures, formulae, and the integration of NLP to coordinate with the social media analysis attempts to construct the implemented solution for the prevention and awareness of mental health issues. This minimally invasive approach is meant to provide community members as well as individuals with more appropriate mental health services during early intervention and prevention.},
  keywords={Support vector machines;Social networking (online);Prevention and mitigation;Anxiety disorders;Mental health;Predictive models;Depression;Natural language processing;Vectors;Random forests;NLP;GRU;LSTM;Random Forest;Support Vector Machine;Mental health prediction},
  doi={10.1109/ICTACS62700.2024.10840917},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{10263141,
  author={Abid, Mohammad Anas and Dehghan, Zahra and Shinde, Tanmay and Narang, Geetika},
  booktitle={2023 IEEE International Conference on Contemporary Computing and Communications (InC4)}, 
  title={Machine Learning based approaches for Identification and Prediction of diverse Mental Health Conditions}, 
  year={2023},
  volume={1},
  number={},
  pages={1-5},
  abstract={Today, looking after our mental health has become as essential as maintaining our physical health and well-being. It is found that a lot of people belonging to different age groups, gender and a wide range of professional backgrounds suffer from different mental disorders globally that lead to sizable losses in health and functioning of an individual. Mental health issues such as depression, anxiety and stress can originate due to various biological, psychological, and environmental factors which give rise to suicidal thoughts. These challenges have encouraged the advancement of numerous machine learning based approaches for providing an impactful solution to predict and identify the severity of various mental health issues on time, and therefore suggest potential treatment outcomes. It has been observed that Machine learning is one of the most efficient approaches that can be used to analyze enormous amounts of data for making accurate predictions in the healthcare system. This paper explores various sources for data collection (Clinical questionnaires, interviews, social media, medical history and speech alterations), automated methods and ML-based depression detection algorithms of different classes including classification, regression algorithms, deep learning, and ensemble method used by researchers for analyzing varied mental health conditions. Few studies made use of Synthetic Minority Oversampling Technique (SMOTE) to reduce the class imbalance of the training data in order to achieve better accuracy. A comparison of different parameters such as objectives, results and limitations between the referred research papers presented in the domain of depression detection has also been included in this paper.},
  keywords={Deep learning;Social networking (online);Training data;Mental health;Speech recognition;Medical services;Predictive models;Depression;Deep Learning;Machine Learning (ML);SMOTE;mRMR;NLP;TF-IDF;Elastic Net;Decision Tree;Random Forest},
  doi={10.1109/InC457730.2023.10263141},
  ISSN={},
  month={April},}@INPROCEEDINGS{10721562,
  author={Reviriego, Adrián and Raynova, Ralitza},
  booktitle={2024 XXXIII International Scientific Conference Electronics (ET)}, 
  title={Naïveve Bayes and Logistic Regression for sentiment analysis and emotion detection from text}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={This paper presents a comprehensive approach to emotion detection using machine learning by transforming text data into numerical vectors. It standardizes datasets into “Text” and “Label” columns, converting emotions to binary classification. Naïveve Bayes and Logistic Regression were selected, with hyperparameter tuning conducted via GridSearchCV and 5 -fold cross-validation. Naïveve Bayes used alpha and fit_prior parameters, while Logistic Regression used C and solver. Logistic Regression showed robust performance, highlighting the importance of data preprocessing and hyperparameter tuning in enhancing model accuracy.},
  keywords={Training;Logistic regression;Analytical models;Emotion recognition;Accuracy;Depression;Data models;Vectors;Bayes methods;Tuning;emotion classification;binary classification;data preprocessing;machine learning;natural language processing (NLP);sentiment analysis;text vectorization},
  doi={10.1109/ET63133.2024.10721562},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10963224,
  author={Nushida, Tomoki and Kang, Xin and Matsumoto, Kazuyuki and Yoshida, Minoru and Zhou, Jiazheng},
  booktitle={2025 IEEE 17th International Conference on Computer Research and Development (ICCRD)}, 
  title={An Automated Depression Diagnosis System Utilizing a Knowledge Base Created with GPT}, 
  year={2025},
  volume={},
  number={},
  pages={329-333},
  abstract={We propose an automated depression diagnosis system using a knowledge base and GPT. This system detects depression from text posted on social media. This paper proposes an approach that utilizes knowledge graphs, which are a part of the knowledge base. In this research, we propose three models: a model with the knowledge graph of data from individuals with depression as input, a model with the knowledge graph of data from healthy individuals as input, and a model is supported to use knowledge graph from both depression individuals and healthy individuals. The proposed model achieved a precision of 89% and exceeded 90% in both recall and F1 score. The proposed method demonstrated the potential of using GPT as a system for detecting depression.},
  keywords={Accuracy;Social networking (online);Large language models;Computational modeling;Knowledge based systems;Knowledge graphs;Depression;Data models;Research and development;Large Language Model;GPT;Knowledge base;Depression Detection;Graph RAG;Knowledge Graph},
  doi={10.1109/ICCRD64588.2025.10963224},
  ISSN={},
  month={Jan},}@ARTICLE{9733425,
  author={Ansari, Luna and Ji, Shaoxiong and Chen, Qian and Cambria, Erik},
  journal={IEEE Transactions on Computational Social Systems}, 
  title={Ensemble Hybrid Learning Methods for Automated Depression Detection}, 
  year={2023},
  volume={10},
  number={1},
  pages={211-219},
  abstract={Changes in human lifestyle have led to an increase in the number of people suffering from depression over the past century. Although in recent years, rates of diagnosing mental illness have improved, many cases remain undetected. Automated detection methods can help identify depressed or individuals at risk. An understanding of depression detection requires effective feature representation and analysis of language use. In this article, text classifiers are trained for depression detection. The key objective is to improve depression detection performance by examining and comparing two sets of methods: hybrid and ensemble. The results show that ensemble models outperform the hybrid model classification results. The strength and effectiveness of the combined features demonstrate that better performance can be achieved by multiple feature combinations and proper feature selection.},
  keywords={Feature extraction;Depression;Social networking (online);Hidden Markov models;Data models;Neural networks;Linguistics;Deep neural networks;depression detection;ensemble methods;sentiment lexicon},
  doi={10.1109/TCSS.2022.3154442},
  ISSN={2329-924X},
  month={Feb},}@INPROCEEDINGS{10206166,
  author={Deng, Bin and Wang, Zikai and Shu, Xin and Shu, Jian},
  booktitle={2023 6th International Conference on Artificial Intelligence and Big Data (ICAIBD)}, 
  title={Transformer-Based Graphic-Text Fusion Depressive Tendency Detection}, 
  year={2023},
  volume={},
  number={},
  pages={701-705},
  abstract={Depression is a common mental illness. Many depressed people choose to express their inner feelings on social media, which provides a possibility to detect user’s depressive tendencies. This paper proposes a Transformer-based graphic-text fusion depressive tendency detection model (TGFDTD). This paper uses pre-trained Albert and VGG models to extract text feature vectors and image feature vectors respectively. To address the problem that multimodal fusion methods tend to generate redundant information, this paper uses Transformer Encoder layer combined with positional encoding for feature fusion. The experimental results show the proposed model performs better than the unimodal detection model in terms of the F1 score.},
  keywords={Deep learning;Social networking (online);Blogs;Big Data;Feature extraction;Transformers;Depression;depressive tendency detection;image-text fusion;Transformer},
  doi={10.1109/ICAIBD57115.2023.10206166},
  ISSN={2769-3554},
  month={May},}@INPROCEEDINGS{10088304,
  author={Pandey, Asheema and Mohapatra, Subhasish and Mishra, Jibitesh and Sinha, Ritesh Kumar},
  booktitle={2022 International Conference on Advancements in Smart, Secure and Intelligent Computing (ASSIC)}, 
  title={Novel depression detection technique using Bert on social media}, 
  year={2022},
  volume={},
  number={},
  pages={1-6},
  abstract={The social media platforms are tremendously used nowadays. A huge amount of realistic data are being created everyday. The data are mainly feelings, emotions, mood of a person. The innovative research from these online users data are to predict levels posts such as negative or positive. The blogging sites like twitter, facebook, instagram have become so popular places to express online users thoughts and feelings. The data can be extensively filtered and used for the purpose of analyzing the depression levels. This can be a great platform for deep learning research. The social media tweets and comments are utilized. The two models simple BI-LSTM along with hybrid model of BERT CNN BI-LSTM is implemented. The hybrid model of BERT CNN BI-LSTM which achieves a higher accuracy than other deep learning models and the BERT Model is efficiently handles the different types of social media users data.},
  keywords={Deep learning;Social networking (online);Mood;Bit error rate;Blogs;Multimedia Web sites;Depression;Social data;bi-lstm;bert;twitter},
  doi={10.1109/ASSIC55218.2022.10088304},
  ISSN={},
  month={Nov},}@ARTICLE{9760468,
  author={Ahmed, Usman and Lin, Jerry Chun-Wei},
  journal={IEEE Transactions on Computational Social Systems}, 
  title={Deep Explainable Hate Speech Active Learning on Social-Media Data}, 
  year={2024},
  volume={11},
  number={4},
  pages={4625-4635},
  abstract={Hate speech is demonstrably aimed at social tension and violence. Detection becomes increasingly difficult as overlapping emotional feelings occur. However, there are still several unresolved issues with informal and indirect targeting of negative communication, including sarcasm, misrepresentation, and praise for the target’s or society’s immoral behavior. In this study, we proposed a method for instance selection based on attention network visualization. The goal is to categorize, modify, and expand the number of training instances. To this end, we first used the lexicons of hate speech and online forums to train the embedding using transfer learning. Then, we used synonym expansion to the semantic vectors. The active learning approach was used to train the task using the result-label pairs. The entropy-based selection and visualization techniques help select unlabeled text for each active learning cycle. The approach is improved, and the number of training instances is increased to improve the model’s accuracy. The active learning cycles are repeated until all unlabeled texts are converted to labeled text. The semantic embedding and lexicon expansion improve the model receiver operating characteristics (ROCs) from 0.89 to 0.91. The bidirectional LSTM with attention and active learning achieved 0.90 for precision–recall. The learned model can visualize the position-weighted terms to illustrate why hate speech is classified.},
  keywords={Hate speech;Social networking (online);Artificial intelligence;Medical services;Feature extraction;Internet;Depression;Deep learning;ethnic hate;explainable machine learning (ML);hate speech detection},
  doi={10.1109/TCSS.2022.3165136},
  ISSN={2329-924X},
  month={Aug},}@INPROCEEDINGS{10915163,
  author={Juarto, Budi},
  booktitle={2024 IEEE International Conference on Control & Automation, Electronics, Robotics, Internet of Things, and Artificial Intelligence (CERIA)}, 
  title={Sentiment Analysis for Mental Health Using Boosting, Bagging, and DeBERTa from Social Media Data}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={Nowadays, social media influences from misinformation to cyberbullying and from influencing anxiety and depression to suicidal tendencies have been quite high. All such conditions require proper and timely identification for suitable intervention. The classes used for this work are “Anxiety”, “Bipolar”, “Depression”, “Normal”, “Personality Disorder”, “Stress”, and “Suicidal”. The text was cleaned, under-sampling was done to make the class labels balanced, and labels were encoded. The research employs machine learning models such as Random Forest, Gradient Boosting, LightGBM, and DeBERTa, using an 80-20% train-test split and undersampling to balance class labels. The objective of this research is to assess the effectiveness of boosting, bagging, and the DeBERTa model in classifying mental health conditions based on social media data. The study achieved very good performance using the DeBERTa model: an accuracy of 0.8741, precision of 0.8749, a recall of 0.8741, and an F1-score of 0.8740. However, classes such as “Depression” versus “Suicidal” were slightly overrated. It is a take-home message from the current study that machine learning might effectively enhance diagnostic-related to mental health-more precisely by the DeBERTa algorithm. This study advances the understanding of classifying mental health conditions with a focus on improving detection between closely related conditions like depression and suicidal tendencies.},
  keywords={Sentiment analysis;Accuracy;Soft sensors;Anxiety disorders;Mental health;Depression;Boosting;Data models;Bagging;Robots;DeBERTA;classification;mental health;machine learning;natural language processing},
  doi={10.1109/CERIA64726.2024.10915163},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10475293,
  author={Sheikhi, Farnaz and Fakher, Laya and Chekani, Danial},
  booktitle={2024 20th CSI International Symposium on Artificial Intelligence and Signal Processing (AISP)}, 
  title={Depression Detection on e-Risk 2017 using Long Short-term Memory Models}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={In today’s fast-paced world, individuals are increasingly vulnerable to high levels of stress, which consequently raise the risk of developing depression. Depres-sion may represent itself via various symptoms, ranging from emotional to physical pains. The symptoms appear gradually, deceiving patients to ignore their changes. The reluctance to accept the depression and the social stigma surrounding this mental disorder prevent a remarkable fraction of patients from vising the specialists and receiv- ing the treatments. Although people feel uncomfortable to reveal themselves in face-to-face connections, they have an opposite attitude towards social networks. People willingly share their opinions, thoughts, and feelings on social networks nowadays. Psychological studies have explored potential differences in the literature used by individuals with depression and those without. Hence, social network data has become a valuable source of information to study the mental health of users. Following this motivation, in this paper, we have examined the power of several deep learning algorithms for automati- cally detecting depression on eRisk 2017 dataset, obtained from the social network of Reddit. To this aim, we have studied and compared Long Short-Term Memory (LSTM), Bidirectional LSTM (Bi-LSTM), Gated Recurrent Unit (GRU), Bidirectional GRU (Bi-GRU), and hybrid LSTM- GRU models for depression detection. The results have illustrated superiority of LSTMs in terms of accuracy and timing of detecting depression over the rest of the models. These findings contribute to the expanding body of research on using artificial intelligence for detecting mental health issues.},
  keywords={Social networking (online);Pain;Signal processing algorithms;Mental health;Signal processing;Depression;Timing;Depression;mental health;eRisk;deep learning;LSTM;GRU;social network},
  doi={10.1109/AISP61396.2024.10475293},
  ISSN={2640-5768},
  month={Feb},}@INPROCEEDINGS{11368263,
  author={George, Agnus Maria and R, Kavitha and Kumar, Dalvin Vinoth},
  booktitle={2025 IEEE 17th International Conference on Computational Intelligence and Communication Networks (CICN)}, 
  title={Fairness-Aware and Interpretable Depression Detection on Social Media Using BERT with Gender Bias Mitigations}, 
  year={2025},
  volume={},
  number={},
  pages={1973-1979},
  abstract={Reddit and similar social media platforms offer substantial information regarding mental health issues. The automatic detection of depression raises different issues pertaining to fairness and transparency. This paper presents a Fairness Aware and Interpretable Depression Detection framework that utilizes BERT and incorporates an explicit gender bias mitigation mechanism. Data were obtained from gender-specific forums on Reddit. The Mistral language model based classifier was used to set a high confidence threshold, which helped in inferring gender labels while both depressed and non-depressed were among the patients assigned the labels. A balanced dataset with four groups (Depressed-Male, Depressed-Female, NonDepressed-Male, NonDepressed-Female) was prepared. Two pipelines were carried out where one involved a baseline BERT classifier while the other employed a fairness aware BERT model that incorporated gender embeddings during the training phase. The models were assessed using accuracy, precision, recall, F1 score, and confusion matrices and the fairness metrics applied were Demographic Parity Difference (DPD) and Equal Opportunity Difference (EOD). To enhance the model's reasoning transparency, SHAP was applied due to its capability to provide clear and comprehensive explanations. The results indicated that the fairness centered model effectively reduced gender biasness and equalized error rates among the different groups without losing its original accuracy. The essential point is that the model had learned to give precedence to clinical indicators over gender specific language. This study suggests a roadmap for the creation of ethical AI by combining fairness, interpretability and high performance into a seamless framework.},
  keywords={Training;Accuracy;Social networking (online);Error analysis;Terminology;Prevention and mitigation;Pipelines;Mental health;Depression;Equal opportunities;BERT;Depression detection;Fairness aware machine learning;Gender bias mitigation;Interpretability;Social media},
  doi={10.1109/CICN67655.2025.11368263},
  ISSN={2472-7555},
  month={Dec},}@INPROCEEDINGS{10396981,
  author={H K, Parjanya and Hegde, Ramakrishna and Mishra, Nikhil Kumar and Kumar Sandliya, Abhishek and Singh, Anant and S M, Soumyasri},
  booktitle={2023 IEEE 3rd Mysore Sub Section International Conference (MysuruCon)}, 
  title={Detection of Mental Health Issues and Solution to Online Toxicity using Machine Learning}, 
  year={2023},
  volume={},
  number={},
  pages={1-7},
  abstract={In modern times, the use of the internet and social media has greatly increased, leading to the emergence of online toxicity, which can have serious consequences for individuals' mental health. Machine learning techniques can be used to detect mental health issues and address online toxicity. One approach to detecting mental health issues in its early stages is to use machine learning to analyze social media posts and other online content. By training a model on large datasets of labeled text, it is possible to identify patterns and indicators of mental health issues such as depression, anxiety, and stress. To address online toxicity, machine learning can be used to identify and classify toxic content, such as hate speech or cyberbullying. This can be done by training a model on a dataset of labeled toxic and non-toxic content Once the model is trained, it can be used to identify and flag the toxic content in real-time, allowing it to be moderated or removed completely. Overall, the use of machine learning for the detection of mental health issues and the solution to online toxicity can be a powerful tool for promoting mental wellbeing and creating a safer and more positive online environment.},
  keywords={Training;Sentiment analysis;Analytical models;Toxicology;Machine learning;Mental health;Feature extraction;Machine Learning;Online Toxicity;Depression;Anxiety;Mental Health.},
  doi={10.1109/MysuruCon59703.2023.10396981},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{11356556,
  author={Qiao, Zhengnan and Zhang, Xianguo},
  booktitle={2025 IEEE International Conference on Bioinformatics and Biomedicine (BIBM)}, 
  title={Multi-Strategy Collaborative Training of Large Language Models for Depression Text Generation and Detection}, 
  year={2025},
  volume={},
  number={},
  pages={7638-7644},
  abstract={Early identification of depression is of great significance for clinical intervention. At present, artificial intelligence technology has made effective progress in the field of automatic detection of depression. However, due to the scarcity and homogeneity of data, the existing models have the problem of insufficient robustness and generalization ability for unseen data or out-ofdistribution data. To address these challenges, this paper proposes a multi-strategy collaborative training framework, DeprGen-RL, which combines the advantages of large language models (LLMs) with reinforcement learning (RL), aiming to improve the generation quality of depression text and the robustness of detection models. A large language model is used to play the role of a generator to learn and reproduce the unique vocabulary, syntactic structure and emotional expression of patients with depression. The reward mechanism of reinforcement learning was used to guide the text generation process to ensure that the generated text was highly consistent with the correlation of depression in language features. Through the collaborative training of the generator and the discriminator, the performance of the LLM generator is continuously optimized, so that the model can generate high-quality synthetic texts to expand the training set and improve the robustness of the downstream classifier. Experiments show that the DeprGen-RL discriminator performs better than traditional methods in cross-dataset experiments, achieving an accuracy of 0.72 on the Pirina dataset and 0.81 on the DAIC-WOZ dataset. At the same time, the generation quality (measured by perplexity and BLEU value) is also improved.},
  keywords={Training;Large language models;Biological system modeling;Collaboration;Reinforcement learning;Depression;Data models;Robustness;Generators;Videos;Depression detection;Large language model;Reinforcement learning;Data augmentation;Model generalization},
  doi={10.1109/BIBM66473.2025.11356556},
  ISSN={2156-1133},
  month={Dec},}@INPROCEEDINGS{11403725,
  author={S.P.Vidyassri and B S, Jhanani and K, Michelle Carolene and V, Netra and H, Pragadeesh and Athiksha, R.Jeyanth and Shrivastava, Anurag},
  booktitle={2025 2nd International Conference on Artificial Intelligence for Innovations in Healthcare Industries (ICAIIHI)}, 
  title={Artificial Intelligence for Predicting Mental Health Disorders in Adolescents}, 
  year={2025},
  volume={},
  number={},
  pages={1-5},
  abstract={Artificial intelligence (AI) has come out as a potentially revolutionary device in the sphere of adolescent mental health care providing better opportunities of early diagnosis, risk prediction, monitoring, and interventions. The literature used shows that there are various applications of AI like machine learning, deep learning, wearable and mobile sensing, predictive modeling, which together improve the process of detecting psychiatric disorders such as depression, anxiety, social anxiety disorder, and internalizing disorders. A number of studies prove that AI-based models are able to recognize the most important risk factors, process multimodal data sources, including clinical reports, behavioral trends, activity on social media and physiological indicators, and make reliable predictions in diverse cultural and clinical backgrounds. Other uses of AI-enabled systems are optimization of therapy, suicide risk, disability, and continuous mental health management. Nevertheless, despite the great advancement, there are still some challenges, such as the model generalizability, ethical issues, data privacy, and the necessity of strong validation in the real-world setting. The available evidence highlights the opportunities of AI to support mental health professionals and give scalable assistance to adolescents, but further studies should be conducted on the aspects of transparency, fairness, longitudinal analysis, and the implementation of AI tools into clinical practices. This overall review shows that AI can be instrumental in improving the methods of early identification and interventions of adolescent mental health disorders.},
  keywords={Deep learning;Ethics;Social networking (online);Reviews;Anxiety disorders;Mental health;Predictive models;Data models;Biomedical monitoring;Monitoring;Artificial intelligence;Adolescents;Mental health;Machine learning;Risk prediction;Early diagnosis},
  doi={10.1109/ICAIIHI67124.2025.11403725},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{11006204,
  author={Fard, Zeinab Sheikh Hosseini and Fooladvand, Hesam and Parvizimosaed, Mohammadreza and Damia, Amirhossein},
  booktitle={2025 11th International Conference on Web Research (ICWR)}, 
  title={Detection of Psychological States in Persian Social Media Posts Using Advanced Deep Learning Architectures with Attention Mechanisms}, 
  year={2025},
  volume={},
  number={},
  pages={522-528},
  abstract={In recent years, social media platforms have emerged as significant spaces for users to express their psychological states. Early detection of mental health conditions such as depression, anxiety, and suicidal ideation in these environments can play a vital role in timely intervention and prevention. This study presents a system based on advanced deep learning architectures incorporating attention mechanisms for the automatic detection of psychological states in Persian-speaking users. Data were collected from platforms such as Instagram, Twitter, Telegram, and specialized psychiatric websites, and were labeled by a team of expert psychiatrists. After comprehensive preprocessing of Persian texts, several models including LSTM, BiLSTM, and Bidirectional GRU with Attention were evaluated. Results indicate that the Bidirectional GRU with Attention achieved the highest performance with an accuracy of 0.87. By focusing on Persian language data and utilizing expert-labeled realworld content, this research contributes a significant step toward the development of intelligent tools for mental health monitoring in digital environments.},
  keywords={Attention mechanisms;Social networking (online);Prevention and mitigation;Focusing;Mental health;Depression;Natural language processing;Web sites;Multimedia communication;Monitoring;Psychological States;Social Media;Mental Health;Deep Learning;Persian Language;Attention Mechanism;Natural Language Processing},
  doi={10.1109/ICWR65219.2025.11006204},
  ISSN={2837-8296},
  month={April},}@ARTICLE{11062349,
  author={Ning, Xifeng and Sun, Hailu and Yu, Dejun and Yang, Chao and Fang, Ruonan and Fan, Lin and Lin, Qika and Zhu, Yifan},
  journal={IEEE Intelligent Systems}, 
  title={Fine-Tuning Large Language Models With Behavioral Alignment for Depression Detection}, 
  year={2025},
  volume={40},
  number={6},
  pages={10-18},
  abstract={Depression is a prevalent mental health issue, and early detection is crucial for effective intervention. In this article, we propose the depression large language model (DLLM), a novel two-stage fine-tuning framework designed to enhance the accuracy and robustness of depression detection using multimodal data from social media. In the first stage, we design specific prompts to incorporate various types of multimodal data and collect diverse instruction data. The DLLM is then fine-tuned for depression detection based on these data. In the second stage, we enhance the model’s robustness and generalization by performing behavioral alignment. This involves a deep understanding of user actions to improve behavior perception, enabling the policy model to distinguish between positive and negative behaviors for individual users. Experiments on the WU3D dataset show that DLLM outperforms state-of-the-art baselines (e.g., +6.2% accuracy over ALBERT, +2.4% F1 over EKG-MDDM) and demonstrates strong generalization in ablation studies.},
  keywords={Depression;Social networking (online);Data models;Computational modeling;Artificial intelligence;Mental health;Robustness;Accuracy;Training;Predictive models},
  doi={10.1109/MIS.2025.3584888},
  ISSN={1941-1294},
  month={Nov},}@INPROCEEDINGS{11288683,
  author={Vysotska, Victoria and Bychkov, Illia and Lynnyk, Roman and Fedchuk, Rostyslav and Lozynska, Olga and Markiv, Oksana},
  booktitle={2025 IEEE 6th KhPI Week on Advanced Technology (KhPIWeek)}, 
  title={MindGuard: Intelligent System for Depressive and Suicidal Intentions Detection in Social Media Texts Based on CNN, BERT and RoBERTa}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={The paper presents the development and experimental implementation of the MindGuard information and analytics platform, designed for automated analysis of the texts of social media users in order to identify signs of depression, anxiety and suicidal intentions. The system uses modern natural language processing (NLP) methods, including TF-IDF, deep neural networks (CNN) and transformer models (BERT, RoBERTa). A mark-up of data based on Reddit posts (≈ 348 examples), which covers three categories: non-psycho, depression and suicide. Several variants of classification models have been developed. The highest accuracy was demonstrated by the deep CNN model with GloVe embedding: Accuracy ( 81.5%), F1-score (0.92 for non-psycho, 0.74 for depression and 0.76 for suicide), AUC ROC (0.990 for non-psycho, 0.911 for depression and 0.910 for suicide), Inference latency ≈ 15 ms, bandwidth - up to 66 requests/s per CPU. Practical implementation is implemented in the form of a web application with REST API, which provides instant processing of text queries and convenient visualisation of results for psychologists, moderators or users. The system supports multilingualism and can be easily adapted to local needs.},
  keywords={Accuracy;Social networking (online);Text categorization;Psychology;Artificial neural networks;Depression;Transformers;Systems support;Service-oriented architecture;System analysis and design;depression;suicidal intentions;NLP;text classification;social networks;Transformers;CNN;psycholinguistics;MindGuard;Sentiment analysis},
  doi={10.1109/KhPIWeek61436.2025.11288683},
  ISSN={3064-9579},
  month={Oct},}@INPROCEEDINGS{10730445,
  author={Fabian and Sutrisno, Neil Errando and Ebenezer, Joseph Adiel and Edbert, Ivan Sebastian and Philip, Samuel},
  booktitle={2024 8th International Conference on Information Technology, Information Systems and Electrical Engineering (ICITISEE)}, 
  title={Depression Detection from Text Classification Using Neural Network}, 
  year={2024},
  volume={},
  number={},
  pages={286-291},
  abstract={Depression has become a common mental health problem in our society. In fact, according to WHO, depression is a mental health that occurs to 10% of the global population every year. The risk of failure to handle depression is the risk of suicide. People often use social media to express their feelings. Artificial Intelligence, one technological improvement, was created to solve cognitive problems. One of the capabilities to interpret and predict results from text is called Natural Language Processing (NLP). In this research, the researchers propose the idea of forming a model that can classify whether the text entered is classified as depression or non-depression. This research focuses on using deep learning as a model, ratio comparisons in the dataset, and using a bidirectional layer for the models. After conducting the study, the best model is the Bi-GRU model with the dataset ratio of 80:10:10, where this model achieves an accuracy of 0.9955 and a loss accuracy of 0.0154. Hopefully, this model will continue this research until it impacts the surrounding environment.},
  keywords={Accuracy;Computational modeling;Text categorization;Mental health;Predictive models;Logic gates;Depression;Data models;Tokenization;Long short term memory;Deep Learning;Text Classification;GRU;LSTM;Bidirectional;Depression},
  doi={10.1109/ICITISEE63424.2024.10730445},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{10206303,
  author={Wang, Zikai and Deng, Bin and Shu, Xin and Shu, Jian},
  booktitle={2023 6th International Conference on Artificial Intelligence and Big Data (ICAIBD)}, 
  title={Multimodal Depression Detection Model fusing Emotion Knowledge Graph}, 
  year={2023},
  volume={},
  number={},
  pages={21-26},
  abstract={More and more patients with depression use social platforms to share their daily life. The abundant multimodal information contained in Weibo makes the early detection of depression possible. This paper proposes a multimodal depression detection model fusing emotion knowledge graph(EKG-MDDM). To construct user text sequences, EKG-MDDM combines emotional knowledge graph vocabulary and BS algorithm to process user blog posts. EKG-MDDM uses ALBERT and AGG16 networks to extract text and image features. In addition, this paper summarizes and extracts 11 behavioral features from user’s descriptions and posting behaviors. Finally, the fusion features are applied to the task of depression detection. This model effectively exploits the emotional information contained in user blog posts. Compared with the previous recognition methods, the proposed model is superior to the baseline model in terms of Accuracy, Precision, Recall and F1 indicators.},
  keywords={Emotion recognition;Vocabulary;Social networking (online);Blogs;Semantics;Knowledge graphs;Feature extraction;detection of depression tendency;feature fusion;emotional knowledge graph;multimodal},
  doi={10.1109/ICAIBD57115.2023.10206303},
  ISSN={2769-3554},
  month={May},}@INPROCEEDINGS{11265243,
  author={Annur, Ahmad Ihda Falah and Irawan, Devina Salsabilla and Witanto, Talitha Rahmadewati and Rafif, Sulthan},
  booktitle={2025 International Conference on Information Technology and Computing (ICITCOM)}, 
  title={Machine Learning for Emotional Tone Detection: Comparing Naive Bayes and Support Vector Machine in Mental Health Contexts}, 
  year={2025},
  volume={},
  number={},
  pages={198-203},
  abstract={Mental health disorders are psychological conditions that occur due to a person's inability to deal with pressure or problems. In recent years, mental health issues have received increasing attention in the world of public health, especially among university students. The growing use of social media platforms like X (formerly Twitter) has provided users with a space to share experiences and opinions related to mental health. However, posts on social media are often unstructured, using informal language, slang, or sarcasm, making them difficult to manual analysis. This research focuses on comparing Naïve Bayes and Support Vector Machine algorithms for mental health sentiment classification. The dataset used in this research is obtained from GitHub, which contains X user uploads categorized into two classes: Depression (Positive) and Non-Depression (Negative). The findings indicate that the SVM algorithm outperforms Naïve Bayes, achieving an accuracy of 99% across precision, recall, and F1 Score, whereas Naïve Bayes only reaches an accuracy of 87%. This finding shows that the application of hyperplane lines in SVM is more effective in separating two classes, depression and non-depression for sentiment analysis on mental health through social media data.},
  keywords={Support vector machines;Sentiment analysis;Accuracy;Social networking (online);Mental health;Depression;Bayes methods;Classification algorithms;Public healthcare;Software development management;Mental Health;Sentiment Classification;Naïve Bayes;Support Vector Machine},
  doi={10.1109/ICITCOM66635.2025.11265243},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{10403623,
  author={Shetty M, Swara and Praveen, Varsha and Chinmayi, H. S. and K S, Bhavitha and Kamal, Shoaib and Rao, Trupthi},
  booktitle={2023 International Conference on Computational Intelligence for Information, Security and Communication Applications (CIISCA)}, 
  title={Using Machine Learning to Forecast the Risk of Suicide Attempts Over Time}, 
  year={2023},
  volume={},
  number={},
  pages={297-303},
  abstract={Suicide is recognized as a grave public health concern affecting individuals of all ages, from children and adolescents to young adults and beyond. It represents a significant cause of mortality within this population, influenced by various factors. Conventional methods for predicting suicide attempts have restricted the accuracy and scope of detecting these perilous behaviors. To enhance the accuracy and scope of detecting suicide attempts, we utilized machine learning on electronic health records from a vast medical database. Our study involved 469 adults exhibiting suicidal tendencies, among whom 85 patients made suicide attempts (cases). Additionally, 384 participants who did not attempt suicide but had depression showed promising signs of suicidal behavior, as confirmed by expert record review. This approach surpasses the limitations of traditional methods in predicting suicide attempts. Through the development of machine learning algorithms, we achieved accurate predictions of future suicide attempts (AUC = 0.80, precision= 0.30, recall = 0.54, Fl-score = 0.32, support=13). Our findings are a significant stride towards precise and scalable detection of suicide risk. Additionally, they offer valuable insights into how the risk of suicide attempts fluctuates over time.},
  keywords={Logistic regression;Pediatrics;Sociology;Machine learning;Behavioral sciences;Statistics;Public healthcare;Suicide;attempt;adolescents;forecast;mental;depression;social media},
  doi={10.1109/CIISCA59740.2023.00064},
  ISSN={},
  month={June},}@ARTICLE{10510456,
  author={Prama, Tabia Tanzin and Islam, Md. Saiful and Anwar, Md Musfique and Jahan, Ifrat},
  journal={IEEE Transactions on Computational Social Systems}, 
  title={AI-Enabled Deep Depression Detection and Evaluation Informed by DSM-5-TR}, 
  year={2024},
  volume={11},
  number={5},
  pages={6453-6465},
  abstract={Depression, a prevalent and debilitating mental health disorder, affects millions of individuals worldwide, profoundly impacting their quality of life. Early identification and diagnosis of depression and its intensity are crucial for effective treatment and management. However, many people with depression do not seek professional help, especially in the early stages. In recent years, social media platforms like Twitter have gained popularity as spaces for sharing personal thoughts and emotions, including sensitive signals indicative of serious issues such as self-harm, suicidal thoughts, or illegal activities. These signals may help us to identify depression-related tweets and determine whether an individual is suffering from depression. This research focuses on utilizing artificial intelligence and deep learning (DL) models to categorize tweets related to depression and measure its intensity. The proposed approach combines emotional features, topical events, and behavioral-biometric signals to train the long short-term memory (LSTM)-based DL models. To create a comprehensive dataset, we collaborated with an expert psychologist who followed the clinical assessment procedure outlined in the Diagnostic and Statistical Manual of Mental Disorders, Fifth Edition (DSM-5-TR) to label 95 322 tweets as “non-depressed” or “depressed,” further categorized into “mild,” “moderate,” and “severe” intensity levels. Through a series of experiments, our proposed method achieved superior performance compared to baseline models, yielding a mean squared error of 0.002336 and the highest $R$2 value of 0.61. These results highlight the accuracy and potential applications of our approach in automatic depression screening and monitoring on social media platforms.},
  keywords={Depression;Social networking (online);Mental health;Blogs;Long short term memory;Linguistics;Feature extraction;Deep learning;Depression Detection & Evaluation;Diagnostic and Statistical Manual of Mental Disorders (DSM-5-TR);long short-term memory (LSTM)},
  doi={10.1109/TCSS.2024.3382139},
  ISSN={2329-924X},
  month={Oct},}@INPROCEEDINGS{10128254,
  author={Shanthi, N. and Muthuraja, M. and Sharmila, C. and Jagadeesh, S and Karthick, R and Bharanidharan, M},
  booktitle={2023 International Conference on Computer Communication and Informatics (ICCCI)}, 
  title={Suicidal Ideation Prediction Using Machine Learning}, 
  year={2023},
  volume={},
  number={},
  pages={1-4},
  abstract={In the present world, accidents and health {complications account for the majority of fatalities. The majority of deaths after accidents are caused by suicide due to depression and natural catastrophes. The widespread use of the Internet has given people a new means of communicating their feelings. It is also a platform with a massive amount of content where users may read other users’ opinions, which are divided into several sentiment groups and are becoming more and more important in decision-making process. This paper contributes to the classification that is useful to examine the data in the form of the quantity of tweets where comments are extremely unstructured and either negative or positive or somewhere in between these two. To do this, we first pre-processed the data, then extracted the adjectives with meaning from the tweet, and last utilised machine learning-base classification methods, specifically. When compared to the current system, the accuracy of the TFIDF, N-gram, and LinearSVC algorithms for suicide prediction with tweets including suicidal thoughts was improved to 95 percent. Such testing and observation may help in both individual and population-wide prevention. By establishing a baseline for suicide identification on online social networks, such as Twitter, the experimental work suggests the viability of the approach adopted. In the end, we evaluated the classifier’s performance in terms of accuracy.},
  keywords={Training;Machine learning algorithms;Social networking (online);Prediction algorithms;Classification algorithms;Internet;Informatics;Suicidal Prevention;Machine Learning;Tweets;Depression},
  doi={10.1109/ICCCI56745.2023.10128254},
  ISSN={2473-7577},
  month={Jan},}@INPROCEEDINGS{10511974,
  author={Gujarathi, Parth and Menon, Kartik and Patel, Jai and Ghane, Sunil},
  booktitle={2024 3rd International Conference for Innovation in Technology (INOCON)}, 
  title={Psychological Distress Detection and Classification}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={This research paper introduces an innovative method for stress detection and classification by utilizing a combination of machine learning, deep learning techniques, and BERT. Today with the advancement of technology and techniques like artificial intelligence and machine learning various manual tasks can be replaced very easily. Hence in this research paper, we have proposed various machine learning algorithms, deep neural networks, and BERT pre-trained models for the detection of stress based on their social media posts and then classifying their stress levels based on their responses to the universally accepted DASS(Depression Anxiety Stress Scales) questionnaire. This study aims to develop an effective system that can accurately detect and classify stress levels based on textual data. The results reflect that our system outperforms existing methods for stress detection and classification and proposes a refined approach for the classification of stress levels. This system, therefore, has potential applications in various domains, including mental health diagnosis, social media monitoring, and personalized stress management.},
  keywords={Deep learning;Technological innovation;Social networking (online);Human factors;Mental health;Manuals;Predictive models;Stress;DASS;CNN;RNN;BERT;word2vec;glove},
  doi={10.1109/INOCON60754.2024.10511974},
  ISSN={},
  month={March},}@INPROCEEDINGS{10212609,
  author={Nadeem, Muhammad and Rashid, Junaid and Moon, Hyeonjoon and Dosset, Arailym},
  booktitle={2023 International Technical Conference on Circuits/Systems, Computers, and Communications (ITC-CSCC)}, 
  title={Machine Learning for Mental Health: A Systematic Study of Seven Approaches for Detecting Mental Disorders}, 
  year={2023},
  volume={},
  number={},
  pages={1-6},
  abstract={Mental disorders are a prevalent issue among teenagers. The widespread use of smartphones and social media has revolutionized the way individuals communicate and exchange information with millions of people using these technologies every day. As a result, vast amounts of data are generated, which can be harnessed to improve mental health detection. The increasing prevalence of mental health issues and the demand for quality healthcare services have led to research exploring the potential of machine learning (ML) to address these challenges. This paper provides a systematic study of seven ML approaches used in previous studies to detect mental disorders. The study examines the datasets employed, the accuracy achieved, and the limitations of each ML approach. The seven ML approaches studied in this paper are Support Vector Machine (SVM), Least Absolute Shrinkage and Selection Operator (LASSO), Long Short-Term Memory (LSTM), Random Forest (RF), Logistic Regression (LR), Artificial Neural Networks (ANN), and eXtreme Gradient Boosting (XGBoost). These approaches have been utilized in various studies to detect mental disorders and this paper aims to provide a comprehensive understanding of their effectiveness. The findings indicate that machine learning approaches have demonstrated significant potential for the detection of mental disorders, with promising implications for enhancing healthcare services. Additionally, the paper discusses the open research challenges and future directions for mental health.},
  keywords={Support vector machines;Radio frequency;Systematics;Social networking (online);Mental disorders;Mental health;Medical services;Machine Learning;SVM;Social Media;human mental health monitoring;algorithms;mental disorders;Twitter;healthcare;XGBoost},
  doi={10.1109/ITC-CSCC58803.2023.10212609},
  ISSN={},
  month={June},}@INPROCEEDINGS{10465560,
  author={Samal, Somya Sarathi and Pathak, Kussagra and Nimala, K. and Nareshkumar, R.},
  booktitle={2023 International Conference on Innovative Computing, Intelligent Communication and Smart Electrical Systems (ICSES)}, 
  title={Sentiment Analysis for Depression using Human Expression}, 
  year={2023},
  volume={},
  number={},
  pages={1-7},
  abstract={Millions of people across the globe suffer from the debilitating mental illness known as depression. Early intervention and treatment of those suffering from depression is of the utmost importance in ensuring that the condition does not worsen. This study demonstrates a machine learning system for recognizing depression in an individual through their vocal characteristics and facial expressions. Psychological questions are posed, and their answers are recorded along with their voice and facial features, to evaluate their current emotional state.To develop this system, we employ AngularJS for the front end, Flask for the back end and Python for the machine learning process. Specifically, we utilize Python packages such as io, cv2, pickle, numpy, pandas, talk\_recognition, moviepy, pydub, keras, tempfile, flask, vander Sentiment and twitter_analysis. The data collected is then processed through video, audio and question-and-answer methods, and the results show that our system is able to detect mood disorder with 89\% precision, 92% accuracy, 87% recall, and 89% F1 outcomes. The conclusion that can be drawn is that these techniques have the potential to be effective tools in the early identification of depression.},
  keywords={Sentiment analysis;Electric potential;Mood;Face recognition;Machine learning;Depression;Character recognition;Emotion;Sentiment analysis;Machine learning;CRM},
  doi={10.1109/ICSES60034.2023.10465560},
  ISSN={},
  month={Dec},}@ARTICLE{11108260,
  author={Khan, Zohaib Ahmad and Xia, Yuanqing and Khaliq, Fiza and Jiang, Weiwei and Anwar, Muhammad Shahid},
  journal={IEEE Intelligent Systems}, 
  title={AI-Based Hate Speech Detection System Using Video URLs for Effective Content Moderation}, 
  year={2025},
  volume={40},
  number={6},
  pages={29-40},
  abstract={Countering online hate speech is essential for creating a safer digital space where positive interactions can thrive. As central hubs of global communication, platforms like social media platforms require effective moderation through explainable and affective computing approaches. This study introduces a novel artificial intelligence-driven system for detecting misogynstic discourse. We collected 11,245 YouTube video uniform resource locators using specific keywords, then extracted audio to create Urdu transcripts and transliterated them into Roman Urdu, resulting in two distinct datasets. Various feature sets were explored using classic machine learning and deep learning algorithms. The results showed that classical models achieved 0.90 accuracy on the Urdu dataset, while deep learning models reached 0.96 accuracy on Roman Urdu. The corpus is publicly available to promote transparency and further research. Comparative evaluations against existing English hate speech dataset demonstrate the effectiveness of the proposed approach. This work lays the foundation for more ethical and transparent content moderation systems.},
  keywords={Hate speech;Web sites;Video on demand;Annotations;Social networking (online);Intelligent systems;Training;Deep learning;Libraries;Artificial intelligence;Information integrity;Data integrity},
  doi={10.1109/MIS.2025.3594849},
  ISSN={1941-1294},
  month={Nov},}@ARTICLE{10666498,
  author={Basyouni, Abdallah and Abdulkader, Hatem and Elkilani, Wail S. and Alharbi, Abdullah and Xiao, Yulong and Ali, Asmaa H.},
  journal={IEEE Access}, 
  title={A Suicidal Ideation Detection Framework on Social Media Using Machine Learning and Genetic Algorithms}, 
  year={2024},
  volume={12},
  number={},
  pages={124816-124833},
  abstract={Suicide is a serious problem that affects modern societies all over the world, and its prevention is critical. Suicidal ideas are influenced by a variety of risk factors, such as depression, anxiety, hopelessness, and social isolation. Early detection of these risk factors can significantly reduce or prevent suicide attempts. Online platforms, particularly social media, have become a popular outlet for young people to express suicidal ideation. However, detecting and responding to such ideation effectively poses significant challenges in natural language processing (NLP) and psychology. To improve the efficiency of detecting suicidal ideation, this study proposes a novel framework that overcomes prior research limitations, such as feature redundancy and limited relevance to the target class. The framework addresses these issues by extracting meaningful and context-related features from posts that capture contextual and semantic aspects. Furthermore, a genetic algorithm is used to select the most important and relevant features that are strongly associated with the target class while excluding those that are redundant or irrelevant. To evaluate the effectiveness of the proposed framework, the following machine learning classifiers were used to determine whether a post indicates suicidal ideation or not: Random Forest (RF), Naive Bayes (NB), gradient boost classification tree (GBDT), and XGBoost. The proposed framework’s results outperformed previous research, demonstrating the framework’s high efficiency. The best performance in our study was achieved using the Random Forest (RF) classifier, which was applied to the features selected by the Genetic Algorithm (GA) from the linguistic feature set. When evaluated using 5-fold cross-validation, this approach yielded an impressive accuracy rate of 98.92% and an F1-score of 98.92%. These outstanding performance metrics demonstrate the framework’s effectiveness in accurately detecting suicidal ideation.},
  keywords={Social networking (online);Feature extraction;Blogs;Text categorization;Natural language processing;Machine learning;Deep learning;Mental health;Mental health;suicide detection;Reddit social media;feature selection;genetic algorithm},
  doi={10.1109/ACCESS.2024.3454796},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{10791111,
  author={Nabilah 'Izzaturrahmah, Asty and Kurniawan, Isman},
  booktitle={2024 International Conference on Electrical Engineering and Computer Science (ICECOS)}, 
  title={Tweet-based Depression Detection Using BERT Optimized by Grey Wolf Optimization}, 
  year={2024},
  volume={},
  number={},
  pages={129-134},
  abstract={Depression affects approximately 280 million people globally, characterized by persistent sadness and lack of interest. Limited access to treatment due to high costs and availability issues, highlighting the need for affordable early detection methods. Machine learning has shown promise in detecting depression, especially using text data from social media, where users share emotions openly. This study explores using BERT, a transformer model, combined with the Grey Wolf Optimizer (GWO) to detect depression in tweets. A professionally re-labeled Kaggle dataset is used to enhance early detection. The study demonstrates that GWO significantly improves BERT's performance in text-based depression detection. The best performance is achieved using BERT optimized by GWO, outperforming BERT alone. The best parameters, which achieves the best validation F1-score, are model name as bert-base-cased-finetuned-mrpc, batch size of 64, and learning rate of 0.0001. The testing set results display an accuracy of 0.8400 and precision, recall, and F1-score of 0.8356.},
  keywords={Electrical engineering;Computer science;Costs;Social networking (online);Computational modeling;Machine learning;Depression;Transformers;Optimization;Testing;depression detection;text classification;BERT;GWO},
  doi={10.1109/ICECOS63900.2024.10791111},
  ISSN={},
  month={Sep.},}@ARTICLE{10677342,
  author={Akter Asma, Salma and Akhter, Nazneen and Sharmin, Shayla and Rahman, Md. Sazzadur and Sanwar Hosen, A. S. M. and Lee, Oh-Sung and Ra, In-Ho},
  journal={IEEE Access}, 
  title={Hierarchical Explainable Network for Investigating Depression From Multilingual Textual Data}, 
  year={2024},
  volume={12},
  number={},
  pages={131915-131927},
  abstract={Depression is the most prevalent mental health disorder, which is spreading like an epidemic. With the rise of the internet, people from all over the world now express their daily lives on social media, which can be utilized to analyze their mental health condition. Automated approaches like Machine Learning (ML) and Deep Learning (DL) are used to analyze social media posts. The ML techniques are performing well in detecting depression from monolingual text. Nevertheless, ML model’s low interpretability makes it difficult to identify depression in multilingual texts. Hence, the study focuses on seven languages for developing the model. Traditional ML and DL algorithms like Convolutional Neural Network (CNN), Support Vector Machine, Random Forest, and Decision Tree lack interpretability regarding prediction. To effectively analyze the multilingual dataset, CNN with a Hierarchical Attention Network is implemented in the model and then the Gaussian Naive Bayes algorithm is applied to the extracted output layer to generate an interpretable prediction, allowing it to offer enhanced explainability compared to other state-of-the-art algorithms. The proposed approach demonstrates effectiveness in analyzing multilingual texts with an accuracy of 89.09% outperforming other ML and DL models in terms of time and memory efficiency.},
  keywords={Depression;Social networking (online);Feature extraction;Accuracy;Long short term memory;Support vector machines;Transformers;Convolutional neural network;depression detection;explainability;hierarchical attention network;multilingual},
  doi={10.1109/ACCESS.2024.3458815},
